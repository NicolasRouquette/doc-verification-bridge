.URM.Program.toStandardForm_isStandardForm\"><span class=\"name\">Cslib</span>.<span class=\"name\">URM</span>.<span class=\"name\">Program</span>.<span class=\"name\">toStandardForm_isStandardForm</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">p</span> : <a href=\"./Cslib/Computability/URM/Defs.html#Cslib.URM.Program\">Program</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><span class=\"fn\"><span class=\"fn\">p</span>.<a href=\"./Cslib/Computability/URM/StandardForm.html#Cslib.URM.Program.toStandardForm\">toStandardForm</a></span>.<a href=\"./Cslib/Computability/URM/StandardForm.html#Cslib.URM.Program.IsStandardForm\">IsStandardForm</a></span></div></div>","info":{"doc":"toStandardForm produces a standard form program. ","docLink":"./Cslib/Computability/URM/StandardForm.html#Cslib.URM.Program.toStandardForm_isStandardForm","kind":"theorem","line":52,"name":"Cslib.URM.Program.toStandardForm_isStandardForm","sourceLink":"https://github.com/leanprover/cslib/blob/b00648a4fe741981bb586a3cc845258ab1583f61/Cslib/Computability/URM/StandardForm.lean#L52-L59"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">theorem</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Cslib/Computability/URM/StandardForm.html#Cslib.URM.Program.toStandardForm_length\"><span class=\"name\">Cslib</span>.<span class=\"name\">URM</span>.<span class=\"name\">Program</span>.<span class=\"name\">toStandardForm_length</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">p</span> : <a href=\"./Cslib/Computability/URM/Defs.html#Cslib.URM.Program\">Program</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Init/Prelude.html#List.length\">List.length</a> <span class=\"fn\"><span class=\"fn\">p</span>.<a href=\"./Cslib/Computability/URM/StandardForm.html#Cslib.URM.Program.toStandardForm\">toStandardForm</a></span></span> <a href=\"./Init/Prelude.html#Eq\">=</a> <span class=\"fn\"><a href=\"./Init/Prelude.html#List.length\">List.length</a> <span class=\"fn\">p</span></span></div></div>","info":{"doc":"toStandardForm preserves program length. ","docLink":"./Cslib/Computability/URM/StandardForm.html#Cslib.URM.Program.toStandardForm_length","kind":"theorem","line":46,"name":"Cslib.URM.Program.toStandardForm_length","sourceLink":"https://github.com/leanprover/cslib/blob/b00648a4fe741981bb586a3cc845258ab1583f61/Cslib/Computability/URM/StandardForm.lean#L46-L50"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Cslib/Computability/URM/StandardForm.html#Cslib.URM.Program.toStandardForm\"><span class=\"name\">Cslib</span>.<span class=\"name\">URM</span>.<span class=\"name\">Program</span>.<span class=\"name\">toStandardForm</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">p</span> : <a href=\"./Cslib/Computability/URM/Defs.html#Cslib.URM.Program\">Program</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Cslib/Computability/URM/Defs.html#Cslib.URM.Program\">Program</a></div></div>","info":{"doc":"Convert a program to standard form by capping all jump targets at the program length. ","docLink":"./Cslib/Computability/URM/StandardForm.html#Cslib.URM.Program.toStandardForm","kind":"def","line":42,"name":"Cslib.URM.Program.toStandardForm","sourceLink":"https://github.com/leanprover/cslib/blob/b00648a4fe741981bb586a3cc845258ab1583f61/Cslib/Computability/URM/StandardForm.lean#L42-L44"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">instance</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Cslib/Computability/URM/StandardForm.html#Cslib.URM.Program.instDecidableIsStandardForm\"><span class=\"name\">Cslib</span>.<span class=\"name\">URM</span>.<span class=\"name\">Program</s