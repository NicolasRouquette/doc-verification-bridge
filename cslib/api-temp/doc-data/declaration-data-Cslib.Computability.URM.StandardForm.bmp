M.Step.from_toStandardForm","kind":"theorem","line":152,"name":"Cslib.URM.Step.from_toStandardForm","sourceLink":"https://github.com/leanprover/cslib/blob/b00648a4fe741981bb586a3cc845258ab1583f61/Cslib/Computability/URM/StandardForm.lean#L152-L188"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">theorem</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Cslib/Computability/URM/StandardForm.html#Cslib.URM.Halts.toStandardForm\"><span class=\"name\">Cslib</span>.<span class=\"name\">URM</span>.<span class=\"name\">Halts</span>.<span class=\"name\">toStandardForm</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">p</span> : <a href=\"./Cslib/Computability/URM/Defs.html#Cslib.URM.Program\">Program</a>}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">inputs</span> : <span class=\"fn\"><a href=\"./Init/Prelude.html#List\">List</a> <a href=\"./Init/Prelude.html#Nat\">ℕ</a></span>}</span></span>\n</span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">h</span> : <span class=\"fn\"><a href=\"./Cslib/Computability/URM/Execution.html#Cslib.URM.Halts\">Halts</a> <span class=\"fn\">p</span> <span class=\"fn\">inputs</span></span>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Cslib/Computability/URM/Execution.html#Cslib.URM.Halts\">Halts</a> <span class=\"fn\"><span class=\"fn\">p</span>.<a href=\"./Cslib/Computability/URM/StandardForm.html#Cslib.URM.Program.toStandardForm\">toStandardForm</a></span> <span class=\"fn\">inputs</span></span></div></div>","info":{"doc":"Forward halting theorem. ","docLink":"./Cslib/Computability/URM/StandardForm.html#Cslib.URM.Halts.toStandardForm","kind":"theorem","line":145,"name":"Cslib.URM.Halts.toStandardForm","sourceLink":"https://github.com/leanprover/cslib/blob/b00648a4fe741981bb586a3cc845258ab1583f61/Cslib