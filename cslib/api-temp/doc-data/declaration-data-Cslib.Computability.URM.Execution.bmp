ib.URM.step_confluent\"><span class=\"name\">Cslib</span>.<span class=\"name\">URM</span>.<span class=\"name\">step_confluent</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">p</span> : <a href=\"./Cslib/Computability/URM/Defs.html#Cslib.URM.Program\">Program</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Cslib/Foundations/Data/Relation.html#Relation.Confluent\">Relation.Confluent</a> <span class=\"fn\">(<a href=\"./Cslib/Computability/URM/Execution.html#Cslib.URM.Step\">Step</a> <span class=\"fn\">p</span>)</span></span></div></div>","info":{"doc":"The step relation is confluent. ","docLink":"./Cslib/Computability/URM/Execution.html#Cslib.URM.step_confluent","kind":"theorem","line":134,"name":"Cslib.URM.step_confluent","sourceLink":"https://github.com/leanprover/cslib/blob/b00648a4fe741981bb586a3cc845258ab1583f61/Cslib/Computability/URM/Execution.lean#L134-L137"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">theorem</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Cslib/Computability/URM/Execution.html#Cslib.URM.isHalted_iff_normal\"><span class=\"name\">Cslib</span>.<span class=\"name\">URM</span>.<span class=\"name\">isHalted_iff_normal</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">p</span> : <a href=\"./Cslib/Computability/URM/Defs.html#Cslib.URM.Program\">Program</a>}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">s</span> : <a href=\"./Cslib/Computability/URM/Defs.html#Cslib.URM.State\">State</a>}</span></span>\n</span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><span class=\"fn\"><span class=\"fn\">s</span>.<a href=\"./Cslib/Computability/URM/Defs.html#Cslib.URM.State.isHalted\">isHalted</a></span> <span class=\"fn\">p</span></span> <a href=\"./Init/Core.html#Iff\">↔</a> <span class=\"fn\"><a href=\"./Cslib/Foundations/Data/Relation.html#Relation.Normal\">Relation.Normal</a> <span class=\"fn\">(<a href=\"./Cslib/Computability/URM/Execution.html#Cslib.URM.Step\">Step</a> <span class=\"fn\">p</span>)</span> <span class=\"fn\">s</span></span></div></div>","info":{"doc":"A state is halted iff it is normal (has no successor) in the reduction system. ","docLink":"./Cslib/Computability/URM/Execution.html#Cslib.URM.isHalted_iff_normal","kind":"theorem","line":112,"name":"Cslib.URM.isHalted_iff_normal","sourceLink":"https://github.com/leanprover/cslib/blob/b00648a4fe741981bb586a3cc845258ab1583f61/Cslib/Computability/URM/Execution.lean#L112-L132"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">theorem</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Cslib/Computability/URM/Execution.html#Cslib.URM.Step.preserves_register\"><span class=\"name\">Cslib</span>.<span class=\"name\">URM</span>.<span class=\"name\">Step</span>.<span class=\"name\">preserves_register</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">p</span> : <a href=\"./Cslib/Computability/URM/Defs.html#Cslib.URM.Program\">Program</a>}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">s </span><span class=\"fn\">s'</span> : <a href=\"./Cslib/Computability/URM/Defs.html#Cslib.URM.State\">State</a>}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">r</span> : <a href=\"./Init/Prelude.html#Nat\">ℕ</a>}</span></span>\n</span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">hstep</span> : <span class=\"fn\"><a href=\"./Cslib/Computability/URM/Execution.html#Cslib.URM.Step\">Step</a> <span class=\"fn\">p</span> <span class=\"fn\">s</span> <span class=\"fn\">s'</span></span>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<s