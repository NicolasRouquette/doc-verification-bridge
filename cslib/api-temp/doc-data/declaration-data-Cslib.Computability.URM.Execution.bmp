 `halts_iff_normalizable`. ","docLink":"./Cslib/Computability/URM/Execution.html#Cslib.URM.Halts","kind":"def","line":168,"name":"Cslib.URM.Halts","sourceLink":"https://github.com/leanprover/cslib/blob/b00648a4fe741981bb586a3cc845258ab1583f61/Cslib/Computability/URM/Execution.lean#L168-L173"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">theorem</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Cslib/Computability/URM/Execution.html#Cslib.URM.Steps.eq_of_halts\"><span class=\"name\">Cslib</span>.<span class=\"name\">URM</span>.<span class=\"name\">Steps</span>.<span class=\"name\">eq_of_halts</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">p</span> : <a href=\"./Cslib/Computability/URM/Defs.html#Cslib.URM.Program\">Program</a>}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">init </span><span class=\"fn\">s₁ </span><span class=\"fn\">s₂</span> : <a href=\"./Cslib/Computability/URM/Defs.html#Cslib.URM.State\">State</a>}</span></span>\n</span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">h1</span> : <span class=\"fn\"><a href=\"./Cslib/Computability/URM/Execution.html#Cslib.URM.Steps\">Steps</a> <span class=\"fn\">p</span> <span class=\"fn\">init</span> <span class=\"fn\">s₁</span></span>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">hh1</span> : <span class=\"fn\"><span class=\"fn\"><span class=\"fn\">s₁</span>.<a href=\"./Cslib/Computability/URM/Defs.html#Cslib.URM.State.isHalted\">isHalted</a></span> <span class=\"fn\">p</span></span>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">h2</span> : <span class=\"fn\"><a href=\"./Cslib/Computability/URM/Execution.html#Cslib.URM.Steps\">Steps</a> <span class=\"fn\">p</span> <span class=\"fn\">init</span> <span class=\"fn\">s₂</span></span>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">hh2</span> : <span class=\"fn\"><span class=\"fn\"><span class=\"fn\">s₂</span>.<a href=\"./Cslib/Computability/URM/Defs.html#Cslib.URM.State.isHalted\">isHalted</a></span> <span class=\"fn\">p</span></span>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\">s₁</span> <a href=\"./Init/Prelude.html#Eq\">=</a> <span class=\"fn\">s₂</span></div></div>","info":{"doc":"If two halted states are reachable from the same start, they are equal.\n\nThis follows from confluence: since `Step p` is confluent and both `s₁` and `s₂`\nare normal forms reachable from `init`, they must be equal. ","docLink":"./Cslib/Computability/URM/Execution.html#Cslib.URM.Steps.eq_of_halts","kind":"theorem","line":152,"name":"Cslib.URM.Steps.eq_of_halts","sourceLink":"https://github.com/leanprover/cslib/blob/b00648a4fe741981bb586a3cc845258ab1583f61/Cslib/Computability/URM/Execution.lean#L152-L164"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">theorem</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Cslib/Computability/URM/Execution.html#Cslib.URM.Steps.preserves_register\"><span class=\"name\">Cslib</span>.<span class=\"name\">URM</span>.<span class=\"name\">Steps</span>.<span class=\"name\">preserves_register</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">p</span> : <a href=\"./Cslib/Computability/URM/Defs.html#Cslib.URM.Program\">Program</a>}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">s </span><span class=\"fn\">s'</span> : <a href=\"./Cslib/Computability/URM/Defs.html#Cslib.URM.State\">State</a>}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">r</span> : <a href=\"./Init/Prelude.html#Nat\">ℕ</a>}</span></span>\n</span><span class=\"decl_args\">\n<span class=\"fn\">