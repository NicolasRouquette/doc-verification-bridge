\">Monad</a> <span class=\"fn\">m</span></span>]</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">α</span> : <a href=\"./foundational_types.html\">Type</a> u}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">handler</span> : <span class=\"fn\">{<span class=\"fn\">ι</span> : <a href=\"./foundational_types.html\">Type</a> u} → <span class=\"fn\"><span class=\"fn\"><span class=\"fn\">F</span> <span class=\"fn\">ι</span></span> → <span class=\"fn\"><span class=\"fn\">m</span> <span class=\"fn\">ι</span></span></span></span>}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">interp</span> : <span class=\"fn\"><span class=\"fn\"><a href=\"./Cslib/Foundations/Control/Monad/Free.html#Cslib.FreeM\">FreeM</a> <span class=\"fn\">F</span> <span class=\"fn\">α</span></span> → <span class=\"fn\"><span class=\"fn\">m</span> <span class=\"fn\">α</span></span></span>}</span></span>\n</span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">apply_pure</span> : <span class=\"fn\">∀ (<span class=\"fn\">a</span> : <span class=\"fn\">α</span>), <span class=\"fn\"><span class=\"fn\">interp</span> <span class=\"fn\">(<a href=\"./Cslib/Foundations/Control/Monad/Free.html#Cslib.FreeM.pure\">FreeM.pure</a> <span class=\"fn\">a</span>)</span></span> <a href=\"./Init/Prelude.html#Eq\">=</a> <span class=\"fn\"><a href=\"./Init/Prelude.html#Pure.pure\">pure</a> <span class=\"fn\">a</span></span></span>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">apply_liftBind</span> :\n  <span class=\"fn\">∀ {<span class=\"fn\">ι</span> : <a href=\"./foundational_types.html\">Type</a> u} (<span class=\"fn\">op</span> : <span class=\"fn\"><span class=\"fn\">F</span> <span class=\"fn\">ι</span></span>) (<span class=\"fn\">cont</span> : <span class=\"fn\"><span class=\"fn\">ι</span> → <span class=\"fn\"><a href=\"./Cslib/Foundations/Control/Monad/Free.html#Cslib.FreeM\">FreeM</a> <span class=\"fn\">F</span> <span class=\"fn\">α</span></span></span>),\n    <span class=\"fn\"><span class=\"fn\">interp</span> <span class=\"fn\">(<a href=\"./Cslib/Foundations/Control/Monad/Free.html#Cslib.FreeM.liftBind\">liftBind</a> <span class=\"fn\">op</span> <span class=\"fn\">cont</span>)</span></span> <a href=\"./Init/Prelude.html#Eq\">=</a> <span class=\"fn\">do\n      let <span class=\"fn\">x</span> ← <span class=\"fn\"><span class=\"fn\">handler</span> <span class=\"fn\">op</span></span>\n      <span class=\"fn\"><span class=\"fn\">interp</span> <span class=\"fn\">(<span class=\"fn\">cont</span> <span class=\"fn\">x</span>)</span></span></span></span>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Cslib/Foundations/Control/Monad/Free.html#Cslib.FreeM.Interprets\">Interprets</a> <span class=\"fn\">handler</span> <span class=\"fn\">interp</span></span></div></div>","info":{"doc":"","docLink":"./Cslib/Foundations/Control/Monad/Free.html#Cslib.FreeM.Interprets.mk","kind":"ctor","line":238,"name":"Cslib.FreeM.Interprets.mk","sourceLink":"https://github.com/leanprover/cslib/blob/7f88669e78c0fa9d9c4f41a397072114cbb9aa7e/Cslib/Foundations/Control/Monad/Free.lean#L238-L238"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">structure</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Cslib/Foundations/Control/Monad/Free.html#Cslib.FreeM.Interprets\"><span class=\"name\">Cslib</span>.<span class=\"name\">FreeM</span>.<span class=\"name\">Interprets</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">F</span> : <span class=\"fn\"><a href=\"./foundational_types.html\">Type</a> u → <a href=\"./foundational_types.html\">Type</a> v</span>}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">m</span> : <span class=\"fn\"><a href=\"./foundational_types.html\">Type</a> u → <a href=\"./foundational_types.html\">Type</a> w</span>}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">[<span class=\"fn\"><a href=\"./Init/Prelude.html#Monad\">Monad</a> <span class=\"fn\">m</span></span>]</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">α</span> : <a href=\"./foundational_types.html\">Type</a> u}</span></span>\n</span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">handler</span> : <span class=\"fn\">{<span class=\"fn\">ι</span> : <a href=\"./foundational_types.html\">Type</a> u} → <span class=\"fn\"><span class=\"fn\"><span class=\"fn\">F</span> <span class=\"fn\">ι</span></span> → <span class=\"fn\"><span class=\"fn\">m</span> <span class=\"fn\">ι</span></span></span></span>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">interp</span> : <span class=\"fn\"><span class=\"fn\"><a href=\"./Cslib/Foundations/Control/Monad/Free.html#Cslib.FreeM\">FreeM</a> <span class=\"fn\">F</span> <span class=\"fn\">α</span></span> → <span class=\"fn\"><span class=\"fn\">m</span> <span class=\"fn\">α</span></span></span>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./foundational_types.html\">Prop</a></div></div>","info":{"doc":"A predicate stating that `interp : FreeM F α → m α` is an interpreter for the effect\nhandler `handler : ∀ {α}, F α → m α`.\n\nThis means that `interp` is a monad morphism from the free monad `FreeM F` to the\nmonad `m`, and that it extends the interpretation of individual operations\ngiven by `f`.\n\nFormally, `interp` satisfies the two equations:\n- `interp (pure a) = pure a`\n- `interp (liftBind op k) = handler op >>= fun x => interp (k x)`\n","docLink":"./Cslib/Foundations/Control/Monad/Free.html#Cslib.FreeM.I