\">{<span class=\"fn\">F</span> : <span class=\"fn\"><a href=\"./foundational_types.html\">Type</a> u → <a href=\"./foundational_types.html\">Type</a> v</span>}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">α</span> : <a href=\"./foundational_types.html\">Type</a> w}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">ι</span> : <a href=\"./foundational_types.html\">Type</a> u}</span></span>\n</span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">op</span> : <span class=\"fn\"><span class=\"fn\">F</span> <span class=\"fn\">ι</span></span>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">cont</span> : <span class=\"fn\"><span class=\"fn\">ι</span> → <span class=\"fn\"><a href=\"./Cslib/Foundations/Control/Monad/Free.html#Cslib.FreeM\">FreeM</a> <span class=\"fn\">F</span> <span class=\"fn\">α</span></span></span>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Cslib/Foundations/Control/Monad/Free.html#Cslib.FreeM\">FreeM</a> <span class=\"fn\">F</span> <span class=\"fn\">α</span></span></div></div>","info":{"doc":"Invoke the operation `op` with contuation `cont`.\n\nNote that Lean's inductive types prevent us splitting this into separate bind and lift\nconstructors. ","docLink":"./Cslib/Foundations/Control/Monad/Free.html#Cslib.FreeM.liftBind","kind":"ctor","line":86,"name":"Cslib.FreeM.liftBind","sourceLink":"https://github.com/leanprover/cslib/blob/7f88669e78c0fa9d9c4f41a397072114cbb9aa7e/Cslib/Foundations/Control/Monad/Free.lean#L86-L90"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">constructor</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Cslib/Foundations/Control/Monad/Free.html#Cslib.FreeM.pure\"><span class=\"name\">Cslib</span>.<span class=\"name\">FreeM</span>.<span class=\"name\">pure</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">F</span> : <span class=\"fn\"><a href=\"./foundational_types.html\">Type</a> u → <a href=\"./foundational_types.html\">Type</a> v</span>}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">α</span> : <a href=\"./foundational_types.html\">Type</a> w}</span></span>\n</span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">a</span> : <span class=\"fn\">α</span>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Cslib/Foundations/Control/Monad/Free.html#Cslib.FreeM\">FreeM</a> <span class=\"fn\">F</span> <span class=\"fn\">α</span></span></div></div>","info":{"doc":"The action that does nothing and returns `a`. ","docLink":"./Cslib/Foundations/Control/Monad/Free.html#Cslib.FreeM.pure","kind":"ctor","line":84,"name":"Cslib.FreeM.pure","sourceLink":"https://github.com/leanprover/cslib/blob/7f88669e78c0fa9d9c4f41a397072114cbb9aa7e/Cslib/Foundations/Control/Monad/Free.lean#L84-L85"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">inductive</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Cslib/Foundations/Control/Monad/Free.html#Cslib.FreeM\"><span class=\"name\">Cslib</span>.<span class=\"name\">FreeM</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">F</span> : <span class=\"fn\"><a href=\"./foundational_types.html\">Type</a> u → <a href=\"./foundational_types.html\">Type</a> v</span>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">α</span> : <a href=\"./foundational_types.html\">Type</a> w)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./foundational_types.html\">Type</a> (max (max (u + 1) v) w)</div></div>","info":{"doc":"The Free monad over a type constructor `F`.\n\nA `FreeM F a` is a tree of operations from the type constructor `F`, with leaves of type `a`.\nIt has two constructors: `pure` for wrapping a value of type `a`, and `liftBind` for\nrepresenting an operation from `F` followed by a continuation.\n\nThis construction provides a free monad for any type constructor `F`, allowing for composable\neffect descriptions that can be interpreted later. Unlike the traditional free monad,\nthis does not require `F` to be a functor. ","docLink":"./Cslib/Foundations/Control/Monad/Free.html#Cslib.FreeM","kind":"inductive","line":74,"name":"Cslib.FreeM","sourceLink":"https://github.com/leanprover/cslib/blob/7f88669e78c0fa9d9c4f41a397072114cbb9aa7e/Cslib/Foundations/Control/Monad/Free.lean#L74-L90"}}],"imports":["Init","Cslib.Init"],"instances":[{"className":"Pure","name":"Cslib.FreeM.instPure","typeNames":["Cslib.FreeM"]},{"className":"Bind","name":"Cslib.FreeM.instBind","typeNames":["Cslib.FreeM"]},{"className":"Functor","name":"Cslib.FreeM.instFunctor","typeNames":["Cslib.FreeM"]},{"className":"LawfulFunctor","name":"Cslib.FreeM.instLawfulFunctor","typeNames":["Cslib.FreeM"]},{"className":"Monad","name":"Cslib.FreeM.instMonad","typeNames":["Cslib.FreeM"]},{"className":"LawfulMonad","name":"Cslib.FreeM.instLawfulMonad","typeNames":["Cslib.FreeM"]}],"name":"Cslib.Foundations.Control.Monad.Free"}