<span class=\"fn\">x</span> : <span class=\"fn\">α</span>), <span class=\"fn\">x</span> <a href=\"./Init/Prelude.html#LT.lt\">&lt;</a> <span class=\"fn\"><span class=\"fn\">f</span> <span class=\"fn\">x</span></span></span>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Cslib/Foundations/Data/HasFresh.html#Cslib.HasFresh\">HasFresh</a> <span class=\"fn\">α</span></span></div></div>","info":{"doc":"Construct a fresh element given a function `f` with `x < f x`. ","docLink":"./Cslib/Foundations/Data/HasFresh.html#Cslib.HasFresh.ofSucc","kind":"def","line":152,"name":"Cslib.HasFresh.ofSucc","sourceLink":"https://github.com/leanprover/cslib/blob/7f88669e78c0fa9d9c4f41a397072114cbb9aa7e/Cslib/Foundations/Data/HasFresh.lean#L152-L158"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Cslib/Foundations/Data/HasFresh.html#Cslib.HasFresh.ofNatEmbed\"><span class=\"name\">Cslib</span>.<span class=\"name\">HasFresh</span>.<span class=\"name\">ofNatEmbed</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">α</span> : <a href=\"./foundational_types.html\">Type</a> u}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">[<span class=\"fn\"><a href=\"./Init/Prelude.html#DecidableEq\">DecidableEq</a> <span class=\"fn\">α</span></span>]</span></span>\n</span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">e</span> : <a href=\"./Init/Prelude.html#Nat\">ℕ</a> <a href=\"./Mathlib/Logic/Embedding/Basic.html#Function.Embedding\">↪</a> <span class=\"fn\">α</span>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Cslib/Foundations/Data/HasFresh.html#Cslib.HasFresh\">HasFresh</a> <span class=\"fn\">α</span></span></div></div>","info":{"doc":"Construct a fresh element from an embedding of `ℕ` using `Nat.find`. ","docLink":"./Cslib/Foundations/Data/HasFresh.html#Cslib.HasFresh.ofNatEmbed","kind":"def","line":146,"name":"Cslib.HasFresh.ofNatEmbed","sourceLink":"https://github.com/leanprover/cslib/blob/7f88669e78c0fa9d9c4f41a397072114cbb9aa7e/Cslib/Foundations/Data/HasFresh.lean#L146-L150"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">noncomputable def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Cslib/Foundations/Data/HasFresh.html#Cslib.HasFresh.of_infinite\"><span class=\"name\">Cslib</span>.<span class=\"name\">HasFresh</span>.<span class=\"name\">of_infinite</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">α</span> : <a href=\"./foundational_types.html\">Type</a> u)</span></span>\n<span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">[<span class=\"fn\"><a href=\"./Mathlib/Data/Finite/Defs.html#Infinite\">Infinite</a> <span class=\"fn\">α</span></span>]</span></span>\n</span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Cslib/Foundations/Data/HasFresh.html#Cslib.HasFresh\">HasFresh</a> <span class=\"fn\">α</span></span></div></div>","info":{"doc":"All infinite types have an associated (at least noncomputable) fresh function.\nThis, in conjunction with `HasFresh.not_of_finite`, characterizes `HasFresh`. ","docLink":"./Cslib/Foundations/Data/HasFresh.html#Cslib.HasFresh.of_infinite","kind":"def","line":139,"name":"Cslib.HasFresh.of_infinite","sourceLink":"https://github.com/leanprover/cslib/blob/7f88669e78c0fa9d9c4f41a397072114cbb9aa7e/Cslib/Foundations/Data/HasFresh.lean#L139-L143"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">theorem</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Cslib/Foundations/Data/HasFresh.html#Cslib.HasFresh.not_of_finite\"><span class=\"name\">Cslib</span>.<span class=\"name\">HasFresh</span>.<span class=\"name\">not_of_finite</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">α</span> : <a href=\"./foundational_types.html\">Type</a> u)</span></span>\n<span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">[<span class=\"fn\"><a href=\"./Mathlib/Data/Fintype/Defs.html#Fintype\">Fintype</a> <span class=\"fn\">α</span></span>]</span></span>\n</span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Mathlib/Logic/IsEmpty.html#IsEmpty\">IsEmpty</a> <span class=\"fn\">(<a href=\"./Cslib/Foundations/Data/HasFresh.html#Cslib.HasFresh\">HasFresh</a> <span class=\"fn\">α</span>)</span></span></div></div>","info":{"doc":"","docLink":"./Cslib/Foundations/Data/HasFresh.html#Cslib.HasFresh.not_of_finite","kind":"theorem","line":136,"name":"Cslib.HasFresh.not_of_finite","sourceLink":"https://github.com/leanprover/cslib/blob/7f88669e78c0fa9d9c4f41a397072114cbb9aa7e/Cslib/Foundations/Data/HasFresh.lean#L136-L137"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Cslib/Foundations/Data/HasFresh.html#Cslib.HasFresh.freeUnion\"><span class=\"name\">Cslib</span>.<span class=\"name\">HasFresh</span>.<span class=\"name\">freeUnion</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Lean/Elab/Term/TermElabM.html#Lean.Elab.Term.TermElab\">Lean.Elab.Term.TermElab</a></div></div>","info":{"doc":"Elaborator for `free_union`. ","docLink":"./Cslib/Foundations/Data/HasFresh.html#Cslib.HasFresh.freeUnion","kind":"def","line":80,"name":"Cslib.HasFresh.freeUnion","sourceLink":"https://github.com/leanprover/cslib/blob/7f88669e78c0fa9d9c4f41a397072114cbb9aa7e/Cslib/Foundations/Data/HasFresh.lean#L80-L129"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Cslib/Foundations/Data/HasFresh.html#Cslib.freeUnion\"><span class=\"name\">Cslib</span>.<span class=\"name\">freeUnion</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Init/Prelude.html#Lean.ParserDescr\">Lean.ParserDescr</a></div></div>","info":{"doc":"Given a `DecidableEq Var` instance, this elaborator automatically constructs\nthe union of any variables, finite sets of variables, and optionally the\nresults of provided functions mapping to variables. This is configurable with\noptional boolean boolean arguments `singleton` and `finset`.\n\nAs an example, consider the following:\n\n```\nvariable (x : ℕ) (xs : Finset ℕ) (var : String)\n\ndef f (_ : String) : Finset ℕ := {1, 2, 3}\ndef g (_ : String) : Finset ℕ := {4, 5, 6}\n\n-- info: ∅ ∪ {x} ∪ id xs : Finset ℕ\n#check free_union ℕ\n\n-- info: ∅ ∪ {x} ∪ id xs ∪ f var ∪ g var : Finset ℕ\n#check free_union [f, g] ℕ\n\ninfo: ∅ ∪ id xs : Finset ℕ\n#check free_union (singleton := false) ℕ\n\n-- info: ∅ ∪ {x} : Finset ℕ\n#check free_union (finset := false) ℕ\n\n-- info: ∅ : Finset ℕ\n#check free_union (singleton := false) (finset := false) ℕ\n```\n","docLink":"./Cslib/Foundations/Data/HasFresh.html#Cslib.freeUnion","kind":"def","line":47,"name":"Cslib.freeUnion","sourceLink":"https://github.com/leanprover/cslib/blob/7f88669e78c0fa9d9c4f41a397072114cbb9aa7e/Cslib/Foundations/Data/HasFresh.lean#L47-L77"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Cslib/Foundations/Data/HasFresh.html#Cslib.elabFreeUnionConfig\"><span class=\"name\">Cslib</span>.<span class=\"name\">elabFreeUnionConfig</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Init/Prelude.html#Lean.Syntax\">Lean.Syntax</a> → <span class=\"fn\"><a href=\"./Lean/Elab/Tactic/Basic.html#Lean.Elab.Tactic.TacticM\">Lean.Elab.Tactic.TacticM</a> <a href=\"./Cslib/Foundations/Data/HasFresh.html#Cslib.FreeUnionConfig\">FreeUnionConfig</a></span></span></div></div>","info":{"doc":"Elaborate a FreeUnionConfig. ","docLink":"./Cslib/Foundations/Data/HasFresh.html#Cslib.elabFreeUnionConfig","kind":"def","line":44,"name":"Cslib.elabFreeUnionConfig","sourceLink":"https://github.com/leanprover/cslib/blob/7f88669e78c0fa9d9c4f41a397072114cbb9aa7e/Cslib/Foundations/Data/HasFresh.lean#L44-L45"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">abbrev</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Cslib/Foundations/Data/HasFresh.html#Cslib.FreeUnionConfig.finset\"><span class=\"name\">Cslib</span>.<span class=\"name\">FreeUnionConfig</span>.<span class=\"name\">finset</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">self</span> : <a href=\"./Cslib/Foundations/Data/HasFresh.html#Cslib.FreeUnionConfig\">FreeUnionConfig</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Init/Prelude.html#Bool\">Bool</a></div></div>","info":{"doc":"For `free_union Var`, include all `xs : Finset Var`. Defaults to true. ","docLink":"./Cslib/Foundations/Data/HasFresh.html#Cslib.FreeUnionConfig.finset","kind":"def","line":42,"name":"Cslib.FreeUnionConfig.finset","sourceLink":"https://github.com/leanprover/cslib/blob/7f88669e78c0fa9d9c4f41a397072114cbb9aa7e/Cslib/Foundations/Data/HasFresh.lean#L42-L42"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">abbrev</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Cslib/Foundations/Data/HasFresh.html#Cslib.FreeUnionConfig.singleton\"><span class=\"name\">Cslib</span>.<span class=\"name\">FreeUnionConfig</span>.<span class=\"name\">singleton</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">self</span> : <a href=\"./Cslib/Foundations/Data/HasFresh.html#Cslib.FreeUnionConfig\">FreeUnionConfig</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Init/Prelude.html#Bool\">Bool</a></div></div>","info":{"