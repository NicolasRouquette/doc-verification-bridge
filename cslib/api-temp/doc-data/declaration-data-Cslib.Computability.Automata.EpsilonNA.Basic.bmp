ng for reusing the definitions and results on saturated transitions of `LTS` to deal with\nε-closure. ","docLink":"./Cslib/Computability/Automata/EpsilonNA/Basic.html#Cslib.Automata.εNA","kind":"structure","line":17,"name":"Cslib.Automata.εNA","sourceLink":"https://github.com/leanprover/cslib/blob/7f88669e78c0fa9d9c4f41a397072114cbb9aa7e/Cslib/Computability/Automata/EpsilonNA/Basic.lean#L17-L23"}}],"imports":["Init","Cslib.Computability.Automata.NA.Basic"],"instances":[{"className":"Cslib.HasTau","name":"Cslib.Automata.instHasTauOption","typeNames":["Option"]},{"className":"Cslib.Automata.Acceptor","name":"Cslib.Automata.εNA.FinAcc.instAcceptor","typeNames":["Cslib.Automata.εNA.FinAcc"]}],"name":"Cslib.Computability.Automata.EpsilonNA.Basic"}