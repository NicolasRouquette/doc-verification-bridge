":30,"name":"Cslib.Automata.εNA.εClosure","sourceLink":"https://github.com/leanprover/cslib/blob/7f88669e78c0fa9d9c4f41a397072114cbb9aa7e/Cslib/Computability/Automata/EpsilonNA/Basic.lean#L30-L33"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">instance</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Cslib/Computability/Automata/EpsilonNA/Basic.html#Cslib.Automata.instHasTauOption\"><span class=\"name\">Cslib</span>.<span class=\"name\">Automata</span>.<span class=\"name\">instHasTauOption</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">α</span> : <a href=\"./foundational_types.html\">Type</a> u_3}</span></span>\n</span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Cslib/Foundations/Semantics/LTS/Basic.html#Cslib.HasTau\">HasTau</a> <span class=\"fn\">(<a href=\"./Init/Prelude.html#Option\">Option</a> <span class=\"fn\">α</span>)</span></span></div></div>","info":{"doc":"","docLink":"./Cslib/Computability/Automata/EpsilonNA/Basic.html#Cslib.Automata.instHasTauOption","kind":"instance","line":27,"name":"Cslib.Automata.instHasTauOption","sourceLink":"https://github.com/leanprover/cslib/blob/7f88669e78c0fa9d9c4f41a397072114cbb9aa7e/Cslib/Computability/Automata/EpsilonNA/Basic.lean#L27-L28"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">constructor</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Cslib/Computability/Automata/EpsilonNA/Basic.html#Cslib.Automata.εNA.mk\"><span class=\"name\">Cslib</span>.<span class=\"name\">Automata</span>.<span class=\"name\">εNA</span>.<span class=\"name\">mk</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">State</span> : <a href=\"./foundational_types.html\">Type</a> u_1}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">Symbol</spa