ons/Semantics/LTS/Bisimulation.html#Cslib.Bisimilarity.deterministic_traceEq_bisim","kind":"theorem","line":723,"name":"Cslib.Bisimilarity.deterministic_traceEq_bisim","sourceLink":"https://github.com/leanprover/cslib/blob/7f88669e78c0fa9d9c4f41a397072114cbb9aa7e/Cslib/Foundations/Semantics/LTS/Bisimulation.lean#L723-L732"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">theorem</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Cslib/Foundations/Semantics/LTS/Bisimulation.html#Cslib.Bisimulation.deterministic_traceEq_is_bisim\"><span class=\"name\">Cslib</span>.<span class=\"name\">Bisimulation</span>.<span class=\"name\">deterministic_traceEq_is_bisim</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">State</span> : <a href=\"./foundational_types.html\">Type</a> u}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">Label</span> : <a href=\"./foundational_types.html\">Type</a> v}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">lts</span> : <span class=\"fn\"><a href=\"./Cslib/Foundations/Semantics/LTS/Basic.html#Cslib.LTS\">LTS</a> <span class=\"fn\">State</span> <span class=\"fn\">Label</span></span>}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">[<span class=\"fn\"><span class=\"fn\">lts</span>.<a href=\"./Cslib/Foundations/Semantics/LTS/Basic.html#Cslib.LTS.Deterministic\">Deterministic</a></span>]</span></span>\n</span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><span class=\"fn\"><span class=\"fn\">lts</span>.<a href=\"./Cslib/Foundations/Semantics/LTS/Bisimulation.html#Cslib.LTS.IsBisimulation\">IsBisimulation</a></span> <span class=\"fn\">(<a href=\"./Cslib/Foundations/Semantics/LTS/TraceEq.html#Cslib.TraceEq\">TraceEq</a> <span class=\"fn\">lts</span>)</span></span></div></div>","info":{"doc":"In any deterministic LTS, trace equivalence is a bisimulation. ","docLink":"./Cslib/Foundations/Semantics/LTS/Bisimulation.html#Cslib.Bisimulation.deterministic_traceEq_is_bisim","kind":"theorem","line":702,"name":"Cslib.Bisimulation.deterministic_traceEq_is_bisim","sourceLink":"https://github.com/leanprover/cslib/blob/7f88669e78c0fa9d9c4f41a397072114cbb9aa7e/Cslib/Foundations/Semantics/LTS/Bisimulation.lean#L702-L721"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">theorem</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Cslib/Foundations/Semantics/LTS/Bisimulation.html#Cslib.Bisimilarity.bisimilarity_neq_traceEq\"><span class=\"name\">Cslib</span>.<span class=\"name\">Bisimilarity</span>.<span class=\"name\">bisimilarity_neq_traceEq</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\">∃ (<span class=\"fn\">State</span> : <a href=\"./foundational_types.html\">Type</a>) (<span class=\"fn\">Label</span> : <a href=\"./foundational_types.html\">Type</a>) (<span class=\"fn\">lts</span> : <span class=\"fn\"><a href=\"./Cslib/Foundations/Semantics/LTS/Basic.html#Cslib.LTS\">LTS</a> <span class=\"fn\">State</span> <span class=\"fn\">Label</span></span>), <span class=\"fn\"><a href=\"./Cslib/Foundations/Semantics/LTS/Bisimulation.html#Cslib.Bisimilarity\">Bisimilarity</a> <span class=\"fn\">lts</span></span> <a href=\"./Init/Core.html#Ne\">≠</a> <span class=\"fn\"><a href=\"./Cslib/Foundations/Semantics/LTS/TraceEq.html#Cslib.TraceEq\">TraceEq</a> <span class=\"fn\">lts</span></span></span></div></div>","info":{"doc":"In general, bisimilarity and trace equivalence are distinct. ","docLink":"./Cslib/Foundations/Semantics/LTS/Bisimulation.html#Cslib.Bisimilarity.bisimilarity_neq_traceEq","kind":"theorem","line":692,"name":"Cslib.Bisimilarity.bisimilarity_neq_traceEq","sourceLink":"https://github.com/leanprover/cslib/blob/7f88669e78c0fa9d9c4f41a397072114cbb9aa7