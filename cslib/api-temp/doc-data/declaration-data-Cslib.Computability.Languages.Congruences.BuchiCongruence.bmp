uences/BuchiCongruence.html#Cslib.Automata.NA.Buchi.buchiCongrParam_surjective","kind":"theorem","line":56,"name":"Cslib.Automata.NA.Buchi.buchiCongrParam_surjective","sourceLink":"https://github.com/leanprover/cslib/blob/b00648a4fe741981bb586a3cc845258ab1583f61/Cslib/Computability/Languages/Congruences/BuchiCongruence.lean#L56-L69"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">noncomputable def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Cslib/Computability/Languages/Congruences/BuchiCongruence.html#Cslib.Automata.NA.Buchi.BuchiCongrParam\"><span class=\"name\">Cslib</span>.<span class=\"name\">Automata</span>.<span class=\"name\">NA</span>.<span class=\"name\">Buchi</span>.<span class=\"name\">BuchiCongrParam</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">Symbol</span> : <a href=\"./foundational_types.html\">Type</a> u_1}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">State</span> : <a href=\"./foundational_types.html\">Type</a>}</span></span>\n</span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">na</span> : <span class=\"fn\"><a href=\"./Cslib/Computability/Automata/NA/Basic.html#Cslib.Automata.NA.Buchi\">Buchi</a> <span class=\"fn\">State</span> <span class=\"fn\">Symbol</span></span>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">f</span> : <span class=\"fn\"><span class=\"fn\">State</span> → <span class=\"fn\">State</span> → <a href=\"./foundational_types.html\">Prop</a> <a href=\"./Init/Prelude.html#Prod\">×</a> <a href=\"./foundational_types.html\">Prop</a></span>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Init/Core.html#Quotient\">Quotient</a> <span class=\"fn\"><span class=\"fn\"><span class=\"fn\">na</span>.<a href=\"./Cslib/Computability/Languages/Congruences/BuchiCongruence.html#Cslib.Automata.NA.Buchi.BuchiCongruence\">BuchiCongruence</a></span>.<a href=\"./Cslib/Computability/Languages/Congruences/RightCongruence.html#Cslib.RightCongruence.eq\">eq</a></span></span></div></div>","info":{"doc":"`BuchiCongrParam` is a parameterization of the equivalence classes of `na.BuchiCongruence`\nusing the type `State → State → Prop × Prop`, which is finite if `State` is. ","docLink":"./Cslib/Computability/Languages/Congruences/BuchiCongruence.html#Cslib.Automata.NA.Buchi.BuchiCongrParam","kind":"def","line":45,"name":"Cslib.Automata.NA.Buchi.BuchiCongrParam","sourceLink":"https://github.com/leanprover/cslib/blob/b00648a4fe741981bb586a3cc845258ab1583f61/Cslib/Computability/Languages/Congruences/BuchiCongruence.lean#L45-L52"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Cslib/Computability/Languages/Congruences/BuchiCongruence.html#Cslib.Automata.NA.Buchi.BuchiCongruence\"><span class=\"name\">Cslib</span>.<span class=\"name\">Automata</span>.<span class=\"name\">NA</span>.<span class=\"name\">Buchi</span>.<span class=\"name\">BuchiCongruence</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">Symbol</span> : <a href=\"./foundational_types.html\">Type</a> u_1}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">State</span> : <a href=\"./foundational_types.html\">Type</a>}</span></span>\n</span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">na</span> : <span class=\"fn\"><a href=\"./Cslib/Computability/Automata/NA/Basic.html#Cslib.Automata.NA.Buchi\">Buchi</a> <span class=\"fn\">State</span> <span class=\"fn\">Symbol</span></span>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Cslib/Computability/Languages/Congruences/RightCongruence.html#Cslib.RightCongruence\">RightCongruence</a> <span class=\"fn\">Symbol</span></span></div></div>","info":{"doc":"Given a Buchi automaton `na`, two finite words `u` and `v` are Buchi-congruent\naccording to `na` iff for every pair of states `s` and `t` of `na`, both of the\nfollowing two conditions hold:\n(1) `u` can move `na` from `s` to `t` iff `v` can move `na` from `s` to `t`;\n(2) `u` can move `na` from `s` to `t` via an acceptingg states iff `v` can move `na`\nfrom `s` to `t` via an acceptingg states. ","docLink":"./Cslib/Computability/Languages/Congruences/BuchiCongruence.html#Cslib.Automata.NA.Buchi.BuchiCongruence","kind":"def","line":27,"name":"Cslib.Automata.NA.Buchi.BuchiCongruence","sourceLink":"https://github.com/leanprover/cslib/blob/b00648a4fe741981bb586a3cc845258ab1583f61/Cslib/Computability/Languages/Congruences/BuchiCongruence.lean#L27-L42"}}],"imports":["Init","Cslib.Computability.Automata.NA.Pair","Cslib.Computability.Languages.Congruences.RightCongruence"],"instances":[],"name":"Cslib.Computability.Languages.Congruences.BuchiCongruence"}