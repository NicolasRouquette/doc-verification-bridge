t\">scaleUnit</a> <span class=\"fn\">u1</span> <span class=\"fn\">u2</span> <span class=\"fn\">m</span>)</span></span> <a href=\"./Init/Prelude.html#Eq\">=</a> <span class=\"fn\"><a href=\"./PhysLean/Units/UnitDependent.html#UnitDependent.scaleUnit\">scaleUnit</a> <span class=\"fn\">u1</span> <span class=\"fn\">u3</span> <span class=\"fn\">m</span></span></div></div>","info":{"doc":"","docLink":"./PhysLean/Units/UnitDependent.html#UnitDependent.scaleUnit_trans","kind":"theorem","line":42,"name":"UnitDependent.scaleUnit_trans","sourceLink":"https://github.com/HEPLean/PhysLean#L42-L42"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">abbrev</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./PhysLean/Units/UnitDependent.html#UnitDependent.scaleUnit\"><span class=\"name\">UnitDependent</span>.<span class=\"name\">scaleUnit</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">M</span> : <a href=\"./foundational_types.html\">Type</a>}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">[<span class=\"fn\">self</span> : <span class=\"fn\"><a href=\"./PhysLean/Units/UnitDependent.html#UnitDependent\">UnitDependent</a> <span class=\"fn\">M</span></span>]</span></span>\n</span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./PhysLean/Units/Basic.html#UnitChoices\">UnitChoices</a> → <a href=\"./PhysLean/Units/Basic.html#UnitChoices\">UnitChoices</a> → <span class=\"fn\"><span class=\"fn\">M</span> → <span class=\"fn\">M</span></span></span></div></div>","info":{"doc":"`scaleUnit u1 u2` is the map transforming elements of `M` under a\nscaling of units which would take the unit `u1` to the unit `u2`. This is not\nto say that in `scaleUnit u1 u2 m` that `m` should be interpreted as being in the units `u1`,\nalthough this is often the case.\n","docLink":"./PhysLean/Units/UnitDependent.html#UnitDependent.scaleUnit","kind":"def","line":41,"name":"UnitDependent.scaleUnit","sourceLink":"https://github.com/HEPLean/PhysLean#L41-L41"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">constructor</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./PhysLean/Units/UnitDependent.html#UnitDependent.mk\"><span class=\"name\">UnitDependent</span>.<span class=\"name\">mk</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">M</span> : <a href=\"./foundational_types.html\">Type</a>}</span></span>\n</span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">scaleUnit</span> : <span class=\"fn\"><a href=\"./PhysLean/Units/Basic.html#UnitChoices\">UnitChoices</a> → <a href=\"./PhysLean/Units/Basic.html#UnitChoices\">UnitChoices</a> → <span class=\"fn\"><span class=\"fn\">M</span> → <span class=\"fn\">M</span></span></span>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">scaleUnit_trans</span> : <span class=\"fn\">∀ (<span class=\"fn\">u1 </span><span class=\"fn\">u2 </span><span class=\"fn\">u3</span> : <a href=\"./PhysLean/Units/Basic.html#UnitChoices\">UnitChoices</a>) (<span class=\"fn\">m</span> : <span class=\"fn\">M</span>), <span class=\"fn\"><span class=\"fn\">scaleUnit</span> <span class=\"fn\">u2</span> <span class=\"fn\">u3</span> <span class=\"fn\">(<span class=\"fn\">scaleUnit</span> <span class=\"fn\">u1</span> <span class=\"fn\">u2</span> <span class=\"fn\">m</span>)</span></span> <a href=\"./Init/Prelude.html#Eq\">=</a> <span class=\"fn\"><span class=\"fn\">scaleUnit</span> <span class=\"fn\">u1</span> <span class=\"fn\">u3</span> <span class=\"fn\">m</span></span></span>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">scaleUnit_trans'</span> : <span class=\"fn\">∀ (<span class=\"fn\">u1 </span><span class=\"fn\">u2 </span><span class=\"fn\">u3</span> : <a href=\"./PhysLean/Units/Basic.html#UnitChoices\">UnitChoices</a>) (<span class=\"fn\">m</span> : <span class=\"fn\">M</span>), <span class=\"fn\"><span class=\"fn\">scaleUnit</span> <span class=\"fn\">u1</span> <span class=\"fn\">u2</span> <span class=\"fn\">(<span class=\"fn\">scaleUnit</span> <span class=\"fn\">u2</span> <span class=\"fn\">u3</span> <span class=\"fn\">m</span>)</span></span> <a href=\"./Init/Prelude.html#Eq\">=</a> <span class=\"fn\"><span class=\"fn\">scaleUnit</span> <span class=\"fn\">u1</span> <span class=\"fn\">u3</span> <span class=\"fn\">m</span></span></span>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">scaleUnit_id</span> : <span class=\"fn\">∀ (<span class=\"fn\">u</span> : <a href=\"./PhysLean/Units/Basic.html#UnitChoices\">UnitChoices</a>) (<span class=\"fn\">m</span> : <span class=\"fn\">M</span>), <span class=\"fn\"><span class=\"fn\">scaleUnit</span> <span class=\"fn\">u</span> <span class=\"fn\">u</span> <span class=\"fn\">m</span></span> <a href=\"./Init/Prelude.html#Eq\">=</a> <span class=\"fn\">m</span></span>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./PhysLean/Units/UnitDependent.html#UnitDependent\">UnitDependent</a> <span class=\"fn\">M</span></span></div></div>","info":{"doc":"","docLink":"./PhysLean/Units/UnitDependent.html#UnitDependent.mk","kind":"ctor","line":35,"name":"UnitDependent.mk","sourceLink":"https://github.com/HEPLean/PhysLean#L35-L35"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">class</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./PhysLean/Units/UnitDependent.html#UnitDependent\"><span class=\"name\">UnitDependent</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">M</span> : <a href=\"./foundational_types.html\">Type</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./foundational_types.html\">Type</a></div></div>","info":{"doc":"A type carries the instance `UnitDependent M` if it depends on a choice of units.\nThis dependence is manifested in `scaleUnit u1 u2` which describes how elements of `M` change\nunder a scaling of units which would take `u1` to `u2`.\n\nThis type is used for functions, and propositions etc.\n","docLink":"./PhysLean/Units/UnitDependent.html#UnitDependent","kind":"class","line":29,"name":"UnitDependent","sourceLink":"https://github.com/HEPLean/PhysLean#L29-L44"}}],"imports":["Init","PhysLean.Units.Basic"],"instances":[{"className":"UnitDependent","name":"instUnitDependentUnitChoices","typeNames":["UnitChoices"]},{"className":"MulUnitDependent","name":"instMulUnitDependent","typeNames":[]},{"className":"LinearUnitDependent","name":"instLinearUnitDependentOfHasDim","typeNames":[]},{"className":"ContinuousLinearUnitDependent","name":"instContinuousLinearUnitDependentOfHasDimOfContinuousConstSMulReal","typeNames":[]},{"className":"UnitDependent","name":"instUnitDependentForall","typeNames":[]},{"className":"LinearUnitDependent","name":"instLinearUnitDependentLinearMapRealId","typeNames":["LinearMap"]},{"className":"ContinuousLinearUnitDependent","name":"instContinuousLinearUnitDependentContinuousLinearMapRealId","typeNames":["ContinuousLinearMap"]},{"className":"UnitDependent","name":"instUnitDependentForall_1","typeNames":[]},{"className":"UnitDependent","name":"instUnitDependentTwoSided","typeNames":[]},{"className":"MulUnitDependent","name":"instUnitDependentTwoSidedMul","typeNames":[]},{"className":"ContinuousLinearUnitDependent","name":"instContinuousLinearUnitDependentMap","typeNames":["ContinuousLinearMap"]},{"className":"MulAction","name":"instMulActionNNRealElemDimSet","typeNames":["NNReal","Set.Elem"]},{"className":"CarriesDimension","name":"instCarriesDimensionElemDimSet","typeNames":["Set.Elem"]}],"name":"PhysLean.Units.UnitDependent"}