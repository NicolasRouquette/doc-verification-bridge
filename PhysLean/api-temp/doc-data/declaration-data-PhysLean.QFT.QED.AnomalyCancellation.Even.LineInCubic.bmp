cc</a></span></span> → <a href=\"./Init/Data/Rat/Basic.html#Rat\">ℚ</a></span>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">f</span> : <span class=\"fn\"><span class=\"fn\"><a href=\"./Init/Prelude.html#Fin\">Fin</a> <span class=\"fn\">n</span></span> → <a href=\"./Init/Data/Rat/Basic.html#Rat\">ℚ</a></span>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><span class=\"fn\"><span class=\"fn\">S</span>.<a href=\"./PhysLean/QFT/AnomalyCancellation/Basic.html#ACCSystemLinear.LinSols.val\">val</a></span> <a href=\"./Init/Prelude.html#Eq\">=</a> <span class=\"fn\"><a href=\"./PhysLean/QFT/QED/AnomalyCancellation/Even/BasisLinear.html#PureU1.VectorLikeEvenPlane.P\">VectorLikeEvenPlane.P</a> <span class=\"fn\">g</span></span> <a href=\"./Init/Prelude.html#HAdd.hAdd\">+</a> <span class=\"fn\"><a href=\"./PhysLean/QFT/QED/AnomalyCancellation/Even/BasisLinear.html#PureU1.VectorLikeEvenPlane.P!\">VectorLikeEvenPlane.P!</a> <span class=\"fn\">f</span></span> →\n  <span class=\"fn\"><span class=\"fn\">(<span class=\"fn\">(<a href=\"./PhysLean/QFT/QED/AnomalyCancellation/Basic.html#PureU1.accCubeTriLinSymm\">accCubeTriLinSymm</a> <span class=\"fn\">(<a href=\"./PhysLean/QFT/QED/AnomalyCancellation/Even/BasisLinear.html#PureU1.VectorLikeEvenPlane.P\">VectorLikeEvenPlane.P</a> <span class=\"fn\">g</span>)</span>)</span> <span class=\"fn\">(<a href=\"./PhysLean/QFT/QED/AnomalyCancellation/Even/BasisLinear.html#PureU1.VectorLikeEvenPlane.P\">VectorLikeEvenPlane.P</a> <span class=\"fn\">g</span>)</span>)</span> <span class=\"fn\">(<a href=\"./PhysLean/QFT/QED/AnomalyCancellation/Even/BasisLinear.html#PureU1.VectorLikeEvenPlane.P!\">VectorLikeEvenPlane.P!</a> <span class=\"fn\">f</span>)</span></span> <a href=\"./Init/Prelude.html#Eq\">=</a> <span class=\"fn\">0</span></span></div></div>","info":{"doc":"This lemma states that for a given `S` of type `(PureU1 (2 * n.succ)).AnomalyFreeLinear` and\na proof `h` that the line through `S` lies on a cubic curve,\nfor any functions `g : Fin n.succ → ℚ` and `f : Fin n → ℚ`, if `S.val = P g + P! f`,\nthen `accCubeTriLinSymm.toFun (P g, P g, P! f) = 0`.\n","docLink":"./PhysLean/QFT/QED/AnomalyCancellation/Even/LineInCubic.html#PureU1.Even.line_in_cubic_P_P_P!","kind":"theorem","line":59,"name":"PureU1.Even.line_in_cubic_P_P_P!","sourceLink":"https://github.com/HEPLean/PhysLean#L59-L70"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">theorem</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./PhysLean/QFT/QED/AnomalyCancellation/Even/LineInCubic.html#PureU1.Even.lineInCubic_expand\"><span class=\"name\">PureU1</span>.<span class=\"name\">Even</span>.<span class=\"name\">lineInCubic_expand</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">n</span> : <a href=\"./Init/Prelude.html#Nat\">ℕ</a>}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">S</span> : <span class=\"fn\"><span class=\"fn\">(<a href=\"./PhysLean/QFT/QED/AnomalyCancellation/Basic.html#PureU1\">PureU1</a> (<span class=\"fn\">2</span> <a href=\"./Init/Prelude.html#HMul.hMul\">*</a> <span class=\"fn\"><span class=\"fn\">n</span>.<a href=\"./Init/Prelude.html#Nat.succ\">succ</a></span>))</span>.<a href=\"./PhysLean/QFT/AnomalyCancellation/Basic.html#ACCSystemLinear.LinSols\">LinSols</a></span>}</span></span>\n</span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">h</span> : <span class=\"fn\"><a href=\"./PhysLean/QFT/QED/AnomalyCancellation/Even/LineInCubic.html#PureU1.Even.LineInCubic\">LineInCubic</a> <span class=\"fn\">S</span></span>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">g</span> : <span class=\"fn\"><span class=\"fn\"><a href=\"./Init/Prelude.html#Fin\">Fin</a> <span class=\"fn\"><span class=\"fn\">n</span>.<a href=\"./Init/Prelude.html#Nat.succ\">succ</a></span></span> → <a href=\"./Init/Data/Rat/Basic.html#Rat\">ℚ</a></span>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">f</span> : <span class=\"fn\"><span class=\"fn\"><a href=\"./Init/Prelude.html#Fin\">Fin</a> <span class=\"fn\">n</span></span> → <a href=\"./Init/Data/Rat/Basic.html#Rat\">ℚ</a></span>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><span class=\"fn\"><span class=\"fn\">S</span>.<a href=\"./PhysLean/QFT/AnomalyCancellation/Basic.html#ACCSystemLinear.LinSols.val\">val</a></span> <a href=\"./Init/Prelude.html#Eq\">=</a> <span class=\"fn\"><a href=\"./PhysLean/QFT/QED/AnomalyCancellation/Even/BasisLinear.html#PureU1.VectorLikeEvenPlane.Pa\">VectorLikeEvenPlane.Pa</a> <span class=\"fn\">g</span> <span class=\"fn\">f</span></span> →\n  <span class=\"fn\">∀ (<span class=\"fn\">a </span><span class=\"fn\">b</span> : <a href=\"./Init/Data/Rat/Basic.html#Rat\">ℚ</a>),\n    <span class=\"fn\">3</span> <a href=\"./Init/Prelude.html#HMul.hMul\">*</a> <span class=\"fn\">a</span> <a href=\"./Init/Prelude.html#HMul.hMul\">*</a> <span class=\"fn\">b</span> <a href=\"./Init/Prelude.html#HMul.hMul\">*</a>         (<span class=\"fn\">a</span> <a href=\"./Init/Prelude.html#HMul.hMul\">*</a> <span class=\"fn\"><span class=\"fn\">(<span class=\"fn\">(<a href=\"./PhysLean/QFT/QED/AnomalyCancellation/Basic.html#PureU1.accCubeTriLinSymm\">accCubeTriLinSymm</a> <span class=\"fn\">(<a href=\"./PhysLean/QFT/QED/AnomalyCancellation/Even/BasisLinear.html#PureU1.VectorLikeEvenPlane.P\">VectorLikeEvenPlane.P</a> <span class=\"fn\">g</span>)</span>)</span> <span class=\"fn\">(<a href=\"./PhysLean/QFT/QED/AnomalyCancellation/Even/BasisLinear.html#PureU1.VectorLikeEvenPlane.P\">VectorLikeEvenPlane.P</a> <span class=\"fn\">g</span>)</span>)</span> <span class=\"fn\">(<a href=\"./PhysLean/QFT/QED/AnomalyCancellation/Even/BasisLinear.html#PureU1.VectorLikeEvenPlane.P!\">VectorLikeEvenPlane.P!</a> <span class=\"fn\">f</span>)</span></span> <a href=\"./Init/Prelude.html#HAdd.hAdd\">+</a>           <span class=\"fn\">b</span> <a href=\"./Init/Prelude.html#HMul.hMul\">*</a> <span class=\"fn\"><span class=\"fn\">(<span class=\"fn\">(<a href=\"./PhysLean/QFT/QED/AnomalyCancellation/Basic.html#PureU1.accCubeTriLinSymm\">accCubeTriLinSymm</a> <span class=\"fn\">(<a href=\"./PhysLean/QFT/QED/AnomalyCancellation/Even/BasisLinear.html#PureU1.VectorLikeEvenPlane.P!\">VectorLikeEvenPlane.P!</a> <span class=\"fn\">f</span>)</span>)</span> <span class=\"fn\">(<a href=\"./PhysLean/QFT/QED/AnomalyCancellation/Even/BasisLinear.html#PureU1.VectorLikeEvenPlane.P!\">VectorLikeEvenPlane.P!</a> <span class=\"fn\">f</span>)</span>)</span> <span class=\"fn\">(<a href=\"./PhysLean/QFT/QED/AnomalyCancellation/Even/BasisLinear.html#PureU1.VectorLikeEvenPlane.P\">VectorLikeEvenPlane.P</a> <span class=\"fn\">g</span>)</span></span>) <a href=\"./Init/Prelude.html#Eq\">=</a>       <span class=\"fn\">0</span></span></span></div></div>","info":{"doc":"","docLink":"./PhysLean/QFT/QED/AnomalyCancellation/Even/LineInCubic.html#PureU1.Even.lineInCubic_expand","kind":"theorem","line":38,"name":"PureU1.Even.lineInCubic_expand","sourceLink":"https://github.com/HEPLean/PhysLean#L38-L57"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./PhysLean/QFT/QED/AnomalyCancellation/Even/LineInCubic.html#PureU1.Even.LineInCubic\"><span class=\"name\">PureU1</span>.<span class=\"name\">Even</span>.<span class=\"name\">LineInCubic</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">n</span> : <a href=\"./Init/Prelude.html#Nat\">ℕ</a>}</span></span>\n</span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">S</span> : <span class=\"fn\"><span class=\"fn\">(<a href=\"./PhysLean/QFT/QED/AnomalyCancellation/Basic.html#PureU1\">PureU1</a> (<span class=\"fn\">2</span> <a href=\"./Init/Prelude.html#HMul.hMul\">*</a> <span class=\"fn\"><span class=\"fn\">n</span>.<a href=\"./Init/Prelude.html#Nat.succ\">succ</a></span>))</span>.<a href=\"./PhysLean/QFT/AnomalyCancellation/Basic.html#ACCSystemLinear.LinSols\">LinSols</a></span>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./foundational_types.html\">Prop</a></div></div>","info":{"doc":"A property on `LinSols`, satisfied if every point on the line between the two planes\nin the basis through that point is in the cubic. ","docLink":"./PhysLean/QFT/QED/AnomalyCancellation/Even/LineInCubic.html#PureU1.Even.LineInCubic","kind":"def","line":32,"name":"PureU1.Even.LineInCubic","sourceLink":"https://github.com/HEPLean/PhysLean#L32-L36"}}],"imports":["Init","PhysLean.QFT.QED.AnomalyCancellation.Even.BasisLinear","PhysLean.QFT.QED.AnomalyCancellation.LineInPlaneCond"],"instances":[],"name":"PhysLean.QFT.QED.AnomalyCancellation.Even.LineInCubic"}