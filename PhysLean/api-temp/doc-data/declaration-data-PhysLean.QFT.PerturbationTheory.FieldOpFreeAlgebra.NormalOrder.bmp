bationTheory/FieldOpFreeAlgebra/NormalOrder.html#FieldSpecification.FieldOpFreeAlgebra.normalOrderF_ofCrAnListF","kind":"theorem","line":49,"name":"FieldSpecification.FieldOpFreeAlgebra.normalOrderF_ofCrAnListF","sourceLink":"https://github.com/HEPLean/PhysLean#L49-L51"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./PhysLean/QFT/PerturbationTheory/FieldOpFreeAlgebra/NormalOrder.html#FieldSpecification.FieldOpFreeAlgebra.«term𝓝ᶠ(_)»\"><span class=\"name\">FieldSpecification</span>.<span class=\"name\">FieldOpFreeAlgebra</span>.<span class=\"name\">«term𝓝ᶠ(_)»</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Init/Prelude.html#Lean.ParserDescr\">Lean.ParserDescr</a></div></div>","info":{"doc":"For a field specification `𝓕`, `normalOrderF` is the linear map\n\n`FieldOpFreeAlgebra 𝓕 →ₗ[ℂ] FieldOpFreeAlgebra 𝓕`\n\ndefined by its action on the basis `ofCrAnListF φs`, taking `ofCrAnListF φs` to\n\n`normalOrderSign φs • ofCrAnListF (normalOrderList φs)`.\n\nThat is, `normalOrderF` normal-orders the field operators and multiplies by the sign of the\nnormal order.\n\nThe notation `𝓝ᶠ(a)` is used for `normalOrderF a` for `a` an element of\n`FieldOpFreeAlgebra 𝓕`. ","docLink":"./PhysLean/QFT/PerturbationTheory/FieldOpFreeAlgebra/NormalOrder.html#FieldSpecification.FieldOpFreeAlgebra.«term𝓝ᶠ(_)»","kind":"def","line":46,"name":"FieldSpecification.FieldOpFreeAlgebra.«term𝓝ᶠ(_)»","sourceLink":"https://github.com/HEPLean/PhysLean#L46-L47"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./PhysLean/QFT/PerturbationTheory/FieldOpFreeAlgebra/NormalOrder.html#FieldSpecification.FieldOpFreeAlgebra.normalOrderF\"><span class=\"name\">FieldSpecification</span>.<span class=\"name\">FieldOpFreeAlgebra</span>.<span class=\"name\">normalOrderF</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">𝓕</span> : <a href=\"./PhysLean/QFT/PerturbationTheory/FieldSpecification/Basic.html#FieldSpecification\">FieldSpecification</a>}</span></span>\n</span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><span class=\"fn\">𝓕</span>.<a href=\"./PhysLean/QFT/PerturbationTheory/FieldOpFreeAlgebra/Basic.html#FieldSpecification.FieldOpFreeAlgebra\">FieldOpFreeAlgebra</a></span> <a href=\"./Mathlib/Algebra/Module/LinearMap/Defs.html#LinearMap\">→ₗ[</a><a href=\"./Mathlib/Data/Complex/Basic.html#Complex\">ℂ</a><a href=\"./Mathlib/Algebra/Module/LinearMap/Defs.html#LinearMap\">]</a> <span class=\"fn\"><span class=\"fn\">𝓕</span>.<a href=\"./PhysLean/QFT/PerturbationTheory/FieldOpFreeAlgebra/Basic.html#FieldSpecification.FieldOpFreeAlgebra\">FieldOpFreeAlgebra</a></span></div></div>","info":{"doc":"For a field specification `𝓕`, `normalOrderF` is the linear map\n\n`FieldOpFreeAlgebra 𝓕 →ₗ[ℂ] FieldOpFreeAlgebra 𝓕`\n\ndefined by its action on the basis `ofCrAnListF φs`, taking `ofCrAnListF φs` to\n\n`normalOrderSign φs • ofCrAnListF (normalOrderList φs)`.\n\nThat is, `normalOrderF` normal-orders the field operators and multiplies by the sign of the\nnormal order.\n\nThe notation `𝓝ᶠ(a)` is used for `normalOrderF a` for `a` an element of\n`FieldOpFreeAlgebra 𝓕`. ","docLink":"./PhysLean/QFT/PerturbationTheory/FieldOpFreeAlgebra/NormalOrder.html#FieldSpecification.FieldOpFreeAlgebra.normalOrderF","kind":"def","line":29,"name":"FieldSpecification.FieldOpFreeAlgebra.normalOrderF","sourceLink":"https://github.com/HEPLean/PhysLean#L29-L44"}}],"imports":["Init","PhysLean.QFT.PerturbationTheory.FieldSpecification.NormalOrder","PhysLean.QFT.PerturbationTheory.FieldOpFreeAlgebra.SuperCommute"],"instances":[],"name":"PhysLean.QFT.PerturbationTheory.FieldOpFreeAlgebra.NormalOrder"}