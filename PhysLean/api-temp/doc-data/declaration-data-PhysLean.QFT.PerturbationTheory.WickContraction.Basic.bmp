ionTheory/WickContraction/Basic.html#WickContraction\">WickContraction</a> <span class=\"fn\">n</span></span></div></div>","info":{"doc":"The contraction consisting of no contracted pairs. ","docLink":"./PhysLean/QFT/PerturbationTheory/WickContraction/Basic.html#WickContraction.empty","kind":"def","line":34,"name":"WickContraction.empty","sourceLink":"https://github.com/HEPLean/PhysLean#L34-L35"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">instance</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./PhysLean/QFT/PerturbationTheory/WickContraction/Basic.html#WickContraction.instDecidableEq\"><span class=\"name\">WickContraction</span>.<span class=\"name\">instDecidableEq</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">n</span> : <a href=\"./Init/Prelude.html#Nat\">ℕ</a>}</span></span>\n</span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Init/Prelude.html#DecidableEq\">DecidableEq</a> <span class=\"fn\">(<a href=\"./PhysLean/QFT/PerturbationTheory/WickContraction/Basic.html#WickContraction\">WickContraction</a> <span class=\"fn\">n</span>)</span></span></div></div>","info":{"doc":"Wick contractions are decidable. ","docLink":"./PhysLean/QFT/PerturbationTheory/WickContraction/Basic.html#WickContraction.instDecidableEq","kind":"instance","line":31,"name":"WickContraction.instDecidableEq","sourceLink":"https://github.com/HEPLean/PhysLean#L31-L32"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./PhysLean/QFT/PerturbationTheory/WickContraction/Basic.html#WickContraction\"><span class=\"name\">WickContraction</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">n</span> : <a href=\"./Init/Prelude.html#Nat\">ℕ</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./foundational_types.html\">Type</a></div></div>","info":{"doc":"Given a natural number `n`, which will correspond to the number of fields needing\ncontracting, a Wick contraction\nis a finite set of pairs of `Fin n` (numbers `0`, ..., `n-1`), such that no\nelement of `Fin n` occurs in more than one pair. The pairs are the positions of fields we\n'contract' together.\n","docLink":"./PhysLean/QFT/PerturbationTheory/WickContraction/Basic.html#WickContraction","kind":"def","line":16,"name":"WickContraction","sourceLink":"https://github.com/HEPLean/PhysLean#L16-L25"}}],"imports":["Init","PhysLean.QFT.PerturbationTheory.FieldSpecification.Basic"],"instances":[{"className":"Decidable","name":"WickContraction.instDecidableEq","typeNames":["Eq"]}],"name":"PhysLean.QFT.PerturbationTheory.WickContraction.Basic"}