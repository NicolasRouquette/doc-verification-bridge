fication/Basic.html#FieldSpecification\">FieldSpecification</a>}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">φ </span><span class=\"fn\">ψ</span> : <span class=\"fn\"><span class=\"fn\">𝓕</span>.<a href=\"./PhysLean/QFT/PerturbationTheory/FieldSpecification/CrAnFieldOp.html#FieldSpecification.CrAnFieldOp\">CrAnFieldOp</a></span>}</span></span>\n</span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">h</span> : <a href=\"./Init/Prelude.html#Not\">¬</a><span class=\"fn\"><a href=\"./PhysLean/QFT/PerturbationTheory/FieldSpecification/TimeOrder.html#FieldSpecification.crAnTimeOrderRel\">crAnTimeOrderRel</a> <span class=\"fn\">φ</span> <span class=\"fn\">ψ</span></span>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./PhysLean/QFT/PerturbationTheory/FieldSpecification/TimeOrder.html#FieldSpecification.crAnTimeOrderSign\">crAnTimeOrderSign</a> <a href=\"./Init/Prelude.html#List.cons\">[</a><span class=\"fn\">φ</span><a href=\"./Init/Prelude.html#List.cons\">,</a> <span class=\"fn\">ψ</span><a href=\"./Init/Prelude.html#List.cons\">]</a></span> <a href=\"./Init/Prelude.html#Eq\">=</a> <span class=\"fn\"><span class=\"fn\">(<a href=\"./PhysLean/QFT/PerturbationTheory/FieldStatistics/ExchangeSign.html#FieldStatistic.exchangeSign\">FieldStatistic.exchangeSign</a> <span class=\"fn\">(<span class=\"fn\"><span class=\"fn\">𝓕</span>.<a href=\"./PhysLean/QFT/PerturbationTheory/FieldSpecification/CrAnFieldOp.html#FieldSpecification.crAnStatistics\">crAnStatistics</a></span> <span class=\"fn\">φ</span>)</span>)</span> <span class=\"fn\">(<span class=\"fn\"><span class=\"fn\">𝓕</span>.<a href=\"./PhysLean/QFT/PerturbationTheory/FieldSpecification/CrAnFieldOp.html#FieldSpecification.crAnStatistics\">crAnStatistics</a></span> <span class=\"fn\">ψ</span>)</span></span></div></div>","info":{"doc":"","docLink":"./PhysLean/QFT/PerturbationTheory/FieldSpecification/TimeOrder.html#FieldSpecification.crAnTimeOrderSign_pair_not_ordered","kind":"theorem","line":244,"name":"FieldSpecification.crAnTimeOrderSign_pair_not_ordered","sourceLink":"https://github.com/HEPLean/PhysLean#L244-L248"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">theorem</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./PhysLean/QFT/PerturbationTheory/FieldSpecification/TimeOrder.html#FieldSpecification.crAnTimeOrderSign_pair_ordered\"><span class=\"name\">FieldSpecification</span>.<span class=\"name\">crAnTimeOrderSign_pair_ordered</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">𝓕</span> : <a href=\"./PhysLean/QFT/PerturbationTheory/FieldSpecification/Basic.html#FieldSpecification\">FieldSpecification</a>}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">φ </span><span class=\"fn\">ψ</span> : <span class=\"fn\"><span class=\"fn\">𝓕</span>.<a href=\"./PhysLean/QFT/PerturbationTheory/FieldSpecification/CrAnFieldOp.html#FieldSpecification.CrAnFieldOp\">CrAnFieldOp</a></span>}</span></span>\n</span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">h</span> : <span class=\"fn\"><a href=\"./PhysLean/QFT/PerturbationTheory/FieldSpecification/TimeOrder.html#FieldSpecification.crAnTimeOrderRel\">crAnTimeOrderRel</a> <span class=\"fn\">φ</span> <span class=\"fn\">ψ</span></span>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./PhysLean/QFT/PerturbationTheory/FieldSpecification/TimeOrder.html#FieldSpecification.crAnTimeOrderSign\">crAnTimeOrderSign</a> <a href=\"./Init/Prelude.html#List.cons\">[</a><span class=\"fn\">φ</span><a href=\"./Init/Prelude.html#List.cons\">,</a> <span class=\"fn\">ψ</span><a href=\"./Init/Prelude.html#List.cons\">]</a></span> <a href=\"./Init/Prelude.html#Eq\">=</a> <span class=\"fn\">1</span></div></div>","info":{"doc":"","docLink":"./PhysLean/QFT/PerturbationTheory/FieldSpecification/TimeOrder.html#FieldSpecification.crAnTimeOrderSign_pair_ordered","kind":"theorem","line":238,"name":"FieldSpecification.crAnTimeOrderSign_pair_ordered","sourceLink":"https://github.com/HEPLean/PhysLean#L238-L242"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">theorem</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./PhysLean/QFT/PerturbationTheory/FieldSpecification/TimeOrder.html#FieldSpecification.crAnTimeOrderSign_nil\"><span class=\"name\">FieldSpecification</span>.<span class=\"name\">crAnTimeOrderSign_nil</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">𝓕</span> : <a href=\"./PhysLean/QFT/PerturbationTheory/FieldSpecification/Basic.html#FieldSpecification\">FieldSpecification</a>}</span></span>\n</span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./PhysLean/QFT/PerturbationTheory/FieldSpecification/TimeOrder.html#FieldSpecification.crAnTimeOrderSign\">crAnTimeOrderSign</a> <a href=\"./Init/Prelude.html#List.nil\">[</a><a href=\"./Init/Prelude.html#List.nil\">]</a></span> <a href=\"./Init/Prelude.html#Eq\">=</a> <span class=\"fn\">1</span></div></div>","info":{"doc":"","docLink":"./PhysLean/QFT/PerturbationTheory/FieldSpecification/TimeOrder.html#FieldSpecification.crAnTimeOrderSign_nil","kind":"theorem","line":233,"name":"FieldSpecification.crAnTimeOrderSign_nil","sourceLink":"https://github.com/HEPLean/PhysLean#L233-L236"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./PhysLean/QFT/PerturbationTheory/FieldSpecification/TimeOrder.html#FieldSpecification.crAnTimeOrderSign\"><span class=\"name\">FieldSpecification</span>.<span class=\"name\">crAnTimeOrderSign</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">𝓕</span> : <a href=\"./PhysLean/QFT/PerturbationTheory/FieldSpecification/Basic.html#FieldSpecification\">FieldSpecification</a>}</span></span>\n</span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">φs</span> : <span class=\"fn\"><a href=\"./Init/Prelude.html#List\">List</a> <span class=\"fn\"><span class=\"fn\">𝓕</span>.<a href=\"./PhysLean/QFT/PerturbationTheory/FieldSpecification/CrAnFieldOp.html#FieldSpecification.CrAnFieldOp\">CrAnFieldOp</a></span></span>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Mathlib/Data/Complex/Basic.html#Complex\">ℂ</a></div></div>","info":{"doc":"For a field specification `𝓕`, and a list `φs` of `𝓕.CrAnFieldOp`,\n`𝓕.crAnTimeOrderSign φs` is the sign corresponding to the number of `ferimionic`-`fermionic`\nexchanges undertaken to time-order (i.e. order with respect to `𝓕.crAnTimeOrderRel`) `φs` using\nthe insertion sort algorithm. ","docLink":"./PhysLean/QFT/PerturbationTheory/FieldSpecification/TimeOrder.html#FieldSpecification.crAnTimeOrderSign","kind":"def","line":226,"name":"FieldSpecification.crAnTimeOrderSign","sourceLink":"https://github.com/HEPLean/PhysLean#L226-L231"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">theorem</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./PhysLean/QFT/PerturbationTheory/FieldSpecification/TimeOrder.html#FieldSpecification.crAnTimeOrderRel_refl\"><span class=\"name\">FieldSpecification</span>.<span class=\"name\">crAnTimeOrderRel_refl</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">𝓕</span> : <a href=\"./PhysLean/QFT/PerturbationTheory/FieldSpecification/Basic.html#FieldSpecification\">FieldSpecification</a>}</span></span>\n</span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">φ</span> : <span class=\"fn\"><span class=\"fn\">𝓕</span>.<a href=\"./PhysLean/QFT/PerturbationTheory/FieldSpecification/CrAnFieldOp.html#FieldSpecification.CrAnFieldOp\">CrAnFieldOp</a></span>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./PhysLean/QFT/PerturbationTheory/FieldSpecification/TimeOrder.html#FieldSpecification.crAnTimeOrderRel\">crAnTimeOrderRel</a> <span class=\"fn\">φ</span> <span class=\"fn\">φ</span></span></div></div>","info":{"doc":"","docLink":"./PhysLean/QFT/PerturbationTheory/FieldSpecification/TimeOrder.html#FieldSpecification.crAnTimeOrderRel_refl","kind":"theorem","line":222,"name":"FieldSpecification.crAnTimeOrderRel_refl","sourceLink":"https://github.com/HEPLean/PhysLean#L222-L224"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">instance</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./PhysLean/QFT/PerturbationTheory/FieldSpecification/TimeOrder.html#FieldSpecification.instIsTransCrAnFieldOpCrAnTimeOrderRel\"><span class=\"name\">FieldSpecification</span>.<span class=\"name\">instIsTransCrAnFieldOpCrAnTimeOrderRel</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">𝓕</span> : <a href=\"./PhysLean/QFT/PerturbationTheory/FieldSpecification/Basic.html#FieldSpecification\">FieldSpecification</a>}</span></span>\n</span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Mathlib/Order/Defs/Unbundled.html#IsTrans\">IsTrans</a> <span class=\"fn\"><span class=\"fn\">𝓕</span>.<a href=\"./PhysLean/QFT/PerturbationTheory/FieldSpecification/CrAnFieldOp.html#FieldSpecification.CrAnFieldOp\">CrAnFieldOp</a></span> <a href=\"./PhysLean/QFT/PerturbationTheory/FieldSpecification/TimeOrder.html#FieldSpecification.crAnTimeOrderRel\">crAnTimeOrderRel</a></span></div></div>","info":{"doc":"Time ordering of `CrAnFieldOp` is transitive. ","docLink":"./PhysLean/QFT/PerturbationTheory/FieldSpecification/TimeOrder.html#FieldSpecification.instIsTransCrAnFieldOpCrAnTimeOrderRel","kind":"instance","line":218,"name":"FieldSpecification.instIsTransCrAnFieldOpCrAnTimeOrderRel","sourceLink":"https://github.com/HEPLean/PhysLean#L218-L220"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">instance</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./PhysLean/QFT/PerturbationTheory/FieldSpecification/TimeOrder.html#FieldSpecification.instIsTotalCrAnFieldOpCrAnTimeOrderRel\"><span class=\"name\">FieldSpecification</span>.<span class=\"name\">instIsTotalCrAnFieldOpCrAnTimeOrderRel</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">𝓕</span> : <a href=\"./PhysLean/QFT/PerturbationTheory/FieldSpecification/Basic.html#FieldSpecification\">FieldSpecification</a>}</span></span>\n</span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Mathlib/Order/Defs/Unbundled.html#IsTotal\">IsTotal</a> <span class=\"fn\"><span class=\"fn\">𝓕</span>.<a href=\"./PhysLean/QFT/PerturbationTheory/FieldSpecification/CrAnFieldOp.html#FieldSpecification.CrAnFieldOp\">CrAnFieldOp</a></span> <a href=\"./PhysLean/QFT/PerturbationTheory/FieldSpecification/TimeOrder.html#FieldSpecification.crAnTimeOrderRel\">crAnTimeOrderRel</a></span></div></div>","info":{"doc":"Time ordering of `CrAnFieldOp` is total. ","docLink":"./PhysLean/QFT/PerturbationTheory/FieldSpecification/TimeOrder.html#FieldSpecification.instIsTotalCrAnFieldOpCrAnTimeOrderRel","kind":"instance","line":214,"name":"FieldSpecification.instIsTotalCrAnFieldOpCrAnTimeOrderRel","sourceLink":"https://github.com/HEPLean/PhysLean#L214-L216"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">noncomputable instance</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./PhysLean/QFT/PerturbationTheory/FieldSpecification/TimeOrder.html#FieldSpecification.instDecidableCrAnTimeOrderRel\"><span class=\"name\">FieldSpecification</span>.<span class=\"name\">instDecidableCrAnTimeOrderRel</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">𝓕</span> : <a href=\"./PhysLean/QFT/PerturbationTheory/FieldSpecification/Basic.html#FieldSpecification\">FieldSpecification</a>}</span></span>\n</span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">φ </span><span class=\"fn\">φ'</span> : <span class=\"fn\"><span class=\"fn\">𝓕</span>.<a href=\"./PhysLean/QFT/PerturbationTheory/FieldSpecification/CrAnFieldOp.html#FieldSpecification.CrAnFieldOp\">CrAnFieldOp</a></span>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Init/Prelude.html#Decidable\">Decidable</a> <span class=\"fn\">(<a href=\"./PhysLean/QFT/PerturbationTheory/FieldSpecification/TimeOrder.html#FieldSpecification.crAnTimeOrderRel\">crAnTimeOrderRel</a> <span class=\"fn\">φ</span> <span class=\"fn\">φ'</span>)</span></span></div></div>","info":{"doc":"The relation `crAnTimeOrderRel` is decidable, but not computable so due to\n`Real.decidableLE`. ","docLink":"./PhysLean/QFT/PerturbationTheory/FieldSpecification/TimeOrder.html#FieldSpecification.instDecidableCrAnTimeOrderRel","kind":"instance","line":209,"name":"FieldSpecification.instDecidableCrAnTimeOrderRel","sourceLink":"https://github.com/HEPLean/PhysLean#L209-L212"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./PhysLean/QFT/PerturbationTheory/FieldSpecification/TimeOrder.html#FieldSpecification.crAnTimeOrderRel\"><span class=\"name\">FieldSpecification</span>.<span class=\"name\">crAnTimeOrderRel</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">𝓕</span> : <a href=\"./PhysLean/QFT/PerturbationTheory/FieldSpecification/Basic.html#FieldSpecification\">FieldSpecification</a>}</span></span>\n</span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">a </span><span class=\"fn\">b</span> : <span class=\"fn\"><span class=\"fn\">𝓕</span>.<a href=\"./PhysLean/QFT/PerturbationTheory/FieldSpecification/CrAnFieldOp.html#FieldSpecification.CrAnFieldOp\">CrAnFieldOp</a></span>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./foundational_types.html\">Prop</a></div></div>","info":{"doc":"For a field specification `𝓕`, `𝓕.crAnTimeOrderRel` is a relation on\n  `𝓕.CrAnFieldOp` representing time ordering.\n  It is defined such that `𝓕.crAnTimeOrderRel φ₀ φ₁` is true if and only if one of the following\n  holds\n- `φ₀` is an *outgoing* asymptotic operator\n- `φ₁` is an *incoming* asymptotic field operator\n- `φ₀` and `φ₁` are both position field operators where\n  the `SpaceTime` point of `φ₀` has a time *greater* than or equal to that of `φ₁`.\n\nThus, colloquially `𝓕.crAnTimeOrderRel φ₀ φ₁` if `φ₀` has time *greater* than or equal to `φ₁`.\nThe use of *greater* than rather then *less* than is because on ordering lists of operators\nit is needed that the operator with the greatest time is to the left.\n","docLink":"./PhysLean/QFT/PerturbationTheory/FieldSpecification/TimeOrder.html#FieldSpecification.crAnTimeOrderRel","kind":"def","line":194,"name":"FieldSpecification.crAnTimeOrderRel","sourceLink":"https://github.com/HEPLean/PhysLean#L194-L207"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">theorem</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./PhysLean/QFT/PerturbationTheory/FieldSpecification/TimeOrder.html#FieldSpecification.timeOrderList_eq_maxTimeField_timeOrderList\"><span class=\"name\">FieldSpecification</span>.<span class=\"name\">timeOrderList_eq_maxTimeField_timeOrderList</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">𝓕</span> : <a href=\"./PhysLean/QFT/PerturbationTheory/FieldSpecification/Basic.html#FieldSpecification\">FieldSpecification</a>}</span></span>\n</span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">φ</span> : <span class=\"fn\"><span class=\"fn\">𝓕</span>.<a href=\"./PhysLean/QFT/PerturbationTheory/FieldSpecification/Basic.html#FieldSpecification.FieldOp\">FieldOp</a></span>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">φs</span> : <span class=\"fn\"><a href=\"./Init/Prelude.html#List\">List</a> <span class=\"fn\"><span class=\"fn\">𝓕</span>.<a href=\"./PhysLean/QFT/PerturbationTheory/FieldSpecification/Basic.html#FieldSpecification.FieldOp\">FieldOp</a></span></span>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./PhysLean/QFT/PerturbationTheory/FieldSpecification/TimeOrder.html#FieldSpecification.timeOrderList\">timeOrderList</a> (<span class=\"fn\">φ</span> <a href=\"./Init/Prelude.html#List.cons\">::</a> <span class=\"fn\">φs</span>)</span> <a href=\"./Init/Prelude.html#Eq\">=</a> <span class=\"fn\"><a href=\"./PhysLean/QFT/PerturbationTheory/FieldSpecification/TimeOrder.html#FieldSpecification.maxTimeField\">maxTimeField</a> <span class=\"fn\">φ</span> <span class=\"fn\">φs</span></span> <a href=\"./Init/Prelude.html#List.cons\">::</a> <span class=\"fn\"><a href=\"./PhysLean/QFT/PerturbationTheory/FieldSpecification/TimeOrder.html#FieldSpecification.timeOrderList\">timeOrderList</a> <span class=\"fn\">(<a href=\"./PhysLean/QFT/PerturbationTheory/FieldSpecification/TimeOrder.html#FieldSpecification.eraseMaxTimeField\">eraseMaxTimeField</a> <span class=\"fn\">φ</span> <span class=\"fn\">φs</span>)</span></span></div></div>","info":{"doc":"","docLink":"./PhysLean/QFT/PerturbationTheory/FieldSpecification/TimeOrder.html#FieldSpecification.timeOrderList_eq_maxTimeField_timeOrderList","kind":"theorem","line":178,"name":"FieldSpecification.timeOrderList_eq_maxTimeField_timeOrderList","sourceLink":"https://github.com/HEPLean/PhysLean#L178-L180"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">theorem<