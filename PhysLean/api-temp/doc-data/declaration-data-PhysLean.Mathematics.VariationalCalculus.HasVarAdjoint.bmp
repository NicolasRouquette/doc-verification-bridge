inner</a> <a href=\"./Mathlib/Data/Real/Basic.html#Real\">ℝ</a> <span class=\"fn\">(<span class=\"fn\">φ</span> <span class=\"fn\">x</span>)</span> <span class=\"fn\">(<span class=\"fn\">F'</span> <span class=\"fn\">ψ</span> <span class=\"fn\">x</span>)</span></span></span></span></span></span>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">ext'</span> : <span class=\"fn\"><a href=\"./PhysLean/Mathematics/VariationalCalculus/IsLocalizedfunctionTransform.html#IsLocalizedFunctionTransform\">IsLocalizedFunctionTransform</a> <span class=\"fn\">F'</span></span>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./PhysLean/Mathematics/VariationalCalculus/HasVarAdjoint.html#HasVarAdjoint\">HasVarAdjoint</a> <span class=\"fn\">F</span> <span class=\"fn\">F'</span></span></div></div>","info":{"doc":"","docLink":"./PhysLean/Mathematics/VariationalCalculus/HasVarAdjoint.html#HasVarAdjoint.mk","kind":"ctor","line":46,"name":"HasVarAdjoint.mk","sourceLink":"https://github.com/HEPLean/PhysLean#L46-L46"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">structure</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./PhysLean/Mathematics/VariationalCalculus/HasVarAdjoint.html#HasVarAdjoint\"><span class=\"name\">HasVarAdjoint</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">X</span> : <a href=\"./foundational_types.html\">Type</a> u_1}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">[<span class=\"fn\"><a href=\"./Mathlib/Analysis/Normed/Group/Basic.html#NormedAddCommGroup\">NormedAddCommGroup</a> <span class=\"fn\">X</span></span>]</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">[<span class=\"fn\"><a href=\"./Mathlib/Analysis/Normed/Module/Basic.html#NormedSpace\">NormedSpace</a> <a href=\"./Mathlib/Data/Real/Bas