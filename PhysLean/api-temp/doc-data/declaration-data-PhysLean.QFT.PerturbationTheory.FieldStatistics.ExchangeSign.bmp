rturbationTheory/FieldStatistics/Basic.html#FieldStatistic.bosonic\">bosonic</a>)</span> <span class=\"fn\">a</span></span> <a href=\"./Init/Prelude.html#Eq\">=</a> <span class=\"fn\">1</span></div></div>","info":{"doc":"","docLink":"./PhysLean/QFT/PerturbationTheory/FieldStatistics/ExchangeSign.html#FieldStatistic.bosonic_exchangeSign","kind":"theorem","line":75,"name":"FieldStatistic.bosonic_exchangeSign","sourceLink":"https://github.com/HEPLean/PhysLean#L75-L77"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">theorem</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./PhysLean/QFT/PerturbationTheory/FieldStatistics/ExchangeSign.html#FieldStatistic.exchangeSign_bosonic\"><span class=\"name\">FieldStatistic</span>.<span class=\"name\">exchangeSign_bosonic</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">a</span> : <a href=\"./PhysLean/QFT/PerturbationTheory/FieldStatistics/Basic.html#FieldStatistic\">FieldStatistic</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><span class=\"fn\">(<a href=\"./PhysLean/QFT/PerturbationTheory/FieldStatistics/ExchangeSign.html#FieldStatistic.exchangeSign\">exchangeSign</a> <span class=\"fn\">a</span>)</span> <a href=\"./PhysLean/QFT/PerturbationTheory/FieldStatistics/Basic.html#FieldStatistic.bosonic\">bosonic</a></span> <a href=\"./Init/Prelude.html#Eq\">=</a> <span class=\"fn\">1</span></div></div>","info":{"doc":"","docLink":"./PhysLean/QFT/PerturbationTheory/FieldStatistics/ExchangeSign.html#FieldStatistic.exchangeSign_bosonic","kind":"theorem","line":71,"name":"FieldStatistic.exchangeSign_bosonic","sourceLink":"https://github.com/HEPLean/PhysLean#L71-L73"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">theorem</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./PhysLean/QFT/PerturbationTheory/FieldStatistics/ExchangeSign.html#FieldStatistic.exchangeSign_symm\"><span class=\"name\">FieldStatistic</span>.<span class=\"name\">exchangeSign_symm</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">a </span><span class=\"fn\">b</span> : <a href=\"./PhysLean/QFT/PerturbationTheory/FieldStatistics/Basic.html#FieldStatistic\">FieldStatistic</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><span class=\"fn\">(<a href=\"./PhysLean/QFT/PerturbationTheory/FieldStatistics/ExchangeSign.html#FieldStatistic.exchangeSign\">exchangeSign</a> <span class=\"fn\">a</span>)</span> <span class=\"fn\">b</span></span> <a href=\"./Init/Prelude.html#Eq\">=</a> <span class=\"fn\"><span class=\"fn\">(<a href=\"./PhysLean/QFT/PerturbationTheory/FieldStatistics/ExchangeSign.html#FieldStatistic.exchangeSign\">exchangeSign</a> <span class=\"fn\">b</span>)</span> <span class=\"fn\">a</span></span></div></div>","info":{"doc":"The exchange sign is symmetric. ","docLink":"./PhysLean/QFT/PerturbationTheory/FieldStatistics/ExchangeSign.html#FieldStatistic.exchangeSign_symm","kind":"theorem","line":67,"name":"FieldStatistic.exchangeSign_symm","sourceLink":"https://github.com/HEPLean/PhysLean#L67-L69"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./PhysLean/QFT/PerturbationTheory/FieldStatistics/ExchangeSign.html#FieldStatistic.«term𝓢(_,_)»\"><span class=\"name\">FieldStatistic</span>.<span class=\"name\">«term𝓢(_,_)»</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Init/Prelude.html#Lean.ParserDescr\">Lean.ParserDescr</a></div></div>","info":{"doc":"The exchange sign, `exchangeSign`, is defined as the group homomorphism\n\n`FieldStatistic →* FieldStatistic →* ℂ`,\n\nfor which `exchangeSign a b` is `-1` if both `a` and `b` are `fermionic` and `1` otherwise.\nThe exchange sign is the sign one picks up on exchanging an operator or field `φ₁` of statistic\n`a` with an operator or field `φ₂` of statistic `b`, i.e. `φ₁φ₂ → φ₂φ₁`.\n\nThe notation `𝓢(a, b)` is used for the exchange sign of `a` and `b`. ","docLink":"./PhysLean/QFT/PerturbationTheory/FieldStatistics/ExchangeSign.html#FieldStatistic.«term𝓢(_,_)»","kind":"def","line":64,"name":"FieldStatistic.«term𝓢(_,_)»","sourceLink":"https://github.com/HEPLean/PhysLean#L64-L65"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./PhysLean/QFT/PerturbationTheory/FieldStatistics/ExchangeSign.html#FieldStatistic.exchangeSign\"><span class=\"name\">FieldStatistic</span>.<span class=\"name\">exchangeSign</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./PhysLean/QFT/PerturbationTheory/FieldStatistics/Basic.html#FieldStatistic\">FieldStatistic</a> <a href=\"./Mathlib/Algebra/Group/Hom/Defs.html#MonoidHom\">→*</a> <a href=\"./PhysLean/QFT/PerturbationTheory/FieldStatistics/Basic.html#FieldStatistic\">FieldStatistic</a> <a href=\"./Mathlib/Algebra/Group/Hom/Defs.html#MonoidHom\">→*</a> <a href=\"./Mathlib/Data/Complex/Basic.html#Complex\">ℂ</a></div></div>","info":{"doc":"The exchange sign, `exchangeSign`, is defined as the group homomorphism\n\n`FieldStatistic →* FieldStatistic →* ℂ`,\n\nfor which `exchangeSign a b` is `-1` if both `a` and `b` are `fermionic` and `1` otherwise.\nThe exchange sign is the sign one picks up on exchanging an operator or field `φ₁` of statistic\n`a` with an operator or field `φ₂` of statistic `b`, i.e. `φ₁φ₂ → φ₂φ₁`.\n\nThe notation `𝓢(a, b)` is used for the exchange sign of `a` and `b`. ","docLink":"./PhysLean/QFT/PerturbationTheory/FieldStatistics/ExchangeSign.html#FieldStatistic.exchangeSign","kind":"def","line":28,"name":"FieldStatistic.exchangeSign","sourceLink":"https://github.com/HEPLean/PhysLean#L28-L62"}}],"imports":["Init","PhysLean.QFT.PerturbationTheory.FieldStatistics.Basic","Mathlib.Analysis.Complex.Basic"],"instances":[],"name":"PhysLean.QFT.PerturbationTheory.FieldStatistics.ExchangeSign"}