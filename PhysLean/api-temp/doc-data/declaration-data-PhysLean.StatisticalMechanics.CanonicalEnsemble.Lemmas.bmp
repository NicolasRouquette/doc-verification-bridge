an/StatisticalMechanics/CanonicalEnsemble/Basic.html#CanonicalEnsemble.energy\">energy</a></span> <span class=\"fn\">i</span></span>)</span> <a href=\"./Mathlib/MeasureTheory/Integral/Bochner/Basic.html#MeasureTheory.integral\">∂</a><span class=\"fn\"><span class=\"fn\">𝓒</span>.<a href=\"./PhysLean/StatisticalMechanics/CanonicalEnsemble/Basic.html#CanonicalEnsemble.μ\">μ</a></span></span>)</span>\n    (<a href=\"./Init/Prelude.html#Neg.neg\">-</a><span class=\"fn\"><a href=\"./Mathlib/MeasureTheory/Integral/Bochner/Basic.html#MeasureTheory.integral\">∫</a> (<span class=\"fn\">i</span> : <span class=\"fn\">ι</span>)<a href=\"./Mathlib/MeasureTheory/Integral/Bochner/Basic.html#MeasureTheory.integral\">,</a> <span class=\"fn\"><span class=\"fn\"><span class=\"fn\">𝓒</span>.<a href=\"./PhysLean/StatisticalMechanics/CanonicalEnsemble/Basic.html#CanonicalEnsemble.energy\">energy</a></span> <span class=\"fn\">i</span></span> <a href=\"./Init/Prelude.html#HMul.hMul\">*</a> <span class=\"fn\"><a href=\"./Mathlib/Analysis/Complex/Exponential.html#Real.exp\">Real.exp</a> (<a href=\"./Init/Prelude.html#Neg.neg\">-</a><span class=\"fn\">↑<span class=\"fn\"><span class=\"fn\">T</span>.<a href=\"./PhysLean/Thermodynamics/Temperature/Basic.html#Temperature.β\">β</a></span></span> <a href=\"./Init/Prelude.html#HMul.hMul\">*</a> <span class=\"fn\"><span class=\"fn\"><span class=\"fn\">𝓒</span>.<a href=\"./PhysLean/StatisticalMechanics/CanonicalEnsemble/Basic.html#CanonicalEnsemble.energy\">energy</a></span> <span class=\"fn\">i</span></span>)</span> <a href=\"./Mathlib/MeasureTheory/Integral/Bochner/Basic.html#MeasureTheory.integral\">∂</a><span class=\"fn\"><span class=\"fn\">𝓒</span>.<a href=\"./PhysLean/StatisticalMechanics/CanonicalEnsemble/Basic.html#CanonicalEnsemble.μ\">μ</a></span></span>) <span class=\"fn\">(<a href=\"./Mathlib/Order/Interval/Set/Defs.html#Set.Ioi\">Set.Ioi</a> <span class=\"fn\">0</span>)</span> <span class=\"fn\">↑<span class=\"fn\"><span class=\"fn\">T</