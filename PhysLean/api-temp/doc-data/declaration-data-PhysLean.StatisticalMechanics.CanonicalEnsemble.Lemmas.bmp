s/CanonicalEnsemble/Basic.html#CanonicalEnsemble.energy\">energy</a></span> <span class=\"fn\">x</span></span>)</span> <a href=\"./Mathlib/MeasureTheory/Integral/Bochner/Basic.html#MeasureTheory.integral\">∂</a><span class=\"fn\"><span class=\"fn\">𝓒</span>.<a href=\"./PhysLean/StatisticalMechanics/CanonicalEnsemble/Basic.html#CanonicalEnsemble.μ\">μ</a></span></span></div></div>","info":{"doc":"","docLink":"./PhysLean/StatisticalMechanics/CanonicalEnsemble/Lemmas.html#CanonicalEnsemble.integral_bolt_eq_integral_mul_exp","kind":"theorem","line":434,"name":"CanonicalEnsemble.integral_bolt_eq_integral_mul_exp","sourceLink":"https://github.com/HEPLean/PhysLean#L434-L457"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">theorem</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./PhysLean/StatisticalMechanics/CanonicalEnsemble/Lemmas.html#CanonicalEnsemble.hasDerivWithinAt_log_comp'\"><span class=\"name\">CanonicalEnsemble</span>.<span class=\"name\">hasDerivWithinAt_log_comp'</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">f</span> : <span class=\"fn\"><a href=\"./Mathlib/Data/Real/Basic.html#Real\">ℝ</a> → <a href=\"./Mathlib/Data/Real/Basic.html#Real\">ℝ</a></span>}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">f'</span> : <a href=\"./Mathlib/Data/Real/Basic.html#Real\">ℝ</a>}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">s</span> : <span class=\"fn\"><a href=\"./Mathlib/Data/Set/Defs.html#Set\">Set</a> <a href=\"./Mathlib/Data/Real/Basic.html#Real\">ℝ</a></span>}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">x</span> : <a href=\"./Mathlib/Data/Real/Basic.html#Real\">ℝ</a>}</span></span>\n</span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">hf</span> : <span class=\"fn\"><a href=\"./Mathlib/Analysis/Calculus/Deriv/Basic.html#HasDerivWithinAt\">HasDerivWithinAt</a> <span class=\"fn\">f</span> <span class=\"fn\">f'</span> <span class=\"fn\">s</span> <span class=\"fn\">x</span></span>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">hx</span> : <span class=\"fn\"><span class=\"fn\">f</span> <span class=\"fn\">x</span></span> <a href=\"./Init/Core.html#Ne\">≠</a> <span class=\"fn\">0</span>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Mathlib/Analysis/Calculus/Deriv/Basic.html#HasDerivWithinAt\">HasDerivWithinAt</a> <span class=\"fn\">(fun (<span class=\"fn\">t</span> : <a href=\"./Mathlib/Data/Real/Basic.html#Real\">ℝ</a>) =&gt; <span class=\"fn\"><a href=\"./Mathlib/Analysis/SpecialFunctions/Log/Basic.html#Real.log\">Real.log</a> <span class=\"fn\">(<span class=\"fn\">f</span> <span class=\"fn\">t</span>)</span></span>)</span> (<span class=\"fn\">1</span> <a href=\"./Init/Prelude.html#HDiv.hDiv\">/</a> <span class=\"fn\"><span class=\"fn\">f</span> <span class=\"fn\">x</span></span> <a href=\"./Init/Prelude.html#HMul.hMul\">*</a> <span class=\"fn\">f'</span>) <span class=\"fn\">s</span> <span class=\"fn\">x</span></span></div></div>","info":{"doc":"A version rewriting the derivative value with `1 / f x`. ","docLink":"./PhysLean/StatisticalMechanics/CanonicalEnsemble/Lemmas.html#CanonicalEnsemble.hasDerivWithinAt_log_comp'","kind":"theorem","line":425,"name":"CanonicalEnsemble.hasDerivWithinAt_log_comp'","sourceLink":"https://github.com/HEPLean/PhysLean#L425-L432"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">theorem</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./PhysLean/StatisticalMechanics/CanonicalEnsemble/Lemmas.html#CanonicalEnsemble.hasDerivWithinAt_log_comp\"><span class=\"name\">CanonicalEnsemble</span>.<span class=\"name\">hasDerivWithinAt_log_comp</span></a></span><span c