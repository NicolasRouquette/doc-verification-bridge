=\"fn\"><a href=\"./Init/Prelude.html#Option\">Option</a> <span class=\"fn\">𝓩</span></span></div></div>","info":{"doc":"The charge of the `Hd` particle. ","docLink":"./PhysLean/Particles/SuperSymmetry/SU5/ChargeSpectrum/Basic.html#SuperSymmetry.SU5.ChargeSpectrum.qHd","kind":"def","line":82,"name":"SuperSymmetry.SU5.ChargeSpectrum.qHd","sourceLink":"https://github.com/HEPLean/PhysLean#L82-L82"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">constructor</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./PhysLean/Particles/SuperSymmetry/SU5/ChargeSpectrum/Basic.html#SuperSymmetry.SU5.ChargeSpectrum.mk\"><span class=\"name\">SuperSymmetry</span>.<span class=\"name\">SU5</span>.<span class=\"name\">ChargeSpectrum</span>.<span class=\"name\">mk</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">𝓩</span> : <span class=\"fn\"><a href=\"./Init/Prelude.html#optParam\">optParam</a> <a href=\"./foundational_types.html\">Type</a> <a href=\"./Init/Data/Int/Basic.html#Int\">ℤ</a></span>}</span></span>\n</span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">qHd </span><span class=\"fn\">qHu</span> : <span class=\"fn\"><a href=\"./Init/Prelude.html#Option\">Option</a> <span class=\"fn\">𝓩</span></span>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">Q5 </span><span class=\"fn\">Q10</span> : <span class=\"fn\"><a href=\"./Mathlib/Data/Finset/Defs.html#Finset\">Finset</a> <span class=\"fn\">𝓩</span></span>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./PhysLean/Particles/SuperSymmetry/SU5/ChargeSpectrum/Basic.html#SuperSymmetry.SU5.ChargeSpectrum\">ChargeSpectrum</a> <span class=\"fn\">𝓩</span></span></div></div>","info":{"doc":"","docLink":"./PhysLean/Particles/SuperSymmetry/SU5/ChargeSpectrum/Basic.html#SuperSymmetry.SU5.ChargeSpectrum.mk","kind":"ctor","line":80,"name":"SuperSymmetry.SU5.ChargeSpectrum.mk","sourceLink":"https://github.com/HEPLean/PhysLean#L80-L80"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">structure</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./PhysLean/Particles/SuperSymmetry/SU5/ChargeSpectrum/Basic.html#SuperSymmetry.SU5.ChargeSpectrum\"><span class=\"name\">SuperSymmetry</span>.<span class=\"name\">SU5</span>.<span class=\"name\">ChargeSpectrum</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">𝓩</span> : <a href=\"./foundational_types.html\">Type</a> := <a href=\"./Init/Data/Int/Basic.html#Int\">ℤ</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./foundational_types.html\">Type</a></div></div>","info":{"doc":"The type such that an element corresponds to the collection of\n  charges associated with the matter content of the theory.\n  The order of charges is implicitly taken to be `qHd`, `qHu`, `Q5`, `Q10`.\n\n  The `Q5` and `Q10` charges are represented by `Finset` rather than\n  `Multiset`, so multiplicity is not included.\n\n  This is defined for a general type `𝓩`, which could be e.g.\n- `ℤ` in the case of `U(1)`,\n- `ℤ × ℤ` in the case of `U(1) × U(1)`,\n- `Fin 2` in the case of `ℤ₂` etc.\n","docLink":"./PhysLean/Particles/SuperSymmetry/SU5/ChargeSpectrum/Basic.html#SuperSymmetry.SU5.ChargeSpectrum","kind":"structure","line":68,"name":"SuperSymmetry.SU5.ChargeSpectrum","sourceLink":"https://github.com/HEPLean/PhysLean#L68-L89"}}],"imports":["Init","Mathlib.Data.Finset.Powerset","Mathlib.Data.Finset.Prod","Mathlib.Data.Finset.Sort","PhysLean.Particles.SuperSymmetry.SU5.Potential"],"instances":[{"className":"Decidable","name":"SuperSymmetry.SU5.ChargeSpectrum.instDecidableEq","typeNames":["Eq"]},{"className":"Repr","name":"SuperSymmetry.SU5.ChargeSpectrum.instRepr","typeNames":["SuperSymmetry.SU5.ChargeSpectrum"]},{"className":"HasSubset","name":"SuperSymmetry.SU5.ChargeSpectrum.hasSubset","typeNames":["SuperSymmetry.SU5.ChargeSpectrum"]},{"className":"HasSSubset","name":"SuperSymmetry.SU5.ChargeSpectrum.hasSSubset","typeNames":["SuperSymmetry.SU5.ChargeSpectrum"]},{"className":"Decidable","name":"SuperSymmetry.SU5.ChargeSpectrum.subsetDecidable","typeNames":["HasSubset.Subset"]},{"className":"EmptyCollection","name":"SuperSymmetry.SU5.ChargeSpectrum.emptyInst","typeNames":["SuperSymmetry.SU5.ChargeSpectrum"]}],"name":"PhysLean.Particles.SuperSymmetry.SU5.ChargeSpectrum.Basic"}