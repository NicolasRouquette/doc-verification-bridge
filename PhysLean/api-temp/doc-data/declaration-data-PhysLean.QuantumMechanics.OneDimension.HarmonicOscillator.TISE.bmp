{"declarations":[{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">theorem</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./PhysLean/QuantumMechanics/OneDimension/HarmonicOscillator/TISE.html#QuantumMechanics.OneDimension.HarmonicOscillator.schrodingerOperator_eigenfunction\"><span class=\"name\">QuantumMechanics</span>.<span class=\"name\">OneDimension</span>.<span class=\"name\">HarmonicOscillator</span>.<span class=\"name\">schrodingerOperator_eigenfunction</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">Q</span> : <a href=\"./PhysLean/QuantumMechanics/OneDimension/HarmonicOscillator/Basic.html#QuantumMechanics.OneDimension.HarmonicOscillator\">HarmonicOscillator</a>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">n</span> : <a href=\"./Init/Prelude.html#Nat\">ℕ</a>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">x</span> : <a href=\"./Mathlib/Data/Real/Basic.html#Real\">ℝ</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><span class=\"fn\"><span class=\"fn\">Q</span>.<a href=\"./PhysLean/QuantumMechanics/OneDimension/HarmonicOscillator/Basic.html#QuantumMechanics.OneDimension.HarmonicOscillator.schrodingerOperator\">schrodingerOperator</a></span> <span class=\"fn\">(<span class=\"fn\"><span class=\"fn\">Q</span>.<a href=\"./PhysLean/QuantumMechanics/OneDimension/HarmonicOscillator/Eigenfunction.html#QuantumMechanics.OneDimension.HarmonicOscillator.eigenfunction\">eigenfunction</a></span> <span class=\"fn\">n</span>)</span> <span class=\"fn\">x</span></span> <a href=\"./Init/Prelude.html#Eq\">=</a> <span class=\"fn\">↑<span class=\"fn\">(<span class=\"fn\"><span class=\"fn\">Q</span>.<a href=\"./PhysLean/QuantumMechanics/OneDimension/HarmonicOscillator/TISE.html#QuantumMechanics.OneDimension.HarmonicOscillator.eigenValue\">eigenValue</a></span> <span class=\"fn\">n</span>)</spa