bationTheory/WickAlgebra/Basic.html#FieldSpecification.WickAlgebra.ofFieldOpList\">ofFieldOpList</a> <span class=\"fn\">(<span class=\"fn\"><span class=\"fn\">φs</span>.<a href=\"./Init/Data/List/Basic.html#List.insertIdx\">insertIdx</a></span> <span class=\"fn\">(↑<span class=\"fn\">k</span>)</span> <span class=\"fn\">φ</span>)</span>)</span></span></div></div>","info":{"doc":"Within a proto-operator algebra, `N(φφ₀φ₁…φₙ) = s • N(φ₀…φₖ₋₁φφₖ…φₙ)`, where\n`s` is the exchange sign for `φ` and `φ₀…φₖ₋₁`.\n","docLink":"./PhysLean/QFT/PerturbationTheory/WickAlgebra/NormalOrder/Lemmas.html#FieldSpecification.WickAlgebra.ofFieldOpList_normalOrder_insert","kind":"theorem","line":387,"name":"FieldSpecification.WickAlgebra.ofFieldOpList_normalOrder_insert","sourceLink":"https://github.com/HEPLean/PhysLean#L387-L404"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">theorem</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./PhysLean/QFT/PerturbationTheory/WickAlgebra/NormalOrder/Lemmas.html#FieldSpecification.WickAlgebra.ofFieldOp_mul_normalOrder_ofFieldOpList_eq_sum\"><span class=\"name\">FieldSpecification</span>.<span class=\"name\">WickAlgebra</span>.<span class=\"name\">ofFieldOp_mul_normalOrder_ofFieldOpList_eq_sum</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">𝓕</span> : <a href=\"./PhysLean/QFT/PerturbationTheory/FieldSpecification/Basic.html#FieldSpecification\">FieldSpecification</a>}</span></span>\n</span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">φ</span> : <span class=\"fn\"><span class=\"fn\">𝓕</span>.<a href=\"./PhysLean/QFT/PerturbationTheory/FieldSpecification/Basic.html#FieldSpecification.FieldOp\">FieldOp</a></span>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">φs</span> : <span class=\"fn\"><a href=\"./Init/Prelude.html#List\">List</a> <span class=\"fn\"><span class=\"fn\">𝓕</span>.<a href=\"./PhysLean/QFT/PerturbationTheory/FieldSpecification/Basic.html#FieldSpecification.FieldOp\">FieldOp</a></span></span>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./PhysLean/QFT/PerturbationTheory/WickAlgebra/Basic.html#FieldSpecification.WickAlgebra.ofFieldOp\">ofFieldOp</a> <span class=\"fn\">φ</span></span> <a href=\"./Init/Prelude.html#HMul.hMul\">*</a> <span class=\"fn\"><a href=\"./PhysLean/QFT/PerturbationTheory/WickAlgebra/NormalOrder/Basic.html#FieldSpecification.WickAlgebra.normalOrder\">normalOrder</a> <span class=\"fn\">(<a href=\"./PhysLean/QFT/PerturbationTheory/WickAlgebra/Basic.html#FieldSpecification.WickAlgebra.ofFieldOpList\">ofFieldOpList</a> <span class=\"fn\">φs</span>)</span></span> <a href=\"./Init/Prelude.html#Eq\">=</a>   <span class=\"fn\">∑ <span class=\"fn\">n</span> : <span class=\"fn\"><a href=\"./Init/Prelude.html#Option\">Option</a> <span class=\"fn\">(<a href=\"./Init/Prelude.html#Fin\">Fin</a> <span class=\"fn\"><span class=\"fn\">φs</span>.<a href=\"./Init/Prelude.html#List.length\">length</a></span>)</span></span>,\n    <span class=\"fn\"><a href=\"./PhysLean/QFT/PerturbationTheory/WickAlgebra/NormalOrder/Lemmas.html#FieldSpecification.WickAlgebra.contractStateAtIndex\">contractStateAtIndex</a> <span class=\"fn\">φ</span> <span class=\"fn\">φs</span> <span class=\"fn\">n</span></span> <a href=\"./Init/Prelude.html#HMul.hMul\">*</a> <span class=\"fn\"><a href=\"./PhysLean/QFT/PerturbationTheory/WickAlgebra/NormalOrder/Basic.html#FieldSpecification.WickAlgebra.normalOrder\">normalOrder</a> <span class=\"fn\">(<a href=\"./PhysLean/QFT/PerturbationTheory/WickAlgebra/Basic.html#FieldSpecification.WickAlgebra.ofFieldOpList\">ofFieldOpList</a> <span class=\"fn\">(<a href=\"./PhysLean/Mathematics/List.html#PhysLean.List.optionEraseZ\">PhysLean.List.optionEraseZ</a> <span class=\"fn\">φs</span> <span class=\"fn\">φ</span> <span class=\"fn\">n</span>)</span>)</span></span></span></div></div>","info":{"doc":"For a field specification `𝓕`, a `φ` in `𝓕.FieldOp` and a list `φs` of `𝓕.FieldOp`\nthen `φ * 𝓝(φ₀φ₁…φₙ)` is equal to\n\n`𝓝(φφ₀φ₁…φₙ) + ∑ i, (𝓢(φ,φ₀φ₁…φᵢ₋₁) • [anPart φ, φᵢ]ₛ) * 𝓝(φ₀…φᵢ₋₁φᵢ₊₁…φₙ)`.\n\nThe proof ultimately goes as follows:\n- `ofFieldOp_eq_crPart_add_anPart` is used to split `φ` into its creation and annihilation parts.\n- The following relation is then used\n\n  `crPart φ * 𝓝(φ₀φ₁…φₙ) = 𝓝(crPart φ * φ₀φ₁…φₙ)`.\n\n- It used that `anPart φ * 𝓝(φ₀φ₁…φₙ)` is equal to\n\n  `𝓢(φ, φ₀φ₁…φₙ) 𝓝(φ₀φ₁…φₙ) * anPart φ + [anPart φ, 𝓝(φ₀φ₁…φₙ)]`\n\n- Then it is used that\n\n  `𝓢(φ, φ₀φ₁…φₙ) 𝓝(φ₀φ₁…φₙ) * anPart φ = 𝓝(anPart φ * φ₀φ₁…φₙ)`\n\n- The result `ofCrAnOp_superCommute_normalOrder_ofCrAnList_sum` is used\n  to expand `[anPart φ, 𝓝(φ₀φ₁…φₙ)]` as a sum.\n","docLink":"./PhysLean/QFT/PerturbationTheory/WickAlgebra/NormalOrder/Lemmas.html#FieldSpecification.WickAlgebra.ofFieldOp_mul_normalOrder_ofFieldOpList_eq_sum","kind":"theorem","line":348,"name":"FieldSpecification.WickAlgebra.ofFieldOp_mul_normalOrder_ofFieldOpList_eq_sum","sourceLink":"https://github.com/HEPLean/PhysLean#L348-L379"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">noncomputable def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./PhysLean/QFT/PerturbationTheory/WickAlgebra/NormalOrder/Lemmas.html#FieldSpecification.WickAlgebra.contractStateAtIndex\"><span class=\"name\">FieldSpecification</span>.<span class=\"name\">WickAlgebra</span>.<span class=\"name\">contractStateAtIndex</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">𝓕</span> : <a href=\"./PhysLean/QFT/PerturbationTheory/FieldSpecification/Basic.html#FieldSpecification\">FieldSpecification</a>}</span></span>\n</span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">φ</span> : <span class=\"fn\"><span class=\"fn\">𝓕</span>.<a href=\"./PhysLean/QFT/PerturbationTheory/FieldSpecification/Basic.html#FieldSpecification.FieldOp\">FieldOp</a></span>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">φs</span> : <span class=\"fn\"><a href=\"./Init/Prelude.html#List\">List</a> <span class=\"fn\"><span class=\"fn\">𝓕</span>.<a href=\"./PhysLean/QFT/PerturbationTheory/FieldSpecification/Basic.html#FieldSpecification.FieldOp\">FieldOp</a></span></span>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">n</span> : <span class=\"fn\"><a href=\"./Init/Prelude.html#Option\">Option</a> <span class=\"fn\">(<a href=\"./Init/Prelude.html#Fin\">Fin</a> <span class=\"fn\"><span class=\"fn\">φs</span>.<a href=\"./Init/Prelude.html#List.length\">length</a></span>)</span></span>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><span class=\"fn\">𝓕</span>.<a href=\"./PhysLean/QFT/PerturbationTheory/WickAlgebra/Basic.html#FieldSpecification.WickAlgebra\">WickAlgebra</a></span></div></div>","info":{"doc":"In the expansion of `ofFieldOpF φ * normalOrderF (ofFieldOpListF φs)` the element\nof `𝓞.A` associated with contracting `φ` with the (optional) `n`th element of `φs`. ","docLink":"./PhysLean/QFT/PerturbationTheory/WickAlgebra/NormalOrder/Lemmas.html#FieldSpecification.WickAlgebra.contractStateAtIndex","kind":"def","line":340,"name":"FieldSpecification.WickAlgebra.contractStateAtIndex","sourceLink":"https://github.com/HEPLean/PhysLean#L340-L346"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">theorem</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./PhysLean/QFT/PerturbationTheory/WickAlgebra/NormalOrder/Lemmas.html#FieldSpecification.WickAlgebra.ofFieldOp_mul_normalOrder_ofFieldOpList_eq_superCommute\"><span class=\"name\">FieldSpecification</span>.<span class=\"name\">WickAlgebra</span>.<span class=\"name\">ofFieldOp_mul_normalOrder_ofFieldOpList_eq_superCommute</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">𝓕</span> : <a href=\"./PhysLean/QFT/PerturbationTheory/FieldSpecification/Basic.html#FieldSpecification\">FieldSpecification</a>}</span></span>\n</span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">φ</span> : <span class=\"fn\"><span class=\"fn\">𝓕</span>.<a href=\"./PhysLean/QFT/PerturbationTheory/FieldSpecification/Basic.html#FieldSpecification.FieldOp\">FieldOp</a></span>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">φs</span> : <span class=\"fn\"><a href=\"./Init/Prelude.html#List\">List</a> <span class=\"fn\"><span class=\"fn\">𝓕</span>.<a href=\"./PhysLean/QFT/PerturbationTheory/FieldSpecification/Basic.html#FieldSpecification.FieldOp\">FieldOp</a></span></span>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./PhysLean/QFT/PerturbationTheory/WickAlgebra/Basic.html#FieldSpecification.WickAlgebra.ofFieldOp\">ofFieldOp</a> <span class=\"fn\">φ</span></span> <a href=\"./Init/Prelude.html#HMul.hMul\">*</a> <span class=\"fn\"><a href=\"./PhysLean/QFT/PerturbationTheory/WickAlgebra/NormalOrder/Basic.html#FieldSpecification.WickAlgebra.normalOrder\">normalOrder</a> <span class=\"fn\">(<a href=\"./PhysLean/QFT/PerturbationTheory/WickAlgebra/Basic.html#FieldSpecification.WickAlgebra.ofFieldOpList\">ofFieldOpList</a> <span class=\"fn\">φs</span>)</span></span> <a href=\"./Init/Prelude.html#Eq\">=</a>   <span class=\"fn\"><a href=\"./PhysLean/QFT/PerturbationTheory/WickAlgebra/NormalOrder/Basic.html#FieldSpecification.WickAlgebra.normalOrder\">normalOrder</a> (<span class=\"fn\"><a href=\"./PhysLean/QFT/PerturbationTheory/WickAlgebra/Basic.html#FieldSpecification.WickAlgebra.ofFieldOp\">ofFieldOp</a> <span class=\"fn\">φ</span></span> <a href=\"./Init/Prelude.html#HMul.hMul\">*</a> <span class=\"fn\"><a href=\"./PhysLean/QFT/PerturbationTheory/WickAlgebra/Basic.html#FieldSpecification.WickAlgebra.ofFieldOpList\">ofFieldOpList</a> <span class=\"fn\">φs</span></span>)</span> <a href=\"./Init/Prelude.html#HAdd.hAdd\">+</a> <span class=\"fn\"><span class=\"fn\">(<a href=\"./PhysLean/QFT/PerturbationTheory/WickAlgebra/SuperCommute.html#FieldSpecification.WickAlgebra.superCommute\">superCommute</a> <span class=\"fn\">(<a href=\"./PhysLean/QFT/PerturbationTheory/WickAlgebra/Basic.html#FieldSpecification.WickAlgebra.anPart\">anPart</a> <span class=\"fn\">φ</span>)</span>)</span> <span class=\"fn\">(<a href=\"./PhysLean/QFT/PerturbationTheory/WickAlgebra/NormalOrder/Basic.html#FieldSpecification.WickAlgebra.normalOrder\">normalOrder</a> <span class=\"fn\">(<a href=\"./PhysLean/QFT/PerturbationTheory/WickAlgebra/Basic.html#FieldSpecification.WickAlgebra.ofFieldOpList\">ofFieldOpList</a> <span class=\"fn\">φs</span>)</span>)</span></span></div></div>","info":{"doc":"Within a proto-operator algebra we have that\n`φ * 𝓝ᶠ(φ₀φ₁…φₙ) = 𝓝ᶠ(φφ₀φ₁…φₙ) + [anpart φ, 𝓝ᶠ(φ₀φ₁…φₙ)]ₛF`.\n","docLink":"./PhysLean/QFT/PerturbationTheory/WickAlgebra/NormalOrder/Lemmas.html#FieldSpecification.WickAlgebra.ofFieldOp_mul_normalOrder_ofFieldOpList_eq_superCommute","kind":"theorem","line":326,"name":"FieldSpecification.WickAlgebra.ofFieldOp_mul_normalOrder_ofFieldOpList_eq_superCommute","sourceLink":"https://github.com/HEPLean/PhysLean#L326-L338"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">theorem</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./PhysLean/QFT/PerturbationTheory/WickAlgebra/NormalOrder/Lemmas.html#FieldSpecification.WickAlgebra.anPart_mul_normalOrder_ofFieldOpList_eq_superCommute_reorder\"><span class=\"name\">FieldSpecification</span>.<span class=\"name\">WickAlgebra</span>.<span class=\"name\">anPart_mul_normalOrder_ofFieldOpList_eq_superCommute_reorder</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">𝓕</span> : <a href=\"./PhysLean/QFT/PerturbationTheory/FieldSpecification/Basic.html#FieldSpecification\">FieldSpecification</a>}</span></span>\n</span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">φ</span> : <span class=\"fn\"><span class=\"fn\">𝓕</span>.<a href=\"./PhysLean/QFT/PerturbationTheory/FieldSpecification/Basic.html#FieldSpecification.FieldOp\">FieldOp</a></span>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">φs</span> : <span class=\"fn\"><a href=\"./Init/Prelude.html#List\">List</a> <span class=\"fn\"><span class=\"fn\">𝓕</span>.<a href=\"./PhysLean/QFT/PerturbationTheory/FieldSpecification/Basic.html#FieldSpecification.FieldOp\">FieldOp</a></span></span>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./PhysLean/QFT/PerturbationTheory/WickAlgebra/Basic.html#FieldSpecification.WickAlgebra.anPart\">anPart</a> <span class=\"fn\">φ</span></span> <a href=\"./Init/Prelude.html#HMul.hMul\">*</a> <span class=\"fn\"><a href=\"./PhysLean/QFT/PerturbationTheory/WickAlgebra/NormalOrder/Basic.html#FieldSpecification.WickAlgebra.normalOrder\">normalOrder</a> <span class=\"fn\">(<a href=\"./PhysLean/QFT/PerturbationTheory/WickAlgebra/Basic.html#FieldSpecification.WickAlgebra.ofFieldOpList\">ofFieldOpList</a> <span class=\"fn\">φs</span>)</span></span> <a href=\"./Init/Prelude.html#Eq\">=</a>   <span class=\"fn\"><a href=\"./PhysLean/QFT/PerturbationTheory/WickAlgebra/NormalOrder/Basic.html#FieldSpecification.WickAlgebra.normalOrder\">normalOrder</a> (<span class=\"fn\"><a href=\"./PhysLean/QFT/PerturbationTheory/WickAlgebra/Basic.html#FieldSpecification.WickAlgebra.anPart\">anPart</a> <span class=\"fn\">φ</span></span> <a href=\"./Init/Prelude.html#HMul.hMul\">*</a> <span class=\"fn\"><a href=\"./PhysLean/QFT/PerturbationTheory/WickAlgebra/Basic.html#FieldSpecification.WickAlgebra.ofFieldOpList\">ofFieldOpList</a> <span class=\"fn\">φs</span></span>)</span> <a href=\"./Init/Prelude.html#HAdd.hAdd\">+</a> <span class=\"fn\"><span class=\"fn\">(<a href=\"./PhysLean/QFT/PerturbationTheory/WickAlgebra/SuperCommute.html#FieldSpecification.WickAlgebra.superCommute\">superCommute</a> <span class=\"fn\">(<a href=\"./PhysLean/QFT/PerturbationTheory/WickAlgebra/Basic.html#FieldSpecification.WickAlgebra.anPart\">anPart</a> <span class=\"fn\">φ</span>)</span>)</span> <span class=\"fn\">(<a href=\"./PhysLean/QFT/PerturbationTheory/WickAlgebra/NormalOrder/Basic.html#FieldSpecification.WickAlgebra.normalOrder\">normalOrder</a> <span class=\"fn\">(<a href=\"./PhysLean/QFT/PerturbationTheory/WickAlgebra/Basic.html#FieldSpecification.WickAlgebra.ofFieldOpList\">ofFieldOpList</a> <span class=\"fn\">φs</span>)</span>)</span></span></div></div>","info":{"doc":"Within a proto-operator algebra we have that\n`anPartF φ * 𝓝(φ₀φ₁…φₙ) = 𝓝((anPart φ)φ₀φ₁…φₙ) + [anpart φ, 𝓝(φ₀φ₁…φₙ)]ₛ`.\n","docLink":"./PhysLean/QFT/PerturbationTheory/WickAlgebra/NormalOrder/Lemmas.html#FieldSpecification.WickAlgebra.anPart_mul_normalOrder_ofFieldOpList_eq_superCommute_reorder","kind":"theorem","line":315,"name":"FieldSpecification.WickAlgebra.anPart_mul_normalOrder_ofFieldOpList_eq_superCommute_reorder","sourceLink":"https://github.com/HEPLean/PhysLean#L315-L324"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">theorem</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./PhysLean/QFT/PerturbationTheory/WickAlgebra/NormalOrder/Lemmas.html#FieldSpecification.WickAlgebra.anPart_superCommute_normalOrder_ofFieldOpList_sum\"><span class=\"name\">FieldSpecification</span>.<span class=\"name\">WickAlgebra</span>.<span class=\"name\">anPart_superCommute_normalOrder_ofFieldOpList_sum</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">𝓕</span> : <a href=\"./PhysLean/QFT/PerturbationTheory/FieldSpecification/Basic.html#FieldSpecification\">FieldSpecification</a>}</span></span>\n</span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">φ</span> : <span class=\"fn\"><span class=\"fn\">𝓕</span>.<a href=\"./PhysLean/QFT/PerturbationTheory/FieldSpecification/Basic.html#FieldSpecification.FieldOp\">FieldOp</a></span>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">φs</span> : <span class=\"fn\"><a href=\"./Init/Prelude.html#List\">List</a> <span class=\"fn\"><span class=\"fn\">𝓕</span>.<a href=\"./PhysLean/QFT/PerturbationTheory/FieldSpecification/Basic.html#FieldSpecification.FieldOp\">FieldOp</a></span></span>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><span class=\"fn\">(<a href=\"./PhysLean/QFT/PerturbationTheory/WickAlgebra/SuperCommute.html#FieldSpecification.WickAlgebra.superCommute\">superCommute</a> <span class=\"fn\">(<a href=\"./PhysLean/QFT/PerturbationTheory/WickAlgebra/Basic.html#FieldSpecification.WickAlgebra.anPart\">anPart</a> <span class=\"fn\">φ</span>)</span>)</span> <span class=\"fn\">(<a href=\"./PhysLean/QFT/PerturbationTheory/WickAlgebra/NormalOrder/Basic.html#FieldSpecification.WickAlgebra.normalOrder\">normalOrder</a> <span class=\"fn\">(<a href=\"./PhysLean/QFT/PerturbationTheory/WickAlgebra/Basic.html#FieldSpecification.WickAlgebra.ofFieldOpList\">ofFieldOpList</a> <span class=\"fn\">φs</span>)</span>)</span></span> <a href=\"./Init/Prelude.html#Eq\">=</a>   <span class=\"fn\">∑ <span class=\"fn\">n</span> : <span class=\"fn\"><a href=\"./Init/Prelude.html#Fin\">Fin</a> <span class=\"fn\"><span class=\"fn\">φs</span>.<a href=\"./Init/Prelude.html#List.length\">length</a></span></span>,\n    <span class=\"fn\"><span class=\"fn\">(<a href=\"./PhysLean/QFT/PerturbationTheory/FieldStatistics/ExchangeSign.html#FieldStatistic.exchangeSign\">FieldStatistic.exchangeSign</a> <span class=\"fn\">(<span class=\"fn\"><span class=\"fn\">𝓕</span>.<a href=\"./PhysLean/QFT/PerturbationTheory/FieldSpecification/Basic.html#FieldSpecification.fieldOpStatistic\">fieldOpStatistic</a></span> <span class=\"fn\">φ</span>)</span>)</span>\n          <span class=\"fn\">(<a href=\"./PhysLean/QFT/PerturbationTheory/FieldStatistics/Basic.html#FieldStatistic.ofList\">FieldStatistic.ofList</a> <span class=\"fn\"><span class=\"fn\">𝓕</span>.<a href=\"./PhysLean/QFT/PerturbationTheory/FieldSpecification/Basic.html#FieldSpecification.fieldOpStatistic\">fieldOpStatistic</a></span> <span class=\"fn\">(<a href=\"./Init/Data/List/Basic.html#List.take\">List.take</a> <span class=\"fn\">(↑<span class=\"fn\">n</span>)</span> <span class=\"fn\">φs</span>)</span>)</span></span> <a href=\"./Init/Prelude.html#HSMul.hSMul\">•</a>         <span class=\"fn\"><span class=\"fn\">(<a href=\"./PhysLean/QFT/PerturbationTheory/WickAlgebra/SuperCommute.html#FieldSpecification.WickAlgebra.superCommute\">superCommute</a> <span class=\"fn\">(<a href=\"./PhysLean/QFT/PerturbationTheory/WickAlgebra/Basic.html#FieldSpecification.WickAlgebra.anPart\">anPart</a> <span class=\"fn\">φ</span>)</span>)</span> <span class=\"fn\">↑<span class=\"fn\">(<a href=\"./PhysLean/QFT/PerturbationTheory/FieldOpFreeAlgebra/Basic.html#FieldSpecification.FieldOpFreeAlgebra.ofFieldOpF\">FieldOpFreeAlgebra.ofFieldOpF</a> <span class=\"fn\">φs</span><a href=\"./Init/GetElem.html#GetElem.getElem\">[</a><span class=\"fn\">n</span><a href=\"./Init/GetElem.html#GetElem.getElem\">]</a>)</span></span></span> <a href=\"./Init/Prelude.html#HMul.hMul\">*</a>       <span class=\"fn\"><a href=\"./PhysLean/QFT/PerturbationTheory/WickAlgebra/NormalOrder/Basic.html#FieldSpecification.WickAlgebra.normalOrder\">normalOrder</a> <span class=\"fn\">(<a href=\"./PhysLean/QFT/PerturbationTheory/WickAlgebra/Basic.html#FieldSpecification.WickAlgebra.ofFieldOpList\">ofFieldOpList</a> <span class=\"fn\">(<span class=\"fn\"><span class=\"fn\">φs</span>.<a href=\"./Init/Data/List/Basic.html#List.eraseIdx\">eraseIdx</a></span> <span class=\"fn\">↑<span class=\"fn\">n</span></span>)</span>)</span></span></span></div></div>","info":{"doc":"The commutator of the annihilation part of a field operator with a normal ordered list of field\noperators can be decomposed into the sum of the commutators of the annihilation part with each\nelement of the list of field operators, i.e.\n`[anPart φ, 𝓝(φ₀…φₙ)]ₛ= ∑ i, 𝓢(φ, φ₀…φᵢ₋₁) • [anPart φ, φᵢ]ₛ * 𝓝(φ₀…φᵢ₋₁φᵢ₊₁…φₙ)`.\n","docLink":"./PhysLean/QFT/PerturbationTheory/WickAlgebra/NormalOrder/Lemmas.html#FieldSpecification.WickAlgebra.anPart_superCommute_normalOrder_ofFieldOpList_sum","kind":"theorem","line":285,"name":"FieldSpecification.WickAlgebra.anPart_superCommute_normalOrder_ofFieldOpList_sum","sourceLink":"https://github.com/HEPLean/PhysLean#L285-L308"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">theorem</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./PhysLean/QFT/PerturbationTheory/WickAlgebra/NormalOrder/Lemmas.html#FieldSpecification.WickAlgebra.ofCrAnOp_superCommute_normalOrder_ofFieldOpList_sum\"><span class=\"name\">FieldSpecification</span>.<span class=\"name\">WickAlgebra</span>.<span class=\"name\">ofCrAnOp_superCommute_normalOrder_ofFieldOpList_sum</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">𝓕</span> : <a href=\"./PhysLean/QFT/PerturbationTheory/FieldSpecification/Basic.html#FieldSpecification\">FieldSpecification</a>}</span></span>\n</span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">φ</span> : <span class=\"fn\"><span class=\"fn\">𝓕</span>.<a href=\"./PhysLean/QFT/PerturbationTheory/FieldSpecification/CrAnFieldOp.html#FieldSpecification.CrAnFieldOp\">CrAnFieldOp</a></span>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">φs</span> : <span class=\"fn\"><a href=\"./Init/Prelude.html#List\">List</a> <span class=\"fn\"><span class=\"fn\">𝓕</span>.<a href=\"./PhysLean/QFT/PerturbationTheory/FieldSpecification/Basic.html#FieldSpecification.FieldOp\">FieldOp</a></span></span>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"