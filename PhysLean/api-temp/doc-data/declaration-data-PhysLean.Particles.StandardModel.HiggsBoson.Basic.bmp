/HiggsBoson/Basic.html#StandardModel.HiggsVec.ofU1Subgroup_smul_eq_smul\"><span class=\"name\">StandardModel</span>.<span class=\"name\">HiggsVec</span>.<span class=\"name\">ofU1Subgroup_smul_eq_smul</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">g</span> : <span class=\"fn\">↥<span class=\"fn\">(<a href=\"./Mathlib/Algebra/Star/Unitary.html#unitary\">unitary</a> <a href=\"./Mathlib/Data/Complex/Basic.html#Complex\">ℂ</a>)</span></span>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">φ</span> : <a href=\"./PhysLean/Particles/StandardModel/HiggsBoson/Basic.html#StandardModel.HiggsVec\">HiggsVec</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./PhysLean/Particles/StandardModel/Basic.html#StandardModel.GaugeGroupI.ofU1Subgroup\">GaugeGroupI.ofU1Subgroup</a> <span class=\"fn\">g</span></span> <a href=\"./Init/Prelude.html#HSMul.hSMul\">•</a> <span class=\"fn\">φ</span> <a href=\"./Init/Prelude.html#Eq\">=</a> <span class=\"fn\"><a href=\"./Mathlib/Analysis/Normed/Lp/WithLp.html#WithLp.toLp\">WithLp.toLp</a> <span class=\"fn\">2</span> <span class=\"fn\">(<span class=\"fn\"><span class=\"fn\">!![<span class=\"fn\">1</span>, <span class=\"fn\">0</span>; <span class=\"fn\">0</span>, <span class=\"fn\">↑<span class=\"fn\">g</span></span> <a href=\"./Init/Prelude.html#HPow.hPow\">^</a> <span class=\"fn\">6</span>]</span>.<a href=\"./Mathlib/Data/Matrix/Mul.html#Matrix.mulVec\">mulVec</a></span> <span class=\"fn\"><span class=\"fn\">φ</span>.<a href=\"./Mathlib/Analysis/Normed/Lp/WithLp.html#WithLp.ofLp\">ofLp</a></span>)</span></span></div></div>","info":{"doc":"","docLink":"./PhysLean/Particles/StandardModel/HiggsBoson/Basic.html#StandardModel.HiggsVec.ofU1Subgroup_smul_eq_smul","kind":"theorem","line":377,"name":"StandardModel.HiggsVec.ofU1Subgroup_smul_eq_smul","sourceLink":"https://github.com/HEPLean/PhysLean#L377-L398"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./PhysLean/Particles/StandardModel/HiggsBoson/Basic.html#StandardModel.HiggsVec.stability_group\"><span class=\"name\">StandardModel</span>.<span class=\"name\">HiggsVec</span>.<span class=\"name\">stability_group</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./PhysLean/Meta/Informal/Basic.html#InformalLemma\">InformalLemma</a></div></div>","info":{"doc":"The subgroup of `gaugeGroup := SU(3) × SU(2) × U(1)` which preserves every `HiggsVec` by the\naction of `StandardModel.HiggsVec.rep` is given by `SU(3) × ℤ₆` where `ℤ₆` is the subgroup of\n`SU(2) × U(1)` with elements `(α^(-3) * I₂, α)` where `α` is a sixth root of unity.\n","docLink":"./PhysLean/Particles/StandardModel/HiggsBoson/Basic.html#StandardModel.HiggsVec.stability_group","kind":"def","line":363,"name":"StandardModel.HiggsVec.stability_group","sourceLink":"https://github.com/HEPLean/PhysLean#L363-L369"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./PhysLean/Particles/StandardModel/HiggsBoson/Basic.html#StandardModel.HiggsVec.stability_group_single\"><span class=\"name\">StandardModel</span>.<span class=\"name\">HiggsVec</span>.<span class=\"name\">stability_group_single</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./PhysLean/Meta/Informal/Basic.html#InformalLemma\">InformalLemma</a></div></div>","info":{"doc":"The Higgs boson breaks electroweak symmetry down to the electromagnetic force, i.e., the\nstability group of the action of `rep` on `![0, Complex.ofReal ‖φ‖]`, for non-zero `‖φ‖`, is the\n`SU(3) × U(1)` subgroup of `gaugeGroup := SU(3) × SU(2) × U(1)` with the embedding given by\n`(g, e^{i θ}) ↦ (g, diag (e ^ {3 * i θ}, e ^ {- 3 * i θ}), e^{i θ})`.\n","docLink":"./PhysLean/Particles/StandardModel/HiggsBoson/Basic.html#StandardModel.HiggsVec.stability_group_single","kind":"def","line":354,"name":"StandardModel.HiggsVec.stability_group_single","sourceLink":"https://github.com/HEPLean/PhysLean#L354-L361"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">theorem</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./PhysLean/Particles/StandardModel/HiggsBoson/Basic.html#StandardModel.HiggsVec.mem_orbit_gaugeGroupI_iff\"><span class=\"name\">StandardModel</span>.<span class=\"name\">HiggsVec</span>.<span class=\"name\">mem_orbit_gaugeGroupI_iff</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">φ </span><span class=\"fn\">ψ</span> : <a href=\"./PhysLean/Particles/StandardModel/HiggsBoson/Basic.html#StandardModel.HiggsVec\">HiggsVec</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\">ψ</span> <a href=\"./Init/Prelude.html#Membership.mem\">∈</a> <span class=\"fn\"><a href=\"./Mathlib/GroupTheory/GroupAction/Defs.html#MulAction.orbit\">MulAction.orbit</a> <a href=\"./PhysLean/Particles/StandardModel/Basic.html#StandardModel.GaugeGroupI\">GaugeGroupI</a> <span class=\"fn\">φ</span></span> <a href=\"./Init/Core.html#Iff\">↔</a> <a href=\"./Mathlib/Analysis/Normed/Group/Basic.html#Norm.norm\">‖</a><span class=\"fn\">ψ</span><a href=\"./Mathlib/Analysis/Normed/Group/Basic.html#Norm.norm\">‖</a> <a href=\"./Init/Prelude.html#Eq\">=</a> <a href=\"./Mathlib/Analysis/Normed/Group/Basic.html#Norm.norm\">‖</a><span class=\"fn\">φ</span><a href=\"./Mathlib/Analysis/Normed/Group/Basic.html#Norm.norm\">‖</a></div></div>","info":{"doc":"","docLink":"./PhysLean/Particles/StandardModel/HiggsBoson/Basic.html#StandardModel.HiggsVec.mem_orbit_gaugeGroupI_iff","kind":"theorem","line":331,"name":"StandardModel.HiggsVec.mem_orbit_gaugeGroupI_iff","sourceLink":"https://github.com/HEPLean/PhysLean#L331-L341"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">theorem</span>\n<span cla