,"name":"TensorSpecies.Tensor.equalTermMap","sourceLink":"https://github.com/HEPLean/PhysLean#L416-L419"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./PhysLean/Relativity/Tensors/Elab.html#TensorSpecies.Tensor.addTermMap\"><span class=\"name\">TensorSpecies</span>.<span class=\"name\">Tensor</span>.<span class=\"name\">addTermMap</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">P </span><span class=\"fn\">T1 </span><span class=\"fn\">T2</span> : <a href=\"./Init/Meta/Defs.html#Lean.Syntax.Term\">Lean.Term</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Lean/Elab/Term/TermElabM.html#Lean.Elab.Term.TermElabM\">Lean.Elab.TermElabM</a> <a href=\"./Init/Meta/Defs.html#Lean.Syntax.Term\">Lean.Term</a></span></div></div>","info":{"doc":"The syntax for a equality of tensor trees. ","docLink":"./PhysLean/Relativity/Tensors/Elab.html#TensorSpecies.Tensor.addTermMap","kind":"def","line":411,"name":"TensorSpecies.Tensor.addTermMap","sourceLink":"https://github.com/HEPLean/PhysLean#L411-L414"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./PhysLean/Relativity/Tensors/Elab.html#TensorSpecies.Tensor.actionTermMap\"><span class=\"name\">TensorSpecies</span>.<span class=\"name\">Tensor</span>.<span class=\"name\">actionTermMap</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">c </span><span class=\"fn\">T</span> : <a href=\"./Init/Meta/Defs.html#Lean.Syntax.Term\">Lean.Term</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Init/Meta/Defs.html#Lean.Syntax.Term\">Lean.Term</a></div></div>","info":{"doc":"The syntax associated with the group action of tensors. ","docLink":"./PhysLean/Relativity/Tensors/Elab.html#TensorSpecies.Tensor.actionTermMap","kind":"def","line":407,"name":"TensorSpecies.Tensor.actionTermMap","sourceLink":"https://github.com/HEPLean/PhysLean#L407-L409"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./PhysLean/Relativity/Tensors/Elab.html#TensorSpecies.Tensor.smulTermMap\"><span class=\"name\">TensorSpecies</span>.<span class=\"name\">Tensor</span>.<span class=\"name\">smulTermMap</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">c </span><span class=\"fn\">T</span> : <a href=\"./Init/Meta/Defs.html#Lean.Syntax.Term\">Lean.Term</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Init/Meta/Defs.html#Lean.Syntax.Term\">Lean.Term</a></div></div>","info":{"doc":"The syntax associated with the scalar multiplication of tensors. ","docLink":"./PhysLean/Relativity/Tensors/Elab.html#TensorSpecies.Tensor.smulTermMap","kind":"def","line":403,"name":"TensorSpecies.Tensor.smulTermMap","sourceLink":"https://github.com/HEPLean/PhysLean#L403-L405"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./PhysLean/Relativity/Tensors/Elab.html#TensorSpecies.Tensor.negTermMap\"><span class=\"name\">TensorSpecies</span>.<span class=\"name\">Tensor</span>.<span class=\"name\">negTermMap</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">T1</span> : <a href=\"./Init/Meta/Defs.html#Lean.Syntax.Term\">Lean.Term</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Init/Meta/Defs.html#Lean.Syntax.Term\">Lean.Term</a></div></div>","info":{"doc":"The syntax associated with negation of tensors. ","docLink":"./PhysLean/Relativity/Tensors/Elab.html#TensorSpecies.Tensor.negTermMap","kind":"def","line":399,"name":"TensorSpecies.Tensor.negTermMap","sourceLink":"https://github.com/HEPLean/PhysLean#L399-L401"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./PhysLean/Relativity/Tensors/Elab.html#TensorSpecies.Tensor.prodTermMap\"><span class=\"name\">TensorSpecies</span>.<span class=\"name\">Tensor</span>.<span class=\"name\">prodTermMap</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">T1 </span><span class=\"fn\">T2</span> : <a href=\"./Init/Meta/Defs.html#Lean.Syntax.Term\">Lean.Term</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Init/Meta/Defs.html#Lean.Syntax.Term\">Lean.Term</a></div></div>","info":{"doc":"The syntax associated with a product of tensors. ","docLink":"./PhysLean/Relativity/Tensors/Elab.html#TensorSpecies.Tensor.prodTermMap","kind":"def","line":395,"name":"TensorSpecies.Tensor.prodTermMap","sourceLink":"https://github.com/HEPLean/PhysLean#L395-L397"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./PhysLean/Relativity/Tensors/Elab.html#TensorSpecies.Tensor.contrTermMap\"><span class=\"name\">TensorSpecies</span>.<span class=\"name\">Tensor</span>.<span class=\"name\">contrTermMap</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">n</span> : <a href=\"./Init/Prelude.html#Nat\">ℕ</a>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">l</span> : <span class=\"fn\"><a href=\"./Init/Prelude.html#List\">List</a> (<a href=\"./Init/Prelude.html#Nat\">ℕ</a> <a href=\"./Init/Prelude.html#Prod\">×</a> <a href=\"./Init/Prelude.html#Nat\">ℕ</a>)</span>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">T</span> : <a href=\"./Init/Meta/Defs.html#Lean.Syntax.Term\">Lean.Term</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Init/Meta/Defs.html#Lean.Syntax.Term\">Lean.Term</a></div></div>","info":{"doc":"For each element of `l : List (ℕ × ℕ)` applies `TensorTree.contr` to the given term. ","docLink":"./PhysLean/Relativity/Tensors/Elab.html#TensorSpecies.Tensor.contrTermMap","kind":"def","line":387,"name":"TensorSpecies.Tensor.contrTermMap","sourceLink":"https://github.com/HEPLean/PhysLean#L387-L393"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./PhysLean/Relativity/Tensors/Elab.html#TensorSpecies.Tensor.evalTermMap\"><span class=\"name\">TensorSpecies</span>.<span class=\"name\">Tensor</span>.<span class=\"name\">evalTermMap</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">l</span> : <span class=\"fn\"><a href=\"./Init/Prelude.html#List\">List</a> (<a href=\"./Init/Prelude.html#Nat\">ℕ</a> <a href=\"./Init/Prelude.html#Prod\">×</a> <a href=\"./Init/Prelude.html#Nat\">ℕ</a>)</span>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">T</span> : <a href=\"./Init/Meta/Defs.html#Lean.Syntax.Term\">Lean.Term</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Init/Meta/Defs.html#Lean.Syntax.Term\">Lean.Term</a></div></div>","info":{"doc":"Given a list `l` of pairs `ℕ × ℕ` and a term `T` corresponding to a tensor tree,\nfor each `(a, b)` in `l`, `evalSyntax` applies `TensorTree.eval a b` to `T` recursively.\nHere `a` is the position of the index to be evaluated and `b` is the value it is evaluated to.\n\nFor example, if `l` is `[(1, 2), (1, 4)]` and `T` is a tensor tree then `evalSyntax l T`\nis `TensorTree.eval 1 4 (TensorTree.eval 1 2 T)`.\n\nThe list `l` is expected to be the output of `getEvalPos`.\n","docLink":"./PhysLean/Relativity/Tensors/Elab.html#TensorSpecies.Tensor.evalTermMap","kind":"def","line":374,"name":"TensorSpecies.Tensor.evalTermMap","sourceLink":"https://github.com/HEPLean/PhysLean#L374-L385"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./PhysLean/Relativity/Tensors/Elab.html#TensorSpecies.Tensor.nodeTermMap\"><span class=\"name\">TensorSpecies</span>.<span class=\"name\">Tensor</span>.<span class=\"name\">nodeTermMap</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">T</span> : <a href=\"./Init/Meta/Defs.html#Lean.Syntax.Term\">Lean.Term</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Init/Meta/Defs.html#Lean.Syntax.Term\">Lean.Term</a></div></div>","info":{"doc":"For a term of the form `T` where `T` is `S.F.obj (OverColor.mk c)`,\n`tensorTermToTensorTree` returns the term corresponding to the `tensorNode T` ","docLink":"./PhysLean/Relativity/Tensors/Elab.html#TensorSpecies.Tensor.nodeTermMap","kind":"def","line":369,"name":"TensorSpecies.Tensor.nodeTermMap","sourceLink":"https://github.com/HEPLean/PhysLean#L369-L372"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./PhysLean/Relativity/Tensors/Elab.html#TensorSpecies.Tensor.getIndicesRightEq\"><span class=\"name\">TensorSpecies</span>.<span class=\"name\">Tensor</span>.<span class=\"name\">getIndicesRightEq</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">stx</span> : <a href=\"./Init/Prelude.html#Lean.Syntax\">Lean.Syntax</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Lean/Elab/Term/TermElabM.html#Lean.Elab.Term.TermElabM\">Lean.Elab.TermElabM</a> <span class=\"fn\">(<a href=\"./Init/Prelude.html#List\">List</a> (<a href=\"./Init/Prelude.html#Lean.TSyntax\">Lean.TSyntax</a> <span class=\"fn\">`indexExpr</span>))</span></span></div></div>","info":{"doc":"Gets the indices associated with the RHS of an equality. ","docLink":"./PhysLean/Relativity/Tensors/Elab.html#TensorSpecies.Tensor.getIndicesRightEq","kind":"def","line":354,"name":"TensorSpecies.Tensor.getIndicesRightEq","sourceLink":"https://github.com/HEPLean/PhysLean#L354-L360"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./PhysLean/Relativity/Tensors/Elab.html#TensorSpecies.Tensor.getIndicesLeftEq\"><span class=\"name\">TensorSpecies</span>.<span class=\"name\">Tensor</span>.<span class=\"name\">getIndicesLeftEq</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">stx</span> : <a href=\"./Init/Prelude.html#Lean.Syntax\">Lean.Syntax</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Lean/Elab/Term/TermElabM.html#Lean.Elab.Term.TermElabM\">Lean.Elab.TermElabM</a> <span class=\"fn\">(<a href=\"./Init/Prelude.html#List\">List</a> (<a href=\"./Init/Prelude.html#Lean.TSyntax\">Lean.TSyntax</a> <span class=\"fn\">`indexExpr</span>))</span></span></div></div>","info":{"doc":"Gets the indices associated with the LHS of an equality. ","docLink":"./PhysLean/Relativity/Tensors/Elab.html#TensorSpecies.Tensor.getIndicesLeftEq","kind":"def","line":346,"name":"TensorSpecies.Tensor.getIndicesLeftEq","sourceLink":"https://github.com/HEPLean/PhysLean#L346-L352"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./PhysLean/Relativity/Tensors/Elab.html#TensorSpecies.Tensor.getIndicesRight\"><span class=\"name\">TensorSpecies</span>.<span class=\"name\">Tensor</span>.<span class=\"name\">getIndicesRight</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">stx</span> : <a href=\"./Init/Prelude.html#Lean.Syntax\">Lean.Syntax</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Lean/Elab/Term/TermElabM.html#Lean.Elab.Term.TermElabM\">Lean.Elab.TermElabM</a> <span class=\"fn\">(<a href=\"./Init/Prelude.html#List\">List</a> (<a href=\"./Init/Prelude.html#Lean.TSyntax\">Lean.TSyntax</a> <span class=\"fn\">`indexExpr</span>))</span></span></div></div>","info":{"doc":"Gets the indices associated with the RHS of an addition. ","docLink":"./PhysLean/Relativity/Tensors/Elab.html#TensorSpecies.Tensor.getIndicesRight","kind":"def","line":338,"name":"TensorSpecies.Tensor.getIndicesRight","sourceLink":"https://github.com/HEPLean/PhysLean#L338-L344"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./PhysLean/Relativity/Tensors/Elab.html#TensorSpecies.Tensor.getIndicesLeft\"><span class=\"name\">TensorSpecies</span>.<span class=\"name\">Tensor</span>.<span class=\"name\">getIndicesLeft</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">stx</span> : <a href=\"./Init/Prelude.html#Lean.Syntax\">Lean.Syntax</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Lean/Elab/Term/TermElabM.html#Lean.Elab.Term.TermElabM\">Lean.Elab.TermElabM</a> <span class=\"fn\">(<a href=\"./Init/Prelude.html#List\">List</a> (<a href=\"./Init/Prelude.html#Lean.TSyntax\">Lean.TSyntax</a> <span class=\"fn\">`indexExpr</span>))</span></span></div></div>","info":{"doc":"Gets the indices associated with the LHS of an addition. ","docLink":"./PhysLean/Relativity/Tensors/Elab.html#TensorSpecies.Tensor.getIndicesLeft","kind":"def","line":330,"name":"TensorSpecies.Tensor.getIndicesLeft","sourceLink":"https://github.com/HEPLean/PhysLean#L330-L336"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">partial def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./PhysLean/Relativity/Tensors/Elab.html#TensorSpecies.Tensor.getIndicesFull\"><span class=\"name\">TensorSpecies</span>.<span class=\"name\">Tensor</span>.<span class=\"name\">getIndicesFull</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">stx</span> : <a href=\"./Init/Prelude.html#Lean.Syntax\">Lean.Syntax</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Lean/Elab/Term/TermElabM.html#Lean.Elab.Term.TermElabM\">Lean.Elab.TermElabM</a> <span class=\"fn\">(<a href=\"./Init/Prelude.html#List\">List</a> (<a href=\"./Init/Prelude.html#Lean.TSyntax\">Lean.TSyntax</a> <span class=\"fn\">`indexExpr</span>))</span></span></div></div>","info":{"doc":"Returns the remaining indices of a tensor expression after contraction and evaluation.\n  Thus every index in the output of `getIndicesFull` is ident and there are no duplicates.\n  Examples are:\n1. `T | α β 2 β` gives `[α]`\n2. `T1 | α β 2 β ⊗ T2 | α γ δ δ` gives `[γ]`\n3. `(T1 | α β 2 β ⊗ T2 | α γ δ δ) ⊗ T3 | γ` gives `[]`\n4. `T1 | α β 2 β + T2 | α 4 δ δ` gives `[α]`\n","docLink":"./PhysLean/Relativity/Tensors/Elab.html#TensorSpecies.Tensor.getIndicesFull","kind":"opaque","line":305,"name":"TensorSpecies.Tensor.getIndicesFull","sourceLink":"https://github.com/HEPLean/PhysLean#L305-L328"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">partial def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./PhysLean/Relativity/Tensors/Elab.html#TensorSpecies.Tensor.getProdIndices\"><span class=\"name\">TensorSpecies</span>.<span class=\"name\">Tensor</span>.<span class=\"name\">getProdIndices</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">stx</span> : <a href=\"./Init/Prelude.html#Lean.Syntax\">Lean.Syntax</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Lean/Elab/Term/TermElabM.html#Lean.Elab.Term.TermElabM\">Lean.Elab.TermElabM</a> <span class=\"fn\">(<a href=\"./Init/Prelude.html#List\">List</a> (<a href=\"./Init/Prelude.html#Lean.TSyntax\">Lean.TSyntax</a> <span class=\"fn\">`indexExpr</span>))</span></span></div></div>","info":{"doc":"The function `getProdIndices` is defined for the following syntax:\n1. For e.g. `T | α β 2 β`, it returns all uncontracted and unevaluated indices e.g.`[α]`\n2. For e.g. `T1 | α β 2 β ⊗ T2 | α γ δ δ` it returns all unevaluated indices which\n    are not contracted in either tensor e.g. `[α, α, γ]`.\n3. For e.g. `(T1 | α β 2 β ⊗ T2 | α γ δ δ) ⊗ T3 | γ` it does `2` recursively e.g. `[γ, γ]`\n","docLink":"./PhysLean/Relativity/Tensors/Elab.html#TensorSpecies.Tensor.getProdIndices","kind":"opaque","line":286,"name":"TensorSpecies.Tensor.getProdIndices","sourceLink":"https://github.com/HEPLean/PhysLean#L286-L303"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./PhysLean/Relativity/Tensors/Elab.html#TensorSpecies.Tensor.getAllIndices\"><span class=\"name\">TensorSpecies</span>.<span class=\"name\">Tensor</span>.<span class=\"name\">getAllIndices</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">stx</span> : <a href=\"./Init/Prelude.html#Lean.Syntax\">Lean.Syntax</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Lean/Elab/Term/TermElabM.html#Lean.Elab.Term.TermElabM\">Lean.Elab.TermElabM</a> <span class=\"fn\">(<a href=\"./Init/Prelude.html#List\">List</a> (<a href=\"./Init/Prelude.html#Lean.TSyntax\">Lean.TSyntax</a> <span class=\"fn\">`indexExpr</span>))</span></span></div></div>","info":{"doc":"For syntax of the form `T | α β 2 β`, `getAllIndices` returns a list `[α, β, 2, β]`\nof all `indexExpr`. ","docLink":"./PhysLean/Relativity/Tensors/Elab.html#TensorSpecies.Tensor.getAllIndices","kind":"def","line":274,"name":"TensorSpecies.Tensor.getAllIndices","sourceLink":"https://github.com/HEPLean/PhysLean#L274-L284"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./PhysLean/Relativity/Tensors/Elab.html#TensorSpecies.Tensor.getNumIndicesExact\"><span class=\"name\">TensorSpecies</span>.<span class=\"name\">Tensor</span>.<span class=\"name\">getNumIndicesExact</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">stx</span> : <a href=\"./Init/Prelude.html#Lean.Syntax\">Lean.Syntax</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Lean/Elab/Term/TermElabM.html#Lean.Elab.Term.TermElabM\">Lean.Elab.TermElabM</a> <a href=\"./Init/Prelude.html#Nat\">ℕ</a></span></div></div>","info":{"doc":"For syntax of the form `T` where `T` is `S.F.obj (OverColor.mk c)` this returns\nthe value of `TensorSpecies.numIndices T`. That is, the exact number of indices\nassociated with that tensor. ","docLink":"./PhysLean/Relativity/Tensors/Elab.html#TensorSpecies.Tensor.getNumIndicesExact","kind":"def","line":260,"name":"TensorSpecies.Tensor.getNumIndicesExact","sourceLink":"https://github.com/HEPLean/PhysLean#L260-L272"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./PhysLean/Relativity/Tensors/Elab.html#TensorSpecies.Tensor.«tensorExpr-_»\"><span class=\"name\">TensorSpecies</span>.<span class=\"name\">Tensor</span>.<span class=\"name\">«tensorExpr-_»</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Init/Prelude.html#Lean.ParserDescr\">Lean.ParserDescr</a></div></div>","info":{"doc":"Negation of a tensor tree. ","docLink":"./PhysLean/Relativity/Tensors/Elab.html#TensorSpecies.Tensor.«tensorExpr-_»","kind":"def","line":251,"name":"TensorSpecies.Tensor.«tensorExpr-_»","sourceLink":"https://github.com/HEPLean/PhysLean#L251-L252"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./PhysLean/Relativity/Tensors/Elab.html#TensorSpecies.Tensor.«tensorExpr_•ₐ_»\"><span class=\"name\">TensorSpecies</span>.<span class=\"name\">Tensor</span>.<span class=\"name\">«tensorExpr_•ₐ_»</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Init/Prelude.html#Lean.ParserDescr\">Lean.ParserDescr</a></div></div>","info":{"doc":"group action for tensors. ","docLink":"./PhysLean/Relativity/Tensors/Elab.html#TensorSpecies.Tensor.«tensorExpr_•ₐ_»","kind":"def","line":248,"name":"TensorSpecies.Tensor.«tensorExpr_•ₐ_»","sourceLink":"https://github.com/HEPLean/PhysLean#L248-L249"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./PhysLean/Relativity/Tensors/Elab.html#TensorSpecies.Tensor.«tensorExpr_•ₜ_»\"><span class=\"name\">TensorSpecies</span>.<span class=\"name\">Tensor</span>.<span class=\"name\">«tensorExpr_•ₜ_»</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Init/Prelude.html#Lean.ParserDescr\">Lean.ParserDescr</a></div></div>","info":{"doc":"Scalar multiplication for tensors. ","docLink":"./PhysLean/Relativity/Tensors/Elab.html#TensorSpecies.Tensor.«tensorExpr_•ₜ_»","kind":"def","line":245,"name":"TensorSpecies.Tensor.«tensorExpr_•ₜ_»","sourceLink":"https://github.com/HEPLean/PhysLean#L245-L246"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./PhysLean/Relativity/Tensors/Elab.html#TensorSpecies.Tensor.«tensorExpr(_)»\"><span class=\"name\">TensorSpecies</span>.<span class=\"name\">Tensor</span>.<span class=\"name\">«tensorExpr(_)»</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Init/Prelude.html#Lean.ParserDescr\">Lean.ParserDescr</a></div></div>","info":{"doc":"Allowing brackets to be used in a tensor expression. ","docLink":"./PhysLean/Relativity/Tensors/Elab.html#TensorSpecies.Tensor.«tensorExpr(_)»","kind":"def","line":242,"name":"TensorSpecies.Tensor.«tensorExpr(_)»","sourceLink":"https://github.com/HEPLean/PhysLean#L242-L243"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./PhysLean/Relativity/Tensors/Elab.html#TensorSpecies.Tensor.«tensorExpr_+_»\"><span class=\"name\">TensorSpecies</span>.<span class=\"name\">Tensor</span>.<span class=\"name\">«tensorExpr_+_»</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Init/Prelude.html#Lean.TrailingParserDescr\">Lean.TrailingParserDescr</a></div></div>","info":{"doc":"The syntax for tensor addition. ","docLink":"./PhysLean/Relativity/Tensors/Elab.html#TensorSpecies.Tensor.«tensorExpr_+_»","kind":"def","line":239,"name":"TensorSpecies.Tensor.«tensorExpr_+_»","sourceLink":"https://github.com/HEPLean/PhysLean#L239-L240"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./PhysLean/Relativity/Tensors/Elab.html#TensorSpecies.Tensor.«tensorExpr_⊗_»\"><span class=\"name\">TensorSpecies</span>.<span class=\"name\">Tensor</span>.<span class=\"name\">«tensorExpr_⊗_»</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Init/Prelude.html#Lean.TrailingParserDescr\">Lean.TrailingParserDescr</a></div></div>","info":{"doc":"The syntax for tensor prod two tensor nodes. ","docLink":"./PhysLean/Relativity/Tensors/Elab.html#TensorSpecies.Tensor.«tensorExpr_⊗_»","kind":"def","line":236,"name":"TensorSpecies.Tensor.«tensorExpr_⊗_»","sourceLink":"https://github.com/HEPLean/PhysLean#L236-L237"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./PhysLean/Relativity/Tensors/Elab.html#TensorSpecies.Tensor.«tensorExpr_=_»\"><span class=\"name\">TensorSpecies</span>.<span class=\"name\">Tensor</span>.<span class=\"name\">«tensorExpr_=_»</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Init/Prelude.html#Lean.TrailingParserDescr\">Lean.TrailingParserDescr</a></div></div>","info":{"doc":"Equality. ","docLink":"./PhysLean/Relativity/Tensors/Elab.html#TensorSpecies.Tensor.«tensorExpr_=_»","kind":"def","line":233,"name":"TensorSpecies.Tensor.«tensorExpr_=_»","sourceLink":"https://github.com/HEPLean/PhysLean#L233-L234"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./PhysLean/Relativity/Tensors/Elab.html#TensorSpecies.Tensor.«tensorExpr_|__»\"><span class=\"name\">TensorSpecies</span>.<span class=\"name\">Tensor</span>.<span class=\"name\">«tensorExpr_|__»</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Init/Prelude.html#Lean.ParserDescr\">Lean.ParserDescr</a></div></div>","info":{"doc":"The syntax for a tensor node. ","docLink":"./PhysLean/Relativity/Tensors/Elab.html#TensorSpecies.Tensor.«tensorExpr_|__»","kind":"def","line":230,"name":"TensorSpecies.Tensor.«tensorExpr_|__»","sourceLink":"https://github.com/HEPLean/PhysLean#L230-L231"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./PhysLean/Relativity/Tensors/Elab.html#Lean.Parser.Category.tensorExpr\"><span class=\"name\">Lean</span>.<span class=\"name\">Parser</span>.<span class=\"name\">Category</span>.<span class=\"name\">tensorExpr</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Init/Notation.html#Lean.Parser.Category\">Category</a></div></div>","info":{"doc":"A syntax category for tensor expressions. ","docLink":"./PhysLean/Relativity/Tensors/Elab.html#Lean.Parser.Category.tensorExpr","kind":"def","line":227,"name":"Lean.Parser.Category.tensorExpr","sourceLink":"https://github.com/HEPLean/PhysLean#L227-L228"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def<