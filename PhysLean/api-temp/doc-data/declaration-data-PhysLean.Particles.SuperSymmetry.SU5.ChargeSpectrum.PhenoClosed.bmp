athlib/Algebra/Group/Defs.html#AddCommGroup\">AddCommGroup</a> <span class=\"fn\">𝓩</span></span>]</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">S5 </span><span class=\"fn\">S10</span> : <span class=\"fn\"><a href=\"./Mathlib/Data/Finset/Defs.html#Finset\">Finset</a> <span class=\"fn\">𝓩</span></span>}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">charges</span> : <span class=\"fn\"><a href=\"./Mathlib/Data/Multiset/Defs.html#Multiset\">Multiset</a> <span class=\"fn\">(<a href=\"./PhysLean/Particles/SuperSymmetry/SU5/ChargeSpectrum/Basic.html#SuperSymmetry.SU5.ChargeSpectrum\">ChargeSpectrum</a> <span class=\"fn\">𝓩</span>)</span></span>}</span></span>\n</span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">charges_topYukawa</span> : <span class=\"fn\">∀ <span class=\"fn\">x</span> ∈ <span class=\"fn\">charges</span>, <span class=\"fn\"><span class=\"fn\"><span class=\"fn\">x</span>.<a href=\"./PhysLean/Particles/SuperSymmetry/SU5/ChargeSpectrum/AllowsTerm.html#SuperSymmetry.SU5.ChargeSpectrum.AllowsTerm\">AllowsTerm</a></span> <a href=\"./PhysLean/Particles/SuperSymmetry/SU5/Potential.html#SuperSymmetry.SU5.PotentialTerm.topYukawa\">PotentialTerm.topYukawa</a></span></span>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">charges_not_isPhenoConstrained</span> : <span class=\"fn\">∀ <span class=\"fn\">x</span> ∈ <span class=\"fn\">charges</span>, <a href=\"./Init/Prelude.html#Not\">¬</a><span class=\"fn\"><span class=\"fn\">x</span>.<a href=\"./PhysLean/Particles/SuperSymmetry/SU5/ChargeSpectrum/PhenoConstrained.html#SuperSymmetry.SU5.ChargeSpectrum.IsPhenoConstrained\">IsPhenoConstrained</a></span></span>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">charges_yukawa</span> : <span class=\"fn\">∀ <span class=\"fn\">x</span> ∈ <span class=\"fn\">