{"declarations":[{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">abbrev</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./PhysLean/Units/WithDim/Momentum.html#Momentum\"><span class=\"name\">Momentum</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">d</span> : <a href=\"./Init/Prelude.html#Nat\">ℕ</a> := <span class=\"fn\">3</span>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./foundational_types.html\">Type</a></div></div>","info":{"doc":"Momentum in `d`-dimensional space in an arbitrary, but given, set of units.\nIn `(3+1)d` space time this corresponds to `3`-momentum not `4`-momentum. ","docLink":"./PhysLean/Units/WithDim/Momentum.html#Momentum","kind":"def","line":18,"name":"Momentum","sourceLink":"https://github.com/HEPLean/PhysLean#L18-L20"}}],"imports":["Init","PhysLean.Units.WithDim.Velocity","PhysLean.Units.WithDim.Mass","PhysLean.Units.WithDim.Basic"],"instances":[],"name":"PhysLean.Units.WithDim.Momentum"}