ver.Hom\">⟶</a> <span class=\"fn\">S₂</span>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">h</span> : <span class=\"fn\"><span class=\"fn\">S₂</span>.<a href=\"./Mathlib/Algebra/Homology/ShortComplex/RightHomology.html#CategoryTheory.ShortComplex.RightHomologyData\">RightHomologyData</a></span>)</span></span>\n<span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">[<span class=\"fn\"><a href=\"./Mathlib/CategoryTheory/Category/Basic.html#CategoryTheory.Epi\">Epi</a> <span class=\"fn\"><span class=\"fn\">φ</span>.<a href=\"./Mathlib/Algebra/Homology/ShortComplex/Basic.html#CategoryTheory.ShortComplex.Hom.τ₁\">τ₁</a></span></span>]</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">[<span class=\"fn\"><a href=\"./Mathlib/CategoryTheory/Iso.html#CategoryTheory.IsIso\">IsIso</a> <span class=\"fn\"><span class=\"fn\">φ</span>.<a href=\"./Mathlib/Algebra/Homology/ShortComplex/Basic.html#CategoryTheory.ShortComplex.Hom.τ₂\">τ₂</a></span></span>]</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">[<span class=\"fn\"><a href=\"./Mathlib/CategoryTheory/Category/Basic.html#CategoryTheory.Mono\">Mono</a> <span class=\"fn\"><span class=\"fn\">φ</span>.<a href=\"./Mathlib/Algebra/Homology/ShortComplex/Basic.html#CategoryTheory.ShortComplex.Hom.τ₃\">τ₃</a></span></span>]</span></span>\n</span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><span class=\"fn\">S₁</span>.<a href=\"./Mathlib/Algebra/Homology/ShortComplex/RightHomology.html#CategoryTheory.ShortComplex.RightHomologyData\">RightHomologyData</a></span></div></div>","info":{"doc":"If `φ : S₁ ⟶ S₂` is a morphism of short complexes such that `φ.τ₁` is epi, `φ.τ₂` is an iso\nand `φ.τ₃` is mono, then a right homology data for `S₂` induces a right homology data for `S₁` with\nthe same `Q` and `H` fields. This is obtained by dualising `LeftHomologyData.ofEpiOfI