/span></span>]</span></span>\n</span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">x</span> : <span class=\"fn\">L</span>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">m</span> : <span class=\"fn\">M</span>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\">m</span> <a href=\"./Init/Prelude.html#Membership.mem\">∈</a> <span class=\"fn\"><a href=\"./Mathlib/Algebra/Lie/Weights/Basic.html#LieModule.posFittingCompOf\">posFittingCompOf</a> <span class=\"fn\">R</span> <span class=\"fn\">M</span> <span class=\"fn\">x</span></span> <a href=\"./Init/Core.html#Iff\">↔</a> <span class=\"fn\">∀ (<span class=\"fn\">k</span> : <a href=\"./Init/Prelude.html#Nat\">ℕ</a>), <span class=\"fn\">∃ (<span class=\"fn\">n</span> : <span class=\"fn\">M</span>), <span class=\"fn\">(<span class=\"fn\"><span class=\"fn\">(<a href=\"./Mathlib/Algebra/Lie/OfAssociative.html#LieModule.toEnd\">toEnd</a> <span class=\"fn\">R</span> <span class=\"fn\">L</span> <span class=\"fn\">M</span>)</span> <span class=\"fn\">x</span></span> <a href=\"./Init/Prelude.html#HPow.hPow\">^</a> <span class=\"fn\">k</span>) <span class=\"fn\">n</span></span> <a href=\"./Init/Prelude.html#Eq\">=</a> <span class=\"fn\">m</span></span></span></div></div>","info":{"doc":"","docLink":"./Mathlib/Algebra/Lie/Weights/Basic.html#LieModule.mem_posFittingCompOf","kind":"theorem","line":415,"name":"LieModule.mem_posFittingCompOf","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/087469e24922b85cb737497c74556c7dacc01f22/Mathlib/Algebra/Lie/Weights/Basic.lean#L415-L417"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Mathlib/Algebra/Lie/Weights/Basic.html#LieModule.posFittingCompOf\"><span class=\"name\">LieModule</span>.<span class=\"name\">posFittingCompOf</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<