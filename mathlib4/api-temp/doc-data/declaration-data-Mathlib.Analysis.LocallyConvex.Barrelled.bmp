ass=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">p</span> : <span class=\"fn\"><a href=\"./Mathlib/Analysis/Seminorm.html#Seminorm\">Seminorm</a> <span class=\"fn\">𝕜</span> <span class=\"fn\">E</span></span>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><span class=\"fn\"><a href=\"./Mathlib/Topology/Semicontinuity/Defs.html#LowerSemicontinuous\">LowerSemicontinuous</a> <span class=\"fn\">⇑<span class=\"fn\">p</span></span></span> → <span class=\"fn\"><a href=\"./Mathlib/Topology/Defs/Basic.html#Continuous\">Continuous</a> <span class=\"fn\">⇑<span class=\"fn\">p</span></span></span></span></div></div>","info":{"doc":"In a barrelled space, all lower semicontinuous seminorms on `E` are actually continuous. ","docLink":"./Mathlib/Analysis/LocallyConvex/Barrelled.html#BarrelledSpace.continuous_of_lowerSemicontinuous","kind":"theorem","line":92,"name":"BarrelledSpace.continuous_of_lowerSemicontinuous","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/0f1dd7505c3d08b5feb82300ccc73179a457bf51/Mathlib/Analysis/LocallyConvex/Barrelled.lean#L92-L92"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">constructor</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Mathlib/Analysis/LocallyConvex/Barrelled.html#BarrelledSpace.mk\"><span class=\"name\">BarrelledSpace</span>.<span class=\"name\">mk</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">𝕜</span> : <a href=\"./foundational_types.html\">Type</a> u_1}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">E</span> : <a href=\"./foundational_types.html\">Type</a> u_2}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">[<span class=\"fn\"><a href=\"./Mathlib/Analysis/Normed/Ring/Basic.html#SeminormedRing\">SeminormedRing</a> <span class=\"fn\">𝕜</span></span>]</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">[<span class=\"fn\"><a href=\"./Mathlib/Algebra/Group/Defs.html#AddGroup\">AddGroup</a> <span class=\"fn\">E</span></span>]</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">[<span class=\"fn\"><a href=\"./Init/Prelude.html#SMul\">SMul</a> <span class=\"fn\">𝕜</span> <span class=\"fn\">E</span></span>]</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">[<span class=\"fn\"><a href=\"./Mathlib/Topology/Defs/Basic.html#TopologicalSpace\">TopologicalSpace</a> <span class=\"fn\">E</span></span>]</span></span>\n</span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">continuous_of_lowerSemicontinuous</span> : <span class=\"fn\">∀ (<span class=\"fn\">p</span> : <span class=\"fn\"><a href=\"./Mathlib/Analysis/Seminorm.html#Seminorm\">Seminorm</a> <span class=\"fn\">𝕜</span> <span class=\"fn\">E</span></span>), <span class=\"fn\"><span class=\"fn\"><a href=\"./Mathlib/Topology/Semicontinuity/Defs.html#LowerSemicontinuous\">LowerSemicontinuous</a> <span class=\"fn\">⇑<span class=\"fn\">p</span></span></span> → <span class=\"fn\"><a href=\"./Mathlib/Topology/Defs/Basic.html#Continuous\">Continuous</a> <span class=\"fn\">⇑<span class=\"fn\">p</span></span></span></span></span>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Mathlib/Analysis/LocallyConvex/Barrelled.html#BarrelledSpace\">BarrelledSpace</a> <span class=\"fn\">𝕜</span> <span class=\"fn\">E</span></span></div></div>","info":{"doc":"","docLink":"./Mathlib/Analysis/LocallyConvex/Barrelled.html#BarrelledSpace.mk","kind":"ctor","line":89,"name":"BarrelledSpace.mk","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/0f1dd7505c3d08b5feb82300ccc73179a457bf51/Mathlib/Analysis/LocallyConvex/Barrelled.lean#L89-L89"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">class</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Mathlib/Analysis/LocallyConvex/Barrelled.html#BarrelledSpace\"><span class=\"name\">BarrelledSpace</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">𝕜</span> : <a href=\"./foundational_types.html\">Type</a> u_1)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">E</span> : <a href=\"./foundational_types.html\">Type</a> u_2)</span></span>\n<span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">[<span class=\"fn\"><a href=\"./Mathlib/Analysis/Normed/Ring/Basic.html#SeminormedRing\">SeminormedRing</a> <span class=\"fn\">𝕜</span></span>]</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">[<span class=\"fn\"><a href=\"./Mathlib/Algebra/Group/Defs.html#AddGroup\">AddGroup</a> <span class=\"fn\">E</span></span>]</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">[<span class=\"fn\"><a href=\"./Init/Prelude.html#SMul\">SMul</a> <span class=\"fn\">𝕜</span> <span class=\"fn\">E</span></span>]</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">[<span class=\"fn\"><a href=\"./Mathlib/Topology/Defs/Basic.html#TopologicalSpace\">TopologicalSpace</a> <span class=\"fn\">E</span></span>]</span></span>\n</span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./foundational_types.html\">Prop</a></div></div>","info":{"doc":"A topological vector space `E` is said to be **barrelled** if all lower semicontinuous\nseminorms on `E` are actually continuous. This is not the usual definition for TVS over `ℝ` or `ℂ`,\nbut this has the big advantage of working and giving sensible results over *any*\n`NontriviallyNormedField`. In particular, the Banach-Steinhaus theorem holds for maps between such\na space and any space whose topology is generated by a family of seminorms. ","docLink":"./Mathlib/Analysis/LocallyConvex/Barrelled.html#BarrelledSpace","kind":"class","line":84,"name":"BarrelledSpace","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/0f1dd7505c3d08b5feb82300ccc73179a457bf51/Mathlib/Analysis/LocallyConvex/Barrelled.lean#L84-L92"}}],"imports":["Init","Mathlib.Analysis.LocallyConvex.WithSeminorms","Mathlib.Topology.Semicontinuity.Basic","Mathlib.Topology.Baire.Lemmas"],"instances":[{"className":"BarrelledSpace","name":"BaireSpace.instBarrelledSpace","typeNames":[]}],"name":"Mathlib.Analysis.LocallyConvex.Barrelled"}