s=\"fn\">X₀</span> : <span class=\"fn\">C</span>}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">k₀</span> : <span class=\"fn\">d</span> <a href=\"./Mathlib/Combinatorics/Quiver/Basic.html#Quiver.Hom\">⟶</a> <span class=\"fn\"><span class=\"fn\"><span class=\"fn\">F</span>.<a href=\"./Mathlib/CategoryTheory/Functor/Basic.html#CategoryTheory.Functor.obj\">obj</a></span> <span class=\"fn\">X₀</span></span>}</span></span>\n</span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">z</span> : <span class=\"fn\"><span class=\"fn\">Z</span> <span class=\"fn\">X₀</span> <span class=\"fn\">k₀</span></span>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><span class=\"fn\">Z</span> <span class=\"fn\">(<a href=\"./Mathlib/CategoryTheory/Limits/Final.html#CategoryTheory.Functor.Final.lift\">lift</a> <span class=\"fn\">F</span> <span class=\"fn\">d</span>)</span> <span class=\"fn\">(<a href=\"./Mathlib/CategoryTheory/Limits/Final.html#CategoryTheory.Functor.Final.homToLift\">homToLift</a> <span class=\"fn\">F</span> <span class=\"fn\">d</span>)</span></span></div></div>","info":{"doc":"We provide an induction principle for reasoning about `lift` and `homToLift`.\nWe want to perform some construction (usually just a proof) about\nthe particular choices `lift F d` and `homToLift F d`,\nit suffices to perform that construction for some other pair of choices\n(denoted `X₀ : C` and `k₀ : d ⟶ F.obj X₀` below),\nand to show how to transport such a construction\n*both* directions along a morphism between such choices.\n","docLink":"./Mathlib/CategoryTheory/Limits/Final.html#CategoryTheory.Functor.Final.induction","kind":"def","line":197,"name":"CategoryTheory.Functor.Final.induction","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/0f1dd7505c3d08b5feb82300ccc73179a457bf51/Mathlib/CategoryTheory/Limits/Final.lean#L197-L224"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Mathlib/CategoryTheory/Limits/Final.html#CategoryTheory.Functor.Final.homToLift\"><span class=\"name\">CategoryTheory</span>.<span class=\"name\">Functor</span>.<span class=\"name\">Final</span>.<span class=\"name\">homToLift</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">C</span> : <a href=\"./foundational_types.html\">Type</a> u₁}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">[<span class=\"fn\"><a href=\"./Mathlib/CategoryTheory/Category/Basic.html#CategoryTheory.Category\">Category.{v₁, u₁}</a> <span class=\"fn\">C</span></span>]</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">D</span> : <a href=\"./foundational_types.html\">Type</a> u₂}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">[<span class=\"fn\"><a href=\"./Mathlib/CategoryTheory/Category/Basic.html#CategoryTheory.Category\">Category.{v₂, u₂}</a> <span class=\"fn\">D</span></span>]</span></span>\n</span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">F</span> : <span class=\"fn\"><a href=\"./Mathlib/CategoryTheory/Functor/Basic.html#CategoryTheory.Functor\">Functor</a> <span class=\"fn\">C</span> <span class=\"fn\">D</span></span>)</span></span>\n<span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">[<span class=\"fn\"><span class=\"fn\">F</span>.<a href=\"./Mathlib/CategoryTheory/Limits/Final.html#CategoryTheory.Functor.Final\">Final</a></span>]</span></span>\n</span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">d</span> : <span class=\"fn\">D</span>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\">d</span> <a href=\"./Mathlib/Combinatorics/Quiver/Basic.html#Quiver.Hom\">⟶</a> <span class=\"fn\"><span class=\"fn\"><span class=\"fn\">F</span>.<a href=\"./Mathlib/CategoryTheory/Functor/Basic.html#CategoryTheory.Functor.obj\">obj</a></span> <span class=\"fn\">(<a href=\"./Mathlib/CategoryTheory/Limits/Final.html#CategoryTheory.Functor.Final.lift\">lift</a> <span class=\"fn\">F</span> <span class=\"fn\">d</span>)</span></span></div></div>","info":{"doc":"When `F : C ⥤ D` is final, we denote by `homToLift` an arbitrary choice of morphism\n`d ⟶ F.obj (lift F d)`.\n","docLink":"./Mathlib/CategoryTheory/Limits/Final.html#CategoryTheory.Functor.Final.homToLift","kind":"def","line":191,"name":"CategoryTheory.Functor.Final.homToLift","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/0f1dd7505c3d08b5feb82300ccc73179a457bf51/Mathlib/CategoryTheory/Limits/Final.lean#L191-L195"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Mathlib/CategoryTheory/Limits/Final.html#CategoryTheory.Functor.Final.lift\"><span class=\"name\">CategoryTheory</span>.<span class=\"name\">Functor</span>.<span class=\"name\">Final</span>.<span class=\"name\">lift</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">C</span> : <a href=\"./foundational_types.html\">Type</a> u₁}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">[<span class=\"fn\"><a href=\"./Mathlib/CategoryTheory/Category/Basic.html#CategoryTheory.Category\">Category.{v₁, u₁}</a> <span class=\"fn\">C</span></span>]</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">D</span> : <a href=\"./foundational_types.html\">Type</a> u₂}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">[<span class=\"fn\"><a href=\"./Mathlib/CategoryTheory/Category/Basic.html#CategoryTheory.Category\">Category.{v₂, u