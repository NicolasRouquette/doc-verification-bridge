clotomicExtension</a> <a href=\"./Init/Core.html#Singleton.singleton\">{</a><span class=\"fn\">p</span> <a href=\"./Init/Prelude.html#HPow.hPow\">^</a> <span class=\"fn\">k</span><a href=\"./Init/Core.html#Singleton.singleton\">}</a> <a href=\"./Init/Data/Rat/Basic.html#Rat\">ℚ</a> <span class=\"fn\">K</span></span>]</span></span>\n</span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">hζ</span> : <span class=\"fn\"><a href=\"./Mathlib/RingTheory/RootsOfUnity/PrimitiveRoots.html#IsPrimitiveRoot\">IsPrimitiveRoot</a> <span class=\"fn\">ζ</span> (<span class=\"fn\">p</span> <a href=\"./Init/Prelude.html#HPow.hPow\">^</a> <span class=\"fn\">k</span>)</span>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Mathlib/RingTheory/Discriminant.html#Algebra.discr\">Algebra.discr</a> <a href=\"./Init/Data/Rat/Basic.html#Rat\">ℚ</a> <span class=\"fn\">⇑<span class=\"fn\"><span class=\"fn\">(<a href=\"./Mathlib/NumberTheory/Cyclotomic/PrimitiveRoots.html#IsPrimitiveRoot.subOnePowerBasis\">IsPrimitiveRoot.subOnePowerBasis</a> <a href=\"./Init/Data/Rat/Basic.html#Rat\">ℚ</a> <span class=\"fn\">hζ</span>)</span>.<a href=\"./Mathlib/RingTheory/PowerBasis.html#PowerBasis.basis\">basis</a></span></span></span> <a href=\"./Init/Prelude.html#Eq\">=</a>   <span class=\"fn\">(-<span class=\"fn\">1</span>)</span> <a href=\"./Init/Prelude.html#HPow.hPow\">^</a> (<span class=\"fn\">(<span class=\"fn\">p</span> <a href=\"./Init/Prelude.html#HPow.hPow\">^</a> <span class=\"fn\">k</span>).<a href=\"./Mathlib/Data/Nat/Totient.html#Nat.totient\">totient</a></span> <a href=\"./Init/Prelude.html#HDiv.hDiv\">/</a> <span class=\"fn\">2</span>) <a href=\"./Init/Prelude.html#HMul.hMul\">*</a> <span class=\"fn\">↑<span class=\"fn\">p</span></span> <a href=\"./Init/Prelude.html#HPow.hPow\">^</a> (<span class=\"fn\">p</span> <a href=\"./Init/Prelude.html#HPow.hPow\">^</a> (<span class=\"fn\">k</span> <a href=\"./Init/Prelude.html#