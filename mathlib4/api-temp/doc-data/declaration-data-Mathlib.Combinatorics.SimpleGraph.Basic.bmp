lass=\"fn\"><span class=\"fn\">G</span>.<a href=\"./Mathlib/Combinatorics/SimpleGraph/Basic.html#SimpleGraph.Adj\">Adj</a></span> <span class=\"fn\">v</span> <span class=\"fn\">w</span></span></div></div>","info":{"doc":"","docLink":"./Mathlib/Combinatorics/SimpleGraph/Basic.html#SimpleGraph.mem_edgeSet","kind":"theorem","line":473,"name":"SimpleGraph.mem_edgeSet","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/0f1dd7505c3d08b5feb82300ccc73179a457bf51/Mathlib/Combinatorics/SimpleGraph/Basic.lean#L473-L475"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">abbrev</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Mathlib/Combinatorics/SimpleGraph/Basic.html#SimpleGraph.edgeSet\"><span class=\"name\">SimpleGraph</span>.<span class=\"name\">edgeSet</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">V</span> : <a href=\"./foundational_types.html\">Type</a> u}</span></span>\n</span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">G</span> : <span class=\"fn\"><a href=\"./Mathlib/Combinatorics/SimpleGraph/Basic.html#SimpleGraph\">SimpleGraph</a> <span class=\"fn\">V</span></span>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Mathlib/Data/Set/Defs.html#Set\">Set</a> <span class=\"fn\">(<a href=\"./Mathlib/Data/Sym/Sym2.html#Sym2\">Sym2</a> <span class=\"fn\">V</span>)</span></span></div></div>","info":{"doc":"`G.edgeSet` is the edge set for `G`.\nThis is an abbreviation for `edgeSetEmbedding G` that permits dot notation. ","docLink":"./Mathlib/Combinatorics/SimpleGraph/Basic.html#SimpleGraph.edgeSet","kind":"def","line":469,"name":"SimpleGraph.edgeSet","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/0f1dd7505c3d08b5feb82300ccc73179a457bf51/Mathlib/Combinatorics/SimpleGraph/Basic.lean#L469-L471"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</s