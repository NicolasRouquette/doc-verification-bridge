constantly `some a` after that. ","docLink":"./Mathlib/Data/Seq/Computation.html#Computation","kind":"def","line":31,"name":"Computation","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/087469e24922b85cb737497c74556c7dacc01f22/Mathlib/Data/Seq/Computation.lean#L31-L35"}}],"imports":["Init","Mathlib.Data.Nat.Find","Mathlib.Data.Stream.Init","Mathlib.Tactic.Common","Batteries.Tactic.Lint.Simp"],"instances":[{"className":"CoeTC","name":"Computation.instCoeTC","typeNames":["Computation"]},{"className":"Inhabited","name":"Computation.instInhabited","typeNames":["Computation"]},{"className":"Membership","name":"Computation.instMembership","typeNames":["Computation"]},{"className":"Computation.Terminates","name":"Computation.ret_terminates","typeNames":["Computation.pure"]},{"className":"Computation.Terminates","name":"Computation.think_terminates","typeNames":["Computation.think"]},{"className":"Computation.Terminates","name":"Computation.thinkN_terminates","typeNames":["Computation.thinkN"]},{"className":"Bind","name":"Computation.instBind","typeNames":["Computation"]},{"className":"Computation.Terminates","name":"Computation.terminates_bind","typeNames":["Computation.bind"]},{"className":"Monad","name":"Computation.monad","typeNames":["Computation"]},{"className":"LawfulMonad","name":"Computation.instLawfulMonad","typeNames":["Computation"]},{"className":"Computation.Terminates","name":"Computation.terminates_map","typeNames":["Computation.map"]},{"className":"Alternative","name":"Computation.instAlternativeComputation","typeNames":["Computation"]}],"name":"Mathlib.Data.Seq.Computation"}