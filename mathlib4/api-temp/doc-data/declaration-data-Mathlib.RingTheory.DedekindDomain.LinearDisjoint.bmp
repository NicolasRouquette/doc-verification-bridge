n class=\"fn\">B</span></span>]</span></span>\n</span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">h₁</span> : <span class=\"fn\"><span class=\"fn\"><span class=\"fn\">F₁</span>.<a href=\"./Mathlib/FieldTheory/LinearDisjoint.html#IntermediateField.LinearDisjoint\">LinearDisjoint</a></span> <span class=\"fn\">↥<span class=\"fn\">F₂</span></span></span>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">h₂</span> : <span class=\"fn\"><span class=\"fn\"><span class=\"fn\">F₁</span>.<a href=\"./Mathlib/FieldTheory/IntermediateField/Basic.html#IntermediateField.toSubalgebra\">toSubalgebra</a></span> ⊔ <span class=\"fn\"><span class=\"fn\">F₂</span>.<a href=\"./Mathlib/FieldTheory/IntermediateField/Basic.html#IntermediateField.toSubalgebra\">toSubalgebra</a></span></span> <a href=\"./Init/Prelude.html#Eq\">=</a> <a href=\"./Mathlib/Order/Notation.html#Top.top\">⊤</a>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">h₃</span> : <span class=\"fn\"><a href=\"./Mathlib/RingTheory/Coprime/Basic.html#IsCoprime\">IsCoprime</a> <span class=\"fn\">(<a href=\"./Mathlib/RingTheory/Ideal/Maps.html#Ideal.map\">Ideal.map</a> <span class=\"fn\">(<a href=\"./Mathlib/Algebra/Algebra/Defs.html#algebraMap\">algebraMap</a> <span class=\"fn\">R₁</span> <span class=\"fn\">B</span>)</span> <span class=\"fn\">(<a href=\"./Mathlib/RingTheory/DedekindDomain/Different.html#differentIdeal\">differentIdeal</a> <span class=\"fn\">A</span> <span class=\"fn\">R₁</span>)</span>)</span> <span class=\"fn\">(<a href=\"./Mathlib/RingTheory/Ideal/Maps.html#Ideal.map\">Ideal.map</a> <span class=\"fn\">(<a href=\"./Mathlib/Algebra/Algebra/Defs.html#algebraMap\">algebraMap</a> <span class=\"fn\">R₂</span> <span class=\"fn\">B</span>)</span> <span class=\"fn\">(<a href=\"./Mathlib/RingTheory/DedekindDomain/Different.html#differentIdeal\">differentIdeal</a> <span class=\"fn\">A</span> <span class=\"fn\">R₂</span>)</span>)</span></span>)</span></span>\n<span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">[<span class=\"fn\"><a href=\"./Mathlib/LinearAlgebra/FreeModule/Basic.html#Module.Free\">Module.Free</a> <span class=\"fn\">A</span> <span class=\"fn\">R₂</span></span>]</span></span>\n</span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><span class=\"fn\"><span class=\"fn\">(<a href=\"./Mathlib/Algebra/Algebra/Tower.html#IsScalarTower.toAlgHom\">IsScalarTower.toAlgHom</a> <span class=\"fn\">A</span> <span class=\"fn\">R₁</span> <span class=\"fn\">B</span>)</span>.<a href=\"./Mathlib/Algebra/Algebra/Subalgebra/Basic.html#AlgHom.range\">range</a></span> ⊔ <span class=\"fn\"><span class=\"fn\">(<a href=\"./Mathlib/Algebra/Algebra/Tower.html#IsScalarTower.toAlgHom\">IsScalarTower.toAlgHom</a> <span class=\"fn\">A</span> <span class=\"fn\">R₂</span> <span class=\"fn\">B</span>)</span>.<a href=\"./Mathlib/Algebra/Algebra/Subalgebra/Basic.html#AlgHom.range\">range</a></span></span> <a href=\"./Init/Prelude.html#Eq\">=</a> <a href=\"./Mathlib/Order/Notation.html#Top.top\">⊤</a></div></div>","info":{"doc":"Let `A ⊆ B` be a finite extension of Dedekind domains and assume that `A ⊆ R₁, R₂ ⊆ B` are two\nsubrings such that `Frac R₁ ⊔ Frac R₂ = Frac B`, `Frac R₁` and `Frac R₂` are linearly disjoint\nover `Frac A`, and that `𝓓(R₁/A)` and `𝓓(R₂/A)` are coprime where `𝓓` denotes the different ideal\nand `Frac R` denotes the fraction field of a domain `R`.\nThen `B` is generated (as an `A`-algebra) by `R₁` and `R₂`.\n","docLink":"./Mathlib/RingTheory/DedekindDomain/LinearDisjoint.html#IsDedekindDomain.range_sup_range_eq_top_of_isCoprime_differentIdeal","kind":"theorem","line":252,"name":"IsDedekindDomain.range_sup_range_eq_top_of_isCoprime_differentIdeal","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/0f1dd7505c3d08b5feb82300ccc73179a457bf51/Mathlib/RingTheory/DedekindDomain/LinearDisjoint.lean#L252-L271"}},{"header":"<div class=\"de