edSpace.expSeries","kind":"def","line":105,"name":"NormedSpace.expSeries","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/0f1dd7505c3d08b5feb82300ccc73179a457bf51/Mathlib/Analysis/Normed/Algebra/Exponential.lean#L105-L108"}}],"imports":["Init","Mathlib.Algebra.Algebra.TransferInstance","Mathlib.Algebra.Ring.Action.ConjAct","Mathlib.Analysis.Analytic.ChangeOrigin","Mathlib.Analysis.Complex.Basic","Mathlib.Data.Nat.Choose.Cast","Mathlib.Analysis.Analytic.OfScalars"],"instances":[],"name":"Mathlib.Analysis.Normed.Algebra.Exponential"}