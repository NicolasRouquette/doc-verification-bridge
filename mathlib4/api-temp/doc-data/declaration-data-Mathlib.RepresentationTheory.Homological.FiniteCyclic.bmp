RepresentationTheory/Rep.html#Rep.trivial\">trivial</a> <span class=\"fn\">k</span> <span class=\"fn\">G</span> <span class=\"fn\">k</span>)</span> <span class=\"fn\">i</span> <span class=\"fn\">hi</span>)</span>.<a href=\"./Mathlib/CategoryTheory/Iso.html#CategoryTheory.Iso.inv\">inv</a></span>)</span></span>\n  else <span class=\"fn\">0</span></span></div></div>","info":{"doc":"","docLink":"./Mathlib/RepresentationTheory/Homological/FiniteCyclic.html#Rep.FiniteCyclicGroup.resolution.π_f","kind":"theorem","line":180,"name":"Rep.FiniteCyclicGroup.resolution.π_f","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/087469e24922b85cb737497c74556c7dacc01f22/Mathlib/RepresentationTheory/Homological/FiniteCyclic.lean#L180-L180"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">noncomputable def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Mathlib/RepresentationTheory/Homological/FiniteCyclic.html#Rep.FiniteCyclicGroup.resolution.π\"><span class=\"name\">Rep</span>.<span class=\"name\">FiniteCyclicGroup</span>.<span class=\"name\">resolution</span>.<span class=\"name\">π</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">k</span> : <a href=\"./foundational_types.html\">Type</a> u)</span></span>\n<span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">G</span> : <a href=\"./foundational_types.html\">Type</a> u}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">[<span class=\"fn\"><a href=\"./Mathlib/Algebra/Ring/Defs.html#CommRing\">CommRing</a> <span class=\"fn\">k</span></span>]</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">[<span class=\"fn\"><a href=\"./Mathlib/Algebra/Group/Defs.html#CommGroup\">CommGroup</a> <span class=\"fn\">G</span></span>]</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">[<span class=\"fn\"><a href=\"./Mathlib/Data/Fintype/Defs.html#Fintype\">Fintype</a> <span class=\"fn\">G</span></span>]</span></span>\n</span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">g</span> : <span class=\"fn\">G</span>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><span class=\"fn\"><span class=\"fn\">(<a href=\"./Mathlib/RepresentationTheory/Homological/FiniteCyclic.html#Rep.FiniteCyclicGroup.chainComplexFunctor\">chainComplexFunctor</a> <span class=\"fn\">k</span> <span class=\"fn\">g</span>)</span>.<a href=\"./Mathlib/CategoryTheory/Functor/Basic.html#CategoryTheory.Functor.obj\">obj</a></span> <span class=\"fn\">(<a href=\"./Mathlib/RepresentationTheory/Rep.html#Rep.leftRegular\">leftRegular</a> <span class=\"fn\">k</span> <span class=\"fn\">G</span>)</span></span> <a href=\"./Mathlib/Combinatorics/Quiver/Basic.html#Quiver.Hom\">⟶</a> <span class=\"fn\"><span class=\"fn\"><span class=\"fn\">(<a href=\"./Mathlib/Algebra/Homology/Single.html#ChainComplex.single₀\">ChainComplex.single₀</a> <span class=\"fn\">(<a href=\"./Mathlib/RepresentationTheory/Rep.html#Rep\">Rep</a> <span class=\"fn\">k</span> <span class=\"fn\">G</span>)</span>)</span>.<a href=\"./Mathlib/CategoryTheory/Functor/Basic.html#CategoryTheory.Functor.obj\">obj</a></span> <span class=\"fn\">(<a href=\"./Mathlib/RepresentationTheory/Rep.html#Rep.trivial\">trivial</a> <span class=\"fn\">k</span> <span class=\"fn\">G</span> <span class=\"fn\">k</span>)</span></span></div></div>","info":{"doc":"Given a finite cyclic group `G` generated by `g : G`, let `P` denote the periodic chain complex\nof `k`-linear `G`-representations given by\n`... ⟶ k[G] --N--> k[G] --(ρ(g) - 𝟙)--> k[G] --N--> k[G] --(ρ(g) - 𝟙)--> k[G] ⟶ 0` where `ρ` is\nthe left regular representation and `N` is the norm map. This is the chain morphism from `P` to\nthe chain complex concentrated at 0 by the trivial representation `k` used to show `P` is a\nprojective resolution of `k`. It sends `x : k[G]` to the sum of its coefficients. ","docLink":"./Mathlib/RepresentationTheory/Homological/FiniteCyclic.html#Rep.FiniteCyclicGroup.resolution.π","kind":"def","line":174,"name":"Rep.FiniteCyclicGroup.resolution.π","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/087469e24922b85cb737497c74556c7dacc01f22/Mathlib/RepresentationTheory/Homological/FiniteCyclic.lean#L174-L185"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">noncomputable abbrev</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Mathlib/RepresentationTheory/Homological/FiniteCyclic.html#Rep.FiniteCyclicGroup.moduleCatCochainComplex\"><span class=\"name\">Rep</span>.<span class=\"name\">FiniteCyclicGroup</span>.<span class=\"name\">moduleCatCochainComplex</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">k </span><span class=\"fn\">G</span> : <a href=\"./foundational_types.html\">Type</a> u}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">[<span class=\"fn\"><a href=\"./Mathlib/Algebra/Ring/Defs.html#CommRing\">CommRing</a> <span class=\"fn\">k</span></span>]</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">[<span class=\"fn\"><a href=\"./Mathlib/Algebra/Group/Defs.html#CommGroup\">CommGroup</a> <span class=\"fn\">G</span></span>]</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">[<span class=\"fn\"><a href=\"./Mathlib/Data/Fintype/Defs.html#Fintype\">Fintype</a> <span class=\"fn\">G</span></span>]</span></span>\n</span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">A</span> : <span class=\"fn\"><a href=\"./Mathlib/RepresentationTheory/Rep.html#Rep\">Rep</a> <span class=\"fn\">k</span> <span class=\"fn\">G</span></span>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">g</span> : <span class=\"fn\">G</span>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Mathlib/Algebra/Homology/HomologicalComplex.html#CochainComplex\">CochainComplex</a> <span class=\"fn\">(<a href=\"./Mathlib/Algebra/Category/ModuleCat/Basic.html#ModuleCat\">ModuleCat</a> <span class=\"fn\">k</span>)</span> <a href=\"./Init/Prelude.html#Nat\">ℕ</a></span></div></div>","info":{"doc":"Given a finite cyclic group `G` generated by `g : G` and a `k`-linear `G`-representation `A`,\nthis is the periodic chain complex in `Rep k G` given by\n`0 ⟶ A --(ρ(g) - 𝟙)--> A --N--> A --(ρ(g) - 𝟙)--> A --N--> A ⟶ ...` where `N` is the norm map.\nIts cohomology is the group cohomology of `A`. ","docLink":"./Mathlib/RepresentationTheory/Homological/FiniteCyclic.html#Rep.FiniteCyclicGroup.moduleCatCochainComplex","kind":"def","line":164,"name":"Rep.FiniteCyclicGroup.moduleCatCochainComplex","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/087469e24922b85cb737497c74556c7dacc01f22/Mathlib/RepresentationTheory/Homological/FiniteCyclic.lean#L164-L170"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">noncomputable abbrev</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Mathlib/RepresentationTheory/Homological/FiniteCyclic.html#Rep.FiniteCyclicGroup.moduleCatChainComplex\"><span class=\"name\">Rep</span>.<span class=\"name\">FiniteCyclicGroup</span>.<span class=\"name\">moduleCatChainComplex</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">k </span><span class=\"fn\">G</span> : <a href=\"./foundational_types.html\">Type</a> u}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">[<span class=\"fn\"><a href=\"./Mathlib/Algebra/Ring/Defs.html#CommRing\">CommRing</a> <span class=\"fn\">k</span></span>]</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">[<span clas