f=\"./Init/Prelude.html#Prod.mk\">)</a></div></div>","info":{"doc":"","docLink":"./Mathlib/Analysis/Normed/Algebra/Unitization.html#Unitization.splitMul_apply","kind":"theorem","line":84,"name":"Unitization.splitMul_apply","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/0f1dd7505c3d08b5feb82300ccc73179a457bf51/Mathlib/Analysis/Normed/Algebra/Unitization.lean#L84-L87"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">noncomputable def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Mathlib/Analysis/Normed/Algebra/Unitization.html#Unitization.splitMul\"><span class=\"name\">Unitization</span>.<span class=\"name\">splitMul</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">𝕜</span> : <a href=\"./foundational_types.html\">Type</a> u_1)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">A</span> : <a href=\"./foundational_types.html\">Type</a> u_2)</span></span>\n<span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">[<span class=\"fn\"><a href=\"./Mathlib/Analysis/Normed/Field/Basic.html#NontriviallyNormedField\">NontriviallyNormedField</a> <span class=\"fn\">𝕜</span></span>]</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">[<span class=\"fn\"><a href=\"./Mathlib/Analysis/Normed/Ring/Basic.html#NonUnitalNormedRing\">NonUnitalNormedRing</a> <span class=\"fn\">A</span></span>]</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">[<span class=\"fn\"><a href=\"./Mathlib/Analysis/Normed/Module/Basic.html#NormedSpace\">NormedSpace</a> <span class=\"fn\">𝕜</span> <span class=\"fn\">A</span></span>]</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">[<span class=\"fn\"><a href=\"./Mathlib/Algebra/Group/Action/Defs.html#IsScalarTower\">IsScalarTower</a> <span class=\"fn\">𝕜</span> <span class=\"fn\">A</span> <span class=\"fn\">A</span></span>]</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">[<span class=\"fn\"><a href=\"./Mathlib/Algebra/Group/Action/Defs.html#SMulCommClass\">SMulCommClass</a> <span class=\"fn\">𝕜</span> <span class=\"fn\">A</span> <span class=\"fn\">A</span></span>]</span></span>\n</span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Mathlib/Algebra/Algebra/Unitization.html#Unitization\">Unitization</a> <span class=\"fn\">𝕜</span> <span class=\"fn\">A</span></span> <a href=\"./Mathlib/Algebra/Algebra/Hom.html#AlgHom\">→ₐ[</a><span class=\"fn\">𝕜</span><a href=\"./Mathlib/Algebra/Algebra/Hom.html#AlgHom\">]</a> <span class=\"fn\">𝕜</span> <a href=\"./Init/Prelude.html#Prod\">×</a> (<span class=\"fn\">A</span> <a href=\"./Mathlib/Topology/Algebra/Module/LinearMap.html#ContinuousLinearMap\">→L[</a><span class=\"fn\">𝕜</span><a href=\"./Mathlib/Topology/Algebra/Module/LinearMap.html#ContinuousLinearMap\">]</a> <span class=\"fn\">A</span>)</div></div>","info":{"doc":"Given `(k, a) : Unitization 𝕜 A`, the second coordinate of `Unitization.splitMul (k, a)` is\nthe natural representation of `Unitization 𝕜 A` on `A` given by multiplication on the left in\n`A →L[𝕜] A`; note that this is not just `NonUnitalAlgHom.Lmul` for a few reasons: (a) that would\neither be `A` acting on `A`, or (b) `Unitization 𝕜 A` acting on `Unitization 𝕜 A`, and (c) that's a\n`NonUnitalAlgHom` but here we need an `AlgHom`. In addition, the first coordinate of\n`Unitization.splitMul (k, a)` should just be `k`. See `Unitization.splitMul_apply` also. ","docLink":"./Mathlib/Analysis/Normed/Algebra/Unitization.html#Unitization.splitMul","kind":"def","line":73,"name":"Unitization.splitMul","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/0f1dd7505c3d08b5feb82300ccc73179a457bf51/Mathlib/Analysis/Normed/Algebra/Unitization.lean#L73-L80"}}],"imports":["Init","Mathlib.Algebra.Algebra.Unitization","Mathlib.Analysis.Normed.Operator.Mul"],"instances":[{"className":"UniformSpace","name":"Unitization.instUniformSpace","typeNames":["Unitization"]},{"className":"Bornology","name":"Unitization.instBornology","typeNames":["Unitization"]},{"className":"CompleteSpace","name":"Unitization.instCompleteSpace","typeNames":["Unitization"]},{"className":"MetricSpace","name":"Unitization.instMetricSpace","typeNames":["Unitization"]},{"className":"NormedRing","name":"Unitization.instNormedRing","typeNames":["Unitization"]},{"className":"NormedAlgebra","name":"Unitization.instNormedAlgebra","typeNames":["Unitization"]},{"className":"NormOneClass","name":"Unitization.instNormOneClass","typeNames":["Unitization"]}],"name":"Mathlib.Analysis.Normed.Algebra.Unitization"}