        {"text":
         "on the hypotheses (and additional proof terms if the user specifies them)."},
        {"raw": "\n"},
        {"text":
         "It proves the goal by generating an appropriate call to the tactic"},
        {"raw": "\n"},
        {"element": ["code", true, [], [{"text": "linear_combination"}]]},
        {"text": ". If this call succeeds, the call to "},
        {"element": ["code", true, [], [{"text": "linear_combination"}]]},
        {"raw": "\n"},
        {"text": "is suggested to the user."}]]},
     {"element":
      ["ul",
       true,
       [],
       [{"element":
         ["li",
          true,
          [],
          [{"element": ["code", true, [], [{"text": "polyrith"}]]},
           {"text":
            " will use all relevant hypotheses in the local context."}]]},
        {"element":
         ["li",
          true,
          [],
          [{"element":
            ["code",
             true,
             [],
             [{"text": "polyrith"},
              {"text": " "},
              {"text": "[t1,"},
              {"text": " "},
              {"text": "t2,"},
              {"text": " "},
              {"text": "t3]"}]]},
           {"text":
            " will add proof terms t1, t2, t3 to the local context."}]]},
        {"element":
         ["li",
          true,
          [],
          [{"element":
            ["code",
             true,
             [],
             [{"text": "polyrith"},
              {"text": " "},
              {"text": "only"},
