              {"text": "h2,"},
              {"text": " "},
              {"text": "h3,"},
              {"text": " "},
              {"text": "t1,"},
              {"text": " "},
              {"text": "t2,"},
              {"text": " "},
              {"text": "t3]"}]]},
           {"text": " will use only local hypotheses"},
           {"raw": "\n"},
           {"element": ["code", true, [], [{"text": "h1"}]]},
           {"text": ", "},
           {"element": ["code", true, [], [{"text": "h2"}]]},
           {"text": ", "},
           {"element": ["code", true, [], [{"text": "h3"}]]},
