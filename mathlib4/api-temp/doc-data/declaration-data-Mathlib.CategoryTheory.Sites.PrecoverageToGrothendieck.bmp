eve</a> <span class=\"fn\">X</span></span>}</span></span>\n</span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\">S</span> <a href=\"./Init/Prelude.html#Membership.mem\">∈</a> <span class=\"fn\"><span class=\"fn\"><span class=\"fn\">J</span>.<a href=\"./Mathlib/CategoryTheory/Sites/PrecoverageToGrothendieck.html#CategoryTheory.Precoverage.toGrothendieck\">toGrothendieck</a></span> <span class=\"fn\">X</span></span> <a href=\"./Init/Core.html#Iff\">↔</a> <span class=\"fn\"><span class=\"fn\"><span class=\"fn\">J</span>.<a href=\"./Mathlib/CategoryTheory/Sites/PrecoverageToGrothendieck.html#CategoryTheory.Precoverage.Saturate\">Saturate</a></span> <span class=\"fn\">X</span> <span class=\"fn\">S</span></span></div></div>","info":{"doc":"","docLink":"./Mathlib/CategoryTheory/Sites/PrecoverageToGrothendieck.html#CategoryTheory.Precoverage.mem_toGrothendieck_iff","kind":"theorem","line":67,"name":"CategoryTheory.Precoverage.mem_toGrothendieck_iff","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/0f1dd7505c3d08b5feb82300ccc73179a457bf51/Mathlib/CategoryTheory/Sites/PrecoverageToGrothendieck.lean#L67-L68"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Mathlib/CategoryTheory/Sites/PrecoverageToGrothendieck.html#CategoryTheory.Precoverage.toGrothendieck\"><span class=\"name\">CategoryTheory</span>.<span class=\"name\">Precoverage</span>.<span class=\"name\">toGrothendieck</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">C</span> : <a href=\"./foundational_types.html\">Type</a> u_1}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">[<span class=\"fn\"><a href=\"./Mathlib/CategoryTheory/Category/Basic.html#CategoryTheory.Category\">Category.{u_2, u_1}</a> <span class=\"fn\">C</span></span>]</span></span>\n</span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">J</span> : <span class=\"fn\"><a href=\"./Mathlib/CategoryTheory/Sites/Precoverage.html#CategoryTheory.Precoverage\">Precoverage</a> <span class=\"fn\">C</span></span>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Mathlib/CategoryTheory/Sites/Grothendieck.html#CategoryTheory.GrothendieckTopology\">GrothendieckTopology</a> <span class=\"fn\">C</span></span></div></div>","info":{"doc":"The Grothendieck topology associated to a precoverage `J`.\nIt is defined *inductively* as follows:\n1. If `S` is a covering presieve for `J`, then the sieve generated by `S` is a covering\n  sieve for the associated Grothendieck topology.\n2. The top sieves are in the associated Grothendieck topology.\n3. Add all sieves required by the pullback stability condition of a Grothendieck topology.\n4. Add all sieves required by the *local character* axiom of a Grothendieck topology.\n","docLink":"./Mathlib/CategoryTheory/Sites/PrecoverageToGrothendieck.html#CategoryTheory.Precoverage.toGrothendieck","kind":"def","line":52,"name":"CategoryTheory.Precoverage.toGrothendieck","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/0f1dd7505c3d08b5feb82300ccc73179a457bf51/Mathlib/CategoryTheory/Sites/PrecoverageToGrothendieck.lean#L52-L65"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">constructor</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Mathlib/CategoryTheory/Sites/PrecoverageToGrothendieck.html#CategoryTheory.Precoverage.Saturate.transitive\"><span class=\"name\">CategoryTheory</span>.<span class=\"name\">Precoverage</span>.<span class=\"name\">Saturate</span>.<span class=\"name\">transitive</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">C</span> : <a href=\"./foundational_types.html\">Type</a> u_1}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\