r/One.html#CategoryTheory.PreOneHypercover\">PreOneHypercover</a> <span class=\"fn\">S</span></span>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Mathlib/CategoryTheory/Sites/Hypercover/Zero.html#CategoryTheory.PreZeroHypercover\">PreZeroHypercover</a> <span class=\"fn\">S</span></span></div></div>","info":{"doc":"","docLink":"./Mathlib/CategoryTheory/Sites/Hypercover/One.html#CategoryTheory.PreOneHypercover.toPreZeroHypercover","kind":"def","line":47,"name":"CategoryTheory.PreOneHypercover.toPreZeroHypercover","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/0f1dd7505c3d08b5feb82300ccc73179a457bf51/Mathlib/CategoryTheory/Sites/Hypercover/One.lean#L47-L56"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">structure</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Mathlib/CategoryTheory/Sites/Hypercover/One.html#CategoryTheory.PreOneHypercover\"><span class=\"name\">CategoryTheory</span>.<span class=\"name\">PreOneHypercover</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">C</span> : <a href=\"./foundational_types.html\">Type</a> u}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">[<span class=\"fn\"><a href=\"./Mathlib/CategoryTheory/Category/Basic.html#CategoryTheory.Category\">Category.{v, u}</a> <span class=\"fn\">C</span></span>]</span></span>\n</span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">S</span> : <span class=\"fn\">C</span>)</span></span>\n<span class=\"decl_extends\">extends</span> <span class=\"fn\"><a href=\"./Mathlib/CategoryTheory/Sites/Hypercover/Zero.html#CategoryTheory.PreZeroHypercover\">CategoryTheory.PreZeroHypercover</a> <span class=\"fn\">S</span></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./foundational_types.html\">Type</a> (max (max u v) (w + 1))</div></div>","info":{"doc":"The categorical data that is involved in a `1`-hypercover of an object `S`. This\nconsists of a family of morphisms `f i : X i ⟶ S` for `i : I₀`, and for each\ntuple `(i₁, i₂)` of elements in `I₀`, a family of objects `Y j` indexed by\na type `I₁ i₁ i₂`, which are equipped with a map to the fibre product of `X i₁`\nand `X i₂`, which is phrased here as the data of the two projections\n`p₁ : Y j ⟶ X i₁`, `p₂ : Y j ⟶ X i₂` and the relation `p₁ j ≫ f i₁ = p₂ j ≫ f i₂`.\n(See `GrothendieckTopology.OneHypercover` for the topological conditions.) ","docLink":"./Mathlib/CategoryTheory/Sites/Hypercover/One.html#CategoryTheory.PreOneHypercover","kind":"structure","line":40,"name":"CategoryTheory.PreOneHypercover","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/0f1dd7505c3d08b5feb82300ccc73179a457bf51/Mathlib/CategoryTheory/Sites/Hypercover/One.lean#L40-L56"}}],"imports":["Init","Mathlib.CategoryTheory.Limits.Shapes.Opposites.Products","Mathlib.CategoryTheory.Sites.Coverage","Mathlib.CategoryTheory.Sites.Sheaf","Mathlib.CategoryTheory.Sites.Hypercover.Zero"],"instances":[{"className":"Unique","name":"CategoryTheory.PreOneHypercover.instUniqueLMulticospanShapeSigmaOfIsColimit","typeNames":["CategoryTheory.Limits.MulticospanShape.L"]},{"className":"Unique","name":"CategoryTheory.PreOneHypercover.instUniqueRMulticospanShapeSigmaOfIsColimit","typeNames":["CategoryTheory.Limits.MulticospanShape.R"]},{"className":"Nonempty","name":"CategoryTheory.PreOneHypercover.instNonempty","typeNames":["CategoryTheory.PreOneHypercover"]},{"className":"CategoryTheory.Category","name":"CategoryTheory.PreOneHypercover.instCategory","typeNames":["CategoryTheory.PreOneHypercover"]},{"className":"Nonempty","name":"CategoryTheory.GrothendieckTopology.OneHypercover.instNonempty","typeNames":["CategoryTheory.GrothendieckTopology.OneHypercover"]},{"className":"CategoryTheory.Category","name":"CategoryTheory.GrothendieckTopology.OneHypercover.instCategory","typeNames":["CategoryTheory.GrothendieckTopology.OneHypercover"]},{"className":"CategoryTheory.Limits.HasLimit","name":"CategoryTheory.instHasPullbacksToPreOneHypercover","typeNames":["CategoryTheory.PreZeroHypercover.f","CategoryTheory.PreZeroHypercover.f"]}],"name":"Mathlib.CategoryTheory.Sites.Hypercover.One"}