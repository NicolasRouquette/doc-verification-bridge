ect\">Subobject</a> <span class=\"fn\">X</span>)</span> <span class=\"fn\">C</span></span></div></div>","info":{"doc":"Use choice to pick a representative underlying object in `C` for any `Subobject X`.\n\nPrefer to use the coercion `P : C` rather than explicitly writing `underlying.obj P`.\n","docLink":"./Mathlib/CategoryTheory/Subobject/Basic.html#CategoryTheory.Subobject.underlying","kind":"def","line":173,"name":"CategoryTheory.Subobject.underlying","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/087469e24922b85cb737497c74556c7dacc01f22/Mathlib/CategoryTheory/Subobject/Basic.lean#L173-L178"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">noncomputable def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Mathlib/CategoryTheory/Subobject/Basic.html#CategoryTheory.Subobject.representativeIso\"><span class=\"name\">CategoryTheory</span>.<span class=\"name\">Subobject</span>.<span class=\"name\">representativeIso</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">C</span> : <a href=\"./foundational_types.html\">Type</a> u₁}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">[<span class=\"fn\"><a href=\"./Mathlib/CategoryTheory/Category/Basic.html#CategoryTheory.Category\">Category.{v₁, u₁}</a> <span class=\"fn\">C</span></span>]</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">X</span> : <span class=\"fn\">C</span>}</span></span>\n</span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">A</span> : <span class=\"fn\"><a href=\"./Mathlib/CategoryTheory/Subobject/MonoOver.html#CategoryTheory.MonoOver\">MonoOver</a> <span class=\"fn\">X</span></span>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><span class=\"fn\"><a href=\"./Mathlib/CategoryTheory/Subobject/Basic.html#CategoryTheory.Subobject.representative\">representative</a>.<a href=\"./Mathlib/CategoryTheory/Functor/Basic.html#CategoryTheory.Functor.obj\">obj</a></span> <span class=\"fn\">(<span class=\"fn\"><span class=\"fn\">(<a href=\"./Mathlib/CategoryTheory/Skeletal.html#CategoryTheory.toThinSkeleton\">toThinSkeleton</a> <span class=\"fn\">(<a href=\"./Mathlib/CategoryTheory/Subobject/MonoOver.html#CategoryTheory.MonoOver\">MonoOver</a> <span class=\"fn\">X</span>)</span>)</span>.<a href=\"./Mathlib/CategoryTheory/Functor/Basic.html#CategoryTheory.Functor.obj\">obj</a></span> <span class=\"fn\">A</span>)</span></span> <a href=\"./Mathlib/CategoryTheory/Iso.html#CategoryTheory.Iso\">≅</a> <span class=\"fn\">A</span></div></div>","info":{"doc":"Starting with `A : MonoOver X`, we can take its equivalence class in `Subobject X`\nthen pick an arbitrary representative using `representative.obj`.\nThis is isomorphic (in `MonoOver X`) to the original `A`.\n","docLink":"./Mathlib/CategoryTheory/Subobject/Basic.html#CategoryTheory.Subobject.representativeIso","kind":"def","line":165,"name":"CategoryTheory.Subobject.representativeIso","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/087469e24922b85cb737497c74556c7dacc01f22/Mathlib/CategoryTheory/Subobject/Basic.lean#L165-L171"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">instance</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Mathlib/CategoryTheory/Subobject/Basic.html#CategoryTheory.Subobject.instIsEquivalenceMonoOverRepresentative\"><span class=\"name\">CategoryTheory</span>.<span class=\"name\">Subobject</span>.<span class=\"name\">instIsEquivalenceMonoOverRepresentative</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">C</span> : <a href=\"./foundational_types.html\">Type</a> u₁}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">[<span class=\"fn\"><a href=\"./Mathlib/CategoryTheory/Category/Basic.html#CategoryTheory.Category\">Category.{v₁, u₁}</a> <span class=\"fn\">C</span></span>]</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">X</span> : <span class=\"fn\">C</span>}</span></span>\n</span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Mathlib/CategoryTheory/Subobject/Basic.html#CategoryTheory.Subobject.representative\">representative</a>.<a href=\"./Mathlib/CategoryTheory/Equivalence.html#CategoryTheory.Functor.IsEquivalence\">IsEquivalence</a></span></div></div>","info":{"doc":"","docLink":"./Mathlib/CategoryTheory/Subobject/Basic.html#CategoryTheory.Subobject.instIsEquivalenceMonoOverRepresentative","kind":"instance","line":162,"name":"CategoryTheory.Subobject.instIsEquivalenceMonoOverRepresentative","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/087469e24922b85cb737497c74556c7dacc01f22/Mathlib/CategoryTheory/Subobject/Basic.lean#L162-L163"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">noncomputable def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Mathlib/CategoryTheory/Subobject/Basic.html#CategoryTheory.Subobject.representative\"><span class=\"name\">CategoryTheory</span>.<span class=\"name\">Subobject</span>.<span class=\"name\">representative</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">C</span> : <a href=\"./foundational_types.html\">Type</a> u₁}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">[<span class=\"fn\"><a href=\"./Mathlib/CategoryTheory/Category/Basic.html#CategoryTheory.Category\">Category.{v₁, u₁}</a> <span class=\"fn\">C</span></span>]</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">X</span> : <span class=\"fn\">C</span>}</span></span>\n</span><span class=\"decl_args\"> :</