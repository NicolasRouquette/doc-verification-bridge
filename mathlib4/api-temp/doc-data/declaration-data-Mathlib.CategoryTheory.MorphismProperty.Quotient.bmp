y/MorphismProperty/Basic.html#CategoryTheory.MorphismProperty\">MorphismProperty</a> <span class=\"fn\">C</span></span>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">homRel</span> : <span class=\"fn\"><a href=\"./Mathlib/CategoryTheory/Quotient.html#HomRel\">HomRel</a> <span class=\"fn\">C</span></span>)</span></span>\n<span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">[<span class=\"fn\"><a href=\"./Mathlib/CategoryTheory/Quotient.html#CategoryTheory.HomRel.IsStableUnderPrecomp\">HomRel.IsStableUnderPrecomp</a> <span class=\"fn\">homRel</span></span>]</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">[<span class=\"fn\"><a href=\"./Mathlib/CategoryTheory/Quotient.html#CategoryTheory.HomRel.IsStableUnderPostcomp\">HomRel.IsStableUnderPostcomp</a> <span class=\"fn\">homRel</span></span>]</span></span>\n</span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./foundational_types.html\">Prop</a></div></div>","info":{"doc":"Let `W : MorphismProperty C` and `homRel : HomRel C`. We say that `W` induces\na class of morphisms on the quotient category by `homRel` if `homRel` is stable under\npre- and postcomposition and if `W f ↔ W g` whenever `homRel f g` hold. ","docLink":"./Mathlib/CategoryTheory/MorphismProperty/Quotient.html#CategoryTheory.MorphismProperty.HasQuotient","kind":"class","line":32,"name":"CategoryTheory.MorphismProperty.HasQuotient","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/0f1dd7505c3d08b5feb82300ccc73179a457bf51/Mathlib/CategoryTheory/MorphismProperty/Quotient.lean#L32-L38"}}],"imports":["Init","Mathlib.CategoryTheory.MorphismProperty.Basic","Mathlib.CategoryTheory.Quotient"],"instances":[],"name":"Mathlib.CategoryTheory.MorphismProperty.Quotient"}