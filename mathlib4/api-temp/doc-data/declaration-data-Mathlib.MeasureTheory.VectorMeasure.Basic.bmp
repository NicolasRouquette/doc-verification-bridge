asic.html#MeasureTheory.VectorMeasure\">VectorMeasure</a> <span class=\"fn\">α</span> <span class=\"fn\">M</span></span>}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">w</span> : <span class=\"fn\"><a href=\"./Mathlib/MeasureTheory/VectorMeasure/Basic.html#MeasureTheory.VectorMeasure\">VectorMeasure</a> <span class=\"fn\">α</span> <span class=\"fn\">N</span></span>}</span></span>\n</span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">s</span> : <span class=\"fn\"><a href=\"./Mathlib/Data/Set/Defs.html#Set\">Set</a> <span class=\"fn\">α</span></span>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">hs</span> : <span class=\"fn\"><a href=\"./Mathlib/MeasureTheory/MeasurableSpace/Defs.html#MeasurableSet\">MeasurableSet</a> <span class=\"fn\">s</span></span>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">h₁</span> : <span class=\"fn\">∀ <span class=\"fn\">t</span> ⊆ <span class=\"fn\">s</span>, <span class=\"fn\"><span class=\"fn\"><a href=\"./Mathlib/MeasureTheory/MeasurableSpace/Defs.html#MeasurableSet\">MeasurableSet</a> <span class=\"fn\">t</span></span> → <span class=\"fn\"><span class=\"fn\">↑<span class=\"fn\">v</span></span> <span class=\"fn\">t</span></span> <a href=\"./Init/Prelude.html#Eq\">=</a> <span class=\"fn\">0</span></span></span>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">h₂</span> : <span class=\"fn\">∀ <span class=\"fn\">t</span> ⊆ <span class=\"fn\">s</span><a href=\"./Mathlib/Order/Notation.html#Compl.compl\">ᶜ</a>, <span class=\"fn\"><span class=\"fn\"><a href=\"./Mathlib/MeasureTheory/MeasurableSpace/Defs.html#MeasurableSet\">MeasurableSet</a> <span class=\"fn\">t</span></span> → <span class=\"fn\"><span class=\"fn\">↑<span class=\"fn\">w</span></span> <span class=\"fn\">t</span></span> <a href=\"./Init/Prelude.html#Eq\">=</a> <span class=\"fn\">0</span></span></span>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><span class=\"fn\"><span class=\"fn\">v</span>.<a href=\"./Mathlib/MeasureTheory/VectorMeasure/Basic.html#MeasureTheory.VectorMeasure.MutuallySingular\">MutuallySingular</a></span> <span class=\"fn\">w</span></span></div></div>","info":{"doc":"","docLink":"./Mathlib/MeasureTheory/VectorMeasure/Basic.html#MeasureTheory.VectorMeasure.MutuallySingular.mk","kind":"theorem","line":1109,"name":"MeasureTheory.VectorMeasure.MutuallySingular.mk","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/087469e24922b85cb737497c74556c7dacc01f22/Mathlib/MeasureTheory/VectorMeasure/Basic.lean#L1109-L1115"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Mathlib/MeasureTheory/VectorMeasure/Basic.html#MeasureTheory.«term_⟂ᵥ_»\"><span class=\"name\">MeasureTheory</span>.<span class=\"name\">«term_⟂ᵥ_»</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Init/Prelude.html#Lean.TrailingParserDescr\">Lean.TrailingParserDescr</a></div></div>","info":{"doc":"Two vector measures `v` and `w` are said to be mutually singular if there exists a measurable\nset `s`, such that for all `t ⊆ s`, `v t = 0` and for all `t ⊆ sᶜ`, `w t = 0`.\n\nWe note that we do not require the measurability of `t` in the definition since this makes it easier\nto use. This is equivalent to the definition which requires measurability. To prove\n`MutuallySingular` with the measurability condition, use\n`MeasureTheory.VectorMeasure.MutuallySingular.mk`. ","docLink":"./Mathlib/MeasureTheory/VectorMeasure/Basic.html#MeasureTheory.«term_⟂ᵥ_»","kind":"def","line":1102,"name":"MeasureTheory.«term_⟂ᵥ_»","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/087469e24922b85cb737497c74556c7dacc01f22/Mathlib/MeasureTheory/VectorMeasure/Basic.lean#L1102-L1103"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Mathlib/MeasureTheory/VectorMeasure/Basic.html#MeasureTheory.VectorMeasure.MutuallySingular\"><span class=\"name\">MeasureTheory</span>.<span class=\"name\">VectorMeasure</span>.<span class=\"name\">MutuallySingular</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">α</span> : <a href=\"./foundational_types.html\">Type</a> u_1}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">m</span> : <span class=\"fn\"><a href=\"./Mathlib/MeasureTheory/MeasurableSpace/Defs.html#MeasurableSpace\">MeasurableSpace</a> <span class=\"fn\">α</span></span>}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">M</span> : <a href=\"./foundational_types.html\">Type</a> u_4}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">N</span> : <a href=\"./foundational_types.html\">Type</a> u_5}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">[<span class=\"fn\"><a href=\"./Mathlib/Algebra/Group/Defs.html#AddCommMonoid\">AddCommMonoid</a> <span class=\"fn\">M</span></span>]</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">[<span class=\"fn\"><a href=\"./Mathlib/Topology/Defs/Basic.html#TopologicalSpace\">TopologicalSpace</a> <span class=\"fn\">M</span></span>]</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">[<span class=\"fn\"><a href=\"./Mathlib/Algebra/Group/Defs.html#AddCommMonoid\">AddCommMonoid</a> <span class=\"fn\">N</span></span>]</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">[<span class=\"fn\"><a href=\"./Mathlib/Topology/Defs/Basic.html#TopologicalSpace\">TopologicalSpace</a> <span class=\"fn\">N</span></span>]</span></span>\n</span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">v</span> : <span class=\"fn\"><a href=\"./Mathlib/MeasureTheory/VectorMeasure/Basic.html#MeasureTheory.VectorMeasure\">VectorMeasure</a> <span class=\"fn\">α</span> <span class=\"fn\">M</span></span>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">w</span> : <span class=\"fn\"><a href=\"./Mathlib/MeasureTheory/VectorMeasure/Basic.html#MeasureTheory.VectorMeasure\">VectorMeasure</a> <span class=\"fn\">α</span> <span class=\"fn\">N</span></span>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./foundational_types.html\">Prop</a></div></div>","info":{"doc":"Two vector measures `v` and `w` are said to be mutually singular if there exists a measurable\nset `s`, such that for all `t ⊆ s`, `v t = 0` and for all `t ⊆ sᶜ`, `w t = 0`.\n\nWe note that we do not require the measurability of `t` in the definition since this makes it easier\nto use. This is equivalent to the definition which requires measurability. To prove\n`MutuallySingular` with the measurability condition, use\n`MeasureTheory.VectorMeasure.MutuallySingular.mk`. ","docLink":"./Mathlib/MeasureTheory/VectorMeasure/Basic.html#MeasureTheory.VectorMeasure.MutuallySingular","kind":"def","line":1092,"name":"MeasureTheory.VectorMeasure.MutuallySingular","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/087469e24922b85cb737497c74556c7dacc01f22/Mathlib/MeasureTheory/VectorMeasure/Basic.lean#L1092-L1100"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">theorem</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Mathlib/MeasureTheory/VectorMeasure/Basic.html#MeasureTheory.VectorMeasure.AbsolutelyContinuous.ennrealToMeasure\"><span class=\"name\">MeasureTheory</span>.<span class=\"name\">VectorMeasure</span>.<span class=\"name\">Absolutely