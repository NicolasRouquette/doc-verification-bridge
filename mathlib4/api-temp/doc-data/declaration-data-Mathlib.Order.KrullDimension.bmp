_args\">\n<span class=\"fn\">{<span class=\"fn\">α</span> : <a href=\"./foundational_types.html\">Type</a> u_1}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">[<span class=\"fn\"><a href=\"./Mathlib/Order/Defs/PartialOrder.html#Preorder\">Preorder</a> <span class=\"fn\">α</span></span>]</span></span>\n</span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">x</span> : <span class=\"fn\">α</span><a href=\"./Mathlib/Order/OrderDual.html#OrderDual\">ᵒᵈ</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Mathlib/Order/KrullDimension.html#Order.height\">height</a> <span class=\"fn\">(<a href=\"./Mathlib/Order/Synonym.html#OrderDual.ofDual\">OrderDual.ofDual</a> <span class=\"fn\">x</span>)</span></span> <a href=\"./Init/Prelude.html#Eq\">=</a> <span class=\"fn\"><a href=\"./Mathlib/Order/KrullDimension.html#Order.coheight\">coheight</a> <span class=\"fn\">x</span></span></div></div>","info":{"doc":"","docLink":"./Mathlib/Order/KrullDimension.html#Order.height_ofDual","kind":"theorem","line":115,"name":"Order.height_ofDual","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/0f1dd7505c3d08b5feb82300ccc73179a457bf51/Mathlib/Order/KrullDimension.lean#L115-L115"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">theorem</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Mathlib/Order/KrullDimension.html#Order.height_toDual\"><span class=\"name\">Order</span>.<span class=\"name\">height_toDual</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">α</span> : <a href=\"./foundational_types.html\">Type</a> u_1}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">[<span class=\"fn\"><a href=\"./Mathlib/Order/Defs/PartialOrder.html#Preorder\">Preorder</a> <span class=\"fn\">α</span></span>]</span></span>\n</span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">x</span> : <span class=\"fn\">α</span>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Mathlib/Order/KrullDimension.html#Order.height\">height</a> <span class=\"fn\">(<a href=\"./Mathlib/Order/Synonym.html#OrderDual.toDual\">OrderDual.toDual</a> <span class=\"fn\">x</span>)</span></span> <a href=\"./Init/Prelude.html#Eq\">=</a> <span class=\"fn\"><a href=\"./Mathlib/Order/KrullDimension.html#Order.coheight\">coheight</a> <span class=\"fn\">x</span></span></div></div>","info":{"doc":"","docLink":"./Mathlib/Order/KrullDimension.html#Order.height_toDual","kind":"theorem","line":114,"name":"Order.height_toDual","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/0f1dd7505c3d08b5feb82300ccc73179a457bf51/Mathlib/Order/KrullDimension.lean#L114-L114"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">noncomputable def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Mathlib/Order/KrullDimension.html#Order.coheight\"><span class=\"name\">Order</span>.<span class=\"name\">coheight</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">α</span> : <a href=\"./foundational_types.html\">Type</a> u_1}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">[<span class=\"fn\"><a href=\"./Mathlib/Order/Defs/PartialOrder.html#Preorder\">Preorder</a> <span class=\"fn\">α</span></span>]</span></span>\n</span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">a</span> : <span class=\"fn\">α</span>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Mathlib/Data/ENat/Defs.html#ENat\">ℕ∞</a></div></div>","info":{"doc":"The **coheight** of an element `a` in a preorder `α` is the supremum of the rightmost index of all\nrelation series of `α` ordered by `<` and beginning with `a`. In other words, it is\nthe largest `n` such that there's a series `a = a₀ < a₁ < ... < aₙ` (or `∞` if there is\nno largest `n`).\n\nThe definition of `coheight` is via the `height` in the dual order, in order to easily transfer\ntheorems between `height` and `coheight`. See `coheight_eq` for the definition with a\nseries ordered by `<` and beginning with `a`.\n","docLink":"./Mathlib/Order/KrullDimension.html#Order.coheight","kind":"def","line":90,"name":"Order.coheight","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/0f1dd7505c3d08b5feb82300ccc73179a457bf51/Mathlib/Order/KrullDimension.lean#L90-L100"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">noncomputable def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Mathlib/Order/KrullDimension.html#Order.height\"><span class=\"name\">Order</span>.<span class=\"name\">height</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">α</span> : <a href=\"./foundational_types.html\">Type</a> u_1}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">[<span class=\"fn\"><a href=\"./Mathlib/Order/Defs/PartialOrder.html#Preorder\">Preorder</a> <span class=\"fn\">α</span></span>]</span></span>\n</span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">a</span> : <span class=\"fn\">α</span>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Mathlib/Data/ENat/Defs.html#ENat\">ℕ∞</a></div></div>","info":{"doc":"The **height** of an element `a` in a preorder `α` is the supremum of the rightmost index of all\nrelation series of `α` ordered by `<` and ending below or at `a`. In other words, it is\nthe largest `n` such that there's a series `a₀ < a₁ < ... < aₙ = a` (or `∞` if there is\nno largest `n`).\n","docLink":"./Mathlib/Order/KrullDimension.html#Order.height","kind":"def","line":81,"name":"Order.height","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/0f1dd7505c3d08b5feb82300ccc73179a457bf51/Mathlib/Order/KrullDimension.lean#L81-L88"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">noncomputable def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Mathlib/Order/KrullDimension.html#Order.krullDim\"><span class=\"name\">Order</span>.<span class=\"name\">krullDim</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">α</span> : <a href=\"./foundational_types.html\">Type</a> u_1)</span></span>\n<span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">[<span class=\"fn\"><a href=\"./Mathlib/Order/Defs/PartialOrder.html#Preorder\">Preorder</a> <span class=\"fn\">α</span></span>]</span></span>\n</span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Mathlib/Order/TypeTags.html#WithBot\">WithBot</a> <a href=\"./Mathlib/Data/ENat/Defs.html#ENat\">ℕ∞</a></span></div></div>","info":{"doc":"The **Krull dimension** of a preorder `α` is the supremum of the rightmost index of all relation\nseries of `α` ordered by `<`. If there is no series `a₀ < a₁ < ... < aₙ` in `α`, then its Krull\ndimension is defined to be negative infinity; if the length of all series `a₀ < a₁ < ... < aₙ` is\nunbounded, its Krull dimension is defined to be positive infinity.\n","docLink":"./Mathlib/Order/KrullDimension.html#Order.krullDim","kind":"def","line":72,"name":"Order.krullDim","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/0f1dd7505c3d08b5feb82300ccc73179a457bf51/Mathlib/Order/KrullDimension.lean#L72-L79"}}],"imports":["Init","Mathlib.Algebra.Order.Group.Int","Mathlib.Algebra.Order.SuccPred.WithBot","Mathlib.Data.ENat.Lattice","Mathlib.Order.Atoms","Mathlib.Order.RelSeries","Mathlib.Tactic.FinCases"],"instances":[{"className":"Order.KrullDimLE","name":"Order.instKrullDimLEOfNatNatOfSubsingleton","typeNames":["OfNat.ofNat"]}],"name":"Mathlib.Order.KrullDimension"}