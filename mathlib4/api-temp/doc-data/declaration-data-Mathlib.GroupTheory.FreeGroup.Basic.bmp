p\">FreeAddGroup</a> <span class=\"fn\">α</span></span></div></div>","info":{"doc":"The canonical map from `List (α × Bool)` to the free additive group on `α`. ","docLink":"./Mathlib/GroupTheory/FreeGroup/Basic.html#FreeAddGroup.mk","kind":"def","line":480,"name":"FreeAddGroup.mk","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/0f1dd7505c3d08b5feb82300ccc73179a457bf51/Mathlib/GroupTheory/FreeGroup/Basic.lean#L480-L480"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Mathlib/GroupTheory/FreeGroup/Basic.html#FreeGroup.mk\"><span class=\"name\">FreeGroup</span>.<span class=\"name\">mk</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">α</span> : <a href=\"./foundational_types.html\">Type</a> u}</span></span>\n</span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">L</span> : <span class=\"fn\"><a href=\"./Init/Prelude.html#List\">List</a> (<span class=\"fn\">α</span> <a href=\"./Init/Prelude.html#Prod\">×</a> <a href=\"./Init/Prelude.html#Bool\">Bool</a>)</span>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Mathlib/GroupTheory/FreeGroup/Basic.html#FreeGroup\">FreeGroup</a> <span class=\"fn\">α</span></span></div></div>","info":{"doc":"The canonical map from `List (α × Bool)` to the free group on `α`. ","docLink":"./Mathlib/GroupTheory/FreeGroup/Basic.html#FreeGroup.mk","kind":"def","line":479,"name":"FreeGroup.mk","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/0f1dd7505c3d08b5feb82300ccc73179a457bf51/Mathlib/GroupTheory/FreeGroup/Basic.lean#L479-L482"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Mathlib/GroupTheory/FreeGroup/Basic.html#FreeAddGroup\"><span class=\"name\">FreeAddGroup</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">α</span> : <a href=\"./foundational_types.html\">Type</a> u)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./foundational_types.html\">Type</a> u</div></div>","info":{"doc":"If `α` is a type, then `FreeAddGroup α` is the free additive group generated by `α`.\nThis is a group equipped with a function `FreeAddGroup.of : α → FreeAddGroup α` which has\nthe following universal property: if `G` is any group, and `f : α → G` is any function,\nthen this function is the composite of `FreeAddGroup.of` and a unique group homomorphism\n`FreeAddGroup.lift f : FreeAddGroup α →+ G`.\n\nA typical element of `FreeAddGroup α` is a formal sum of\nelements of `α` and their formal inverses, quotient by reduction.\nFor example if `x` and `y` are terms of type `α` then `-x + y + y + x + -y` is a\n\"typical\" element of `FreeAddGroup α`. In particular if `α` is empty\nthen `FreeAddGroup α` is isomorphic to the trivial group, and if `α` has one term\nthen `FreeAddGroup α` is isomorphic to `ℤ`.\nIf `α` has two or more terms then `FreeAddGroup α` is not commutative. ","docLink":"./Mathlib/GroupTheory/FreeGroup/Basic.html#FreeAddGroup","kind":"def","line":458,"name":"FreeAddGroup","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/0f1dd7505c3d08b5feb82300ccc73179a457bf51/Mathlib/GroupTheory/FreeGroup/Basic.lean#L458-L471"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Mathlib/GroupTheory/FreeGroup/Basic.html#FreeGroup\"><span class=\"name\">FreeGroup</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">α</span> : <a href=\"./foundational_types.html\">Type</a> u)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./foundational_types.html\">Type</a> u</div></div>","info":{"doc":"If `α` is a type, then `FreeGroup α` is the free group generated by `α`.\nThis is a group equipped with a function `FreeGroup.of : α → FreeGroup α` which has\nthe following universal property: if `G` is any group, and `f : α → G` is any function,\nthen this function is the composite of `FreeGroup.of` and a unique group homomorphism\n`FreeGroup.lift f : FreeGroup α →* G`.\n\nA typical element of `FreeGroup α` is a formal product of\nelements of `α` and their formal inverses, quotient by reduction.\nFor example if `x` and `y` are terms of type `α` then `x⁻¹ * y * y * x * y⁻¹` is a\n\"typical\" element of `FreeGroup α`. In particular if `α` is empty\nthen `FreeGroup α` is isomorphic to the trivial group, and if `α` has one term\nthen `FreeGroup α` is isomorphic to `Multiplicative ℤ`.\nIf `α` has two or more terms then `FreeGroup α` is not commutative.\n","docLink":"./Mathlib/GroupTheory/FreeGroup/Basic.html#FreeGroup","kind":"def","line":443,"name":"FreeGroup","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/0f1dd7505c3d08b5feb82300ccc73179a457bf51/Mathlib/GroupTheory/FreeGroup/Basic.lean#L443-L473"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">theorem</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Mathlib/GroupTheory/FreeGroup/Basic.html#FreeAddGroup.IsReduced.infix\"><span class=\"name\">FreeAddGroup</span>.<span class=\"name\">IsReduced</span>.<span class=\"name\">infix</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">α</span> : <a href=\"./foundational_types.html\">Type</a> u}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">L₁ </span><span class=\"fn\">L₂</span> : <span class=\"fn\"><a href=\"./Init/Prelude.html#List\">List</a> (<span class=\"fn\">α</span> <a href=\"./Init/Prelude.html#Prod\">×</a> <a href=\"./Init/Prelude.html#Bool\">Bool</a>)</span>}</span></span>\n</span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">h</span> : <span class=\"fn\"><a href=\"./Mathlib/GroupTheory/FreeGroup/Basic.html#FreeAddGroup.IsReduced\">IsReduced</a> <span class=\"fn\">L₂</span></span>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">h'</span> : <span class=\"fn\">L₁</span> <a href=\"./Init/Data/List/Basic.html#List.IsInfix\">&lt;:+:</a> <span class=\"fn\">L₂</span>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Mathlib/GroupTheory/FreeGroup/Basic.html#FreeAddGroup.IsReduced\">IsReduced</a> <span class=\"fn\">L₁</span></span></div></div>","info":{"doc":"","docLink":"./Mathlib/GroupTheory/FreeGroup/Basic.html#FreeAddGroup.IsReduced.infix","kind":"theorem","line":437,"name":"FreeAddGroup.IsReduced.infix","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/0f1dd7505c3d08b5feb82300ccc73179a457bf51/Mathlib/GroupTheory/FreeGroup/Basic.lean#L437-L437"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">theorem</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Mathlib/GroupTheory/FreeGroup/Basic.html#FreeGroup.IsReduced.infix\"><span class=\"name\">FreeGroup</span>.<span class=\"name\">IsReduced</span>.<span class=\"name\">infix</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">α</span> : <a href=\"./foundational_types.html\">Type</a> u}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">L₁ </span><span class=\"fn\">L₂</span> : <span class=\"fn\"><a href=\"./Init/Prelude.html#List\">List</a> (<span class=\"fn\">α</span> <a href=\"./Init/Prelude.html#Prod\">×</a> <a href=\"./Init/Prelude.html#Bool\">Bool</a>)</span>}</span></span>\n</span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">h</span> : <span class=\"fn\"><a href=\"./Mathlib/GroupTheory/FreeGroup/Basic.html#FreeGroup.IsReduced\">IsReduced</a> <span class=\"fn\">L₂</span></span>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">h'</span> : <span class=\"fn\">L₁</span> <a href=\"./Init/Data/List/Basic.html#List.IsInfix\">&lt;:+:</a> <span class=\"fn\">L₂</span>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Mathlib/GroupTheory/FreeGroup/Basic.html#FreeGroup.IsReduced\">IsReduced</a> <span class=\"fn\">L₁</span></span></div></div>","info":{"doc":"","docLink":"./Mathlib/GroupTheory/FreeGroup/Basic.html#FreeGroup.IsReduced.infix","kind":"theorem","line":437,"name":"FreeGroup.IsReduced.infix","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/0f1dd7505c3d08b5feb82300ccc73179a457bf51/Mathlib/GroupTheory/FreeGroup/Basic.lean#L437-L438"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">theorem</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Mathlib/GroupTheory/FreeGroup/Basic.html#FreeAddGroup.IsReduced.append_overlap\"><span class=\"name\">FreeAddGroup</span>.<span class=\"name\">IsReduced</span>.<span class=\"name\">append_overlap</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">α</span> : <a href=\"./foundational_types.html\">Type</a> u}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">L₁ </span><span class=\"fn\">L₂ </span><span class=\"fn\">L₃</span> : <span class=\"fn\"><a href=\"./Init/Prelude.html#List\">List</a> (<span class=\"fn\">α</span> <a href=\"./Init/Prelude.html#Prod\">×</a> <a href=\"./Init/Prelude.html#Bool\">Bool</a>)</span>}</span></span>\n</span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">h₁</span> : <span class=\"fn\"><a href=\"./Mathlib/GroupTheory/FreeGroup/Basic.html#FreeAddGroup.IsReduced\">IsReduced</a> (<span class=\"fn\">L₁</span> <a href=\"./Init/Prelude.html#HAppend.hAppend\">++</a> <span class=\"fn\">L₂<