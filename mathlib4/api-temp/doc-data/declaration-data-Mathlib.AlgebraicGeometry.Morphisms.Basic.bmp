cheme.html#AlgebraicGeometry.Scheme.Opens\">Opens</a></span>), <span class=\"fn\"><span class=\"fn\"><span class=\"fn\">P</span> <span class=\"fn\">f</span></span> → <span class=\"fn\"><span class=\"fn\">P</span> (<span class=\"fn\">f</span> <a href=\"./Mathlib/AlgebraicGeometry/Restrict.html#AlgebraicGeometry.morphismRestrict\">∣_</a> <span class=\"fn\">U</span>)</span></span></span>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">of_sSup_eq_top</span> :\n  <span class=\"fn\">∀ {<span class=\"fn\">X </span><span class=\"fn\">Y</span> : <a href=\"./Mathlib/AlgebraicGeometry/Scheme.html#AlgebraicGeometry.Scheme\">Scheme</a>} (<span class=\"fn\">f</span> : <span class=\"fn\">X</span> <a href=\"./Mathlib/Combinatorics/Quiver/Basic.html#Quiver.Hom\">⟶</a> <span class=\"fn\">Y</span>) {<span class=\"fn\">ι</span> : <a href=\"./foundational_types.html\">Type</a> u} (<span class=\"fn\">U</span> : <span class=\"fn\"><span class=\"fn\">ι</span> → <span class=\"fn\"><span class=\"fn\">Y</span>.<a href=\"./Mathlib/AlgebraicGeometry/Scheme.html#AlgebraicGeometry.Scheme.Opens\">Opens</a></span></span>), <span class=\"fn\"><span class=\"fn\"><a href=\"./Mathlib/Order/SetNotation.html#iSup\">iSup</a> <span class=\"fn\">U</span></span> <a href=\"./Init/Prelude.html#Eq\">=</a> <a href=\"./Mathlib/Order/Notation.html#Top.top\">⊤</a> → <span class=\"fn\"><span class=\"fn\">(∀ (<span class=\"fn\">i</span> : <span class=\"fn\">ι</span>), <span class=\"fn\"><span class=\"fn\">P</span> (<span class=\"fn\">f</span> <a href=\"./Mathlib/AlgebraicGeometry/Restrict.html#AlgebraicGeometry.morphismRestrict\">∣_</a> <span class=\"fn\"><span class=\"fn\">U</span> <span class=\"fn\">i</span></span>)</span>)</span> → <span class=\"fn\"><span class=\"fn\">P</span> <span class=\"fn\">f</span></span></span></span></span>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Mathlib/AlgebraicGeometry/Morphisms/Basic.html#AlgebraicGeometry.IsZariskiLocalAtTarget\">IsZariskiLocalAtTarget</a> <span class=\"fn\">P</span></span></div></div>","info":{"doc":"`P` is local at the target if\n1. `P` respects isomorphisms.\n2. If `P` holds for `f : X ⟶ Y`, then `P` holds for `f ∣_ U` for any `U`.\n3. If `P` holds for `f ∣_ U` for an open cover `U` of `Y`, then `P` holds for `f`.\n","docLink":"./Mathlib/AlgebraicGeometry/Morphisms/Basic.html#AlgebraicGeometry.IsZariskiLocalAtTarget.mk'","kind":"theorem","line":117,"name":"AlgebraicGeometry.IsZariskiLocalAtTarget.mk'","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/087469e24922b85cb737497c74556c7dacc01f22/Mathlib/AlgebraicGeometry/Morphisms/Basic.lean#L117-L132"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">abbrev</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Mathlib/AlgebraicGeometry/Morphisms/Basic.html#AlgebraicGeometry.IsZariskiLocalAtTarget\"><span class=\"name\">AlgebraicGeometry</span>.<span class=\"name\">IsZariskiLocalAtTarget</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">P</span> : <span class=\"fn\"><a href=\"./Mathlib/CategoryTheory/MorphismProperty/Basic.html#CategoryTheory.MorphismProperty\">CategoryTheory.MorphismProperty</a> <a href=\"./Mathlib/AlgebraicGeometry/Scheme.html#AlgebraicGeometry.Scheme\">Scheme</a></span>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./foundational_types.html\">Prop</a></div></div>","info":{"doc":"A property is Zariski-local at target if it is local at target in the Zariski topology. ","docLink":"./Mathlib/AlgebraicGeometry/Morphisms/Basic.html#AlgebraicGeometry.IsZariskiLocalAtTarget","kind":"def","line":111,"name":"AlgebraicGeometry.IsZariskiLocalAtTarget","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/087469e24922b85cb737497c74556c7dacc01f22/Mathlib/AlgebraicGeometry/Morphisms/Basic.lean#L111-L113"}}],"imports":["Init","Mathlib.Algebr