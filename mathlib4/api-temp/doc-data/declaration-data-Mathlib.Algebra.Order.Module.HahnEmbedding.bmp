n\"><a href=\"./Mathlib/Algebra/Order/Archimedean/Basic.html#Archimedean\">Archimedean</a> <span class=\"fn\">R</span></span>]</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">[<span class=\"fn\">h</span> : <span class=\"fn\"><a href=\"./Init/Prelude.html#Nonempty\">Nonempty</a> <span class=\"fn\">(<a href=\"./Mathlib/Algebra/Order/Module/HahnEmbedding.html#HahnEmbedding.Seed\">HahnEmbedding.Seed</a> <span class=\"fn\">K</span> <span class=\"fn\">M</span> <span class=\"fn\">R</span>)</span></span>]</span></span>\n</span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\">∃ (<span class=\"fn\">f</span> : <span class=\"fn\">M</span> <a href=\"./Mathlib/Algebra/Module/LinearMap/Defs.html#LinearMap\">→ₗ[</a><span class=\"fn\">K</span><a href=\"./Mathlib/Algebra/Module/LinearMap/Defs.html#LinearMap\">]</a> <span class=\"fn\"><a href=\"./Mathlib/Order/Synonym.html#Lex\">Lex</a> <span class=\"fn\">(<a href=\"./Mathlib/RingTheory/HahnSeries/Basic.html#HahnSeries\">HahnSeries</a> <span class=\"fn\">(<a href=\"./Mathlib/Algebra/Order/Archimedean/Class.html#FiniteArchimedeanClass\">FiniteArchimedeanClass</a> <span class=\"fn\">M</span>)</span> <span class=\"fn\">R</span>)</span></span>),\n  <span class=\"fn\"><a href=\"./Mathlib/Order/Monotone/Defs.html#StrictMono\">StrictMono</a> <span class=\"fn\">⇑<span class=\"fn\">f</span></span></span> <a href=\"./Init/Prelude.html#And\">∧</a> <span class=\"fn\">∀ (<span class=\"fn\">a</span> : <span class=\"fn\">M</span>), <span class=\"fn\"><a href=\"./Mathlib/Algebra/Order/Archimedean/Class.html#ArchimedeanClass.mk\">ArchimedeanClass.mk</a> <span class=\"fn\">a</span></span> <a href=\"./Init/Prelude.html#Eq\">=</a> <span class=\"fn\"><span class=\"fn\">(<a href=\"./Mathlib/Algebra/Order/Archimedean/Class.html#FiniteArchimedeanClass.withTopOrderIso\">FiniteArchimedeanClass.withTopOrderIso</a> <span class=\"fn\">M</span>)</span> <span class=\"fn\"><span class=\"fn\"