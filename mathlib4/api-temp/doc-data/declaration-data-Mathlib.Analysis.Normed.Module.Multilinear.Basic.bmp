Map\">ContinuousMultilinearMap</a> <span class=\"fn\">𝕜</span> <span class=\"fn\">E</span> <span class=\"fn\">G</span></span>}</span></span>\n</span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Mathlib/Analysis/Normed/Group/Defs.html#Norm.norm\">‖</a><span class=\"fn\">f</span><a href=\"./Mathlib/Analysis/Normed/Group/Defs.html#Norm.norm\">‖</a> <a href=\"./Init/Prelude.html#Eq\">=</a> <span class=\"fn\">0</span> <a href=\"./Init/Core.html#Iff\">↔</a> <span class=\"fn\">f</span> <a href=\"./Init/Prelude.html#Eq\">=</a> <span class=\"fn\">0</span></div></div>","info":{"doc":"A continuous linear map is zero iff its norm vanishes. ","docLink":"./Mathlib/Analysis/Normed/Module/Multilinear/Basic.html#ContinuousMultilinearMap.opNorm_zero_iff","kind":"theorem","line":1350,"name":"ContinuousMultilinearMap.opNorm_zero_iff","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/0f1dd7505c3d08b5feb82300ccc73179a457bf51/Mathlib/Analysis/Normed/Module/Multilinear/Basic.lean#L1350-L1352"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">theorem</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Mathlib/Analysis/Normed/Module/Multilinear/Basic.html#ContinuousMultilinearMap.norm_iteratedFDeriv_le'\"><span class=\"name\">ContinuousMultilinearMap</span>.<span class=\"name\">norm_iteratedFDeriv_le'</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">𝕜</span> : <a href=\"./foundational_types.html\">Type</a> u}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">ι</span> : <a href=\"./foundational_types.html\">Type</a> v}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">E₁</span> : <span class=\"fn\"><span class=\"fn\">ι</span> → <a href=\"./foundational_types.html\">Type</a> wE₁</span>}</span></span>\n</span><span class=\"impl_arg\"