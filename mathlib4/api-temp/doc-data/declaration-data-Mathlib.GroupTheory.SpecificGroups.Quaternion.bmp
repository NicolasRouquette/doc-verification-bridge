ude.html#Nat\">ℕ</a>}</span></span>\n</span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><span class=\"fn\"><a href=\"./Mathlib/Data/ZMod/Defs.html#ZMod\">ZMod</a> (<span class=\"fn\">2</span> <a href=\"./Init/Prelude.html#HMul.hMul\">*</a> <span class=\"fn\">n</span>)</span> → <span class=\"fn\"><a href=\"./Mathlib/GroupTheory/SpecificGroups/Quaternion.html#QuaternionGroup\">QuaternionGroup</a> <span class=\"fn\">n</span></span></span></div></div>","info":{"doc":"","docLink":"./Mathlib/GroupTheory/SpecificGroups/Quaternion.html#QuaternionGroup.xa","kind":"ctor","line":54,"name":"QuaternionGroup.xa","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/087469e24922b85cb737497c74556c7dacc01f22/Mathlib/GroupTheory/SpecificGroups/Quaternion.lean#L54-L54"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">constructor</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Mathlib/GroupTheory/SpecificGroups/Quaternion.html#QuaternionGroup.a\"><span class=\"name\">QuaternionGroup</span>.<span class=\"name\">a</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">n</span> : <a href=\"./Init/Prelude.html#Nat\">ℕ</a>}</span></span>\n</span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><span class=\"fn\"><a href=\"./Mathlib/Data/ZMod/Defs.html#ZMod\">ZMod</a> (<span class=\"fn\">2</span> <a href=\"./Init/Prelude.html#HMul.hMul\">*</a> <span class=\"fn\">n</span>)</span> → <span class=\"fn\"><a href=\"./Mathlib/GroupTheory/SpecificGroups/Quaternion.html#QuaternionGroup\">QuaternionGroup</a> <span class=\"fn\">n</span></span></span></div></div>","info":{"doc":"","docLink":"./Mathlib/GroupTheory/SpecificGroups/Quaternion.html#QuaternionGroup.a","kind":"ctor","line":53,"name":"QuaternionGroup.a","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/087469e24922b85cb737497c74556c7dacc01f22/Mathlib/GroupThe