ategoryTheory.Functor.obj\">obj</a></span>\n      <a href=\"./Mathlib/CategoryTheory/Types/Basic.html#CategoryTheory.uliftFunctor\">uliftFunctor.{u₁, max v₁ w}</a>)</span></span></div></div>","info":{"doc":"A variant of the curried version of the Yoneda lemma with a raise in the universe level. ","docLink":"./Mathlib/CategoryTheory/Yoneda.html#CategoryTheory.uliftYonedaOpCompCoyoneda","kind":"def","line":897,"name":"CategoryTheory.uliftYonedaOpCompCoyoneda","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/0f1dd7505c3d08b5feb82300ccc73179a457bf51/Mathlib/CategoryTheory/Yoneda.lean#L897-L913"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">theorem</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Mathlib/CategoryTheory/Yoneda.html#CategoryTheory.hom_ext_uliftYoneda\"><span class=\"name\">CategoryTheory</span>.<span class=\"name\">hom_ext_uliftYoneda</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">C</span> : <a href=\"./foundational_types.html\">Type</a> u₁}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">[<span class=\"fn\"><a href=\"./Mathlib/CategoryTheory/Category/Basic.html#CategoryTheory.Category\">Category.{v₁, u₁}</a> <span class=\"fn\">C</span></span>]</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">P </span><span class=\"fn\">Q</span> : <span class=\"fn\"><a href=\"./Mathlib/CategoryTheory/Functor/Basic.html#CategoryTheory.Functor\">Functor</a> <span class=\"fn\">C</span><a href=\"./Mathlib/Data/Opposite.html#Opposite\">ᵒᵖ</a> <a href=\"./foundational_types.html\">(Type</a> (max w v₁))</span>}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">f </span><span class=\"fn\">g</span> : <span class=\"fn\">P</span> <a href=\"./Mathlib/Combinatorics/Quiver/Basic.html#Quiver.Hom\"