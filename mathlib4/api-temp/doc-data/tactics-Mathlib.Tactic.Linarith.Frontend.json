[{"userName": "nlinarith",
  "tags": [],
  "internalName": "Mathlib.Tactic.nlinarith",
  "docString":
  {"element":
   ["p",
    true,
    [],
    [{"element":
      ["p",
       true,
       [],
       [{"text": "An extension of "},
        {"element": ["code", true, [], [{"text": "linarith"}]]},
        {"text":
         " with some preprocessing to allow it to solve some nonlinear arithmetic"},
        {"raw": "\n"},
        {"text": "problems. (Based on Coq's "},
        {"element": ["code", true, [], [{"text": "nra"}]]},
        {"text": " tactic.) See "},
        {"element": ["code", true, [], [{"text": "linarith"}]]},
        {"text": " for the available syntax of options,"},
        {"raw": "\n"},
        {"text": "which are inherited by "},
        {"element": ["code", true, [], [{"text": "nlinarith"}]]},
        {"text": "; that is, "},
        {"element": ["code", true, [], [{"text": "nlinarith!"}]]},
        {"text": " and "},
        {"element":
         ["code",
          true,
          [],
          [{"text": "nlinarith"},
           {"text": " "},
           {"text": "only"},
           {"text": " "},
           {"text": "[h1,"},
           {"text": " "},
           {"text": "h2]"}]]},
        {"text": " all work as"},
        {"raw": "\n"},
        {"text": "in "},
        {"element": ["code", true, [], [{"text": "linarith"}]]},
        {"text": ". The preprocessing is as follows:"}]]},
     {"element":
      ["ul",
       true,
       [],
       [{"element":
         ["li",
          true,
          [],
          [{"text": "For every subterm "},
           {"element":
            ["code",
             true,
             [],
             [{"text": "a"},
              {"text": " "},
              {"text": "^"},
              {"text": " "},
              {"text": "2"}]]},
           {"text": " or "},
           {"element":
            ["code",
             true,
             [],
             [{"text": "a"},
              {"text": " "},
              {"text": "*"},
              {"text": " "},
              {"text": "a"}]]},
           {"text": " in a hypothesis or the goal,"},
           {"raw": "\n"},
           {"text": "the assumption "},
           {"element":
            ["code",
             true,
             [],
             [{"text": "0"},
              {"text": " "},
              {"text": "≤"},
              {"text": " "},
              {"text": "a"},
              {"text": " "},
              {"text": "^"},
              {"text": " "},
              {"text": "2"}]]},
           {"text": " or "},
           {"element":
            ["code",
             true,
             [],
             [{"text": "0"},
              {"text": " "},
              {"text": "≤"},
              {"text": " "},
              {"text": "a"},
              {"text": " "},
              {"text": "*"},
              {"text": " "},
              {"text": "a"}]]},
           {"text": " is added to the context."}]]},
        {"element":
         ["li",
          true,
          [],
          [{"text": "For every pair of hypotheses "},
           {"element":
            ["code",
             true,
             [],
             [{"text": "a1"},
              {"text": " "},
              {"text": "R1"},
              {"text": " "},
              {"text": "b1"}]]},
           {"text": ", "},
           {"element":
            ["code",
             true,
             [],
             [{"text": "a2"},
              {"text": " "},
              {"text": "R2"},
              {"text": " "},
              {"text": "b2"}]]},
           {"text": " in the context, "},
           {"element":
            ["code",
             true,
             [],
             [{"text": "R1,"},
              {"text": " "},
              {"text": "R2"},
              {"text": " "},
              {"text": "∈"},
              {"text": " "},
              {"text": "{<,"},
              {"text": " "},
              {"text": "≤,"},
              {"text": " "},
              {"text": "=}"}]]},
           {"text": ","},
           {"raw": "\n"},
           {"text": "the assumption "},
           {"element":
            ["code",
             true,
             [],
             [{"text": "0"},
              {"text": " "},
              {"text": "R'"},
              {"text": " "},
              {"text": "(b1"},
              {"text": " "},
              {"text": "-"},
              {"text": " "},
              {"text": "a1)"},
              {"text": " "},
              {"text": "*"},
              {"text": " "},
              {"text": "(b2"},
              {"text": " "},
              {"text": "-"},
              {"text": " "},
              {"text": "a2)"}]]},
           {"text": " is added to the context (non-recursively),"},
           {"raw": "\n"},
           {"text": "where "},
           {"element":
            ["code",
             true,
             [],
             [{"text": "R"},
              {"text": " "},
              {"text": "∈"},
              {"text": " "},
              {"text": "{<,"},
              {"text": " "},
              {"text": "≤,"},
              {"text": " "},
              {"text": "=}"}]]},
           {"text": " is the appropriate comparison derived from "},
           {"element":
            ["code",
             true,
             [],
             [{"text": "R1,"}, {"text": " "}, {"text": "R2"}]]},
           {"text": "."}]]}]]}]]},
  "definingModule": "Mathlib.Tactic.Linarith.Frontend"},
 {"userName": "linarith?",
  "tags": [],
  "internalName": "Mathlib.Tactic.linarith?",
  "docString":
  {"element":
   ["p",
    true,
    [],
    [{"element":
      ["p",
       true,
       [],
       [{"element": ["code", true, [], [{"text": "linarith?"}]]},
        {"text": " behaves like "},
        {"element": ["code", true, [], [{"text": "linarith"}]]},
        {"text": " but, on success, it prints a suggestion of"},
        {"raw": "\n"},
        {"text": "the form "},
        {"element":
         ["code",
          true,
          [],
          [{"text": "linarith"},
           {"text": " "},
           {"text": "only"},
           {"text": " "},
           {"text": "[...]"}]]},
        {"text": " listing a minimized set of hypotheses used in the"},
        {"raw": "\n"},
        {"text": "final proof.  Use "},
        {"element": ["code", true, [], [{"text": "linarith?!"}]]},
        {"text": " for the higher-reducibility variant and set the"},
        {"raw": "\n"},
        {"element": ["code", true, [], [{"text": "minimize"}]]},
        {"text":
         " flag in the configuration to control whether greedy minimization is"},
        {"raw": "\n"},
        {"text": "performed."}]]}]]},
  "definingModule": "Mathlib.Tactic.Linarith.Frontend"},
 {"userName": "linarith",
  "tags": [],
  "internalName": "Mathlib.Tactic.linarith",
  "docString":
  {"element":
   ["p",
    true,
    [],
    [{"element":
      ["p",
       true,
       [],
       [{"element": ["code", true, [], [{"text": "linarith"}]]},
        {"text":
         " attempts to find a contradiction between hypotheses that are linear (in)equalities."},
        {"raw": "\n"},
        {"text":
         "Equivalently, it can prove a linear inequality by assuming its negation and proving "},
        {"element":
         ["code",
          true,
          [],
          [{"element":
            ["a",
             true,
             [["href", "./Init/Prelude.html#False"]],
             [{"text": "False"}]]}]]},
        {"text": "."}]]},
     {"element":
      ["p",
       true,
       [],
       [{"text": "In theory, "},
        {"element": ["code", true, [], [{"text": "linarith"}]]},
        {"text":
         " should prove any goal that is true in the theory of linear arithmetic over"},
        {"raw": "\n"},
        {"text":
         "the rationals. While there is some special handling for non-dense orders like "},
        {"element":
         ["code",
          true,
          [],
          [{"element":
            ["a",
             true,
             [["href", "./Init/Prelude.html#Nat"]],
             [{"text": "Nat"}]]}]]},
        {"text": " and "},
        {"element":
         ["code",
          true,
          [],
          [{"element":
            ["a",
             true,
             [["href", "./Init/Data/Int/Basic.html#Int"]],
             [{"text": "Int"}]]}]]},
        {"text": ","},
        {"raw": "\n"},
        {"text":
         "this tactic is not complete for these theories and will not prove every true goal. It will solve"},
        {"raw": "\n"},
        {"text": "goals over arbitrary types that instantiate "},
        {"element":
         ["code",
          true,
          [],
          [{"element":
            ["a",
             true,
             [["href", "./Mathlib/Algebra/Ring/Defs.html#CommRing"]],
             [{"text": "CommRing"}]]}]]},
        {"text": ", "},
        {"element":
         ["code",
          true,
          [],
          [{"element":
            ["a",
             true,
             [["href", "./Mathlib/Order/Defs/LinearOrder.html#LinearOrder"]],
             [{"text": "LinearOrder"}]]}]]},
        {"text": " and "},
        {"element":
         ["code",
          true,
          [],
          [{"element":
            ["a",
             true,
             [["href",
               "./Mathlib/Algebra/Order/Ring/Defs.html#IsStrictOrderedRing"]],
             [{"text": "IsStrictOrderedRing"}]]}]]},
        {"text": "."}]]},
     {"element": ["p", true, [], [{"text": "An example:"}]]},
     {"element":
      ["pre",
       true,
       [],
       [{"element":
         ["code",
          true,
          [["class", "language-lean"]],
          [{"text": "example"},
           {"text": " "},
           {"text": "(x"},
           {"text": " "},
           {"text": "y"},
           {"text": " "},
           {"text": "z"},
           {"text": " "},
           {"text": ":"},
           {"text": " "},
           {"text": "ℚ)"},
           {"text": " "},
           {"text": "(h1"},
           {"text": " "},
           {"text": ":"},
           {"text": " "},
           {"text": "2*x"},
           {"text": " "},
           {"text": "<"},
           {"text": " "},
           {"text": "3*y)"},
           {"text": " "},
           {"text": "(h2"},
           {"text": " "},
           {"text": ":"},
           {"text": " "},
           {"text": "-4*x"},
           {"text": " "},
           {"text": "+"},
           {"text": " "},
           {"text": "2*z"},
           {"text": " "},
           {"text": "<"},
           {"text": " "},
           {"text": "0)"},
           {"text": ""},
           {"text": "\n"},
           {"text": ""},
           {"text": ""},
           {"text": " "},
           {"text": ""},
           {"text": " "},
           {"text": ""},
           {"text": " "},
           {"text": ""},
           {"text": " "},
           {"text": ""},
           {"text": " "},
           {"text": ""},
           {"text": " "},
           {"text": ""},
           {"text": " "},
           {"text": ""},
           {"text": " "},
           {"text": ""},
           {"text": "(h3"},
           {"text": " "},
           {"text": ":"},
           {"text": " "},
           {"text": "12*y"},
           {"text": " "},
           {"text": "-"},
           {"text": " "},
           {"text": "4*"},
           {"text": " "},
           {"text": "z"},
           {"text": " "},
           {"text": "<"},
           {"text": " "},
           {"text": "0)"},
           {"text": " "},
           {"text": ":"},
           {"text": " "},
           {"element":
            ["a",
             true,
             [["href", "./Init/Prelude.html#False"]],
             [{"text": "False"}]]},
           {"text": " "},
           {"text": ":="},
           {"text": " "},
           {"text": "by"},
           {"text": ""},
           {"text": "\n"},
           {"text": ""},
           {"text": ""},
           {"text": " "},
           {"text": ""},
           {"text": " "},
           {"text": ""},
           {"text": "linarith"},
           {"text": ""},
           {"text": "\n"},
           {"text": ""}]]}]]},
     {"element":
      ["p",
       true,
       [],
       [{"element": ["code", true, [], [{"text": "linarith"}]]},
        {"text":
         " will use all appropriate hypotheses and the negation of the goal, if applicable."},
        {"raw": "\n"},
        {"text":
         "Disequality hypotheses require case splitting and are not normally considered"},
        {"raw": "\n"},
        {"text": "(see the "},
        {"element": ["code", true, [], [{"text": "splitNe"}]]},
        {"text": " option below)."}]]},
     {"element":
      ["p",
       true,
       [],
       [{"element":
         ["code",
          true,
          [],
          [{"text": "linarith"},
           {"text": " "},
           {"text": "[t1,"},
           {"text": " "},
           {"text": "t2,"},
           {"text": " "},
           {"text": "t3]"}]]},
        {"text": " will additionally use proof terms "},
        {"element":
         ["code",
          true,
          [],
          [{"text": "t1,"},
           {"text": " "},
           {"text": "t2,"},
           {"text": " "},
           {"text": "t3"}]]},
        {"text": "."}]]},
     {"element":
      ["p",
       true,
       [],
       [{"element":
         ["code",
          true,
          [],
          [{"text": "linarith"},
           {"text": " "},
           {"text": "only"},
           {"text": " "},
           {"text": "[h1,"},
           {"text": " "},
           {"text": "h2,"},
           {"text": " "},
           {"text": "h3,"},
           {"text": " "},
           {"text": "t1,"},
           {"text": " "},
           {"text": "t2,"},
           {"text": " "},
           {"text": "t3]"}]]},
        {"text": " will use only the goal (if relevant), local hypotheses"},
        {"raw": "\n"},
        {"element": ["code", true, [], [{"text": "h1"}]]},
        {"text": ", "},
        {"element": ["code", true, [], [{"text": "h2"}]]},
        {"text": ", "},
        {"element": ["code", true, [], [{"text": "h3"}]]},
        {"text": ", and proofs "},
        {"element": ["code", true, [], [{"text": "t1"}]]},
        {"text": ", "},
        {"element": ["code", true, [], [{"text": "t2"}]]},
        {"text": ", "},
        {"element": ["code", true, [], [{"text": "t3"}]]},
        {"text": ". It will ignore the rest of the local context."}]]},
     {"element":
      ["p",
       true,
       [],
       [{"element": ["code", true, [], [{"text": "linarith!"}]]},
        {"text":
         " will use a stronger reducibility setting to try to identify atoms. For example,"}]]},
     {"element":
      ["pre",
       true,
       [],
       [{"element":
         ["code",
          true,
          [["class", "language-lean"]],
          [{"text": "example"},
           {"text": " "},
           {"text": "(x"},
           {"text": " "},
           {"text": ":"},
           {"text": " "},
           {"text": "ℚ)"},
           {"text": " "},
           {"text": ":"},
           {"text": " "},
           {"element":
            ["a",
             true,
             [["href", "./Init/Prelude.html#id"]],
             [{"text": "id"}]]},
           {"text": " "},
           {"text": "x"},
           {"text": " "},
           {"text": "≥"},
           {"text": " "},
           {"text": "x"},
           {"text": " "},
           {"text": ":="},
           {"text": " "},
           {"text": "by"},
           {"text": ""},
           {"text": "\n"},
           {"text": ""},
           {"text": ""},
           {"text": " "},
           {"text": ""},
           {"text": " "},
           {"text": ""},
           {"text": "linarith"},
           {"text": ""},
           {"text": "\n"},
           {"text": ""}]]}]]},
     {"element":
      ["p",
       true,
       [],
       [{"text": "will fail, because "},
        {"element": ["code", true, [], [{"text": "linarith"}]]},
        {"text": " will not identify "},
        {"element": ["code", true, [], [{"text": "x"}]]},
        {"text": " and "},
        {"element":
         ["code",
          true,
          [],
          [{"element":
            ["a",
             true,
             [["href", "./Init/Prelude.html#id"]],
             [{"text": "id"}]]},
           {"text": " "},
           {"text": "x"}]]},
        {"text": ". "},
        {"element": ["code", true, [], [{"text": "linarith!"}]]},
        {"text": " will."},
        {"raw": "\n"},
        {"text": "This can sometimes be expensive."}]]},
     {"element":
      ["p",
       true,
       [],
       [{"element":
         ["code",
          true,
          [],
          [{"text": "linarith"},
           {"text": " "},
           {"text": "(config"},
           {"text": " "},
           {"text": ":="},
           {"text": " "},
           {"text": "{"},
           {"text": " "},
           {"text": ".."},
           {"text": " "},
           {"text": "})"}]]},
        {"text": " takes a config object with five"},
        {"raw": "\n"},
        {"text": "optional arguments:"}]]},
     {"element":
      ["ul",
       true,
       [],
       [{"element":
         ["li",
          true,
          [],
          [{"element": ["code", true, [], [{"text": "discharger"}]]},
           {"text":
            " specifies a tactic to be used for reducing an algebraic equation in the"},
           {"raw": "\n"},
           {"text": "proof stage. The default is "},
           {"element": ["code", true, [], [{"text": "ring"}]]},
           {"text": ". Other options include "},
           {"element": ["code", true, [], [{"text": "simp"}]]},
           {"text": " for basic"},
           {"raw": "\n"},
           {"text": "problems."}]]},
        {"element":
         ["li",
          true,
          [],
          [{"element": ["code", true, [], [{"text": "transparency"}]]},
           {"text": " controls how hard "},
           {"element": ["code", true, [], [{"text": "linarith"}]]},
           {"text": " will try to match atoms to each other. By default"},
           {"raw": "\n"},
           {"text": "it will only unfold "},
           {"element": ["code", true, [], [{"text": "reducible"}]]},
           {"text": " definitions."}]]},
        {"element":
         ["li",
          true,
          [],
          [{"text": "If "},
           {"element": ["code", true, [], [{"text": "splitHypotheses"}]]},
           {"text": " is true, "},
           {"element": ["code", true, [], [{"text": "linarith"}]]},
           {"text": " will split conjunctions in the context into separate"},
           {"raw": "\n"},
           {"text": "hypotheses."}]]},
        {"element":
         ["li",
          true,
          [],
          [{"text": "If "},
           {"element": ["code", true, [], [{"text": "splitNe"}]]},
           {"text": " is "},
           {"element": ["code", true, [], [{"text": "true"}]]},
           {"text": ", "},
           {"element": ["code", true, [], [{"text": "linarith"}]]},
           {"text": " will case split on disequality hypotheses."},
           {"raw": "\n"},
           {"text": "For a given "},
           {"element":
            ["code",
             true,
             [],
             [{"text": "x"},
              {"text": " "},
              {"text": "≠"},
              {"text": " "},
              {"text": "y"}]]},
           {"text": " hypothesis, "},
           {"element": ["code", true, [], [{"text": "linarith"}]]},
           {"text": " is run with both "},
           {"element":
            ["code",
             true,
             [],
             [{"text": "x"},
              {"text": " "},
              {"text": "<"},
              {"text": " "},
              {"text": "y"}]]},
           {"text": " and "},
           {"element":
            ["code",
             true,
             [],
             [{"text": "x"},
              {"text": " "},
              {"text": ">"},
              {"text": " "},
              {"text": "y"}]]},
           {"text": ","},
           {"raw": "\n"},
           {"text":
            "and so this runs linarith exponentially many times with respect to the number of"},
           {"raw": "\n"},
           {"text": "disequality hypotheses. ("},
           {"element": ["code", true, [], [{"text": "false"}]]},
           {"text": " by default.)"}]]},
        {"element":
         ["li",
          true,
          [],
          [{"text": "If "},
           {"element": ["code", true, [], [{"text": "exfalso"}]]},
           {"text": " is "},
           {"element": ["code", true, [], [{"text": "false"}]]},
           {"text": ", "},
           {"element": ["code", true, [], [{"text": "linarith"}]]},
           {"text": " will fail when the goal is neither an inequality nor "},
           {"element":
            ["code",
             true,
             [],
             [{"element":
               ["a",
                true,
                [["href", "./Init/Prelude.html#False"]],
                [{"text": "False"}]]}]]},
           {"text": "."},
           {"raw": "\n"},
           {"text": "("},
           {"element": ["code", true, [], [{"text": "true"}]]},
           {"text": " by default.)"}]]},
        {"element":
         ["li",
          true,
          [],
          [{"text": "If "},
           {"element": ["code", true, [], [{"text": "minimize"}]]},
           {"text": " is "},
           {"element": ["code", true, [], [{"text": "false"}]]},
           {"text": ", "},
           {"element": ["code", true, [], [{"text": "linarith?"}]]},
           {"text": " will report all hypotheses appearing in its initial"},
           {"raw": "\n"},
           {"text": "proof without attempting to drop redundancies. ("},
           {"element": ["code", true, [], [{"text": "true"}]]},
           {"text": " by default.)"}]]},
        {"element":
         ["li",
          true,
          [],
          [{"element": ["code", true, [], [{"text": "restrict_type"}]]},
           {"text": " (not yet implemented in mathlib4)"},
           {"raw": "\n"},
           {"text": "will only use hypotheses that are inequalities over "},
           {"element": ["code", true, [], [{"text": "tp"}]]},
           {"text": ". This is useful"},
           {"raw": "\n"},
           {"text":
            "if you have e.g. both integer- and rational-valued inequalities in the local context, which can"},
           {"raw": "\n"},
           {"text": "sometimes confuse the tactic."}]]}]]},
     {"element":
      ["p",
       true,
       [],
       [{"text": "A variant, "},
        {"element": ["code", true, [], [{"text": "nlinarith"}]]},
        {"text":
         ", does some basic preprocessing to handle some nonlinear goals."}]]},
     {"element":
      ["p",
       true,
       [],
       [{"text": "The option "},
        {"element":
         ["code",
          true,
          [],
          [{"text": "set_option"},
           {"text": " "},
           {"text": "trace.linarith"},
           {"text": " "},
           {"text": "true"}]]},
        {"text": " will trace certain intermediate stages of the "},
        {"element": ["code", true, [], [{"text": "linarith"}]]},
        {"raw": "\n"},
        {"text": "routine."}]]}]]},
  "definingModule": "Mathlib.Tactic.Linarith.Frontend"}]