ml#And\">∧</a> <span class=\"fn\"><span class=\"fn\">x</span>.<a href=\"./Mathlib/Algebra/Free.html#FreeAddSemigroup.tail\">tail</a></span> <a href=\"./Init/Prelude.html#Eq\">=</a> <span class=\"fn\"><span class=\"fn\">y</span>.<a href=\"./Mathlib/Algebra/Free.html#FreeAddSemigroup.tail\">tail</a></span></div></div>","info":{"doc":"","docLink":"./Mathlib/Algebra/Free.html#FreeAddSemigroup.ext_iff","kind":"theorem","line":457,"name":"FreeAddSemigroup.ext_iff","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/0f1dd7505c3d08b5feb82300ccc73179a457bf51/Mathlib/Algebra/Free.lean#L457-L457"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">theorem</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Mathlib/Algebra/Free.html#FreeSemigroup.ext\"><span class=\"name\">FreeSemigroup</span>.<span class=\"name\">ext</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">α</span> : <a href=\"./foundational_types.html\">Type</a> u}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">x </span><span class=\"fn\">y</span> : <span class=\"fn\"><a href=\"./Mathlib/Algebra/Free.html#FreeSemigroup\">FreeSemigroup</a> <span class=\"fn\">α</span></span>}</span></span>\n</span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">head</span> : <span class=\"fn\"><span class=\"fn\">x</span>.<a href=\"./Mathlib/Algebra/Free.html#FreeSemigroup.head\">head</a></span> <a href=\"./Init/Prelude.html#Eq\">=</a> <span class=\"fn\"><span class=\"fn\">y</span>.<a href=\"./Mathlib/Algebra/Free.html#FreeSemigroup.head\">head</a></span>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">tail</span> : <span class=\"fn\"><span class=\"fn\">x</span>.<a href=\"./Mathlib/Algebra/Free.html#FreeSemigroup.tail\">tail</a></span> <a href=\"./Init/Prelude.html#Eq\">=</a> <span class=\"fn\"><span class=\"fn\">y</span>.<a href=\"./Mathlib/Algebra/Free.html#FreeSemigroup.tail\">tail</a></span>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\">x</span> <a href=\"./Init/Prelude.html#Eq\">=</a> <span class=\"fn\">y</span></div></div>","info":{"doc":"","docLink":"./Mathlib/Algebra/Free.html#FreeSemigroup.ext","kind":"theorem","line":457,"name":"FreeSemigroup.ext","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/0f1dd7505c3d08b5feb82300ccc73179a457bf51/Mathlib/Algebra/Free.lean#L457-L457"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">theorem</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Mathlib/Algebra/Free.html#FreeAddSemigroup.ext\"><span class=\"name\">FreeAddSemigroup</span>.<span class=\"name\">ext</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">α</span> : <a href=\"./foundational_types.html\">Type</a> u}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">x </span><span class=\"fn\">y</span> : <span class=\"fn\"><a href=\"./Mathlib/Algebra/Free.html#FreeAddSemigroup\">FreeAddSemigroup</a> <span class=\"fn\">α</span></span>}</span></span>\n</span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">head</span> : <span class=\"fn\"><span class=\"fn\">x</span>.<a href=\"./Mathlib/Algebra/Free.html#FreeAddSemigroup.head\">head</a></span> <a href=\"./Init/Prelude.html#Eq\">=</a> <span class=\"fn\"><span class=\"fn\">y</span>.<a href=\"./Mathlib/Algebra/Free.html#FreeAddSemigroup.head\">head</a></span>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">tail</span> : <span class=\"fn\"><span class=\"fn\">x</span>.<a href=\"./Mathlib/Algebra/Free.html#FreeAddSemigroup.tail\">tail</a></span> <a href=\"./Init/Prelude.html#Eq\">=</a> <span class=\"fn\"><span class=\"fn\">y</span>.<a href=\"./Mathlib/Algebra/Free.html#FreeAddSemigroup.tail\">tail</a></span>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\">x</span> <a href=\"./Init/Prelude.html#Eq\">=</a> <span class=\"fn\">y</span></div></div>","info":{"doc":"","docLink":"./Mathlib/Algebra/Free.html#FreeAddSemigroup.ext","kind":"theorem","line":457,"name":"FreeAddSemigroup.ext","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/0f1dd7505c3d08b5feb82300ccc73179a457bf51/Mathlib/Algebra/Free.lean#L457-L457"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">theorem</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Mathlib/Algebra/Free.html#FreeSemigroup.ext_iff\"><span class=\"name\">FreeSemigroup</span>.<span class=\"name\">ext_iff</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">α</span> : <a href=\"./foundational_types.html\">Type</a> u}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">x </span><span class=\"fn\">y</span> : <span class=\"fn\"><a href=\"./Mathlib/Algebra/Free.html#FreeSemigroup\">FreeSemigroup</a> <span class=\"fn\">α</span></span>}</span></span>\n</span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\">x</span> <a href=\"./Init/Prelude.html#Eq\">=</a> <span class=\"fn\">y</span> <a href=\"./Init/Core.html#Iff\">↔</a> <span class=\"fn\"><span class=\"fn\">x</span>.<a href=\"./Mathlib/Algebra/Free.html#FreeSemigroup.head\">head</a></span> <a href=\"./Init/Prelude.html#Eq\">=</a> <span class=\"fn\"><span class=\"fn\">y</span>.<a href=\"./Mathlib/Algebra/Free.html#FreeSemigroup.head\">head</a></span> <a href=\"./Init/Prelude.html#And\">∧</a> <span class=\"fn\"><span class=\"fn\">x</span>.<a href=\"./Mathlib/Algebra/Free.html#FreeSemigroup.tail\">tail</a></span> <a href=\"./Init/Prelude.html#Eq\">=</a> <span class=\"fn\"><span class=\"fn\">y</span>.<a href=\"./Mathlib/Algebra/Free.html#FreeSemigroup.tail\">tail</a></span></div></div>","info":{"doc":"","docLink":"./Mathlib/Algebra/Free.html#FreeSemigroup.ext_iff","kind":"theorem","line":457,"name":"FreeSemigroup.ext_iff","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/0f1dd7505c3d08b5feb82300ccc73179a457bf51/Mathlib/Algebra/Free.lean#L457-L457"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">structure</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Mathlib/Algebra/Free.html#FreeSemigroup\"><span class=\"name\">FreeSemigroup</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">α</span> : <a href=\"./foundational_types.html\">Type</a> u)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./foundational_types.html\">Type</a> u</div></div>","info":{"doc":"If `α` is a type, then `FreeSemigroup α` is the free semigroup generated by `α`.\nThis is a semigroup equipped with a function `FreeSemigroup.of : α → FreeSemigroup α` which has\nthe following universal property: if `M` is any semigroup, and `f : α → M` is any function,\nthen this function is the composite of `FreeSemigroup.of` and a unique semigroup homomorphism\n`FreeSemigroup.lift f : FreeSemigroup α →ₙ* M`.\n\nA typical element of `FreeSemigroup α` is a nonempty formal product of elements of `α`.\nFor example if `x` and `y` are terms of type `α` then `x * y * y * x` is a\n\"typical\" element of `FreeSemigroup α`. In particular if `α` is empty\nthen `FreeSemigroup α` is also empty, and if `α` has one term\nthen `FreeSemigroup α` is isomorphic to `Multiplicative ℕ+`.\nIf `α` has two or more terms then `FreeSemigroup α` is not commutative.\nOne can think of `FreeSemigroup α` as the type of nonempty lists of `α`, with multiplication\ngiven by concatenation.\n","docLink":"./Mathlib/Algebra/Free.html#FreeSemigroup","kind":"structure","line":441,"name":"FreeSemigroup","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/0f1dd7505c3d08b5feb82300ccc73179a457bf51/Mathlib/Algebra/Free.lean#L441-L462"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">abbrev</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Mathlib/Algebra/Free.html#FreeAddSemigroup.tail\"><span class=\"name\">FreeAddSemigroup</span>.<span class=\"name\">tail</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">α</span> : <a href=\"./foundational_types.html\">Type</a> u}</span></span>\n</span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">self</span> : <span class=\"fn\"><a href=\"./Mathlib/Algebra/Free.html#FreeAddSemigroup\">FreeAddSemigroup</a> <span class=\"fn\">α</span></span>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Init/Prelude.html#List\">List</a> <span class=\"fn\">α</span></span></div></div>","info":{"doc":"The tail of the element ","docLink":"./Mathlib/Algebra/Free.html#FreeAddSemigroup.tail","kind":"def","line":438,"name":"FreeAddSemigroup.tail","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/0f1dd7505c3d08b5feb82300ccc73179a457bf51/Mathlib/Algebra/Free.lean#L438-L438"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">abbrev</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Mathlib/Algebra/Free.html#FreeAddSemigroup.head\"><span class=\"name\">FreeAddSemigroup</span>.<span class=\"name\">head</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">α</span> : <a href=\"./foundational_types.html\">Type</a> u}</span></span>\n</span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">self</span> : <span class=\"fn\"><a href=\"./Mathlib/Algebra/Free.html#FreeAddSemigroup\">FreeAddSemigroup</a> <span class=\"fn\">α</span></span>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\">α</span></div></div>","info":{"doc":"The head of the element ","docLink":"./Mathlib/Algebra/Free.html#FreeAddSemigroup.head","kind":"def","line":436,"name":"FreeAddSemigroup.head","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/0f1dd7505c3d08b5feb82300ccc73179a457bf51/Mathlib/Algebra/Free.lean#L436-L436"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">constructor</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Mathlib/Algebra/Free.html#FreeAddSemigroup.mk\"><span class=\"name\">FreeAddSemigroup</span>.<span class=\"name\">mk</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">α</span> : <a href=\"./foundational_types.html\">Type</a> u}</span></span>\n</span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">head</span> : <span class=\"fn\">α</span>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">tail</span> : <span class=\"fn\"><a href=\"./Init/Prelude.html#List\">List</a> <span class=\"fn\">α</span></span>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Mathlib/Algebra/Free.html#FreeAddSemigroup\">FreeAddSemigroup</a> <span class=\"fn\">α</span></span></div></div>","info":{"doc":"","docLink":"./Mathlib/Algebra/Free.html#FreeAddSemigroup.mk","kind":"ctor","line":434,"name":"FreeAddSemigroup.mk","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/0f1dd7505c3d08b5feb82300ccc73179a457bf51/Mathlib/Algebra/Free.lean#L434-L434"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">structure</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Mathlib/Algebra/Free.html#FreeAddSemigroup\"><span class=\"name\">FreeAddSemigroup</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">α</span> : <a href=\"./foundational_types.html\">Type</a> u)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./foundational_types.html\">Type</a> u</div></div>","info":{"doc":"If `α` is a type, then `FreeAddSemigroup α` is the free additive semigroup generated by `α`.\nThis is an additive semigroup equipped with a function\n`FreeAddSemigroup.of : α → FreeAddSemigroup α` which has the following universal property:\nif `M` is any additive semigroup, and `f : α → M` is any function,\nthen this function is the composite of `FreeAddSemigroup.of` and a unique semigroup homomorphism\n`FreeAddSemigroup.lift f : FreeAddSemigroup α →ₙ+ M`.\n\nA typical element of `FreeAddSemigroup α` is a nonempty formal sum of elements of `α`.\nFor example if `x` and `y` are terms of type `α` then `x + y + y + x` is a\n\"typical\" element of `FreeAddSemigroup α`. In particular if `α` is empty\nthen `FreeAddSemigroup α` is also empty, and if `α` has one term\nthen `FreeAddSemigroup α` is isomorphic to `ℕ+`.\nIf `α` has two or more terms then `FreeAddSemigroup α` is not commutative.\nOne can think of `FreeAddSemigroup α` as the type of nonempty lists of `α`, with addition\ngiven by concatenation.\n","docLink":"./Mathlib/Algebra/Free.html#FreeAddSemigroup","kind":"structure","line":417,"name":"FreeAddSemigroup","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/0f1dd7505c3d08b5feb82300ccc73179a457bf51/Mathlib/Algebra/Free.lean#L417-L438"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">theorem</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Mathlib/Algebra/Free.html#AddMagma.FreeAddSemigroup.map_of\"><span class=\"name\">AddMagma</span>.<span class=\"name\">FreeAddSemigroup</span>.<span class=\"name\">map_of</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">α</span> : <a href=\"./foundational_types.html\">Type</a> u}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">[<span class=\"fn\"><a href=\"./Init/Prelude.html#Add\">Add</a> <span class=\"fn\">α</span></span>]</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">β</span> : <a href=\"./foundational_types.html\">Type</a> v}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">[<span class=\"fn\"><a href=\"./Init/Prelude.html#Add\">Add</a> <span class=\"fn\">β</span></span>]</span></span>\n</span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">f</span> : <span class=\"fn\">α</span> <a href=\"./Mathlib/Algebra/Group/Hom/Defs.html#AddHom\">→ₙ+</a> <span class=\"fn\">β</span>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">x</span> : <span class=\"fn\">α</span>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><span class=\"fn\">(<a href=\"./Mathlib/Algebra/Free.html#AddMagma.FreeAddSemigroup.map\">map</a> <span class=\"fn\">f</span>)</span> <span class=\"fn\">(<a href=\"./Mathlib/Algebra/Free.html#AddMagma.FreeAddSemigroup.of\">of</a> <span class=\"fn\">x</span>)</span></span> <a href=\"./Init/Prelude.html#Eq\">=</a> <span class=\"fn\"><a href=\"./Mathlib/Algebra/Free.html#AddMagma.FreeAddSemigroup.of\">of</a> <span class=\"fn\">(<span class=\"fn\">f</span> <span class=\"fn\">x</span>)</span></span></div></div>","info":{"doc":"","docLink":"./Mathlib/Algebra/Free.html#AddMagma.FreeAddSemigroup.map_of","kind":"theorem","line":410,"name":"AddMagma.FreeAddSemigroup.map_of","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/0f1dd7505c3d08b5feb82300ccc73179a457bf51/Mathlib/Algebra/Free.lean#L410-L410"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">theorem</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Mathlib/Algebra/Free.html#Magma.AssocQuotient.map_of\"><span class=\"name\">Magma</span>.<span class=\"name\">AssocQuotient</span>.<span clas