        {"element": ["code", true, [], [{"text": "intros"}]]},
        {"text": "."},
        {"raw": "\n"},
        {"text":
         "This tactic fails when it is unable to solve the goal, making it suitable for"},
        {"raw": "\n"},
        {"text": "use in auto-params."}]]}]]},
  "definingModule": "Mathlib.CategoryTheory.Category.Basic"}]