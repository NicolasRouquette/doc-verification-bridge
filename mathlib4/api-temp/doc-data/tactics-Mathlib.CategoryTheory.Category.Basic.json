  "internalName": "CategoryTheory.aesop_cat?",
  "docString":
  {"element":
   ["p",
    true,
    [],
    [{"element":
      ["p",
       true,
       [],
       [{"text": "We also use "},
        {"element": ["code", true, [], [{"text": "aesop_cat?"}]]},
        {"text": " to pass along a "},
        {"element":
         ["code",
          true,
          [],
          [{"text": "Try"}, {"text": " "}, {"text": "this"}]]},
