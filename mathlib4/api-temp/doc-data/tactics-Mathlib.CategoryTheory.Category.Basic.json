 {"userName": "aesop_cat",
  "tags": [],
  "internalName": "CategoryTheory.aesop_cat",
  "docString":
  {"element":
   ["p",
    true,
    [],
    [{"element":
      ["p",
       true,
       [],
       [{"text": "A thin wrapper for "},
        {"element": ["code", true, [], [{"text": "aesop"}]]},
        {"text": " which adds the "},
        {"element": ["code", true, [], [{"text": "CategoryTheory"}]]},
        {"text": " rule set and"},
        {"raw": "\n"},
        {"text": "allows "},
        {"element": ["code", true, [], [{"text": "aesop"}]]},
