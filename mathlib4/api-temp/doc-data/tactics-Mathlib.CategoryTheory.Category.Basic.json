 {"userName": "rfl_cat",
  "tags": [],
  "internalName": "CategoryTheory.rfl_cat",
  "docString":
  {"element":
   ["p",
    true,
    [],
    [{"element":
      ["p",
       true,
       [],
       [{"element": ["code", true, [], [{"text": "rfl_cat"}]]},
        {"text": " is a macro for "},
        {"element":
         ["code",
          true,
          [],
          [{"text": "intros;"},
           {"text": " "},
           {"element":
            ["a",
             true,
             [["href", "./Init/Prelude.html#rfl"]],
             [{"text": "rfl"}]]}]]},
        {"text": " which is attempted in "},
        {"element": ["code", true, [], [{"text": "aesop_cat"}]]},
        {"text": " before"},
        {"raw": "\n"},
        {"text": "doing the more expensive "},
        {"element": ["code", true, [], [{"text": "aesop"}]]},
        {"text": " tactic."}]]},
     {"element":
      ["p",
       true,
       [],
       [{"text": "This gives a speedup because "},
        {"element": ["code", true, [], [{"text": "simp"}]]},
        {"text": " (called by "},
        {"element": ["code", true, [], [{"text": "aesop"}]]},
        {"text": ") can be very slow."},
        {"raw": "\n"},
        {"element":
         ["a",
          true,
          [["href",
            "https://github.com/leanprover-community/mathlib4/pull/25475"]],
          [{"text":
            "https://github.com/leanprover-community/mathlib4/pull/25475"}]]},
        {"text": " contains measurements from June 2025."}]]},
     {"element": ["p", true, [], [{"text": "Implementation notes:"}]]},
     {"element":
      ["ul",
       true,
       [],
       [{"element":
         ["li",
          true,
          [],
          [{"element":
            ["code",
             true,
             [],
             [{"text": "refine"},
              {"text": " "},
              {"element":
               ["a",
                true,
                [["href", "./Init/Prelude.html#id"]],
                [{"text": "id"}]]},
              {"text": " "},
              {"text": "?_"}]]},
           {"text": ":"},
           {"raw": "\n"},
           {"text":
            "In some cases it is important that the type of the proof matches the expected type exactly."},
           {"raw": "\n"},
           {"text": "e.g. if the goal is "},
           {"element":
            ["code",
             true,
             [],
             [{"text": "2"},
              {"text": " "},
              {"text": "="},
              {"text": " "},
              {"text": "1"},
              {"text": " "},
              {"text": "+"},
              {"text": " "},
              {"text": "1"}]]},
           {"text": ", the "},
           {"element":
            ["code",
             true,
             [],
             [{"element":
               ["a",
                true,
                [["href", "./Init/Prelude.html#rfl"]],
                [{"text": "rfl"}]]}]]},
           {"text": " tactic will give a proof of type "},
           {"element":
            ["code",
             true,
             [],
             [{"text": "2"},
              {"text": " "},
              {"text": "="},
              {"text": " "},
              {"text": "2"}]]},
           {"text": "."},
           {"raw": "\n"},
           {"text": "Starting a proof with "},
           {"element":
            ["code",
             true,
             [],
             [{"text": "refine"},
              {"text": " "},
              {"element":
               ["a",
                true,
                [["href", "./Init/Prelude.html#id"]],
                [{"text": "id"}]]},
              {"text": " "},
              {"text": "?_"}]]},
           {"text": " is a trick to make sure that the proof has exactly"},
           {"raw": "\n"},
           {"text": "the expected type, in this case "},
           {"element":
            ["code",
             true,
             [],
             [{"text": "2"},
              {"text": " "},
              {"text": "="},
              {"text": " "},
              {"text": "1"},
              {"text": " "},
              {"text": "+"},
              {"text": " "},
              {"text": "1"}]]},
           {"text": ". See also"},
           {"raw": "\n"},
           {"text":
            "https://leanprover.zulipchat.com/#narrow/channel/270676-lean4/topic/changing.20a.20proof.20can.20break.20a.20later.20proof"}]]},
        {"element":
         ["li",
          true,
          [],
          [{"element": ["code", true, [], [{"text": "apply_rfl"}]]},
           {"text": ":"},
           {"raw": "\n"},
           {"element":
            ["code",
             true,
             [],
             [{"element":
               ["a",
                true,
                [["href", "./Init/Prelude.html#rfl"]],
                [{"text": "rfl"}]]}]]},
           {"text": " is a macro that attempts both "},
           {"element": ["code", true, [], [{"text": "eq_refl"}]]},
           {"text": " and "},
           {"element": ["code", true, [], [{"text": "apply_rfl"}]]},
           {"text": ". Since "},
           {"element": ["code", true, [], [{"text": "apply_rfl"}]]},
           {"raw": "\n"},
           {"text": "subsumes "},
           {"element": ["code", true, [], [{"text": "eq_refl"}]]},
           {"text": ", we can use "},
           {"element": ["code", true, [], [{"text": "apply_rfl"}]]},
           {"text": " instead. This fails twice as fast as "},
           {"element":
            ["code",
             true,
             [],
             [{"element":
               ["a",
                true,
                [["href", "./Init/Prelude.html#rfl"]],
                [{"text": "rfl"}]]}]]},
           {"text": "."}]]}]]}]]},
  "definingModule": "Mathlib.CategoryTheory.Category.Basic"},
 {"userName": "cat_disch",
  "tags": [],
  "internalName": "CategoryTheory.cat_disch",
  "docString":
  {"element":
   ["p",
    true,
    [],
    [{"element":
      ["p",
       true,
       [],
       [{"text":
         "A tactic for discharging easy category theory goals, widely used as an autoparameter."},
        {"raw": "\n"},
        {"text": "Currently this defaults to the "},
        {"element": ["code", true, [], [{"text": "aesop_cat"}]]},
        {"text": " wrapper around "},
        {"element": ["code", true, [], [{"text": "aesop"}]]},
        {"text": ", but by setting"},
        {"raw": "\n"},
        {"text": "the option "},
        {"element":
         ["code",
          true,
          [],
          [{"element":
            ["a",
             true,
             [["href",
               "./Mathlib/CategoryTheory/Category/Init.html#mathlib.tactic.category.grind"]],
             [{"text": "mathlib.tactic.category.grind"}]]}]]},
        {"text": " to "},
        {"element": ["code", true, [], [{"text": "true"}]]},
        {"text": ", it will use the "},
        {"element": ["code", true, [], [{"text": "grind"}]]},
        {"text": " tactic instead."}]]}]]},
  "definingModule": "Mathlib.CategoryTheory.Category.Basic"},
 {"userName": "aesop_cat_nonterminal",
  "tags": [],
  "internalName": "CategoryTheory.aesop_cat_nonterminal",
  "docString":
  {"element":
   ["p",
