lgebra/Field/Defs.html#Field\">Field</a> <span class=\"fn\">E</span></span>]</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">[<span class=\"fn\"><a href=\"./Mathlib/Algebra/Algebra/Defs.html#Algebra\">Algebra</a> <span class=\"fn\">F</span> <span class=\"fn\">E</span></span>]</span></span>\n</span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./foundational_types.html\">Type</a> v</div></div>","info":{"doc":"`Field.Emb F E` is the type of `F`-algebra homomorphisms from `E` to the algebraic closure\nof `E`. ","docLink":"./Mathlib/FieldTheory/SeparableDegree.html#Field.Emb","kind":"def","line":136,"name":"Field.Emb","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/087469e24922b85cb737497c74556c7dacc01f22/Mathlib/FieldTheory/SeparableDegree.lean#L136-L138"}}],"imports":["Init","Mathlib.FieldTheory.SplittingField.Construction","Mathlib.FieldTheory.IsAlgClosed.AlgebraicClosure","Mathlib.FieldTheory.Separable","Mathlib.FieldTheory.Normal.Closure","Mathlib.RingTheory.AlgebraicIndependent.Adjoin","Mathlib.RingTheory.AlgebraicIndependent.TranscendenceBasis","Mathlib.RingTheory.Polynomial.SeparableDegree","Mathlib.RingTheory.Polynomial.UniqueFactorization"],"instances":[{"className":"Inhabited","name":"Field.instInhabitedEmb","typeNames":["Field.Emb"]},{"className":"NeZero","name":"Field.instNeZeroFinSepDegree","typeNames":["Field.finSepDegree"]},{"className":"Infinite","name":"Field.infinite_emb_of_transcendental","typeNames":["Field.Emb"]}],"name":"Mathlib.FieldTheory.SeparableDegree"}