ryTheory/Iso.html#CategoryTheory.Iso\">≅</a> <span class=\"fn\"><span class=\"fn\"><span class=\"fn\">G</span>.<a href=\"./Mathlib/CategoryTheory/Functor/Basic.html#CategoryTheory.Functor.comp\">comp</a></span> <span class=\"fn\">(<a href=\"./Mathlib/CategoryTheory/Shift/Basic.html#CategoryTheory.shiftFunctor\">shiftFunctor</a> <span class=\"fn\">C</span> <span class=\"fn\">a</span>)</span></span>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">f₂</span> : <span class=\"fn\"><span class=\"fn\"><span class=\"fn\">(<a href=\"./Mathlib/CategoryTheory/Shift/Basic.html#CategoryTheory.shiftFunctor\">shiftFunctor</a> <span class=\"fn\">D</span> <span class=\"fn\">b</span>)</span>.<a href=\"./Mathlib/CategoryTheory/Functor/Basic.html#CategoryTheory.Functor.comp\">comp</a></span> <span class=\"fn\">G</span></span> <a href=\"./Mathlib/CategoryTheory/Iso.html#CategoryTheory.Iso\">≅</a> <span class=\"fn\"><span class=\"fn\"><span class=\"fn\">G</span>.<a href=\"./Mathlib/CategoryTheory/Functor/Basic.html#CategoryTheory.Functor.comp\">comp</a></span> <span class=\"fn\">(<a href=\"./Mathlib/CategoryTheory/Shift/Basic.html#CategoryTheory.shiftFunctor\">shiftFunctor</a> <span class=\"fn\">C</span> <span class=\"fn\">b</span>)</span></span>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">h</span> : <span class=\"fn\"><a href=\"./Mathlib/CategoryTheory/Shift/Adjunction.html#CategoryTheory.Adjunction.CommShift.CompatibilityUnit\">CompatibilityUnit</a> <span class=\"fn\">adj</span> <span class=\"fn\">e₁</span> <span class=\"fn\">e₂</span></span>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">h'</span> : <span class=\"fn\"><a href=\"./Mathlib/CategoryTheory/Shift/Adjunction.html#CategoryTheory.Adjunction.CommShift.CompatibilityUnit\">CompatibilityUnit</a> <span class=\"fn\">adj</span> <span class=\"fn\">f₁</span> <span class=\"fn\">f₂</span></span>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Mathlib/CategoryTheory/Shift/Adjunction.html#CategoryTheory.Adjunction.CommShift.CompatibilityUnit\">CompatibilityUnit</a> <span class=\"fn\">adj</span> <span class=\"fn\">(<a href=\"./Mathlib/CategoryTheory/Shift/CommShift.html#CategoryTheory.Functor.CommShift.isoAdd\">Functor.CommShift.isoAdd</a> <span class=\"fn\">e₁</span> <span class=\"fn\">f₁</span>)</span> <span class=\"fn\">(<a href=\"./Mathlib/CategoryTheory/Shift/CommShift.html#CategoryTheory.Functor.CommShift.isoAdd\">Functor.CommShift.isoAdd</a> <span class=\"fn\">e₂</span> <span class=\"fn\">f₂</span>)</span></span></div></div>","info":{"doc":"Given an adjunction `adj : F ⊣ G`, `a, b` in `A` and commutation isomorphisms\nbetween shifts by `a` (resp. `b`) and `F` and `G`, if these commutation isomorphisms are\ncompatible with the unit of `adj`, then so are the commutation isomorphisms between shifts\nby `a + b` and `F` and `G` constructed by `Functor.CommShift.isoAdd`.\n","docLink":"./Mathlib/CategoryTheory/Shift/Adjunction.html#CategoryTheory.Adjunction.CommShift.compatibilityUnit_isoAdd","kind":"theorem","line":176,"name":"CategoryTheory.Adjunction.CommShift.compatibilityUnit_isoAdd","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/0f1dd7505c3d08b5feb82300ccc73179a457bf51/Mathlib/CategoryTheory/Shift/Adjunction.lean#L176-L199"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">theorem</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Mathlib/CategoryTheory/Shift/Adjunction.html#CategoryTheory.Adjunction.CommShift.compatibilityUnit_isoZero\"><span class=\"name\">CategoryTheory</span>.<span class=\"name\">Adjunction</span>.<span class=\"name\">CommShift</span>.<span class=\"name\">compatibilityUnit_isoZero</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">C</span> : <a href=\"./foundational_types.html\">Type</a> u_1}</span