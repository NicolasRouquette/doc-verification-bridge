le.TotalSpace.mk'\">Bundle.TotalSpace.mk'</a> <span class=\"fn\">F₁</span> <span class=\"fn\">(<span class=\"fn\">b</span> <span class=\"fn\">m</span>)</span> <span class=\"fn\">(<span class=\"fn\">v</span> <span class=\"fn\">m</span>)</span></span>)</span> <span class=\"fn\">x</span></span>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">hw</span> : <span class=\"fn\"><a href=\"./Mathlib/Geometry/Manifold/ContMDiff/Defs.html#ContMDiffAt\">ContMDiffAt</a> <span class=\"fn\">IM</span> <span class=\"fn\">(<span class=\"fn\"><span class=\"fn\">IB</span>.<a href=\"./Mathlib/Geometry/Manifold/IsManifold/Basic.html#ModelWithCorners.prod\">prod</a></span> <span class=\"fn\">(<a href=\"./Mathlib/Geometry/Manifold/IsManifold/Basic.html#modelWithCornersSelf\">modelWithCornersSelf</a> <span class=\"fn\">𝕜</span> <span class=\"fn\">F₂</span>)</span>)</span> <span class=\"fn\">n</span> <span class=\"fn\">(fun (<span class=\"fn\">m</span> : <span class=\"fn\">M</span>) =&gt; <span class=\"fn\"><a href=\"./Mathlib/Data/Bundle.html#Bundle.TotalSpace.mk'\">Bundle.TotalSpace.mk'</a> <span class=\"fn\">F₂</span> <span class=\"fn\">(<span class=\"fn\">b</span> <span class=\"fn\">m</span>)</span> <span class=\"fn\">(<span class=\"fn\">w</span> <span class=\"fn\">m</span>)</span></span>)</span> <span class=\"fn\">x</span></span>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Mathlib/Geometry/Manifold/ContMDiff/Defs.html#ContMDiffAt\">ContMDiffAt</a> <span class=\"fn\">IM</span> <span class=\"fn\">(<span class=\"fn\"><span class=\"fn\">IB</span>.<a href=\"./Mathlib/Geometry/Manifold/IsManifold/Basic.html#ModelWithCorners.prod\">prod</a></span> <span class=\"fn\">(<a href=\"./Mathlib/Geometry/Manifold/IsManifold/Basic.html#modelWithCornersSelf\">modelWithCornersSelf</a> <span class=\"fn\">𝕜</span> <span class=\"fn\">F₃</span>)</span>)</span> <span class=\"fn\">n</span>\n  <span class=\"fn\">(fun (<span class=\"fn\">m</span> : <span class=\"fn\">M</span>) =&gt; <span class=\"fn\"><a href=\"./Mathlib/Data/Bundle.html#Bundle.TotalSpace.mk'\">Bundle.TotalSpace.mk'</a> <span class=\"fn\">F₃</span> <span class=\"fn\">(<span class=\"fn\">b</span> <span class=\"fn\">m</span>)</span> <span class=\"fn\">(<span class=\"fn\">(<span class=\"fn\">(<span class=\"fn\">ψ</span> <span class=\"fn\">m</span>)</span> <span class=\"fn\">(<span class=\"fn\">v</span> <span class=\"fn\">m</span>)</span>)</span> <span class=\"fn\">(<span class=\"fn\">w</span> <span class=\"fn\">m</span>)</span>)</span></span>)</span> <span class=\"fn\">x</span></span></div></div>","info":{"doc":"Consider `C^n` maps `v : M → E₁` and `v : M → E₂` to vector bundles, over a base map\n`b : M → B`, and bilinear maps `ψ m : E₁ (b m) → E₂ (b m) → E₃ (b m)` depending smoothly on `m`.\nOne can apply `ψ  m` to `v m` and `w m`, and the resulting map is `C^n`.\n\nWe give here a version of this statement at a point. ","docLink":"./Mathlib/Geometry/Manifold/VectorBundle/Hom.html#ContMDiffAt.clm_bundle_apply₂","kind":"theorem","line":392,"name":"ContMDiffAt.clm_bundle_apply₂","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/0f1dd7505c3d08b5feb82300ccc73179a457bf51/Mathlib/Geometry/Manifold/VectorBundle/Hom.lean#L392-L405"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">theorem</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Mathlib/Geometry/Manifold/VectorBundle/Hom.html#ContMDiffWithinAt.clm_bundle_apply₂\"><span class=\"name\">ContMDiffWithinAt</span>.<span class=\"name\">clm_bundle_apply₂</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">𝕜</span> : <a href=\"./foundational_types.html\">Type</a> u_1}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">B</span> : <a href=\"./foundational_types.html\">Type</a> u_2}</span></span>\n</span><s