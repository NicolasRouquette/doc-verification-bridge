ml#ContinuousLinearMap\">]</a> <span class=\"fn\">F₂</span>) <span class=\"fn\">(<span class=\"fn\">b</span> <span class=\"fn\">m</span>)</span> <span class=\"fn\">(<span class=\"fn\">ϕ</span> <span class=\"fn\">m</span>)</span></span></span></span>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">hv</span> : <span class=\"fn\"><a href=\"./Mathlib/Geometry/Manifold/ContMDiff/Defs.html#ContMDiff\">ContMDiff</a> <span class=\"fn\">IM</span> <span class=\"fn\">(<span class=\"fn\"><span class=\"fn\">IB</span>.<a href=\"./Mathlib/Geometry/Manifold/IsManifold/Basic.html#ModelWithCorners.prod\">prod</a></span> <span class=\"fn\">(<a href=\"./Mathlib/Geometry/Manifold/IsManifold/Basic.html#modelWithCornersSelf\">modelWithCornersSelf</a> <span class=\"fn\">𝕜</span> <span class=\"fn\">F₁</span>)</span>)</span> <span class=\"fn\">n</span> <span class=\"fn\">fun (<span class=\"fn\">m</span> : <span class=\"fn\">M</span>) =&gt; <span class=\"fn\"><a href=\"./Mathlib/Data/Bundle.html#Bundle.TotalSpace.mk'\">Bundle.TotalSpace.mk'</a> <span class=\"fn\">F₁</span> <span class=\"fn\">(<span class=\"fn\">b</span> <span class=\"fn\">m</span>)</span> <span class=\"fn\">(<span class=\"fn\">v</span> <span class=\"fn\">m</span>)</span></span></span></span>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Mathlib/Geometry/Manifold/ContMDiff/Defs.html#ContMDiff\">ContMDiff</a> <span class=\"fn\">IM</span> <span class=\"fn\">(<span class=\"fn\"><span class=\"fn\">IB</span>.<a href=\"./Mathlib/Geometry/Manifold/IsManifold/Basic.html#ModelWithCorners.prod\">prod</a></span> <span class=\"fn\">(<a href=\"./Mathlib/Geometry/Manifold/IsManifold/Basic.html#modelWithCornersSelf\">modelWithCornersSelf</a> <span class=\"fn\">𝕜</span> <span class=\"fn\">F₂</span>)</span>)</span> <span class=\"fn\">n</span> <span class=\"fn\">fun (<span class=\"fn\">m</span> : <span class=\"fn\">M</span>) =&gt; <span class=\"fn\">