u_1}</span></span>\n</span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">R</span> : <span class=\"fn\"><span class=\"fn\">ι</span> → <a href=\"./foundational_types.html\">Type</a> u_2</span>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">A</span> : <span class=\"fn\">(<span class=\"fn\">i</span> : <span class=\"fn\">ι</span>) → <span class=\"fn\"><a href=\"./Mathlib/Data/Set/Defs.html#Set\">Set</a> <span class=\"fn\">(<span class=\"fn\">R</span> <span class=\"fn\">i</span>)</span></span></span>)</span></span>\n<span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">𝓕</span> : <span class=\"fn\"><a href=\"./Mathlib/Order/Filter/Defs.html#Filter\">Filter</a> <span class=\"fn\">ι</span></span>}</span></span>\n</span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Mathlib/Data/FunLike/Basic.html#DFunLike\">DFunLike</a> <span class=\"fn\">(<a href=\"./Mathlib/Topology/Algebra/RestrictedProduct/Basic.html#RestrictedProduct\">RestrictedProduct</a> <span class=\"fn\">(fun (<span class=\"fn\">i</span> : <span class=\"fn\">ι</span>) =&gt; <span class=\"fn\"><span class=\"fn\">R</span> <span class=\"fn\">i</span></span>)</span> <span class=\"fn\">(fun (<span class=\"fn\">i</span> : <span class=\"fn\">ι</span>) =&gt; <span class=\"fn\"><span class=\"fn\">A</span> <span class=\"fn\">i</span></span>)</span> <span class=\"fn\">𝓕</span>)</span> <span class=\"fn\">ι</span> <span class=\"fn\">R</span></span></div></div>","info":{"doc":"","docLink":"./Mathlib/Topology/Algebra/RestrictedProduct/Basic.html#RestrictedProduct.instDFunLike","kind":"instance","line":99,"name":"RestrictedProduct.instDFunLike","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/0f1dd7505c3d08b5feb82300ccc73179a457bf51/Mathlib/Topology/Algebra/RestrictedProduct/Basic.lean#L99-L101"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Mathlib/Topology/Algebra/RestrictedProduct/Basic.html#RestrictedProduct.«termΠʳ_,[_,_]»\"><span class=\"name\">RestrictedProduct</span>.<span class=\"name\">«termΠʳ_,[_,_]»</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Init/Prelude.html#Lean.ParserDescr\">Lean.ParserDescr</a></div></div>","info":{"doc":"`Πʳ i, [R i, A i]` is `RestrictedProduct R A cofinite`. ","docLink":"./Mathlib/Topology/Algebra/RestrictedProduct/Basic.html#RestrictedProduct.«termΠʳ_,[_,_]»","kind":"def","line":88,"name":"RestrictedProduct.«termΠʳ_,[_,_]»","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/0f1dd7505c3d08b5feb82300ccc73179a457bf51/Mathlib/Topology/Algebra/RestrictedProduct/Basic.lean#L88-L91"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Mathlib/Topology/Algebra/RestrictedProduct/Basic.html#RestrictedProduct.«termΠʳ_,[_,_]_[_]»\"><span class=\"name\">RestrictedProduct</span>.<span class=\"name\">«termΠʳ_,[_,_]_[_]»</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Init/Prelude.html#Lean.ParserDescr\">Lean.ParserDescr</a></div></div>","info":{"doc":"`Πʳ i, [R i, A i]_[𝓕]` is `RestrictedProduct R A 𝓕`. ","docLink":"./Mathlib/Topology/Algebra/RestrictedProduct/Basic.html#RestrictedProduct.«termΠʳ_,[_,_]_[_]»","kind":"def","line":83,"name":"RestrictedProduct.«termΠʳ_,[_,_]_[_]»","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/0f1dd7505c3d08b5feb82300ccc73179a457bf51/Mathlib/Topology/Algebra/RestrictedProduct/Basic.lean#L83-L86"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Mathlib/Topology/Algebra/RestrictedProduct/Basic.html#RestrictedProduct\"><span class=\"name\">RestrictedProduct</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">ι</span> : <a href=\"./foundational_types.html\">Type</a> u_1}</span></span>\n</span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">R</span> : <span class=\"fn\"><span class=\"fn\">ι</span> → <a href=\"./foundational_types.html\">Type</a> u_2</span>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">A</span> : <span class=\"fn\">(<span class=\"fn\">i</span> : <span class=\"fn\">ι</span>) → <span class=\"fn\"><a href=\"./Mathlib/Data/Set/Defs.html#Set\">Set</a> <span class=\"fn\">(<span class=\"fn\">R</span> <span class=\"fn\">i</span>)</span></span></span>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">𝓕</span> : <span class=\"fn\"><a href=\"./Mathlib/Order/Filter/Defs.html#Filter\">Filter</a> <span class=\"fn\">ι</span></span>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./foundational_types.html\">Type</a> (max u_1 u_2)</div></div>","info":{"doc":"The **restricted product** of a family `R : ι → Type*` of types, relative to subsets\n`A : (i : ι) → Set (R i)` and the filter `𝓕 : Filter ι`, is the set of all `x : Π i, R i`\nsuch that the set `{j | x j ∈ A j}` belongs to `𝓕`. We denote it by `Πʳ i, [R i, A i]_[𝓕]`.\n\nThe most common use case is with `𝓕 = cofinite`, in which case the restricted product is the set\nof all `x : Π i, R i` such that `x j ∈ A j` for all but finitely many `j`. We denote it simply\nby `Πʳ i, [R i, A i]`.\n\nSimilarly, if `S` is a principal filter, the restricted product `Πʳ i, [R i, A i]_[𝓟 s]`\nis the set of all `x : Π i, R i` such that `∀ j ∈ S, x j ∈ A j`. ","docLink":"./Mathlib/Topology/Algebra/RestrictedProduct/Basic.html#RestrictedProduct","kind":"def","line":69,"name":"RestrictedProduct","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/0f1dd7505c3d08b5feb82300ccc73179a457bf51/Mathlib/Topology/Algebra/RestrictedProduct/Basic.lean#L69-L79"}}],"imports":["Init","Mathlib.Algebra.Ring.Pi","Mathlib.Algebra.Ring.Subring.Defs","Mathlib.GroupTheory.GroupAction.SubMulAction","Mathlib.Order.Filter.Cofinite","Mathlib.Algebra.Module.Pi"],"instances":[{"className":"DFunLike","name":"RestrictedProduct.instDFunLike","typeNames":["RestrictedProduct"]},{"className":"One","name":"RestrictedProduct.instOneCoeOfOneMemClass","typeNames":["RestrictedProduct"]},{"className":"Zero","name":"RestrictedProduct.instZeroCoeOfZeroMemClass","typeNames":["RestrictedProduct"]},{"className":"Inv","name":"RestrictedProduct.instInvCoeOfInvMemClass","typeNames":["RestrictedProduct"]},{"className":"Neg","name":"RestrictedProduct.instNegCoeOfNegMemClass","typeNames":["RestrictedProduct"]},{"className":"Mul","name":"RestrictedProduct.instMulCoeOfMulMemClass","typeNames":["RestrictedProduct"]},{"className":"Add","name":"RestrictedProduct.instAddCoeOfAddMemClass","typeNames":["RestrictedProduct"]},{"className":"SMul","name":"RestrictedProduct.instSMulCoeOfSMulMemClass","typeNames":["RestrictedProduct"]},{"className":"VAdd","name":"RestrictedProduct.instVAddCoeOfVAddMemClass","typeNames":["RestrictedProduct"]},{"className":"Div","name":"RestrictedProduct.instDivCoeOfSubgroupClass","typeNames":["RestrictedProduct"]},{"className":"Sub","name":"RestrictedProduct.instSubCoeOfAddSubgroupClass","typeNames":["RestrictedProduct"]},{"className":"SMul","name":"RestrictedProduct.instNSMul","typeNames":["Nat","RestrictedProduct"]},{"className":"Pow","name":"RestrictedProduct.instPowCoeNatOfSubmonoidClass","typeNames":["RestrictedProduct","Nat"]},{"className":"Monoid","name":"RestrictedProduct.instMonoidCoeOfSubmonoidClass","typeNames":["RestrictedProduct"]},{"className":"AddMonoid","name":"RestrictedProduct.instAddMonoidCoeOfAddSubmonoidClass","typeNames":["RestrictedProduct"]},{"className":"CommMonoid","name":"RestrictedProduct.instCommMonoidCoeOfSubmonoidClass","typeNames":["RestrictedProduct"]},{"className":"AddCommMonoid","name":"RestrictedProduct.instAddCommMonoidCoeOfAddSubmonoidClass","typeNames":["RestrictedProduct"]},{"className":"SMul","name":"RestrictedProduct.instZSMul","typeNames":["Int","RestrictedProduct"]},{"className":"Pow","name":"RestrictedProduct.instPowCoeIntOfSubgroupClass","typeNames":["RestrictedProduct","Int"]},{"className":"NatCast","name":"RestrictedProduct.instNatCastCoeOfAddSubmonoidWithOneClass","typeNames":["RestrictedProduct"]},{"className":"Group","name":"RestrictedProduct.instGroupCoeOfSubgroupClass","typeNames":["RestrictedProduct"]},{"className":"AddGroup","name":"RestrictedProduct.instAddGroupCoeOfAddSubgroupClass","typeNames":["RestrictedProduct"]},{"className":"CommGroup","name":"RestrictedProduct.instCommGroupCoeOfSubgroupClass","typeNames":["RestrictedProduct"]},{"className":"AddCommGroup","name":"RestrictedProduct.instAddCommGroupCoeOfAddSubgroupClass","typeNames":["RestrictedProduct"]},{"className":"IntCast","name":"RestrictedProduct.instIntCastCoeOfSubringClass","typeNames":["RestrictedProduct"]},{"className":"Ring","name":"RestrictedProduct.instRingCoeOfSubringClass","typeNames":["RestrictedProduct"]},{"className":"CommRing","name":"RestrictedProduct.instCommRingCoeOfSubringClass","typeNames":["RestrictedProduct"]},{"className":"Module","name":"RestrictedProduct.instModuleCoeOfSMulMemClass","typeNames":["RestrictedProduct"]}],"name":"Mathlib.Topology.Algebra.RestrictedProduct.Basic"}