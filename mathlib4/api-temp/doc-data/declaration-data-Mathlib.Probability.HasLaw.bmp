asLaw.mk","kind":"ctor","line":39,"name":"ProbabilityTheory.HasLaw.mk","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/087469e24922b85cb737497c74556c7dacc01f22/Mathlib/Probability/HasLaw.lean#L39-L39"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">structure</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Mathlib/Probability/HasLaw.html#ProbabilityTheory.HasLaw\"><span class=\"name\">ProbabilityTheory</span>.<span class=\"name\">HasLaw</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">Ω</span> : <a href=\"./foundational_types.html\">Type</a> u_1}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">𝓧</span> : <a href=\"./foundational_types.html\">Type</a> u_2}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">mΩ</span> : <span class=\"fn\"><a href=\"./Mathlib/MeasureTheory/MeasurableSpace/Defs.html#MeasurableSpace\">MeasurableSpace</a> <span class=\"fn\">Ω</span></span>}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">m𝓧</span> : <span class=\"fn\"><a href=\"./Mathlib/MeasureTheory/MeasurableSpace/Defs.html#MeasurableSpace\">MeasurableSpace</a> <span class=\"fn\">𝓧</span></span>}</span></span>\n</span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">X</span> : <span class=\"fn\"><span class=\"fn\">Ω</span> → <span class=\"fn\">𝓧</span></span>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">μ</span> : <span class=\"fn\"><a href=\"./Mathlib/MeasureTheory/Measure/MeasureSpaceDef.html#MeasureTheory.Measure\">MeasureTheory.Measure</a> <span class=\"fn\">𝓧</span></span>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">P</span> : <span class=\"fn\"><a href=\"./Mathlib/MeasureTheory/Measure/MeasureSpaceDef.html#MeasureTheory.Measure\">MeasureTheory.Measure</a> <span class=\"fn\">Ω</span></span> := by volume_tac)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./foundational_types.html\">Prop</a></div></div>","info":{"doc":"The predicate `HasLaw X μ P` registers the fact that the random variable `X` has law `μ` under\nthe measure `P`, in other words that `P.map X = μ`. We also require `X` to be `AEMeasurable`,\nto allow for nice interactions with operations on the codomain of `X`. See for instance\n`HasLaw.comp`, `IndepFun.hasLaw_mul` and `IndepFun.hasLaw_add`. ","docLink":"./Mathlib/Probability/HasLaw.html#ProbabilityTheory.HasLaw","kind":"structure","line":34,"name":"ProbabilityTheory.HasLaw","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/087469e24922b85cb737497c74556c7dacc01f22/Mathlib/Probability/HasLaw.lean#L34-L41"}}],"imports":["Init","Mathlib.Probability.Density","Mathlib.Probability.Moments.Variance"],"instances":[],"name":"Mathlib.Probability.HasLaw"}