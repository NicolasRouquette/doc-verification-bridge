ib/Computability/PostTuringMachine.html#Turing.TM0.Cfg\">Cfg</a> <span class=\"fn\">Γ</span> <span class=\"fn\">Λ</span></span>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\">Λ</span></div></div>","info":{"doc":"The current machine state. ","docLink":"./Mathlib/Computability/PostTuringMachine.html#Turing.TM0.Cfg.q","kind":"def","line":148,"name":"Turing.TM0.Cfg.q","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/0f1dd7505c3d08b5feb82300ccc73179a457bf51/Mathlib/Computability/PostTuringMachine.lean#L148-L148"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">constructor</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Mathlib/Computability/PostTuringMachine.html#Turing.TM0.Cfg.mk\"><span class=\"name\">Turing</span>.<span class=\"name\">TM0</span>.<span class=\"name\">Cfg</span>.<span class=\"name\">mk</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">Γ</span> : <a href=\"./foundational_types.html\">Type</a> u_1}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">Λ</span> : <a href=\"./foundational_types.html\">Type</a> u_2}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">[<span class=\"fn\"><a href=\"./Init/Prelude.html#Inhabited\">Inhabited</a> <span class=\"fn\">Γ</span></span>]</span></span>\n</span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">q</span> : <span class=\"fn\">Λ</span>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">Tape</span> : <span class=\"fn\"><a href=\"./Mathlib/Computability/Tape.html#Turing.Tape\">Turing.Tape</a> <span class=\"fn\">Γ</span></span>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Mathlib/Computability/PostTuringMachine.html#Turing.TM0.Cfg\">Cfg</a> <span class=\"fn\">Γ</span> <span class=\"fn\">Λ</span></span></div></div>","info":{"doc":"","docLink":"./Mathlib/Computability/PostTuringMachine.html#Turing.TM0.Cfg.mk","kind":"ctor","line":146,"name":"Turing.TM0.Cfg.mk","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/0f1dd7505c3d08b5feb82300ccc73179a457bf51/Mathlib/Computability/PostTuringMachine.lean#L146-L146"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">structure</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Mathlib/Computability/PostTuringMachine.html#Turing.TM0.Cfg\"><span class=\"name\">Turing</span>.<span class=\"name\">TM0</span>.<span class=\"name\">Cfg</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">Γ</span> : <a href=\"./foundational_types.html\">Type</a> u_1)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">Λ</span> : <a href=\"./foundational_types.html\">Type</a> u_2)</span></span>\n<span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">[<span class=\"fn\"><a href=\"./Init/Prelude.html#Inhabited\">Inhabited</a> <span class=\"fn\">Γ</span></span>]</span></span>\n</span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./foundational_types.html\">Type</a> (max u_1 u_2)</div></div>","info":{"doc":"The configuration state of a Turing machine during operation\nconsists of a label (machine state), and a tape.\nThe tape is represented in the form `(a, L, R)`, meaning the tape looks like `L.rev ++ [a] ++ R`\nwith the machine currently reading the `a`. The lists are\nautomatically extended with blanks as the machine moves around. ","docLink":"./Mathlib/Computability/PostTuringMachine.html#Turing.TM0.Cfg","kind":"structure","line":141,"name":"Turing.TM0.Cfg","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/0f1dd7505c3d08b5feb82300ccc73179a457bf51/Mathlib/Computability/PostTuringMachine.lean#L141-L150"}},{"header":"<div class=