yGeneratedSpace","name":"instUCompactlyGeneratedSpaceSigma","typeNames":["Sigma"]},{"className":"UCompactlyGeneratedSpace","name":"instUCompactlyGeneratedSpaceOfSequentialSpace","typeNames":[]},{"className":"UCompactlyGeneratedSpace","name":"instCompactlyGeneratedSpaceSigma","typeNames":["Sigma"]},{"className":"UCompactlyGeneratedSpace","name":"instCompactlyGeneratedSpaceOfWeaklyLocallyCompactSpace","typeNames":[]},{"className":"CompactlyCoherentSpace","name":"to_compactlyCoherentSpace","typeNames":[]},{"className":"UCompactlyGeneratedSpace","name":"of_compactlyCoherentSpace_of_t2","typeNames":[]}],"name":"Mathlib.Topology.Compactness.CompactlyGeneratedSpace"}