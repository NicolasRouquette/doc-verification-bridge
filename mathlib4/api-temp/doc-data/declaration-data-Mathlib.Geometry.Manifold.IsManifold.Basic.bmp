c/Equiv/PartialEquiv.html#PartialEquiv.invFun\">invFun</a></span></span></div></div>","info":{"doc":"","docLink":"./Mathlib/Geometry/Manifold/IsManifold/Basic.html#PartialEquiv.Continuous.invFun","kind":"theorem","line":143,"name":"PartialEquiv.Continuous.invFun","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/087469e24922b85cb737497c74556c7dacc01f22/Mathlib/Geometry/Manifold/IsManifold/Basic.lean#L143-L145"}}],"imports":["Init","Mathlib.Analysis.Calculus.ContDiff.Operations","Mathlib.Analysis.Normed.Module.Convex","Mathlib.Analysis.RCLike.TangentCone","Mathlib.Data.Bundle","Mathlib.Geometry.Manifold.HasGroupoid"],"instances":[{"className":"CoeFun","name":"ModelWithCorners.instCoeFunForall","typeNames":["ModelWithCorners"]},{"className":"ModelWithCorners.Boundaryless","name":"modelWithCornersSelf_boundaryless","typeNames":["modelWithCornersSelf"]},{"className":"ModelWithCorners.Boundaryless","name":"ModelWithCorners.range_eq_univ_prod","typeNames":["ModelWithCorners.prod"]},{"className":"ClosedUnderRestriction","name":"instClosedUnderRestrictionContDiffGroupoid","typeNames":["contDiffGroupoid"]},{"className":"IsManifold","name":"instIsManifoldModelSpace","typeNames":[]},{"className":"ENat.LEInfty","name":"IsManifold.instLEInftySomeENat","typeNames":["WithTop.some"]},{"className":"ENat.LEInfty","name":"IsManifold.instLEInftyCastWithTopENat","typeNames":["Nat.cast"]},{"className":"ENat.LEInfty","name":"IsManifold.instLEInftyOfNatWithTopENat","typeNames":[]},{"className":"ENat.LEInfty","name":"IsManifold.instLEInftyOfNatWithTopENat_1","typeNames":["OfNat.ofNat"]},{"className":"ENat.LEInfty","name":"IsManifold.instLEInftyOfNatWithTopENat_2","typeNames":["OfNat.ofNat"]},{"className":"IsManifold","name":"IsManifold.instOfSomeENatTopOfLEInfty","typeNames":[]},{"className":"IsManifold","name":"IsManifold.instOfTopWithTopENat","typeNames":[]},{"className":"IsManifold","name":"IsManifold.instOfNatWithTopENat","typeNames":["OfNat.ofNat"]},{"className":"IsMa