          [{"text":
            "variables (P Q R : Prop)\n\nexample (H : ¬ Q → ¬ P) : P → Q := by\n  contrapose\n  exact H\n\nexample (H : ¬ P ↔ ¬ Q) : P ↔ Q := by\n  contrapose\n  exact H\n\nexample (H : ¬ Q → ¬ P) (h : P) : Q := by\n  contrapose h\n  exact H h\n\nexample (H : ¬ R → P → ¬ Q) : (P ∧ Q) → R := by\n  contrapose!\n  exact H\n\nexample (H : ¬ R → ¬ P ∨ ¬ Q) : (P ∧ Q) → R := by\n  contrapose! +distrib\n  exact H\n"}]]}]]}]]},
