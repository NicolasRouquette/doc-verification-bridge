Space\">MeasurableSpace</a> <span class=\"fn\">α</span></span>}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">μ</span> : <span class=\"fn\"><a href=\"./Mathlib/MeasureTheory/Measure/MeasureSpaceDef.html#MeasureTheory.Measure\">Measure</a> <span class=\"fn\">α</span></span>}</span></span>\n</span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">measure_singleton</span> : <span class=\"fn\">∀ (<span class=\"fn\">x</span> : <span class=\"fn\">α</span>), <span class=\"fn\"><span class=\"fn\">μ</span> <a href=\"./Init/Core.html#Singleton.singleton\">{</a><span class=\"fn\">x</span><a href=\"./Init/Core.html#Singleton.singleton\">}</a></span> <a href=\"./Init/Prelude.html#Eq\">=</a> <span class=\"fn\">0</span></span>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Mathlib/MeasureTheory/Measure/Typeclasses/NoAtoms.html#MeasureTheory.NoAtoms\">NoAtoms</a> <span class=\"fn\">μ</span></span></div></div>","info":{"doc":"","docLink":"./Mathlib/MeasureTheory/Measure/Typeclasses/NoAtoms.html#MeasureTheory.NoAtoms.mk","kind":"ctor","line":34,"name":"MeasureTheory.NoAtoms.mk","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/0f1dd7505c3d08b5feb82300ccc73179a457bf51/Mathlib/MeasureTheory/Measure/Typeclasses/NoAtoms.lean#L34-L34"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">class</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Mathlib/MeasureTheory/Measure/Typeclasses/NoAtoms.html#MeasureTheory.NoAtoms\"><span class=\"name\">MeasureTheory</span>.<span class=\"name\">NoAtoms</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">α</span> : <a href=\"./foundational_types.html\">Type</a> u_1}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">m0</span> : <span class=\"fn