[{"userName": "linear_combination'",
  "tags": [],
  "internalName": "Mathlib.Tactic.LinearCombination'.linearCombination'",
  "docString":
  {"element":
   ["p",
    true,
    [],
    [{"element":
      ["p",
       true,
       [],
       [{"element": ["code", true, [], [{"text": "linear_combination'"}]]},
        {"text":
         " attempts to simplify the target by creating a linear combination"},
        {"raw": "\n"},
        {"text": "of a list of equalities and subtracting it from the target."},
        {"raw": "\n"},
        {"text": "The tactic will create a linear"},
        {"raw": "\n"},
        {"text":
         "combination by adding the equalities together from left to right, so the order"},
        {"raw": "\n"},
        {"text": "of the input hypotheses does matter.  If the "},
        {"element": ["code", true, [], [{"text": "norm"}]]},
        {"text": " field of the"},
        {"raw": "\n"},
        {"text": "tactic is set to "},
        {"element": ["code", true, [], [{"text": "skip"}]]},
        {"text": ", then the tactic will simply set the user up to"},
        {"raw": "\n"},
        {"text":
         "prove their target using the linear combination instead of normalizing the subtraction."}]]},
     {"element":
      ["p",
       true,
       [],
       [{"text": "Note: There is also a similar tactic "},
        {"element": ["code", true, [], [{"text": "linear_combination"}]]},
        {"text": " (no prime); this version is"},
        {"raw": "\n"},
        {"text":
         "provided for backward compatibility.  Compared to this tactic, "},
        {"element": ["code", true, [], [{"text": "linear_combination"}]]},
        {"text": ":"}]]},
     {"element":
      ["ul",
       true,
       [],
       [{"element":
         ["li",
          true,
          [],
          [{"text": "drops the "},
           {"element": ["code", true, [], [{"text": "←"}]]},
           {"text":
            " syntax for reversing an equation, instead offering this operation using the "},
           {"element": ["code", true, [], [{"text": "-"}]]},
           {"raw": "\n"},
           {"text": "syntax"}]]},
        {"element":
         ["li",
          true,
          [],
          [{"text": "does not support multiplication of two hypotheses ("},
           {"element":
            ["code",
             true,
             [],
             [{"text": "h1"},
              {"text": " "},
              {"text": "*"},
              {"text": " "},
              {"text": "h2"}]]},
           {"text": "), division by a hypothesis ("},
           {"element":
            ["code",
             true,
             [],
             [{"text": "3"},
              {"text": " "},
              {"text": "/"},
              {"text": " "},
              {"text": "h"}]]},
           {"text": "),"},
           {"raw": "\n"},
           {"text": "or inversion of a hypothesis ("},
           {"element": ["code", true, [], [{"text": "h⁻¹"}]]},
           {"text": ")"}]]},
        {"element":
         ["li",
          true,
          [],
          [{"text":
            "produces noisy output when the user adds or subtracts a constant to a hypothesis ("},
           {"element":
            ["code",
             true,
             [],
             [{"text": "h"},
              {"text": " "},
              {"text": "+"},
              {"text": " "},
              {"text": "3"}]]},
           {"text": ")"}]]}]]},
     {"element":
      ["p",
       true,
       [],
       [{"text":
         "Note: The left and right sides of all the equalities should have the same"},
        {"raw": "\n"},
        {"text":
         "type, and the coefficients should also have this type.  There must be"},
        {"raw": "\n"},
        {"text": "instances of "},
        {"element":
         ["code",
          true,
          [],
          [{"element":
            ["a",
             true,
             [["href", "./Init/Prelude.html#Mul"]],
             [{"text": "Mul"}]]}]]},
        {"text": " and "},
        {"element":
         ["code",
          true,
          [],
          [{"element":
            ["a",
             true,
             [["href", "./Mathlib/Algebra/Group/Defs.html#AddGroup"]],
             [{"text": "AddGroup"}]]}]]},
        {"text": " for this type."}]]},
     {"element":
      ["ul",
       true,
       [],
       [{"element":
         ["li",
          true,
          [],
          [{"text": "The input "},
           {"element": ["code", true, [], [{"text": "e"}]]},
           {"text": " in "},
           {"element":
            ["code",
             true,
             [],
             [{"text": "linear_combination'"}, {"text": " "}, {"text": "e"}]]},
           {"text": " is a linear combination of proofs of equalities,"},
           {"raw": "\n"},
           {"text":
            "given as a sum/difference of coefficients multiplied by expressions."},
           {"raw": "\n"},
           {"text": "The coefficients may be arbitrary expressions."},
           {"raw": "\n"},
           {"text":
            "The expressions can be arbitrary proof terms proving equalities."},
           {"raw": "\n"},
           {"text": "Most commonly they are hypothesis names "},
           {"element":
            ["code",
             true,
             [],
             [{"text": "h1,"},
              {"text": " "},
              {"text": "h2,"},
              {"text": " "},
              {"text": "..."}]]},
           {"text": "."}]]},
        {"element":
         ["li",
          true,
          [],
          [{"element":
            ["code",
             true,
             [],
             [{"text": "linear_combination'"},
              {"text": " "},
              {"text": "(norm"},
              {"text": " "},
              {"text": ":="},
              {"text": " "},
              {"text": "tac)"},
              {"text": " "},
              {"text": "e"}]]},
           {"text": " runs the \"normalization tactic\" "},
           {"element": ["code", true, [], [{"text": "tac"}]]},
           {"raw": "\n"},
           {"text":
            "on the subgoal(s) after constructing the linear combination."},
           {"element":
            ["ul",
             true,
             [],
             [{"element":
               ["li",
                true,
                [],
                [{"text": "The default normalization tactic is "},
                 {"element": ["code", true, [], [{"text": "ring1"}]]},
                 {"text": ", which closes the goal or fails."}]]},
              {"element":
               ["li",
                true,
                [],
                [{"text":
                  "To get a subgoal in the case that it is not immediately provable, use"},
                 {"raw": "\n"},
                 {"element": ["code", true, [], [{"text": "ring_nf"}]]},
                 {"text": " as the normalization tactic."}]]},
              {"element":
               ["li",
                true,
                [],
                [{"text": "To avoid normalization entirely, use "},
                 {"element": ["code", true, [], [{"text": "skip"}]]},
                 {"text": " as the normalization tactic."}]]}]]}]]},
        {"element":
         ["li",
          true,
          [],
          [{"element":
            ["code",
             true,
             [],
             [{"text": "linear_combination'"},
              {"text": " "},
              {"text": "(exp"},
              {"text": " "},
              {"text": ":="},
              {"text": " "},
              {"text": "n)"},
              {"text": " "},
              {"text": "e"}]]},
           {"text": " will take the goal to the "},
           {"element": ["code", true, [], [{"text": "n"}]]},
           {"text": "th power before subtracting the"},
           {"raw": "\n"},
           {"text": "combination "},
           {"element": ["code", true, [], [{"text": "e"}]]},
           {"text": ". In other words, if the goal is "},
           {"element":
            ["code",
             true,
             [],
             [{"text": "t1"},
              {"text": " "},
              {"text": "="},
              {"text": " "},
              {"text": "t2"}]]},
           {"text": ", "},
           {"element":
            ["code",
             true,
             [],
             [{"text": "linear_combination'"},
              {"text": " "},
              {"text": "(exp"},
              {"text": " "},
              {"text": ":="},
              {"text": " "},
              {"text": "n)"},
              {"text": " "},
              {"text": "e"}]]},
           {"raw": "\n"},
           {"text": "will change the goal to "},
           {"element":
            ["code",
             true,
             [],
             [{"text": "(t1"},
              {"text": " "},
              {"text": "-"},
              {"text": " "},
              {"text": "t2)^n"},
              {"text": " "},
              {"text": "="},
              {"text": " "},
              {"text": "0"}]]},
           {"text": " before proceeding as above."},
           {"raw": "\n"},
           {"text": "This feature is not supported for "},
           {"element": ["code", true, [], [{"text": "linear_combination2"}]]},
           {"text": "."}]]},
        {"element":
         ["li",
          true,
          [],
          [{"element":
            ["code",
             true,
             [],
             [{"text": "linear_combination2"}, {"text": " "}, {"text": "e"}]]},
           {"text": " is the same as "},
           {"element":
            ["code",
             true,
             [],
             [{"text": "linear_combination'"}, {"text": " "}, {"text": "e"}]]},
           {"text": " but it produces two"},
           {"raw": "\n"},
           {"text": "subgoals instead of one: rather than proving that "},
           {"element":
            ["code",
             true,
             [],
             [{"text": "(a"},
              {"text": " "},
              {"text": "-"},
              {"text": " "},
              {"text": "b)"},
              {"text": " "},
              {"text": "-"},
              {"text": " "},
              {"text": "(a'"},
              {"text": " "},
              {"text": "-"},
              {"text": " "},
              {"text": "b')"},
              {"text": " "},
              {"text": "="},
              {"text": " "},
              {"text": "0"}]]},
           {"text": " where"},
           {"raw": "\n"},
           {"element":
            ["code",
             true,
             [],
             [{"text": "a'"},
              {"text": " "},
              {"text": "="},
              {"text": " "},
              {"text": "b'"}]]},
           {"text": " is the linear combination from "},
           {"element": ["code", true, [], [{"text": "e"}]]},
           {"text": " and "},
           {"element":
            ["code",
             true,
             [],
             [{"text": "a"},
              {"text": " "},
              {"text": "="},
              {"text": " "},
              {"text": "b"}]]},
           {"text": " is the goal,"},
           {"raw": "\n"},
           {"text": "it instead attempts to prove "},
           {"element":
            ["code",
             true,
             [],
             [{"text": "a"},
              {"text": " "},
              {"text": "="},
              {"text": " "},
              {"text": "a'"}]]},
           {"text": " and "},
           {"element":
            ["code",
             true,
             [],
             [{"text": "b"},
              {"text": " "},
              {"text": "="},
              {"text": " "},
              {"text": "b'"}]]},
           {"text": "."},
           {"raw": "\n"},
           {"text":
            "Because it does not use subtraction, this form is applicable also to semirings."},
           {"element":
            ["ul",
             true,
             [],
             [{"element":
               ["li",
                true,
                [],
                [{"text": "Note that a goal which is provable by "},
                 {"element":
                  ["code",
                   true,
                   [],
                   [{"text": "linear_combination'"},
                    {"text": " "},
                    {"text": "e"}]]},
                 {"text": " may not be provable"},
                 {"raw": "\n"},
                 {"text": "by "},
                 {"element":
                  ["code",
                   true,
                   [],
                   [{"text": "linear_combination2"},
                    {"text": " "},
                    {"text": "e"}]]},
                 {"text": "; in general you may need to add a coefficient to "},
                 {"element": ["code", true, [], [{"text": "e"}]]},
                 {"raw": "\n"},
                 {"text": "to make both sides match, as in "},
                 {"element":
                  ["code",
                   true,
                   [],
                   [{"text": "linear_combination2"},
                    {"text": " "},
                    {"text": "e"},
                    {"text": " "},
                    {"text": "+"},
                    {"text": " "},
                    {"text": "c"}]]},
                 {"text": "."}]]},
              {"element":
               ["li",
                true,
                [],
                [{"text": "You can also reverse equalities using "},
                 {"element":
                  ["code",
                   true,
                   [],
                   [{"text": "←"}, {"text": " "}, {"text": "h"}]]},
                 {"text": ", so for example if "},
                 {"element":
                  ["code",
                   true,
                   [],
                   [{"text": "h₁"},
                    {"text": " "},
                    {"text": ":"},
                    {"text": " "},
                    {"text": "a"},
                    {"text": " "},
                    {"text": "="},
                    {"text": " "},
                    {"text": "b"}]]},
                 {"raw": "\n"},
                 {"text": "then "},
                 {"element":
                  ["code",
                   true,
                   [],
                   [{"text": "2"},
                    {"text": " "},
                    {"text": "*"},
                    {"text": " "},
                    {"text": "(←"},
                    {"text": " "},
                    {"text": "h)"}]]},
                 {"text": " is a proof of "},
                 {"element":
                  ["code",
                   true,
                   [],
                   [{"text": "2"},
                    {"text": " "},
                    {"text": "*"},
                    {"text": " "},
                    {"text": "b"},
                    {"text": " "},
                    {"text": "="},
                    {"text": " "},
                    {"text": "2"},
                    {"text": " "},
                    {"text": "*"},
                    {"text": " "},
                    {"text": "a"}]]},
                 {"text": "."}]]}]]}]]}]]},
     {"element": ["p", true, [], [{"text": "Example Usage:"}]]},
