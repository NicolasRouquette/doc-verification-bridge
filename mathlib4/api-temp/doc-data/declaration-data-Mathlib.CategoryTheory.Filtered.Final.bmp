#CategoryTheory.Category\">Category.{v₁, u₁}</a> <span class=\"fn\">C</span></span>]</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">D</span> : <a href=\"./foundational_types.html\">Type</a> u₂}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">[<span class=\"fn\"><a href=\"./Mathlib/CategoryTheory/Category/Basic.html#CategoryTheory.Category\">Category.{v₂, u₂}</a> <span class=\"fn\">D</span></span>]</span></span>\n</span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">F</span> : <span class=\"fn\"><a href=\"./Mathlib/CategoryTheory/Functor/Basic.html#CategoryTheory.Functor\">Functor</a> <span class=\"fn\">C</span> <span class=\"fn\">D</span></span>)</span></span>\n<span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">[<span class=\"fn\">∀ (<span class=\"fn\">d</span> : <span class=\"fn\">D</span>), <span class=\"fn\"><a href=\"./Mathlib/CategoryTheory/Filtered/Basic.html#CategoryTheory.IsCofiltered\">IsCofiltered</a> <span class=\"fn\">(<a href=\"./Mathlib/CategoryTheory/Comma/StructuredArrow/Basic.html#CategoryTheory.CostructuredArrow\">CostructuredArrow</a> <span class=\"fn\">F</span> <span class=\"fn\">d</span>)</span></span></span>]</span></span>\n</span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><span class=\"fn\">F</span>.<a href=\"./Mathlib/CategoryTheory/Limits/Final.html#CategoryTheory.Functor.Initial\">Initial</a></span></div></div>","info":{"doc":"If `CostructuredArrow F d` is filtered for any `d : D`, then `F : C ⥤ D` is initial. This is\nsimply because cofiltered categories are connected. More profoundly, the converse is also true\nif `C` is cofiltered, see `initial_iff_isCofiltered_costructuredArrow`. ","docLink":"./Mathlib/CategoryTheory/Filtered/Final.html#CategoryTheory.Functor.initial_of_isCofiltered_costructuredArrow","kind":"theorem","line":56,"name":"CategoryTheory.Functor.initial_of_isCofiltered_costructuredArrow","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/0f1dd7505c3d08b5feb82300ccc73179a457bf51/Mathlib/CategoryTheory/Filtered/Final.lean#L56-L61"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">theorem</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Mathlib/CategoryTheory/Filtered/Final.html#CategoryTheory.Functor.final_of_isFiltered_structuredArrow\"><span class=\"name\">CategoryTheory</span>.<span class=\"name\">Functor</span>.<span class=\"name\">final_of_isFiltered_structuredArrow</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">C</span> : <a href=\"./foundational_types.html\">Type</a> u₁}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">[<span class=\"fn\"><a href=\"./Mathlib/CategoryTheory/Category/Basic.html#CategoryTheory.Category\">Category.{v₁, u₁}</a> <span class=\"fn\">C</span></span>]</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">D</span> : <a href=\"./foundational_types.html\">Type</a> u₂}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">[<span class=\"fn\"><a href=\"./Mathlib/CategoryTheory/Category/Basic.html#CategoryTheory.Category\">Category.{v₂, u₂}</a> <span class=\"fn\">D</span></span>]</span></span>\n</span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">F</span> : <span class=\"fn\"><a href=\"./Mathlib/CategoryTheory/Functor/Basic.html#CategoryTheory.Functor\">Functor</a> <span class=\"fn\">C</span> <span class=\"fn\">D</span></span>)</span></span>\n<span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">[<span class=\"fn\">∀ (<span class=\"fn\">d</span> : <span class=\"fn\">D</span>), <span class=\"fn\"><a href=\"./Mathlib/CategoryTheory/Filtered/Basic.html#CategoryTheory.IsFiltered\">IsFiltered</a> <span class=\"fn\">(<a href=\"./Mathlib/CategoryTheory/Comma/StructuredArrow/Basic.html#CategoryTheory.StructuredArrow\">StructuredArrow</a> <span class=\"fn\">d</span> <span class=\"fn\">F</span>)</span></span></span>]</span></span>\n</span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><span class=\"fn\">F</span>.<a href=\"./Mathlib/CategoryTheory/Limits/Final.html#CategoryTheory.Functor.Final\">Final</a></span></div></div>","info":{"doc":"If `StructuredArrow d F` is filtered for any `d : D`, then `F : C ⥤ D` is final. This is\nsimply because filtered categories are connected. More profoundly, the converse is also true if\n`C` is filtered, see `final_iff_isFiltered_structuredArrow`. ","docLink":"./Mathlib/CategoryTheory/Filtered/Final.html#CategoryTheory.Functor.final_of_isFiltered_structuredArrow","kind":"theorem","line":49,"name":"CategoryTheory.Functor.final_of_isFiltered_structuredArrow","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/0f1dd7505c3d08b5feb82300ccc73179a457bf51/Mathlib/CategoryTheory/Filtered/Final.lean#L49-L54"}}],"imports":["Init","Mathlib.CategoryTheory.Filtered.Connected","Mathlib.CategoryTheory.Limits.Final.Connected","Mathlib.CategoryTheory.Limits.Types.Filtered","Mathlib.CategoryTheory.Limits.Sifted"],"instances":[{"className":"CategoryTheory.IsFiltered","name":"CategoryTheory.IsFiltered.under","typeNames":["CategoryTheory.Under"]},{"className":"CategoryTheory.IsCofiltered","name":"CategoryTheory.IsCofiltered.over","typeNames":["CategoryTheory.Over"]},{"className":"CategoryTheory.Functor.Final","name":"CategoryTheory.Under.final_forget","typeNames":["CategoryTheory.Under.forget"]},{"className":"CategoryTheory.Functor.Initial","name":"CategoryTheory.Over.initial_forget","typeNames":["CategoryTheory.Over.forget"]},{"className":"CategoryTheory.IsFiltered","name":"CategoryTheory.instIsFilteredStructuredArrowProdDiagOfIsFilteredOrEmpty","typeNames":["CategoryTheory.StructuredArrow"]}