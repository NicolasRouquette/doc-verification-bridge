Ordinal/Veblen.html#Ordinal.invVeblen₂\"><span class=\"name\">Ordinal</span>.<span class=\"name\">invVeblen₂</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">x</span> : <a href=\"./Mathlib/SetTheory/Ordinal/Basic.html#Ordinal\">Ordinal.{u_1}</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Mathlib/SetTheory/Ordinal/Basic.html#Ordinal\">Ordinal.{u_1}</a></div></div>","info":{"doc":"For any given `x`, there exists a unique pair `(o, a)` such that `ω ^ x = veblen o a` and\n`a < ω ^ x`. `invVeblen₁ x` and `invVeblen₂ x` return the first and second entries of this pair,\nrespectively. See `veblen_eq_opow_iff` for a proof.\n\nComposing this function with `Ordinal.CNF` yields a predicative ordinal notation up to `Γ₀`. ","docLink":"./Mathlib/SetTheory/Ordinal/Veblen.html#Ordinal.invVeblen₂","kind":"def","line":472,"name":"Ordinal.invVeblen₂","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/0f1dd7505c3d08b5feb82300ccc73179a457bf51/Mathlib/SetTheory/Ordinal/Veblen.lean#L472-L474"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">theorem</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Mathlib/SetTheory/Ordinal/Veblen.html#Ordinal.invVeblen₁_zero\"><span class=\"name\">Ordinal</span>.<span class=\"name\">invVeblen₁_zero</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Mathlib/SetTheory/Ordinal/Veblen.html#Ordinal.invVeblen₁\">invVeblen₁</a> <span class=\"fn\">0</span></span> <a href=\"./Init/Prelude.html#Eq\">=</a> <span class=\"fn\">0</span></div></div>","info":{"doc":"","docLink":"./Mathlib/SetTheory/Ordinal/Veblen.html#Ordinal.invVeblen₁_zero","kind":"theorem","line":468,"name":"Ordinal.invVeblen₁_zero","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/0f1dd7505c3d08b5feb82300ccc73179a457bf51/Mathlib/SetTheory/Ordinal/Veblen.lean#L468-L470"}},{"header":"<div class=\"d