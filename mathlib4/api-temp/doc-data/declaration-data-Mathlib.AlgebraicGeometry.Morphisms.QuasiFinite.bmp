etry/RingedSpace/PresheafedSpace.html#AlgebraicGeometry.PresheafedSpace.Hom.base\">base</a></span>)</span>.<a href=\"./Mathlib/CategoryTheory/Functor/Basic.html#CategoryTheory.Functor.obj\">obj</a></span> <span class=\"fn\">U</span></span>),\n            <span class=\"fn\"><span class=\"fn\">(<a href=\"./Mathlib/Algebra/Category/Ring/Basic.html#CommRingCat.Hom.hom\">CommRingCat.Hom.hom</a> <span class=\"fn\">(<a href=\"./Mathlib/AlgebraicGeometry/Scheme.html#AlgebraicGeometry.Scheme.Hom.appLE\">Scheme.Hom.appLE</a> <span class=\"fn\">f</span> <span class=\"fn\">U</span> <span class=\"fn\">V</span> <span class=\"fn\">e</span>)</span>)</span>.<a href=\"./Mathlib/RingTheory/RingHom/QuasiFinite.html#RingHom.QuasiFinite\">QuasiFinite</a></span></span></span></span></span></span></div></div>","info":{"doc":"","docLink":"./Mathlib/AlgebraicGeometry/Morphisms/QuasiFinite.html#AlgebraicGeometry.locallyQuasiFinite_iff","kind":"theorem","line":70,"name":"AlgebraicGeometry.locallyQuasiFinite_iff","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/0f1dd7505c3d08b5feb82300ccc73179a457bf51/Mathlib/AlgebraicGeometry/Morphisms/QuasiFinite.lean#L70-L70"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">class</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Mathlib/AlgebraicGeometry/Morphisms/QuasiFinite.html#AlgebraicGeometry.LocallyQuasiFinite\"><span class=\"name\">AlgebraicGeometry</span>.<span class=\"name\">LocallyQuasiFinite</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">X </span><span class=\"fn\">Y</span> : <a href=\"./Mathlib/AlgebraicGeometry/Scheme.html#AlgebraicGeometry.Scheme\">Scheme</a>}</span></span>\n</span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">f</span> : <span class=\"fn\">X</span> <a href=\"./Mathlib/Combinatorics/Quiver/Basic.html#Quiver.Hom\">⟶</a> <span class=\"fn\">Y</span>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./foundational_types.html\">Prop</a></div></div>","info":{"doc":"We say that a morphism `f : X ⟶ Y` is locally quasi finite if `Γ(Y, U) ⟶ Γ(X, V)` is\nquasi-finite (in the mathlib sense) for every pair of affine opens that `f` maps one into the other.\n\nNote that this does not require `f` to be quasi-compact nor locally of finite type.\n\nBeing locally quasi-finite implies that `f` has discrete and finite fibers\n(via `f.isDiscrete_preimage_singleton` and `f.finite_preimage_singleton`).\nThe converse holds under various scenarios:\n\n- `locallyQuasiFinite_iff_isDiscrete_preimage_singleton`:\n  If `f` is quasi-compact, this is equivalent to `f ⁻¹ {x}` being `κ(x)`-finite for all `x`.\n- `locallyQuasiFinite_iff_isDiscrete_preimage_singleton`:\n  If `f` is locally of finite type, this is equivalent to `f` having discrete fibers.\n- `locallyQuasiFinite_iff_isDiscrete_preimage_singleton`:\n  If `f` is locally of finite type, this is equivalent to `f` having finite fibers.\n","docLink":"./Mathlib/AlgebraicGeometry/Morphisms/QuasiFinite.html#AlgebraicGeometry.LocallyQuasiFinite","kind":"class","line":53,"name":"AlgebraicGeometry.LocallyQuasiFinite","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/0f1dd7505c3d08b5feb82300ccc73179a457bf51/Mathlib/AlgebraicGeometry/Morphisms/QuasiFinite.lean#L53-L74"}}],"imports":["Init","Mathlib.AlgebraicGeometry.Artinian","Mathlib.AlgebraicGeometry.Fiber","Mathlib.AlgebraicGeometry.Morphisms.Finite","Mathlib.AlgebraicGeometry.Morphisms.UniversallyInjective","Mathlib.RingTheory.RingHom.QuasiFinite","Mathlib.RingTheory.ZariskisMainTheorem"],"instances":[{"className":"AlgebraicGeometry.HasRingHomProperty","name":"AlgebraicGeometry.instHasRingHomPropertyLocallyQuasiFiniteQuasiFinite","typeNames":["AlgebraicGeometry.LocallyQuasiFinite"]},{"className":"CategoryTheory.MorphismProperty.IsStableUnderComposition","name":"AlgebraicGeometry.instIsStableUnderCompositionSchemeLocallyQuasiFinite","typeNames":["AlgebraicGeometry.LocallyQuasiFinite"]},{"className":"AlgebraicGeometry.LocallyQuasiFinite","name":"AlgebraicGeometry.instLocallyQuasiFiniteCompScheme","typeNames":["CategoryTheory.CategoryStruct.comp"]},{"className":"AlgebraicGeometry.LocallyQuasiFinite","name":"AlgebraicGeometry.instLocallyQuasiFiniteOfIsFinite","typeNames":[]},{"className":"AlgebraicGeometry.LocallyQuasiFinite","name":"AlgebraicGeometry.instLocallyQuasiFiniteOfIsImmersion","typeNames":[]},{"className":"CategoryTheory.MorphismProperty.IsMultiplicative","name":"AlgebraicGeometry.instIsMultiplicativeSchemeLocallyQuasiFinite","typeNames":["AlgebraicGeometry.LocallyQuasiFinite"]},{"className":"CategoryTheory.MorphismProperty.IsStableUnderBaseChange","name":"AlgebraicGeometry.instIsStableUnderBaseChangeSchemeLocallyQuasiFinite","typeNames":["AlgebraicGeometry.LocallyQuasiFinite"]},{"className":"AlgebraicGeometry.LocallyQuasiFinite","name":"AlgebraicGeometry.instLocallyQuasiFiniteFstScheme","typeNames":["CategoryTheory.Limits.pullback.fst"]},{"className":"AlgebraicGeometry.LocallyQuasiFinite","name":"AlgebraicGeometry.instLocallyQuasiFiniteSndScheme","typeNames":["CategoryTheory.Limits.pullback.snd"]},{"className":"AlgebraicGeometry.LocallyQuasiFinite","name":"AlgebraicGeometry.instLocallyQuasiFiniteMorphismRestrict","typeNames":["AlgebraicGeometry.morphismRestrict"]},{"className":"AlgebraicGeometry.LocallyQuasiFinite","name":"AlgebraicGeometry.instLocallyQuasiFiniteResLE","typeNames":["AlgebraicGeometry.Scheme.Hom.resLE"]},{"className":"CategoryTheory.MorphismProperty.Respects","name":"AlgebraicGeometry.instRespectsSchemeLocallyQuasiFiniteIsOpenImmersion","typeNames":["AlgebraicGeometry.LocallyQuasiFinite","AlgebraicGeometry.IsOpenImmersion"]},{"className":"AlgebraicGeometry.IsLocallyArtinian","name":"AlgebraicGeometry.instIsLocallyArtinianFiberOfLocallyQuasiFinite","typeNames":["AlgebraicGeometry.Scheme.Hom.fiber"]},{"className":"AlgebraicGeometry.IsArtinianScheme","name":"AlgebraicGeometry.instIsArtinianSchemeFiberOfLocallyQuasiFiniteOfQuasiCompact","typeNames":["AlgebraicGeometry.Scheme.Hom.fiber"]},{"className":"AlgebraicGeometry.IsFinite","name":"AlgebraicGeometry.instIsFiniteFiberToSpecResidueFieldOfLocallyQuasiFiniteOfQuasiCompact","typeNames":["AlgebraicGeometry.Scheme.Hom.fiberToSpecResidueField"]},{"className":"AlgebraicGeometry.LocallyQuasiFinite","name":"AlgebraicGeometry.instLocallyQuasiFiniteOfIsPreimmersion","typeNames":[]},{"className":"AlgebraicGeometry.LocallyQuasiFinite","name":"AlgebraicGeometry.instLocallyQuasiFiniteOfLocallyOfFiniteTypeOfUniversallyInjective","typeNames":[]}],"name":"Mathlib.AlgebraicGeometry.Morphisms.QuasiFinite"}