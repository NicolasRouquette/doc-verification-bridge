> : <span class=\"fn\">V</span> <a href=\"./Init/Prelude.html#LE.le\">≤</a> <span class=\"fn\"><span class=\"fn\"><span class=\"fn\">(<a href=\"./Mathlib/Topology/Category/TopCat/Opens.html#TopologicalSpace.Opens.map\">TopologicalSpace.Opens.map</a> <span class=\"fn\"><span class=\"fn\">f</span>.<a href=\"./Mathlib/Geometry/RingedSpace/PresheafedSpace.html#AlgebraicGeometry.PresheafedSpace.Hom.base\">base</a></span>)</span>.<a href=\"./Mathlib/CategoryTheory/Functor/Basic.html#CategoryTheory.Functor.obj\">obj</a></span> <span class=\"fn\">U</span></span>),\n            <span class=\"fn\"><span class=\"fn\">(<a href=\"./Mathlib/Algebra/Category/Ring/Basic.html#CommRingCat.Hom.hom\">CommRingCat.Hom.hom</a> <span class=\"fn\">(<a href=\"./Mathlib/AlgebraicGeometry/Scheme.html#AlgebraicGeometry.Scheme.Hom.appLE\">Scheme.Hom.appLE</a> <span class=\"fn\">f</span> <span class=\"fn\">U</span> <span class=\"fn\">V</span> <span class=\"fn\">e</span>)</span>)</span>.<a href=\"./Mathlib/RingTheory/RingHom/QuasiFinite.html#RingHom.QuasiFinite\">QuasiFinite</a></span></span></span></span></span></span>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Mathlib/AlgebraicGeometry/Morphisms/QuasiFinite.html#AlgebraicGeometry.LocallyQuasiFinite\">LocallyQuasiFinite</a> <span class=\"fn\">f</span></span></div></div>","info":{"doc":"","docLink":"./Mathlib/AlgebraicGeometry/Morphisms/QuasiFinite.html#AlgebraicGeometry.LocallyQuasiFinite.mk","kind":"ctor","line":71,"name":"AlgebraicGeometry.LocallyQuasiFinite.mk","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/0f1dd7505c3d08b5feb82300ccc73179a457bf51/Mathlib/AlgebraicGeometry/Morphisms/QuasiFinite.lean#L71-L71"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">theorem</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Mathlib/AlgebraicGeometry/Morphisms/QuasiFinite.html#AlgebraicGeometry.locallyQuasiFinite_iff\"><span class=\"nam