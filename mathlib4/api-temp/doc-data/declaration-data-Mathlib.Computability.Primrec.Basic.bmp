\">(<a href=\"./Mathlib/Logic/Encodable/Basic.html#Encodable.decode\">Encodable.decode</a> <span class=\"fn\">n</span>)</span></span></span></span>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Mathlib/Computability/Primrec/Basic.html#Primcodable\">Primcodable</a> <span class=\"fn\">α</span></span></div></div>","info":{"doc":"","docLink":"./Mathlib/Computability/Primrec/Basic.html#Primcodable.mk","kind":"ctor","line":132,"name":"Primcodable.mk","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/087469e24922b85cb737497c74556c7dacc01f22/Mathlib/Computability/Primrec/Basic.lean#L132-L132"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">abbrev</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Mathlib/Computability/Primrec/Basic.html#Primcodable.toEncodable\"><span class=\"name\">Primcodable</span>.<span class=\"name\">toEncodable</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">α</span> : <a href=\"./foundational_types.html\">Type</a> u_1}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">[<span class=\"fn\">self</span> : <span class=\"fn\"><a href=\"./Mathlib/Computability/Primrec/Basic.html#Primcodable\">Primcodable</a> <span class=\"fn\">α</span></span>]</span></span>\n</span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Mathlib/Logic/Encodable/Basic.html#Encodable\">Encodable</a> <span class=\"fn\">α</span></span></div></div>","info":{"doc":"","docLink":"./Mathlib/Computability/Primrec/Basic.html#Primcodable.toEncodable","kind":"def","line":132,"name":"Primcodable.toEncodable","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/087469e24922b85cb737497c74556c7dacc01f22/Mathlib/Computability/Primrec/Basic.lean#L132-L133"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">class</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Mathlib/Computability/Primrec/Basic.html#Primcodable\"><span class=\"name\">Primcodable</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">α</span> : <a href=\"./foundational_types.html\">Type</a> u_1)</span></span>\n<span class=\"decl_extends\">extends</span> <span class=\"fn\"><a href=\"./Mathlib/Logic/Encodable/Basic.html#Encodable\">Encodable</a> <span class=\"fn\">α</span></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./foundational_types.html\">Type</a> u_1</div></div>","info":{"doc":"A `Primcodable` type is, essentially, an `Encodable` type for which\nthe encode/decode functions are primitive recursive.\nHowever, such a definition is circular.\n\nInstead, we ask that the composition of `decode : ℕ → Option α` with\n`encode : Option α → ℕ` is primitive recursive. Said composition is\nthe identity function, restricted to the image of `encode`.\nThus, in a way, the added requirement ensures that no predicates\ncan be smuggled in through a cunning choice of the subset of `ℕ` into\nwhich the type is encoded. ","docLink":"./Mathlib/Computability/Primrec/Basic.html#Primcodable","kind":"class","line":122,"name":"Primcodable","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/087469e24922b85cb737497c74556c7dacc01f22/Mathlib/Computability/Primrec/Basic.lean#L122-L133"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">theorem</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Mathlib/Computability/Primrec/Basic.html#Nat.Primrec.pow\"><span class=\"name\">Nat</span>.<span class=\"name\">Primrec</span>.<span class=\"name\">pow</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Mathlib/Computability/Primrec/Basic.html#Nat.Primrec\">Nat.Primrec</a> <span class=\"fn\">(<a href=\"./Mathlib/Computability/Primrec/Basic.html#Nat.unpaired\">unpaired</a> <span class=\"fn\">fun (<span class=\"fn\">x1</span> <span class=\"fn\">x2</span> : <a href=\"./Init/Prelude.html#Nat\">ℕ</a>) =&gt; <span class=\"fn\">x1</span> <a href=\"./Init/Prelude.html#HPow.hPow\">^</a> <span class=\"fn\">x2</span></span>)</span></span></div></div>","info":{"doc":"","docLink":"./Mathlib/Computability/Primrec/Basic.html#Nat.Primrec.pow","kind":"theorem","line":114,"name":"Nat.Primrec.pow","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/087469e24922b85cb737497c74556c7dacc01f22/Mathlib/Computability/Primrec/Basic.lean#L114-L116"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">theorem</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Mathlib/Computability/Primrec/Basic.html#Nat.Primrec.mul\"><span class=\"name\">Nat</span>.<span class=\"name\">Primrec</span>.<span class=\"name\">mul</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Mathlib/Computability/Primrec/Basic.html#Nat.Primrec\">Nat.Primrec</a> <span class=\"fn\">(<a href=\"./Mathlib/Computability/Primrec/Basic.html#Nat.unpaired\">unpaired</a> <span class=\"fn\">fun (<span class=\"fn\">x1</span> <span class=\"fn\">x2</span> : <a href=\"./Init/Prelude.html#Nat\">ℕ</a>) =&gt; <span class=\"fn\">x1</span> <a href=\"./Init/Prelude.html#HMul.hMul\">*</a> <span class=\"fn\">x2</span></span>)</span></span></div></div>","info":{"doc":"","docLink":"./Mathlib/Computability/Primrec/Basic.html#Nat.Primrec.mul","kind":"theorem","line":110,"name":"Nat.Primrec.mul","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/087469e24922b85cb737497c74556c7dacc01f22/Mathlib/Computability/Primrec/Basic.lean#L110-L112"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">theorem</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Mathlib/Computability/Primrec/Basic.html#Nat.Primrec.sub\"><span class=\"name\">Nat</span>.<span class=\"name\">Primrec</