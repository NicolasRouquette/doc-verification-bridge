ude.html#Eq\">=</a> <span class=\"fn\"><a href=\"./Mathlib/Order/Filter/Defs.html#Filter.Eventually\">∀ᶠ</a> (<span class=\"fn\">x</span> : <span class=\"fn\">α</span>) <a href=\"./Mathlib/Order/Filter/Defs.html#Filter.Eventually\">in</a> <span class=\"fn\">l</span><a href=\"./Mathlib/Order/Filter/Defs.html#Filter.Eventually\">,</a> <a href=\"./Mathlib/Analysis/Normed/Group/Defs.html#Norm.norm\">‖</a><span class=\"fn\"><span class=\"fn\">f</span> <span class=\"fn\">x</span></span><a href=\"./Mathlib/Analysis/Normed/Group/Defs.html#Norm.norm\">‖</a> <a href=\"./Init/Prelude.html#LE.le\">≤</a> <span class=\"fn\">c</span> <a href=\"./Init/Prelude.html#HMul.hMul\">*</a> <a href=\"./Mathlib/Analysis/Normed/Group/Defs.html#Norm.norm\">‖</a><span class=\"fn\"><span class=\"fn\">g</span> <span class=\"fn\">x</span></span><a href=\"./Mathlib/Analysis/Normed/Group/Defs.html#Norm.norm\">‖</a></span></div></div>","info":{"doc":"","docLink":"./Mathlib/Analysis/Asymptotics/Defs.html#Asymptotics.IsBigOWith_def","kind":"theorem","line":85,"name":"Asymptotics.IsBigOWith_def","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/0f1dd7505c3d08b5feb82300ccc73179a457bf51/Mathlib/Analysis/Asymptotics/Defs.lean#L85-L90"}}],"imports":["Init","Mathlib.Analysis.Normed.Field.Basic"],"instances":[{"className":"Trans","name":"Asymptotics.transEventuallyEqIsBigO","typeNames":[]},{"className":"Trans","name":"Asymptotics.transEventuallyEqIsLittleO","typeNames":[]},{"className":"Trans","name":"Asymptotics.transIsBigOEventuallyEq","typeNames":[]},{"className":"Trans","name":"Asymptotics.transIsLittleOEventuallyEq","typeNames":[]},{"className":"Trans","name":"Asymptotics.transIsBigOIsBigO","typeNames":[]},{"className":"Trans","name":"Asymptotics.transIsLittleOIsBigO","typeNames":[]},{"className":"Trans","name":"Asymptotics.transIsBigOIsLittleO","typeNames":[]},{"className":"Trans","name":"Asymptotics.transIsLittleOIsLittleO","typeNames":[]}],"name":"Mathlib.Analysis.Asymptotics.Defs"}