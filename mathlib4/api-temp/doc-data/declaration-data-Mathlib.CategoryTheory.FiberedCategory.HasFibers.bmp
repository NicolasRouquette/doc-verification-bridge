bers.instFaithfulFibι","typeNames":["HasFibers.ι"]},{"className":"CategoryTheory.Functor.IsHomLift","name":"HasFibers.homLift","typeNames":["CategoryTheory.CategoryStruct.id","CategoryTheory.Functor.map"]},{"className":"CategoryTheory.Functor.IsHomLift","name":"HasFibers.Fib.mkIsoSelfIsHomLift","typeNames":["CategoryTheory.CategoryStruct.id","CategoryTheory.Iso.hom"]},{"className":"CategoryTheory.Functor.IsCartesian","name":"HasFibers.pullbackMap.isCartesian","typeNames":["HasFibers.pullbackMap"]}],"name":"Mathlib.CategoryTheory.FiberedCategory.HasFibers"}