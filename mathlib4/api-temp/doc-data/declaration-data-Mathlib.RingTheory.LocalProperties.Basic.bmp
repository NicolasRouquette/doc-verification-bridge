gTheory/LocalProperties/Basic.html#RingHom.LocalizationAwayPreserves\">LocalizationAwayPreserves</a> <span class=\"fn\">P</span></span>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">ofLocalizationSpanTarget</span> : <span class=\"fn\"><a href=\"./Mathlib/RingTheory/LocalProperties/Basic.html#RingHom.OfLocalizationSpanTarget\">OfLocalizationSpanTarget</a> <span class=\"fn\">P</span></span>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">ofLocalizationSpan</span> : <span class=\"fn\"><a href=\"./Mathlib/RingTheory/LocalProperties/Basic.html#RingHom.OfLocalizationSpan\">OfLocalizationSpan</a> <span class=\"fn\">P</span></span>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">StableUnderCompositionWithLocalizationAwayTarget</span> : <span class=\"fn\"><a href=\"./Mathlib/RingTheory/LocalProperties/Basic.html#RingHom.StableUnderCompositionWithLocalizationAwayTarget\">RingHom.StableUnderCompositionWithLocalizationAwayTarget</a> <span class=\"fn\">P</span></span>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Mathlib/RingTheory/LocalProperties/Basic.html#RingHom.PropertyIsLocal\">PropertyIsLocal</a> <span class=\"fn\">P</span></span></div></div>","info":{"doc":"","docLink":"./Mathlib/RingTheory/LocalProperties/Basic.html#RingHom.PropertyIsLocal.mk","kind":"ctor","line":183,"name":"RingHom.PropertyIsLocal.mk","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/0f1dd7505c3d08b5feb82300ccc73179a457bf51/Mathlib/RingTheory/LocalProperties/Basic.lean#L183-L183"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">structure</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Mathlib/RingTheory/LocalProperties/Basic.html#RingHom.PropertyIsLocal\"><span class=\"name\">RingHom</span>.<span class=\"name\">PropertyIsLocal</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">P</span> : <span class=\"fn\">{<span class=\"fn\">R </span><span class=\"fn\">S</span> : <a href=\"./foundational_types.html\">Type</a> u} → <span class=\"fn\">[<span class=\"fn\">inst</span> : <span class=\"fn\"><a href=\"./Mathlib/Algebra/Ring/Defs.html#CommRing\">CommRing</a> <span class=\"fn\">R</span></span>] → <span class=\"fn\">[<span class=\"fn\">inst_1</span> : <span class=\"fn\"><a href=\"./Mathlib/Algebra/Ring/Defs.html#CommRing\">CommRing</a> <span class=\"fn\">S</span></span>] → <span class=\"fn\">(<span class=\"fn\">R</span> <a href=\"./Mathlib/Algebra/Ring/Hom/Defs.html#RingHom\">→+*</a> <span class=\"fn\">S</span>) → <a href=\"./foundational_types.html\">Prop</a></span></span></span></span>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./foundational_types.html\">Prop</a></div></div>","info":{"doc":"A property of ring homs is local if it is preserved by localizations and compositions, and for\neach `{ r }` that spans `S`, we have `P (R →+* S) ↔ ∀ r, P (R →+* Sᵣ)`. ","docLink":"./Mathlib/RingTheory/LocalProperties/Basic.html#RingHom.PropertyIsLocal","kind":"structure","line":181,"name":"RingHom.PropertyIsLocal","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/0f1dd7505c3d08b5feb82300ccc73179a457bf51/Mathlib/RingTheory/LocalProperties/Basic.lean#L181-L188"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Mathlib/RingTheory/LocalProperties/Basic.html#RingHom.OfLocalizationPrime\"><span class=\"name\">RingHom</span>.<span class=\"name\">OfLocalizationPrime</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">P</span> : <span class=\"fn\">{<span class=\"fn\">R </span><span class=\"fn\">S</span> : <a href=\"./foundational_types.html\">Type</a> u} → <span class=\"fn\">[<span class=\"fn\">inst</span> : <span class=\"fn\"><a href=\"./Mathlib/Algebra/Ring/Defs.html#CommRing\">CommRing</a> <span class=\"fn\">R</span></span>] → <span class=\"fn\">[<span class=\"fn\">inst_1</span> : <span class=\"fn\"><a href=\"./Mathlib/Algebra/Ring/Defs.html#CommRing\">CommRing</a> <span class=\"fn\">S</span></span>] → <span class=\"fn\">(<span class=\"fn\">R</span> <a href=\"./Mathlib/Algebra/Ring/Hom/Defs.html#RingHom\">→+*</a> <span class=\"fn\">S</span>) → <a href=\"./foundational_types.html\">Prop</a></span></span></span></span>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./foundational_types.html\">Prop</a></div></div>","info":{"doc":"A property `P` of ring homs satisfies `RingHom.OfLocalizationPrime`\nif `P` holds for `R` whenever `P` holds for `Rₘ` for all prime ideals `p`. ","docLink":"./Mathlib/RingTheory/LocalProperties/Basic.html#RingHom.OfLocalizationPrime","kind":"def","line":175,"name":"RingHom.OfLocalizationPrime","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/0f1dd7505c3d08b5feb82300ccc73179a457bf51/Mathlib/RingTheory/LocalProperties/Basic.lean#L175-L179"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Mathlib/RingTheory/LocalProperties/Basic.html#RingHom.OfLocalizationSpanTarget\"><span class=\"name\">RingHom</span>.<span class=\"name\">OfLocalizationSpanTarget</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">P</span> : <span class=\"fn\">{<span class=\"fn\">R </span><span class=\"fn\">S</span> : <a href=\"./foundational_types.html\">Type</a> u} → <span class=\"fn\">[<span class=\"fn\">inst</span> : <span class=\"fn\"><a href=\"./Mathlib/Algebra/Ring/Defs.html#CommRing\">CommRing</a> <span class=\"fn\">R</span></span>] → <span class=\"fn\">[<span class=\"fn\">inst_1</span> : <span class=\"fn\"><a href=\"./Mathlib/Algebra/Ring/Defs.html#CommRing\">CommRing</a> <span class=\"fn\">S</span></span>] → <span class=\"fn\">(<span class=\"fn\">R</span> <a href=\"./Mathlib/Algebra/Ring/Hom/Defs.html#RingHom\">→+*</a> <span class=\"fn\">S</span>) → <a href=\"./foundational_types.html\">Prop</a></span></span></span></span>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./foundational_types.html\">Prop</a></div></div>","info":{"doc":"A property `P` of ring homs satisfies `RingHom.OfLocalizationSpanTarget`\nif `P` holds for `R →+* S` whenever there exists a set `{ r }` that spans `S` such that\n`P` holds for `R →+* Sᵣ`.\n\nNote that this is equivalent to `RingHom.OfLocalizationFiniteSpanTarget` via\n`RingHom.ofLocalizationSpanTarget_iff_finite`, but this has less restrictions when applying. ","docLink":"./Mathlib/RingTheory/LocalProperties/Basic.html#RingHom.OfLocalizationSpanTarget","kind":"def","line":165,"name":"RingHom.OfLocalizationSpanTarget","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/0f1dd7505c3d08b5feb82300ccc73179a457bf51/Mathlib/RingTheory/LocalProperties/Basic.lean#L165-L173"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Mathlib/RingTheory/LocalProperties/Basic.html#RingHom.OfLocalizationFiniteSpanTarget\"><span class=\"name\">RingHom</span>.<span class=\"name\">OfLocalizationFiniteSpanTarget</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">P</span> : <span class=\"fn\">{<span class=\"fn\">R </span><span class=\"fn\">S</span> : <a href=\"./foundational_types.html\">Type</a> u} → <span class=\"fn\">[<span class=\"fn\">inst</span> : <span class=\"fn\"><a href=\"./Mathlib/Algebra/Ring/Defs.html#CommRing\">CommRing</a> <span class=\"fn\">R</span></span>] → <span class=\"fn\">[<span class=\"fn\">inst_1</span> : <span class=\"fn\"><a href=\"./Mathlib/Algebra/Ring/Defs.html#CommRing\">CommRing</a> <span class=\"fn\">S</span></span>] → <span class=\"fn\">(<span class=\"fn\">R</span> <a href=\"./Mathlib/Algebra/Ring/Hom/Defs.html#RingHom\">→+*</a> <span class=\"fn\">S</span>) → <a href=\"./foundational_types.html\">Prop</a></span></span></span></span>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./foundational_types.html\">Prop</a></div></div>","info":{"doc":"A property `P` of ring homs satisfies `RingHom.OfLocalizationFiniteSpanTarget`\nif `P` holds for `R →+* S` whenever there exists a finite set `{ r }` that spans `S` such that\n`P` holds for `R →+* Sᵣ`.\n\nNote that this is equivalent to `RingHom.OfLocalizationSpanTarget` via\n`RingHom.ofLocalizationSpanTarget_iff_finite`, but this is easier to prove. ","docLink":"./Mathlib/RingTheory/LocalProperties/Basic.html#RingHom.OfLocalizationFiniteSpanTarget","kind":"def","line":154,"name":"RingHom.OfLocalizationFiniteSpanTarget","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/0f1dd7505c3d08b5feb82300ccc73179a457bf51/Mathlib/RingTheory/LocalProperties/Basic.lean#L154-L163"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Mathlib/RingTheory/LocalProperties/Basic.html#RingHom.StableUnderCompositionWithLocalizationAway\"><span class=\"name\">RingHom</span>.<span class=\"name\">StableUnderCompositionWithLocalizationAway</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">P</span> : <span class=\"fn\">{<span class=\"fn\">R </span><span class=\"fn\">S</span> : <a href=\"./foundational_types.html\">Type</a> u} → <span class=\"fn\">[<span class=\"fn\">inst</span> : <span class=\"fn\"><a href=\"./Mathlib/Algebra/Ring/Defs.html#CommRing\">CommRing</a> <span class=\"fn\">R</span></span>] → <span class=\"fn\">[<span class=\"fn\">inst_1</span> : <span class=\"fn\"><a href=\"./Mathlib/Algebra/Ring/Defs.html#CommRing\">CommRing</a> <span class=\"fn\">S</span></span>] → <span class=\"fn\">(<span class=\"fn\">R</span> <a href=\"./Mathlib/Algebra/Ring/Hom/Defs.html#RingHom\">→+*</a> <span class=\"fn\">S</span>) → <a href=\"./foundational_types.html\">Prop</a></span></span></span></span>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./foundational_types.html\">Prop</a></div></div>","info":{"doc":"A property `P` of ring homs satisfies `RingHom.StableUnderCompositionWithLocalizationAway`\nif whenever `P` holds for `f` it also holds for the composition with\nlocalization maps on the left and on the right. ","docLink":"./Mathlib/RingTheory/LocalProperties/Basic.html#RingHom.StableUnderCompositionWithLocalizationAway","kind":"def","line":147,"name":"RingHom.StableUnderCompositionWithLocalizationAway","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/0f1dd7505c3d08b5feb82300ccc73179a457bf51/Mathlib/RingTheory/LocalProperties/Basic.lean#L147-L152"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Mathlib/RingTheory/LocalProperties/Basic.html#RingHom.StableUnderCompositionWithLocalizationAwayTarget\"><span class=\"name\">RingHom</span>.<span class=\"name\">StableUnderCompositionWithLocalizationAwayTarget</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">P</span> : <span class=\"fn\">{<span class=\"fn\">R </span><span class=\"fn\">S</span> : <a href=\"./foundational_types.html\">Type</a> u} → <span class=\"fn\">[<span class=\"fn\">inst</span> : <span class=\"fn\"><a href=\"./Mathlib/Algebra/Ring/Defs.html#CommRing\">CommRing</a> <span class=\"fn\">R</span></span>] → <span class=\"fn\">[<span class=\"fn\">inst_1</span> : <span class=\"fn\"><a href=\"./Mathlib/Algebra/Ring/Defs.html#CommRing\">CommRing</a> <span class=\"fn\">S</span></span>] → <span class=\"fn\">(<span class=\"fn\">R</span> <a href=\"./Mathlib/Algebra/Ring/Hom/Defs.html#RingHom\">→+*</a> <span class=\"fn\">S</span>) → <a href=\"./foundational_types.html\">Prop</a></span></span></span></span>)</spa