ategoryTheory.Equivalence.counitIso\">counitIso</a></span>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\">x</span> <a href=\"./Init/Prelude.html#Eq\">=</a> <span class=\"fn\">y</span></div></div>","info":{"doc":"","docLink":"./Mathlib/CategoryTheory/Equivalence.html#CategoryTheory.Equivalence.ext","kind":"theorem","line":84,"name":"CategoryTheory.Equivalence.ext","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/087469e24922b85cb737497c74556c7dacc01f22/Mathlib/CategoryTheory/Equivalence.lean#L84-L84"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">theorem</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Mathlib/CategoryTheory/Equivalence.html#CategoryTheory.Equivalence.ext_iff\"><span class=\"name\">CategoryTheory</span>.<span class=\"name\">Equivalence</span>.<span class=\"name\">ext_iff</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">C</span> : <a href=\"./foundational_types.html\">Type</a> u₁}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">D</span> : <a href=\"./foundational_types.html\">Type</a> u₂}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">inst✝</span> : <span class=\"fn\"><a href=\"./Mathlib/CategoryTheory/Category/Basic.html#CategoryTheory.Category\">Category.{v₁, u₁}</a> <span class=\"fn\">C</span></span>}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">inst✝¹</span> : <span class=\"fn\"><a href=\"./Mathlib/CategoryTheory/Category/Basic.html#CategoryTheory.Category\">Category.{v₂, u₂}</a> <span class=\"fn\">D</span></span>}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">x </span><span class=\"fn\">y</span> : <span class=\"fn\">C</span> <a href=\"./Mathlib/CategoryTheory/Equivalence.html#CategoryTheory.Equivalence\">≌</a> <span class=\"fn\">D</span>}</span></span>\n</span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\">x</span> <a href=\"./Init/Prelude.html#Eq\">=</a> <span class=\"fn\">y</span> <a href=\"./Init/Core.html#Iff\">↔</a> <span class=\"fn\"><span class=\"fn\">x</span>.<a href=\"./Mathlib/CategoryTheory/Equivalence.html#CategoryTheory.Equivalence.functor\">functor</a></span> <a href=\"./Init/Prelude.html#Eq\">=</a> <span class=\"fn\"><span class=\"fn\">y</span>.<a href=\"./Mathlib/CategoryTheory/Equivalence.html#CategoryTheory.Equivalence.functor\">functor</a></span> <a href=\"./Init/Prelude.html#And\">∧</a> <span class=\"fn\"><span class=\"fn\">x</span>.<a href=\"./Mathlib/CategoryTheory/Equivalence.html#CategoryTheory.Equivalence.inverse\">inverse</a></span> <a href=\"./Init/Prelude.html#Eq\">=</a> <span class=\"fn\"><span class=\"fn\">y</span>.<a href=\"./Mathlib/CategoryTheory/Equivalence.html#CategoryTheory.Equivalence.inverse\">inverse</a></span> <a href=\"./Init/Prelude.html#And\">∧</a> <span class=\"fn\"><span class=\"fn\">x</span>.<a href=\"./Mathlib/CategoryTheory/Equivalence.html#CategoryTheory.Equivalence.unitIso\">unitIso</a></span> <a href=\"./Init/Prelude.html#HEq\">≍</a> <span class=\"fn\"><span class=\"fn\">y</span>.<a href=\"./Mathlib/CategoryTheory/Equivalence.html#CategoryTheory.Equivalence.unitIso\">unitIso</a></span> <a href=\"./Init/Prelude.html#And\">∧</a> <span class=\"fn\"><span class=\"fn\">x</span>.<a href=\"./Mathlib/CategoryTheory/Equivalence.html#CategoryTheory.Equivalence.counitIso\">counitIso</a></span> <a href=\"./Init/Prelude.html#HEq\">≍</a> <span class=\"fn\"><span class=\"fn\">y</span>.<a href=\"./Mathlib/CategoryTheory/Equivalence.html#CategoryTheory.Equivalence.counitIso\">counitIso</a></span></div></div>","info":{"doc":"","docLink":"./Mathlib/CategoryTheory/Equivalence.html#CategoryTheory.Equivalence.ext_iff","kind":"theorem","line":84,"name":"CategoryTheory.Equivalence.ext_iff","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/087469e24922b85cb737497c74556c7dacc01f22/Mathlib/CategoryTheory/Equivalence.lean#L84-L84"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">structure</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Mathlib/CategoryTheory/Equivalence.html#CategoryTheory.Equivalence\"><span class=\"name\">CategoryTheory</span>.<span class=\"name\">Equivalence</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">C</span> : <a href=\"./foundational_types.html\">Type</a> u₁)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">D</span> : <a href=\"./foundational_types.html\">Type</a> u₂)</span></span>\n<span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">[<span class=\"fn\"><a href=\"./Mathlib/CategoryTheory/Category/Basic.html#CategoryTheory.Category\">Category.{v₁, u₁}</a> <span class=\"fn\">C</span></span>]</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">[<span class=\"fn\"><a href=\"./Mathlib/CategoryTheory/Category/Basic.html#CategoryTheory.Category\">Category.{v₂, u₂}</a> <span class=\"fn\">D</span></span>]</span></span>\n</span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./foundational_types.html\">Type</a> (max (max (max u₁ u₂) v₁) v₂)</div></div>","info":{"doc":"An equivalence of categories.\n\nWe define an equivalence between `C` and `D`, with notation `C ≌ D`, as a half-adjoint equivalence:\na pair of functors `F : C ⥤ D` and `G : D ⥤ C` with a unit `η : 𝟭 C ≅ F ⋙ G` and counit\n`ε : G ⋙ F ≅ 𝟭 D`, such that the natural isomorphisms `η` and `ε` satisfy the triangle law for\n`F`: namely, `Fη ≫ εF = 𝟙 F`. Or, in other words, the composite `F` ⟶ `F ⋙ G ⋙ F` ⟶ `F` is the\nidentity.\n\nIn `unit_inverse_comp`, we show that this is sufficient to establish a full adjoint\nequivalence. I.e., the composite `G` ⟶ `G ⋙ F ⋙ G` ⟶ `G` is also the identity.\n\nThe triangle equation `functor_unitIso_comp` is written as a family of equalities between\nmorphisms. It is more complicated if we write it as an equality of natural transformations, because\nthen we would either have to insert natural transformations like `F ⟶ F𝟭` or abuse defeq. ","docLink":"./Mathlib/CategoryTheory/Equivalence.html#CategoryTheory.Equivalence","kind":"structure","line":70,"name":"CategoryTheory.Equivalence","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/087469e24922b85cb737497c74556c7dacc01f22/Mathlib/CategoryTheory/Equivalence.lean#L70-L101"}}],"imports":["Init","Mathlib.CategoryTheory.Functor.FullyFaithful","Mathlib.CategoryTheory.ObjectProperty.FullSubcategory","Mathlib.CategoryTheory.Whiskering","Mathlib.CategoryTheory.EssentialImage","Mathlib.Tactic.CategoryTheory.Slice","Mathlib.Data.Int.Notation"],"instances":[{"className":"CategoryTheory.Category","name":"CategoryTheory.Equivalence.instCategory","typeNames":["CategoryTheory.Equivalence"]},{"className":"Inhabited","name":"CategoryTheory.Equivalence.instInhabited","typeNames":["CategoryTheory.Equivalence"]},{"className":"Pow","name":"CategoryTheory.Equivalence.instPowInt","typeNames":["CategoryTheory.Equivalence","Int"]},{"className":"CategoryTheory.Functor.EssSurj","name":"CategoryTheory.Equivalence.essSurj_functor","typeNames":["CategoryTheory.Equivalence.functor"]},{"className":"CategoryTheory.Functor.EssSurj","name":"CategoryTheory.Equivalence.essSurj_inverse","typeNames":["CategoryTheory.Equivalence.inverse"]},{"className":"CategoryTheory.Functor.Faithful","name":"CategoryTheory.Equivalence.faithful_functor","typeNames":["CategoryTheory.Equivalence.functor"]},{"className":"CategoryTheory.Functor.Faithful","name":"CategoryTheory.Equivalence.faithful_inverse","typeNames":["CategoryTheory.Equivalence.inverse"]},{"className":"CategoryTheory.Functor.Full","name":"CategoryTheory.Equivalence.full_functor","typeNames":["CategoryTheory.Equivalence.functor"]},{"className":"CategoryTheory.Functor.Full","name":"CategoryTheory.Equivalence.full_inverse","typeNames":["CategoryTheory.Equivalence.inverse"]},{"className":"CategoryTheory.Functor.IsEquivalence","name":"CategoryTheory.Equivalence.isEquivalence_functor","typeNames":["CategoryTheory.Equivalence.functor"]},{"className":"CategoryTheory.Functor.IsEquivalence","name":"CategoryTheory.Equivalence.isEquivalence_inverse","typeNames":["CategoryTheory.Equivalence.inverse"]},{"className":"CategoryTheory.Functor.IsEquivalence","name":"CategoryTheory.Functor.isEquivalence_refl","typeNames":["CategoryTheory.Functor.id"]},{"className":"CategoryTheory.Functor.IsEquivalence","name":"CategoryTheory.Functor.isEquivalence_inv","typeNames":["CategoryTheory.Functor.inv"]},{"className":"CategoryTheory.Functor.IsEquivalence","name":"CategoryTheory.Functor.isEquivalence_trans","typeNames":["CategoryTheory.Functor.comp"]},{"className":"CategoryTheory.Functor.IsEquivalence","name":"CategoryTheory.Functor.instIsEquivalenceObjWhiskeringLeft","typeNames":["CategoryTheory.Functor.obj"]},{"className":"CategoryTheory.Functor.IsEquivalence","name":"CategoryTheory.Functor.instIsEquivalenceObjWhiskeringRight","typeNames":["CategoryTheory.Functor.obj"]},{"className":"CategoryTheory.Functor.EssSurj","name":"CategoryTheory.Equivalence.essSurjInducedFunctor","typeNames":["CategoryTheory.inducedFunctor"]},{"className":"CategoryTheory.Functor.IsEquivalence","name":"CategoryTheory.Equivalence.inducedFunctorOfEquiv","typeNames":["CategoryTheory.inducedFunctor"]},{"className":"CategoryTheory.Functor.IsEquivalence","name":"CategoryTheory.Equivalence.fullyFaithfulToEssImage","typeNames":["CategoryTheory.Functor.toEssImage"]}],"name":"Mathlib.CategoryTheory.Equivalence"}