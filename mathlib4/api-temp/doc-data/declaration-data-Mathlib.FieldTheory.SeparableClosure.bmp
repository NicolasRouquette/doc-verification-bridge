bleClosure</a> <span class=\"fn\">F</span> <span class=\"fn\">E</span>)</span></span></span></div></div>","info":{"doc":"If `E` is normal over `F`, then the separable closure of `F` in `E` is Galois (i.e.\nnormal and separable) over `F`. ","docLink":"./Mathlib/FieldTheory/SeparableClosure.html#separableClosure.isGalois","kind":"instance","line":184,"name":"separableClosure.isGalois","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/0f1dd7505c3d08b5feb82300ccc73179a457bf51/Mathlib/FieldTheory/SeparableClosure.lean#L184-L191"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">theorem</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Mathlib/FieldTheory/SeparableClosure.html#separableClosure.normalClosure_eq_self\"><span class=\"name\">separableClosure</span>.<span class=\"name\">normalClosure_eq_self</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">F</span> : <a href=\"./foundational_types.html\">Type</a> u)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">E</span> : <a href=\"./foundational_types.html\">Type</a> v)</span></span>\n<span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">[<span class=\"fn\"><a href=\"./Mathlib/Algebra/Field/Defs.html#Field\">Field</a> <span class=\"fn\">F</span></span>]</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">[<span class=\"fn\"><a href=\"./Mathlib/Algebra/Field/Defs.html#Field\">Field</a> <span class=\"fn\">E</span></span>]</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">[<span class=\"fn\"><a href=\"./Mathlib/Algebra/Algebra/Defs.html#Algebra\">Algebra</a> <span class=\"fn\">F</span> <span class=\"fn\">E</span></span>]</span></span>\n</span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Mathlib/FieldTheory/Normal/Closure.html#IntermediateField.normalClosure\">IntermediateField.normalClosure</a> <span class=\"fn\">F</span> <span class=\"fn\">(↥<span class=\"fn\">(<a href=\"./Mathlib/FieldTheory/SeparableClosure.html#separableClosure\">separableClosure</a> <span class=\"fn\">F</span> <span class=\"fn\">E</span>)</span>)</span> <span class=\"fn\">E</span></span> <a href=\"./Init/Prelude.html#Eq\">=</a> <span class=\"fn\"><a href=\"./Mathlib/FieldTheory/SeparableClosure.html#separableClosure\">separableClosure</a> <span class=\"fn\">F</span> <span class=\"fn\">E</span></span></div></div>","info":{"doc":"The normal closure in `E/F` of the separable closure of `F` in `E` is equal to itself. ","docLink":"./Mathlib/FieldTheory/SeparableClosure.html#separableClosure.normalClosure_eq_self","kind":"theorem","line":176,"name":"separableClosure.normalClosure_eq_self","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/0f1dd7505c3d08b5feb82300ccc73179a457bf51/Mathlib/FieldTheory/SeparableClosure.lean#L176-L182"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">theorem</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Mathlib/FieldTheory/SeparableClosure.html#separableClosure.separableClosure_eq_bot\"><span class=\"name\">separableClosure</span>.<span class=\"name\">separableClosure_eq_bot</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">F</span> : <a href=\"./foundational_types.html\">Type</a> u)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">E</span> : <a href=\"./foundational_types.html\">Type</a> v)</span></span>\n<span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">[<span class=\"fn\"><a href=\"./Mathlib/Algebra/Field/Defs.html#Field\">Field</a> <span class=\"fn\">F</span></span>]</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">[<span class=\"fn\"><a href=\"./Mathlib/Algebra/Field/Defs.html#Field\">Field</a> <span class=\"fn\">E</span></span>]</spa