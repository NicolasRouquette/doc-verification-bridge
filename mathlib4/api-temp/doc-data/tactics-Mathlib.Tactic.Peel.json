          [{"text": "p"},
           {"text": " "},
           {"text": "x"},
           {"text": " "},
           {"text": "↔"},
           {"text": " "},
           {"text": "q"},
           {"text": " "},
           {"text": "x"}]]},
        {"text": ". The "},
        {"element": ["code", true, [], [{"text": "congr!"}]]},
        {"text": " tactic can also be applied to goals of this form using"},
        {"raw": "\n"},
        {"element":
         ["code",
