           {"text": " "},
           {"text": "p"},
           {"text": " "},
           {"text": "x)"},
           {"text": " "},
           {"text": "↔"},
           {"text": " "},
           {"text": "∀"},
           {"text": " "},
           {"text": "x,"},
           {"text": " "},
           {"text": "q"},
           {"text": " "},
           {"text": "x"}]]},
        {"text": ", or likewise for any"},
        {"raw": "\n"},
        {"text":
         "other quantifier. In this case, there is no hypothesis or term to supply, but otherwise the syntax"},
        {"raw": "\n"},
        {"text": "is the same. So for such goals, the syntax is "},
        {"element":
         ["code", true, [], [{"text": "peel"}, {"text": " "}, {"text": "1"}]]},
        {"text": " or "},
        {"element":
         ["code",
          true,
          [],
          [{"text": "peel"},
           {"text": " "},
           {"text": "with"},
           {"text": " "},
           {"text": "x"}]]},
