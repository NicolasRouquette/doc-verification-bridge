       [{"element": ["code", true, [], [{"text": "pure_coherence"}]]},
        {"text":
         " uses the coherence theorem for monoidal categories to prove the goal."},
        {"raw": "\n"},
        {"text":
         "It can prove any equality made up only of associators, unitors, and identities."}]]},
     {"element":
      ["pre",
       true,
       [],
       [{"element":
         ["code",
          true,
          [["class", "language-lean"]],
          [{"text": "example"},
           {"text": " "},
           {"text": "{C"},
           {"text": " "},
           {"text": ":"},
           {"text": " "},
           {"text": "Type}"},
           {"text": " "},
           {"text": "[Category*"},
           {"text": " "},
           {"text": "C]"},
           {"text": " "},
           {"text": "[MonoidalCategory"},
           {"text": " "},
           {"text": "C]"},
           {"text": " "},
           {"text": ":"},
           {"text": ""},
           {"text": "\n"},
           {"text": ""},
           {"text": ""},
           {"text": " "},
           {"text": ""},
           {"text": " "},
           {"text": ""},
           {"text": "(λ_"},
           {"text": " "},
           {"text": "(𝟙_"},
           {"text": " "},
           {"text": "C)).hom"},
           {"text": " "},
           {"text": "="},
           {"text": " "},
           {"text": "(ρ_"},
           {"text": " "},
           {"text": "(𝟙_"},
           {"text": " "},
           {"text": "C)).hom"},
           {"text": " "},
           {"text": ":="},
           {"text": " "},
           {"text": "by"},
           {"text": ""},
           {"text": "\n"},
           {"text": ""},
           {"text": ""},
           {"text": " "},
           {"text": ""},
           {"text": " "},
           {"text": ""},
           {"text": "pure_coherence"},
           {"text": ""},
           {"text": "\n"},
           {"text": ""}]]}]]},
     {"element":
      ["p",
       true,
       [],
       [{"text": "Users will typically just use the "},
        {"element": ["code", true, [], [{"text": "coherence"}]]},
        {"text": " tactic,"},
        {"raw": "\n"},
        {"text": "which can also cope with identities of the form"},
        {"raw": "\n"},
        {"element":
         ["code",
          true,
          [],
          [{"text": "a"},
           {"text": " "},
           {"text": "≫"},
           {"text": " "},
           {"text": "f"},
           {"text": " "},
           {"text": "≫"},
           {"text": " "},
           {"text": "b"},
           {"text": " "},
           {"text": "≫"},
           {"text": " "},
           {"text": "g"},
           {"text": " "},
           {"text": "≫"},
           {"text": " "},
           {"text": "c"},
           {"text": " "},
