 {"userName": "liftable_prefixes",
  "tags": [],
  "internalName": "Mathlib.Tactic.Coherence.liftable_prefixes",
  "docString":
  {"element":
   ["p",
    true,
    [],
    [{"element":
      ["p",
       true,
       [],
       [{"text": "Internal tactic used in "},
        {"element": ["code", true, [], [{"text": "coherence"}]]},
        {"text": "."}]]},
     {"element":
      ["p",
       true,
       [],
       [{"text": "Rewrites an equation "},
        {"element":
         ["code",
          true,
          [],
          [{"text": "f"},
           {"text": " "},
           {"text": "="},
           {"text": " "},
           {"text": "g"}]]},
        {"text": " as "},
        {"element":
         ["code",
          true,
          [],
          [{"text": "f₀"},
           {"text": " "},
           {"text": "≫"},
           {"text": " "},
           {"text": "f₁"},
           {"text": " "},
           {"text": "="},
           {"text": " "},
           {"text": "g₀"},
           {"text": " "},
           {"text": "≫"},
           {"text": " "},
           {"text": "g₁"}]]},
        {"text": ","},
        {"raw": "\n"},
        {"text": "where "},
        {"element": ["code", true, [], [{"text": "f₀"}]]},
        {"text": " and "},
        {"element": ["code", true, [], [{"text": "g₀"}]]},
        {"text": " are maximal prefixes of "},
        {"element": ["code", true, [], [{"text": "f"}]]},
        {"text": " and "},
        {"element": ["code", true, [], [{"text": "g"}]]},
        {"text": " (possibly after reassociating)"},
        {"raw": "\n"},
        {"text":
         "which are \"liftable\" (i.e. expressible as compositions of unitors and associators)."}]]}]]},
