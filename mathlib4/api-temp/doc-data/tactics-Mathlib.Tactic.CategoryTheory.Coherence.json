 {"userName": "coherence",
  "tags": [],
  "internalName": "Mathlib.Tactic.Coherence.coherence",
  "docString":
  {"element":
   ["p",
    true,
    [],
    [{"element":
      ["p",
       true,
       [],
       [{"text":
         "Use the coherence theorem for monoidal categories to solve equations in a monoidal equation,"},
        {"raw": "\n"},
        {"text":
         "where the two sides only differ by replacing strings of monoidal structural morphisms"},
        {"raw": "\n"},
        {"text": "(that is, associators, unitors, and identities)"},
        {"raw": "\n"},
        {"text":
         "with different strings of structural morphisms with the same source and target."}]]},
     {"element":
      ["p",
       true,
       [],
       [{"text": "That is, "},
        {"element": ["code", true, [], [{"text": "coherence"}]]},
        {"text": " can handle goals of the form"},
        {"raw": "\n"},
        {"element":
         ["code",
          true,
          [],
          [{"text": "a"},
           {"text": " "},
           {"text": "≫"},
           {"text": " "},
           {"text": "f"},
           {"text": " "},
           {"text": "≫"},
           {"text": " "},
           {"text": "b"},
           {"text": " "},
           {"text": "≫"},
           {"text": " "},
           {"text": "g"},
           {"text": " "},
           {"text": "≫"},
           {"text": " "},
           {"text": "c"},
           {"text": " "},
           {"text": "="},
           {"text": " "},
           {"text": "a'"},
           {"text": " "},
           {"text": "≫"},
           {"text": " "},
           {"text": "f"},
           {"text": " "},
           {"text": "≫"},
           {"text": " "},
           {"text": "b'"},
           {"text": " "},
           {"text": "≫"},
           {"text": " "},
           {"text": "g"},
           {"text": " "},
           {"text": "≫"},
           {"text": " "},
           {"text": "c'"}]]},
        {"raw": "\n"},
        {"text": "where "},
        {"element":
         ["code",
          true,
          [],
          [{"text": "a"},
           {"text": " "},
           {"text": "="},
           {"text": " "},
           {"text": "a'"}]]},
        {"text": ", "},
        {"element":
         ["code",
          true,
          [],
          [{"text": "b"},
           {"text": " "},
           {"text": "="},
           {"text": " "},
           {"text": "b'"}]]},
        {"text": ", and "},
        {"element":
         ["code",
          true,
          [],
          [{"text": "c"},
           {"text": " "},
           {"text": "="},
           {"text": " "},
           {"text": "c'"}]]},
        {"text": " can be proved using "},
        {"element": ["code", true, [], [{"text": "pure_coherence"}]]},
        {"text": "."}]]},
     {"element":
      ["p",
       true,
       [],
       [{"text": "(If you have very large equations on which "},
        {"element": ["code", true, [], [{"text": "coherence"}]]},
        {"text": " is unexpectedly failing,"},
        {"raw": "\n"},
        {"text": "you may need to increase the typeclass search depth,"},
        {"raw": "\n"},
        {"text": "using e.g. "},
        {"element":
         ["code",
          true,
          [],
          [{"text": "set_option"},
           {"text": " "},
           {"text": "synthInstance.maxSize"},
           {"text": " "},
           {"text": "500"}]]},
        {"text": ".)"}]]}]]},
  "definingModule": "Mathlib.Tactic.CategoryTheory.Coherence"},
