           {"text": " "},
           {"text": "≫"},
           {"text": " "},
           {"text": "f"},
           {"text": " "},
           {"text": "≫"},
           {"text": " "},
           {"text": "b'"},
           {"text": " "},
           {"text": "≫"},
           {"text": " "},
           {"text": "g"},
           {"text": " "},
           {"text": "≫"},
           {"text": " "},
           {"text": "c'"}]]},
        {"raw": "\n"},
        {"text": "where "},
        {"element":
         ["code",
          true,
          [],
          [{"text": "a"},
           {"text": " "},
           {"text": "="},
           {"text": " "},
           {"text": "a'"}]]},
        {"text": ", "},
        {"element":
