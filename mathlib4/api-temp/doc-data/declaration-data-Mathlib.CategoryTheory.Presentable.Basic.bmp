Presentable/IsCardinalFiltered.html#CategoryTheory.IsCardinalFiltered\">IsCardinalFiltered</a> <span class=\"fn\">J</span> <span class=\"fn\">κ</span></span>], <span class=\"fn\"><a href=\"./Mathlib/CategoryTheory/Limits/Preserves/Basic.html#CategoryTheory.Limits.PreservesColimitsOfShape\">Limits.PreservesColimitsOfShape</a> <span class=\"fn\">J</span> <span class=\"fn\">F</span></span></span> := by intros;\n  infer_instance)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><span class=\"fn\"><span class=\"fn\">F</span>.<a href=\"./Mathlib/CategoryTheory/Presentable/Basic.html#CategoryTheory.Functor.IsCardinalAccessible\">IsCardinalAccessible</a></span> <span class=\"fn\">κ</span></span></div></div>","info":{"doc":"","docLink":"./Mathlib/CategoryTheory/Presentable/Basic.html#CategoryTheory.Functor.IsCardinalAccessible.mk","kind":"ctor","line":54,"name":"CategoryTheory.Functor.IsCardinalAccessible.mk","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/0f1dd7505c3d08b5feb82300ccc73179a457bf51/Mathlib/CategoryTheory/Presentable/Basic.lean#L54-L54"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">class</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Mathlib/CategoryTheory/Presentable/Basic.html#CategoryTheory.Functor.IsCardinalAccessible\"><span class=\"name\">CategoryTheory</span>.<span class=\"name\">Functor</span>.<span class=\"name\">IsCardinalAccessible</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">C</span> : <a href=\"./foundational_types.html\">Type</a> u₁}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">[<span class=\"fn\"><a href=\"./Mathlib/CategoryTheory/Category/Basic.html#CategoryTheory.Category\">Category.{v₁, u₁}</a> <span class=\"fn\">C</span></span>]</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<spa