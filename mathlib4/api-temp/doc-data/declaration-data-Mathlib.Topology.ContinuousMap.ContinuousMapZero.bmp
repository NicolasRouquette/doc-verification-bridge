pology/ContinuousMap/Defs.html#ContinuousMap\">)</a></div></div>","info":{"doc":"","docLink":"./Mathlib/Topology/ContinuousMap/ContinuousMapZero.html#ContinuousMapZero.toContinuousMap","kind":"def","line":35,"name":"ContinuousMapZero.toContinuousMap","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/0f1dd7505c3d08b5feb82300ccc73179a457bf51/Mathlib/Topology/ContinuousMap/ContinuousMapZero.lean#L35-L37"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">structure</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Mathlib/Topology/ContinuousMap/ContinuousMapZero.html#ContinuousMapZero\"><span class=\"name\">ContinuousMapZero</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">X</span> : <a href=\"./foundational_types.html\">Type</a> u_1)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">R</span> : <a href=\"./foundational_types.html\">Type</a> u_2)</span></span>\n<span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">[<span class=\"fn\"><a href=\"./Init/Prelude.html#Zero\">Zero</a> <span class=\"fn\">X</span></span>]</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">[<span class=\"fn\"><a href=\"./Init/Prelude.html#Zero\">Zero</a> <span class=\"fn\">R</span></span>]</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">[<span class=\"fn\"><a href=\"./Mathlib/Topology/Defs/Basic.html#TopologicalSpace\">TopologicalSpace</a> <span class=\"fn\">X</span></span>]</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">[<span class=\"fn\"><a href=\"./Mathlib/Topology/Defs/Basic.html#TopologicalSpace\">TopologicalSpace</a> <span class=\"fn\">R</span></span>]</span></span>\n</span><span class=\"decl_extends\">extends</span> <a href=\"./Mathlib/Topology/ContinuousMap/Defs.html#ContinuousMap\">C(</a><span class=\"fn\">X</span><a href=\"./Mathlib/Topology/ContinuousMap/Defs.html#ContinuousMap\">,</a> <span class=\"fn\">R</span><a href=\"./Mathlib/Topology/ContinuousMap/Defs.html#ContinuousMap\">)</a><span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./foundational_types.html\">Type</a> (max u_1 u_2)</div></div>","info":{"doc":"The type of continuous maps which map zero to zero.\n\nNote that one should never use the structure projection `ContinuousMapZero.toContinuousMap` and\ninstead favor the coercion `(↑) : C(X, R)₀ → C(X, R)` available from the instance of\n`ContinuousMapClass`. All the instances on `C(X, R)₀` from `C(X, R)` passes through this coercion,\nnot the structure projection. Of course, the two are definitionally equal, but not reducibly so. ","docLink":"./Mathlib/Topology/ContinuousMap/ContinuousMapZero.html#ContinuousMapZero","kind":"structure","line":29,"name":"ContinuousMapZero","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/0f1dd7505c3d08b5feb82300ccc73179a457bf51/Mathlib/Topology/ContinuousMap/ContinuousMapZero.lean#L29-L37"}}],"imports":["Init","Mathlib.Topology.ContinuousMap.Algebra","Mathlib.Topology.ContinuousMap.Compact"],"instances":[{"className":"DFunLike","name":"ContinuousMapZero.instFunLike","typeNames":["ContinuousMapZero"]},{"className":"ContinuousMapClass","name":"ContinuousMapZero.instContinuousMapClass","typeNames":["ContinuousMapZero"]},{"className":"ZeroHomClass","name":"ContinuousMapZero.instZeroHomClass","typeNames":["ContinuousMapZero"]},{"className":"PartialOrder","name":"ContinuousMapZero.instPartialOrder","typeNames":["ContinuousMapZero"]},{"className":"TopologicalSpace","name":"ContinuousMapZero.instTopologicalSpace","typeNames":["ContinuousMapZero"]},{"className":"T0Space","name":"ContinuousMapZero.instT0Space","typeNames":["ContinuousMapZero"]},{"className":"R0Space","name":"ContinuousMapZero.instR0Space","typeNames":["ContinuousMapZero"]},{"className":"T1Space","name":"ContinuousMapZero.instT1Space","typeName