><span class=\"fn\">ideal</span> <span class=\"fn\">(<span class=\"fn\"><span class=\"fn\">X</span>.<a href=\"./Mathlib/AlgebraicGeometry/AffineScheme.html#AlgebraicGeometry.Scheme.affineBasicOpen\">affineBasicOpen</a></span> <span class=\"fn\">f</span>)</span></span></span>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">supportSet</span> : <span class=\"fn\"><a href=\"./Mathlib/Data/Set/Defs.html#Set\">Set</a> <span class=\"fn\">↥<span class=\"fn\">X</span></span></span>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">supportSet_eq_iInter_zeroLocus</span> : <span class=\"fn\">supportSet</span> <a href=\"./Init/Prelude.html#Eq\">=</a> <span class=\"fn\">⋂ (<span class=\"fn\">U</span> : <span class=\"fn\">↑<span class=\"fn\"><span class=\"fn\">X</span>.<a href=\"./Mathlib/AlgebraicGeometry/AffineScheme.html#AlgebraicGeometry.Scheme.affineOpens\">affineOpens</a></span></span>), <span class=\"fn\"><span class=\"fn\"><span class=\"fn\">X</span>.<a href=\"./Mathlib/AlgebraicGeometry/Scheme.html#AlgebraicGeometry.Scheme.zeroLocus\">zeroLocus</a></span> <span class=\"fn\">↑<span class=\"fn\">(<span class=\"fn\">ideal</span> <span class=\"fn\">U</span>)</span></span></span></span> := by rfl)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><span class=\"fn\">X</span>.<a href=\"./Mathlib/AlgebraicGeometry/IdealSheaf/Basic.html#AlgebraicGeometry.Scheme.IdealSheafData\">IdealSheafData</a></span></div></div>","info":{"doc":"","docLink":"./Mathlib/AlgebraicGeometry/IdealSheaf/Basic.html#AlgebraicGeometry.Scheme.IdealSheafData.mk","kind":"ctor","line":65,"name":"AlgebraicGeometry.Scheme.IdealSheafData.mk","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/0f1dd7505c3d08b5feb82300ccc73179a457bf51/Mathlib/AlgebraicGeometry/IdealSheaf/Basic.lean#L65-L65"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">structure</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Mathlib/AlgebraicGeometry/IdealSheaf/Basic.html#AlgebraicGeometry.Scheme.IdealSheafData\"><span class=\"name\">AlgebraicGeometry</span>.<span class=\"name\">Scheme</span>.<span class=\"name\">IdealSheafData</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">X</span> : <a href=\"./Mathlib/AlgebraicGeometry/Scheme.html#AlgebraicGeometry.Scheme\">Scheme</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./foundational_types.html\">Type</a> u</div></div>","info":{"doc":"A structure that contains the data to uniquely define an ideal sheaf, consisting of\n1. an ideal `I(U) ≤ Γ(X, U)` for every affine open `U`\n2. a proof that `I(D(f)) = I(U)_f` for every affine open `U` and every section `f : Γ(X, U)`\n3. a subset of `X` equal to the support.\n\nAlso see `Scheme.IdealSheafData.mkOfMemSupportIff` for a constructor with the condition on the\nsupport being (usually) easier to prove.\n","docLink":"./Mathlib/AlgebraicGeometry/IdealSheaf/Basic.html#AlgebraicGeometry.Scheme.IdealSheafData","kind":"structure","line":56,"name":"AlgebraicGeometry.Scheme.IdealSheafData","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/0f1dd7505c3d08b5feb82300ccc73179a457bf51/Mathlib/AlgebraicGeometry/IdealSheaf/Basic.lean#L56-L74"}}],"imports":["Init","Mathlib.AlgebraicGeometry.Morphisms.QuasiCompact","Mathlib.AlgebraicGeometry.Properties","Mathlib.Tactic.DepRewrite"],"instances":[{"className":"PartialOrder","name":"AlgebraicGeometry.Scheme.IdealSheafData.instPartialOrder","typeNames":["AlgebraicGeometry.Scheme.IdealSheafData"]},{"className":"CompleteSemilatticeSup","name":"AlgebraicGeometry.Scheme.IdealSheafData.instCompleteSemilatticeSup","typeNames":["AlgebraicGeometry.Scheme.IdealSheafData"]},{"className":"OrderTop","name":"AlgebraicGeometry.Scheme.IdealSheafData.instOrderTop","typeNames":["AlgebraicGeometry.Scheme.IdealSheafData"]},{"className":"OrderBot","name":"AlgebraicGeometry.Scheme.IdealSheafData.instOrderBot","typeNames":["AlgebraicGeometry.Scheme.IdealSheafData"]},{"className":"SemilatticeInf","name":"AlgebraicGeometry.Scheme.IdealSheafData.instSemilatticeInf","typeNames":["AlgebraicGeometry.Scheme.IdealSheafData"]},{"className":"CompleteLattice","name":"AlgebraicGeometry.Scheme.IdealSheafData.instCompleteLattice","typeNames":["AlgebraicGeometry.Scheme.IdealSheafData"]},{"className":"Zero","name":"AlgebraicGeometry.Scheme.IdealSheafData.instZero","typeNames":["AlgebraicGeometry.Scheme.IdealSheafData"]},{"className":"One","name":"AlgebraicGeometry.Scheme.IdealSheafData.instOne","typeNames":["AlgebraicGeometry.Scheme.IdealSheafData"]},{"className":"Add","name":"AlgebraicGeometry.Scheme.IdealSheafData.instAdd","typeNames":["AlgebraicGeometry.Scheme.IdealSheafData"]},{"className":"Mul","name":"AlgebraicGeometry.Scheme.IdealSheafData.instMul","typeNames":["AlgebraicGeometry.Scheme.IdealSheafData"]},{"className":"Pow","name":"AlgebraicGeometry.Scheme.IdealSheafData.instPowNat","typeNames":["AlgebraicGeometry.Scheme.IdealSheafData","Nat"]},{"className":"IdemCommSemiring","name":"AlgebraicGeometry.Scheme.IdealSheafData.instIdemCommSemiring","typeNames":["AlgebraicGeometry.Scheme.IdealSheafData"]},{"className":"IsOrderedRing","name":"AlgebraicGeometry.Scheme.IdealSheafData.instIsOrderedRing","typeNames":["AlgebraicGeometry.Scheme.IdealSheafData"]}],"name":"Mathlib.AlgebraicGeometry.IdealSheaf.Basic"}