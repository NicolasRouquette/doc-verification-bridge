">K</span>)</span></span>]</span></span>\n</span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">halg</span> : <span class=\"fn\"><a href=\"./Mathlib/RingTheory/Algebraic/Defs.html#Algebra.IsAlgebraic\">Algebra.IsAlgebraic</a> <span class=\"fn\">F</span> <span class=\"fn\">E</span></span> <a href=\"./Init/Prelude.html#Or\">∨</a> <span class=\"fn\"><a href=\"./Mathlib/RingTheory/Algebraic/Defs.html#Algebra.IsAlgebraic\">Algebra.IsAlgebraic</a> <span class=\"fn\">F</span> <span class=\"fn\">K</span></span>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Mathlib/Algebra/Field/IsField.html#IsField\">IsField</a> <span class=\"fn\">(<a href=\"./Mathlib/LinearAlgebra/TensorProduct/Defs.html#TensorProduct\">TensorProduct</a> <span class=\"fn\">F</span> <span class=\"fn\">E</span> <span class=\"fn\">K</span>)</span></span></div></div>","info":{"doc":"If `E` and `K` are field extensions of `F`, one of them is algebraic, such that\n`E ⊗[F] K` is a domain, then `E ⊗[F] K` is also a field. It is a corollary of\n`Subalgebra.LinearDisjoint.exists_field_of_isDomain_of_injective` and\n`IntermediateField.sup_toSubalgebra_of_isAlgebraic`.\nSee `Algebra.TensorProduct.isAlgebraic_of_isField` for its converse (in an earlier file). ","docLink":"./Mathlib/FieldTheory/LinearDisjoint.html#Algebra.TensorProduct.isField_of_isAlgebraic","kind":"theorem","line":736,"name":"Algebra.TensorProduct.isField_of_isAlgebraic","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/0f1dd7505c3d08b5feb82300ccc73179a457bf51/Mathlib/FieldTheory/LinearDisjoint.lean#L736-L754"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">theorem</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Mathlib/FieldTheory/LinearDisjoint.html#IntermediateField.LinearDisjoint.isField_of_forall\"><span class=\"name\">IntermediateField</span>.<span class=\"name\">LinearDisjoint</span>.<span class=\"name\">isField_of_forall</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">F</span> : <a href=\"./foundational_types.html\">Type</a> u)</span></span>\n<span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">[<span class=\"fn\"><a href=\"./Mathlib/Algebra/Field/Defs.html#Field\">Field</a> <span class=\"fn\">F</span></span>]</span></span>\n</span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">A</span> : <a href=\"./foundational_types.html\">Type</a> v)</span></span>\n<span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">[<span class=\"fn\"><a href=\"./Mathlib/Algebra/Field/Defs.html#Field\">Field</a> <span class=\"fn\">A</span></span>]</span></span>\n</span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">B</span> : <a href=\"./foundational_types.html\">Type</a> w)</span></span>\n<span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">[<span class=\"fn\"><a href=\"./Mathlib/Algebra/Field/Defs.html#Field\">Field</a> <span class=\"fn\">B</span></span>]</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">[<span class=\"fn\"><a href=\"./Mathlib/Algebra/Algebra/Defs.html#Algebra\">Algebra</a> <span class=\"fn\">F</span> <span class=\"fn\">A</span></span>]</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">[<span class=\"fn\"><a href=\"./Mathlib/Algebra/Algebra/Defs.html#Algebra\">Algebra</a> <span class=\"fn\">F</span> <span class=\"fn\">B</span></span>]</span></span>\n</span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">H</span> :\n  <span class=\"fn\">∀ (<span class=\"fn\">K</span> : <a href=\"./foundational_types.html\">Type</a> (max v w)) [<span class=\"fn\">inst</span> : <span class=\"fn\"><a href=\"./Mathlib/Algebra/Field/Defs.html#Field\">Field</a> <span class=\"fn\">K</span></span>] [<span class=\"fn\">inst_1</span> : <span class=\"fn\"><a href=\"./Mathlib/Algebra/Algebra/Defs.html#Algebra\">Algebra</a> <span class=\"fn\">F</span> <span class=\"fn\">K</span></span>] (<span class=\"fn\">fa</span> : <span class=\"fn\">A</span> <a href=\"./Mathlib/Algebra/Algebra/Hom.html#AlgHom\">→ₐ[</a><span class=\"fn\">F</span><a href=\"./Mathlib/Algebra/Algebra/Hom.html#AlgHom\">]</a> <span class=\"fn\">K</span>) (<span class=\"fn\">fb</span> : <span class=\"fn\">B</span> <a href=\"./Mathlib/Algebra/Algebra/Hom.html#AlgHom\">→ₐ[</a><span class=\"fn\">F</span><a href=\"./Mathlib/Algebra/Algebra/Hom.html#AlgHom\">]</a> <span class=\"fn\">K</span>),\n    <span class=\"fn\"><span class=\"fn\"><span class=\"fn\"><span class=\"fn\">fa</span>.<a href=\"./Mathlib/FieldTheory/IntermediateField/Basic.html#AlgHom.fieldRange\">fieldRange</a></span>.<a href=\"./Mathlib/FieldTheory/LinearDisjoint.html#IntermediateField.LinearDisjoint\">LinearDisjoint</a></span> <span class=\"fn\">↥<span class=\"fn\"><span class=\"fn\">fb</span>.<a href=\"./Mathlib/FieldTheory/IntermediateField/Basic.html#AlgHom.fieldRange\">fieldRange</a></span></span></span></span>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Mathlib/Algebra/Field/IsField.html#IsField\">IsField</a> <span class=\"fn\">(<a href=\"./Mathlib/LinearAlgebra/TensorProduct/Defs.html#TensorProduct\">TensorProduct</a> <span class=\"fn\">F</span> <span class=\"fn\">A</span> <span class=\"fn\">B</span>)</span></span></div></div>","info":{"doc":"If for any field extension `K` of `F` that `A` and `B` embed into, their images are\nlinearly disjoint, then `A ⊗[F] B` is a field. (In the proof we choose `K` to be the quotient\nof `A ⊗[F] B` by a maximal ideal.) ","docLink":"./Mathlib/FieldTheory/LinearDisjoint.html#IntermediateField.LinearDisjoint.isField_of_forall","kind":"theorem","line":708,"name":"IntermediateField.LinearDisjoint.isField_of_forall","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/0f1dd7505c3d08b5feb82300ccc7