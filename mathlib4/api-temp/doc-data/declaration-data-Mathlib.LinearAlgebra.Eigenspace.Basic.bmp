 class=\"fn\">R</span></span>]</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">[<span class=\"fn\"><a href=\"./Mathlib/Algebra/Group/Defs.html#AddCommGroup\">AddCommGroup</a> <span class=\"fn\">M</span></span>]</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">[<span class=\"fn\"><a href=\"./Mathlib/Algebra/Module/Defs.html#Module\">Module</a> <span class=\"fn\">R</span> <span class=\"fn\">M</span></span>]</span></span>\n</span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">f</span> : <span class=\"fn\"><a href=\"./Mathlib/Algebra/Module/LinearMap/End.html#Module.End\">End</a> <span class=\"fn\">R</span> <span class=\"fn\">M</span></span>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">μ</span> : <span class=\"fn\">R</span>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">k</span> : <a href=\"./Mathlib/Data/ENat/Defs.html#ENat\">ℕ∞</a>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./foundational_types.html\">Prop</a></div></div>","info":{"doc":"Let `M` be an `R`-module, and `f` an `R`-linear endomorphism of `M`.\nThen `μ : R` and `k : ℕ∞` satisfy `HasUnifEigenvalue f μ k` if\n`f.genEigenspace μ k ≠ ⊥`.\n\nFor `k = 1`, this means that `μ` is an eigenvalue of `f`. ","docLink":"./Mathlib/LinearAlgebra/Eigenspace/Basic.html#Module.End.HasUnifEigenvalue","kind":"def","line":151,"name":"Module.End.HasUnifEigenvalue","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/0f1dd7505c3d08b5feb82300ccc73179a457bf51/Mathlib/LinearAlgebra/Eigenspace/Basic.lean#L151-L157"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Mathlib/LinearAlgebra/Eigenspace/Basic.html#Module.End.HasUnifEigenvector\"><span class=\"name\">Module</span>.<span class=\"name\">End</span>.<sp