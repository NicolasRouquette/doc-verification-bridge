decl_args\">\n<span class=\"fn\">[<span class=\"fn\">self</span> : <span class=\"fn\"><a href=\"./Mathlib/FieldTheory/IsRealClosed/Basic.html#IsRealClosed\">IsRealClosed</a> <span class=\"fn\">R</span></span>]</span></span>\n</span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Mathlib/Algebra/Ring/Semireal/Defs.html#IsSemireal\">IsSemireal</a> <span class=\"fn\">R</span></span></div></div>","info":{"doc":"","docLink":"./Mathlib/FieldTheory/IsRealClosed/Basic.html#IsRealClosed.toIsSemireal","kind":"theorem","line":48,"name":"IsRealClosed.toIsSemireal","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/0f1dd7505c3d08b5feb82300ccc73179a457bf51/Mathlib/FieldTheory/IsRealClosed/Basic.lean#L48-L50"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">class</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Mathlib/FieldTheory/IsRealClosed/Basic.html#IsRealClosed\"><span class=\"name\">IsRealClosed</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">R</span> : <a href=\"./foundational_types.html\">Type</a> u_1)</span></span>\n<span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">[<span class=\"fn\"><a href=\"./Mathlib/Algebra/Field/Defs.html#Field\">Field</a> <span class=\"fn\">R</span></span>]</span></span>\n</span><span class=\"decl_extends\">extends</span> <span class=\"fn\"><a href=\"./Mathlib/Algebra/Ring/Semireal/Defs.html#IsSemireal\">IsSemireal</a> <span class=\"fn\">R</span></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./foundational_types.html\">Prop</a></div></div>","info":{"doc":"A field `R` is real closed if all of the following hold:\n1. `R` is real (that is, `-1` is not a sum of squares in `R`).\n2. for every `x` in `R`, one of `x` or `-x` is a square.\n3. every odd-degree polynomial over `R` has a root in `R`.\n","docLink":"./Mathlib/FieldTheory/IsRealClosed/Basic.html#IsRealClosed","ki