ingTheory/LocalRing/ResidueField/Fiber.html#Ideal.Fiber\">Fiber</a></span> <span class=\"fn\">S</span>)</span></span>)</span>\n    <a href=\"./Mathlib/RingTheory/QuasiFinite/Basic.html#Algebra.QuasiFinite.finite_fiber._autoParam\">QuasiFinite.finite_fiber._autoParam</a></span></div></div>","info":{"doc":"[Stacks Tag 00PM](https://stacks.math.columbia.edu/tag/00PM)","docLink":"./Mathlib/RingTheory/QuasiFinite/Basic.html#Algebra.quasiFinite_iff","kind":"theorem","line":62,"name":"Algebra.quasiFinite_iff","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/087469e24922b85cb737497c74556c7dacc01f22/Mathlib/RingTheory/QuasiFinite/Basic.lean#L62-L62"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">class</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Mathlib/RingTheory/QuasiFinite/Basic.html#Algebra.QuasiFinite\"><span class=\"name\">Algebra</span>.<span class=\"name\">QuasiFinite</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">R</span> : <a href=\"./foundational_types.html\">Type</a> u_1)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">S</span> : <a href=\"./foundational_types.html\">Type</a> u_2)</span></span>\n<span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">[<span class=\"fn\"><a href=\"./Mathlib/Algebra/Ring/Defs.html#CommRing\">CommRing</a> <span class=\"fn\">R</span></span>]</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">[<span class=\"fn\"><a href=\"./Mathlib/Algebra/Ring/Defs.html#CommRing\">CommRing</a> <span class=\"fn\">S</span></span>]</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">[<span class=\"fn\"><a href=\"./Mathlib/Algebra/Algebra/Defs.html#Algebra\">Algebra</a> <span class=\"fn\">R</span> <span class=\"fn\">S</span></span>]</span></span>\n</span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./foundational_types.html\">Prop</a></div></div>","info":{"doc":"We say that an `R`-algebra `S` is quasi-finite\nif `κ(p) ⊗[R] S` is finite-dimensional over `κ(p)` for all primes `p` of `R`.\n\nThis is slightly different from the\n[stacks projects definition](https://stacks.math.columbia.edu/tag/00PL),\nwhich requires `S` to be of finite type over `R`.\n\nAlso see `Algebra.QuasiFinite.iff_finite_comap_preimage_singleton` that\nthis is equivalent to having finite fibers for finite-type algebas.\n","docLink":"./Mathlib/RingTheory/QuasiFinite/Basic.html#Algebra.QuasiFinite","kind":"class","line":51,"name":"Algebra.QuasiFinite","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/087469e24922b85cb737497c74556c7dacc01f22/Mathlib/RingTheory/QuasiFinite/Basic.lean#L51-L65"}}],"imports":["Init","Mathlib.Algebra.Module.FinitePresentation","Mathlib.RingTheory.Artinian.Ring","Mathlib.RingTheory.FiniteStability","Mathlib.RingTheory.Finiteness.NilpotentKer","Mathlib.RingTheory.Jacobson.Artinian","Mathlib.RingTheory.LocalRing.ResidueField.Polynomial","Mathlib.RingTheory.Spectrum.Prime.Jacobson","Mathlib.RingTheory.TensorProduct.Pi","Mathlib.RingTheory.TensorProduct.Quotient"],"instances":[{"className":"IsWellFounded","name":"Algebra.QuasiFinite.instIsArtinianRingFiber","typeNames":["Ideal.Fiber"]},{"className":"Algebra.QuasiFinite","name":"Algebra.QuasiFinite.instOfFinite","typeNames":[]},{"className":"Algebra.QuasiFinite","name":"Algebra.QuasiFinite.baseChange","typeNames":["TensorProduct"]},{"className":"Algebra.QuasiFinite","name":"Algebra.QuasiFinite.instQuotientIdeal","typeNames":["HasQuotient.Quotient"]},{"className":"Algebra.QuasiFinite","name":"Algebra.QuasiFinite.instLocalization","typeNames":["Localization"]},{"className":"Algebra.QuasiFinite","name":"Algebra.QuasiFinite.instOfIsFractionRing","typeNames":[]},{"className":"Algebra.QuasiFinite","name":"Algebra.QuasiFinite.instResidueField","typeNames":["Ideal.ResidueField"]},{"className":"Module.Finite","nam