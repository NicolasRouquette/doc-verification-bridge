efinitionally equal) `ZFSet → Prop`. This means, the preferred way to\nstate that `x : ZFSet` belongs to `A : Class` is to write `A x`. ","docLink":"./Mathlib/SetTheory/ZFC/Class.html#Class","kind":"def","line":30,"name":"Class","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/087469e24922b85cb737497c74556c7dacc01f22/Mathlib/SetTheory/ZFC/Class.lean#L30-L36"}}],"imports":["Init","Mathlib.SetTheory.ZFC.Ordinal"],"instances":[{"className":"HasSubset","name":"instHasSubsetClass","typeNames":["Class"]},{"className":"EmptyCollection","name":"instEmptyCollectionClass","typeNames":["Class"]},{"className":"Nonempty","name":"instNonemptyClass","typeNames":["Class"]},{"className":"Union","name":"instUnionClass","typeNames":["Class"]},{"className":"Inter","name":"instInterClass","typeNames":["Class"]},{"className":"Compl","name":"instComplClass","typeNames":["Class"]},{"className":"SDiff","name":"instSDiffClass","typeNames":["Class"]},{"className":"Insert","name":"instInsertZFSetClass","typeNames":["ZFSet","Class"]},{"className":"Coe","name":"Class.instCoeZFSet","typeNames":["ZFSet","Class"]},{"className":"Membership","name":"Class.instMembership","typeNames":["Class","Class"]},{"className":"IsWellFounded","name":"Class.instIsWellFoundedMem","typeNames":["Class"]},{"className":"WellFoundedRelation","name":"Class.instWellFoundedRelation","typeNames":["Class"]}],"name":"Mathlib.SetTheory.ZFC.Class"}