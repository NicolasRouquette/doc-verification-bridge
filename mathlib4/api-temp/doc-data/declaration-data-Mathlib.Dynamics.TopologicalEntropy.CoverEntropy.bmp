hlib/Data/EReal/Basic.html#EReal\">EReal</a></div></div>","info":{"doc":"The entropy of an entourage `U`, defined as the exponential rate of growth of the size\nof the smallest `(U, n)`-refined cover of `F`. Takes values in the space of extended real numbers\n`[-∞, +∞]`. This second version uses a `liminf`, and is chosen as an alternative definition. ","docLink":"./Mathlib/Dynamics/TopologicalEntropy/CoverEntropy.html#Dynamics.coverEntropyInfEntourage","kind":"def","line":334,"name":"Dynamics.coverEntropyInfEntourage","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/087469e24922b85cb737497c74556c7dacc01f22/Mathlib/Dynamics/TopologicalEntropy/CoverEntropy.lean#L334-L338"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">noncomputable def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Mathlib/Dynamics/TopologicalEntropy/CoverEntropy.html#Dynamics.coverEntropyEntourage\"><span class=\"name\">Dynamics</span>.<span class=\"name\">coverEntropyEntourage</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">X</span> : <a href=\"./foundational_types.html\">Type</a> u_1}</span></span>\n</span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">T</span> : <span class=\"fn\"><span class=\"fn\">X</span> → <span class=\"fn\">X</span></span>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">F</span> : <span class=\"fn\"><a href=\"./Mathlib/Data/Set/Defs.html#Set\">Set</a> <span class=\"fn\">X</span></span>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">U</span> : <span class=\"fn\"><a href=\"./Mathlib/Data/Rel.html#SetRel\">SetRel</a> <span class=\"fn\">X</span> <span class=\"fn\">X</span></span>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Mathlib/Data/EReal/Basic.html#EReal\">EReal</a></div></div>","info":{"doc":"The entropy of an entourage `U`, defined as the exponential rate of growth of the size\nof the smallest `(U, n)`-refined cover of `F`. Takes values in the space of extended real numbers\n`[-∞, +∞]`. This first version uses a `limsup`, and is chosen as the default definition. ","docLink":"./Mathlib/Dynamics/TopologicalEntropy/CoverEntropy.html#Dynamics.coverEntropyEntourage","kind":"def","line":328,"name":"Dynamics.coverEntropyEntourage","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/087469e24922b85cb737497c74556c7dacc01f22/Mathlib/Dynamics/TopologicalEntropy/CoverEntropy.lean#L328-L332"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">theorem</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Mathlib/Dynamics/TopologicalEntropy/CoverEntropy.html#Dynamics.nonempty_inter_of_coverMincard\"><span class=\"name\">Dynamics</span>.<span class=\"name\">nonempty_inter_of_coverMincard</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">X</span> : <a href=\"./foundational_types.html\">Type</a> u_1}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">T</span> : <span class=\"fn\"><span class=\"fn\">X</span> → <span class=\"fn\">X</span></span>}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">U</span> : <span class=\"fn\"><a href=\"./Mathlib/Data/Rel.html#SetRel\">SetRel</a> <span class=\"fn\">X</span> <span class=\"fn\">X</span></span>}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">F</span> : <span class=\"fn\"><a href=\"./Mathlib/Data/Set/Defs.html#Set\">Set</a> <span class=\"fn\">X</span></span>}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">n</span> : <a href=\"./Init/Prelude.html#Nat\">ℕ</a>}</span></span>\n</span><span class=\"impl_ar