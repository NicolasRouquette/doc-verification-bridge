l#MeasureTheory.Measure\">Measure</a> <span class=\"fn\">α</span></span>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">f</span> : <span class=\"fn\"><span class=\"fn\">α</span> → <span class=\"fn\">E</span></span>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\">μ</span><a href=\"./Mathlib/MeasureTheory/Function/ConditionalExpectation/Basic.html#MeasureTheory.condExp\">[</a><span class=\"fn\">f</span> <a href=\"./Mathlib/MeasureTheory/Function/ConditionalExpectation/Basic.html#MeasureTheory.condExp\">|</a> <span class=\"fn\">m</span><a href=\"./Mathlib/MeasureTheory/Function/ConditionalExpectation/Basic.html#MeasureTheory.condExp\">]</a> <a href=\"./Init/Prelude.html#Eq\">=</a>   <span class=\"fn\">if hm : <span class=\"fn\">m</span> <a href=\"./Init/Prelude.html#LE.le\">≤</a> <span class=\"fn\">m₀</span> then\n    <span class=\"fn\">if h : <span class=\"fn\"><a href=\"./Mathlib/MeasureTheory/Measure/Typeclasses/SFinite.html#MeasureTheory.SigmaFinite\">SigmaFinite</a> <span class=\"fn\">(<span class=\"fn\"><span class=\"fn\">μ</span>.<a href=\"./Mathlib/MeasureTheory/Measure/Trim.html#MeasureTheory.Measure.trim\">trim</a></span> <span class=\"fn\">hm</span>)</span></span> <a href=\"./Init/Prelude.html#And\">∧</a> <span class=\"fn\"><a href=\"./Mathlib/MeasureTheory/Function/L1Space/Integrable.html#MeasureTheory.Integrable\">Integrable</a> <span class=\"fn\">f</span> <span class=\"fn\">μ</span></span> then\n      <a href=\"./Init/Prelude.html#ite\">if</a> <span class=\"fn\"><a href=\"./Mathlib/MeasureTheory/Function/StronglyMeasurable/Basic.html#MeasureTheory.StronglyMeasurable\">StronglyMeasurable</a> <span class=\"fn\">f</span></span> <a href=\"./Init/Prelude.html#ite\">then</a> <span class=\"fn\">f</span>\n      <a href=\"./Init/Prelude.html#ite\">else</a>         <span class=\"fn\">have <span class=\"fn\">this</span> := <span class=\"fn\">⋯</span>;\n        <span class=\"fn\"><a href=\"./Mathlib/MeasureTheory/Function/StronglyMeasurable/AEStronglyMeasurable.html#MeasureTheory.AEStronglyMeasurable.mk\">AEStronglyMeasurable.mk</a> <span class=\"fn\">↑<span class=\"fn\">↑<span class=\"fn\">(<a href=\"./Mathlib/MeasureTheory/Function/ConditionalExpectation/CondexpL1.html#MeasureTheory.condExpL1\">condExpL1</a> <span class=\"fn\">hm</span> <span class=\"fn\">μ</span> <span class=\"fn\">f</span>)</span></span></span> <span class=\"fn\">⋯</span></span></span>\n    else <span class=\"fn\">0</span></span>\n  else <span class=\"fn\">0</span></span></div></div>","info":{"doc":"","docLink":"./Mathlib/MeasureTheory/Function/ConditionalExpectation/Basic.html#MeasureTheory.condExp_def","kind":"theorem","line":89,"name":"MeasureTheory.condExp_def","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/087469e24922b85cb737497c74556c7dacc01f22/Mathlib/MeasureTheory/Function/ConditionalExpectation/Basic.lean#L89-L101"}}],"imports":["Init","Mathlib.MeasureTheory.Function.ConditionalExpectation.CondexpL1"],"instances":[],"name":"Mathlib.MeasureTheory.Function.ConditionalExpectation.Basic"}