al_types.html\">Prop</a></span></div></div>","info":{"doc":"`M` has a predicate `Indep` defining its independent sets. ","docLink":"./Mathlib/Combinatorics/Matroid/Basic.html#Matroid.Indep","kind":"def","line":198,"name":"Matroid.Indep","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/087469e24922b85cb737497c74556c7dacc01f22/Mathlib/Combinatorics/Matroid/Basic.lean#L198-L198"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">abbrev</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Mathlib/Combinatorics/Matroid/Basic.html#Matroid.IsBase\"><span class=\"name\">Matroid</span>.<span class=\"name\">IsBase</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">α</span> : <a href=\"./foundational_types.html\">Type</a> u_1}</span></span>\n</span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">self</span> : <span class=\"fn\"><a href=\"./Mathlib/Combinatorics/Matroid/Basic.html#Matroid\">Matroid</a> <span class=\"fn\">α</span></span>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><span class=\"fn\"><a href=\"./Mathlib/Data/Set/Defs.html#Set\">Set</a> <span class=\"fn\">α</span></span> → <a href=\"./foundational_types.html\">Prop</a></span></div></div>","info":{"doc":"`M` has a predicate `Base` defining its bases. ","docLink":"./Mathlib/Combinatorics/Matroid/Basic.html#Matroid.IsBase","kind":"def","line":196,"name":"Matroid.IsBase","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/087469e24922b85cb737497c74556c7dacc01f22/Mathlib/Combinatorics/Matroid/Basic.lean#L196-L196"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">abbrev</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Mathlib/Combinatorics/Matroid/Basic.html#Matroid.E\"><span class=\"name\">Matroid</span>.<span class=\"name\">E</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">α</span> : <a href=\"./foundational_types.html\">Type</a> u_1}</span></span>\n</span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">self</span> : <span class=\"fn\"><a href=\"./Mathlib/Combinatorics/Matroid/Basic.html#Matroid\">Matroid</a> <span class=\"fn\">α</span></span>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Mathlib/Data/Set/Defs.html#Set\">Set</a> <span class=\"fn\">α</span></span></div></div>","info":{"doc":"`M` has a ground set `E`. ","docLink":"./Mathlib/Combinatorics/Matroid/Basic.html#Matroid.E","kind":"def","line":194,"name":"Matroid.E","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/087469e24922b85cb737497c74556c7dacc01f22/Mathlib/Combinatorics/Matroid/Basic.lean#L194-L194"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">constructor</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Mathlib/Combinatorics/Matroid/Basic.html#Matroid.mk\"><span class=\"name\">Matroid</span>.<span class=\"name\">mk</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">α</span> : <a href=\"./foundational_types.html\">Type</a> u_1}</span></span>\n</span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">E</span> : <span class=\"fn\"><a href=\"./Mathlib/Data/Set/Defs.html#Set\">Set</a> <span class=\"fn\">α</span></span>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">IsBase </span><span class=\"fn\">Indep</span> : <span class=\"fn\"><span class=\"fn\"><a href=\"./Mathlib/Data/Set/Defs.html#Set\">Set</a> <span class=\"fn\">α</span></span> → <a href=\"./foundational_types.html\">Prop</a></span>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">indep_iff'</span> : <span class=\"fn\">∀ ⦃<span class=\"fn\">I</span> : <span class=\"fn\"><a href=\"./Mathlib/Data/Set/Defs.html#Set\">Set</a> <span class=\"fn\">α</span></span>⦄, <span class=\"fn\"><span class=\"fn\">Indep</span> <span class=\"fn\">I</span></span> <a href=\"./Init/Core.html#Iff\">↔</a> <span class=\"fn\">∃ (<span class=\"fn\">B</span> : <span class=\"fn\"><a href=\"./Mathlib/Data/Set/Defs.html#Set\">Set</a> <span class=\"fn\">α</span></span>), <span class=\"fn\"><span class=\"fn\">IsBase</span> <span class=\"fn\">B</span></span> <a href=\"./Init/Prelude.html#And\">∧</a> <span class=\"fn\">I</span> <a href=\"./Init/Core.html#HasSubset.Subset\">⊆</a> <span class=\"fn\">B</span></span></span>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">exists_isBase</span> : <span class=\"fn\">∃ (<span class=\"fn\">B</span> : <span class=\"fn\"><a href=\"./Mathlib/Data/Set/Defs.html#Set\">Set</a> <span class=\"fn\">α</span></span>), <span class=\"fn\"><span class=\"fn\">IsBase</span> <span class=\"fn\">B</span></span></span>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">isBase_exchange</span> : <span class=\"fn\"><a href=\"./Mathlib/Combinatorics/Matroid/Basic.html#Matroid.ExchangeProperty\">ExchangeProperty</a> <span class=\"fn\">IsBase</span></span>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">maximality</span> : <span class=\"fn\">∀ <span class=\"fn\">X</span> ⊆ <span class=\"fn\">E</span>, <span class=\"fn\"><a href=\"./Mathlib/Combinatorics/Matroid/Basic.html#Matroid.ExistsMaximalSubsetProperty\">ExistsMaximalSubsetProperty</a> <span class=\"fn\">Indep</span> <span class=\"fn\">X</span></span></span>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">subset_ground</span> : <span class=\"fn\">∀ (<span class=\"fn\">B</span> : <span class=\"fn\"><a href=\"./Mathlib/Data/Set/Defs.html#Set\">Set</a> <span class=\"fn\">α</span></span>), <span class=\"fn\"><span class=\"fn\"><span class=\"fn\">IsBase</span> <span class=\"fn\">B</span></span> → <span class=\"fn\">B</span> <a href=\"./Init/Core.html#HasSubset.Subset\">⊆</a> <span class=\"fn\">E</span></span></span>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Mathlib/Combinatorics/Matroid/Basic.html#Matroid\">Matroid</a> <span class=\"fn\">α</span></span></div></div>","info":{"doc":"","docLink":"./Mathlib/Combinatorics/Matroid/Basic.html#Matroid.mk","kind":"ctor","line":192,"name":"Matroid.mk","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/087469e24922b85cb737497c74556c7dacc01f22/Mathlib/Combinatorics/Matroid/Basic.lean#L192-L192"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">structure</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Mathlib/Combinatorics/Matroid/Basic.html#Matroid\"><span class=\"name\">Matroid</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">α</span> : <a href=\"./foundational_types.html\">Type</a> u_1)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./foundational_types.html\">Type</a> u_1</div></div>","info":{"doc":"A `Matroid α` is a ground set `E` of type `Set α`, and a nonempty collection of its subsets\nsatisfying the exchange property and the maximal subset property. Each such set is called a\n`Base` of `M`. An `Indep`endent set is just a set contained in a base, but we include this\npredicate as a structure field for better definitional properties.\n\nIn most cases, using this definition directly is not the best way to construct a matroid,\nsince it requires specifying both the bases and independent sets. If the bases are known,\nuse `Matroid.ofBase` or a variant. If just the independent sets are known,\ndefine an `IndepMatroid`, and then use `IndepMatroid.matroid`.\n","docLink":"./Mathlib/Combinatorics/Matroid/Basic.html#Matroid","kind":"structure","line":182,"name":"Matroid","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/087469e24922b85cb737497c74556c7dacc01f22/Mathlib/Combinatorics/Matroid/Basic.lean#L182-L210"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Mathlib/Combinatorics/Matroid/Basic.html#Matroid.ExistsMaximalSubsetProperty\"><span class=\"name\">Matroid</span>.<span class=\"name\">ExistsMaximalSubsetProperty</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">α</span> : <a href=\"./foundational_types.html\">Type</a> u_1}</span></span>\n</span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">P</span> : <span class=\"fn\"><span class=\"fn\"><a href=\"./Mathlib/Data/Set/Defs.html#Set\">Set</a> <span class=\"fn\">α</span></span> → <a href=\"./foundational_types.html\">Prop</a></span>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">X</span> : <span class=\"fn\"><a href=\"./Mathlib/Data/Set/Defs.html#Set\">Set</a> <span class=\"fn\">α</span></span>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./foundational_types.html\">Prop</a></div></div>","info":{"doc":"A set `X` has the maximal subset property for a predicate `P` if every subset of `X` satisfying\n`P` is contained in a maximal subset of `X` satisfying `P`. ","docLink":"./Mathlib/Combinatorics/Matroid/Basic.html#Matroid.ExistsMaximalSubsetProperty","kind":"def","line":177,"name":"Matroid.ExistsMaximalSubsetProperty","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/087469e24922b85cb737497c74556c7dacc01f22/Mathlib/Combinatorics/Matroid/Basic.lean#L177-L180"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Mathlib/Combinatorics/Matroid/Basic.html#Matroid.ExchangeProperty\"><span class=\"name\">Matroid</span>.<span class=\"name\">ExchangeProperty</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">α</span> : <a href=\"./foundational_types.html\">Type</a> u_1}</span></span>\n</span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">P</span> : <span class=\"fn\"><span class=\"fn\"><a href=\"./Mathlib/Data/Set/Defs.html#Set\">Set</a> <span class=\"fn\">α</span></span> → <a href=\"./foundational_types.html\">Prop</a></span>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./foundational_types.html\">Prop</a></div></div>","info":{"doc":"A predicate `P` on sets satisfies the **exchange property** if,\nfor all `X` and `Y` satisfying `P` and all `a ∈ X \\ Y`, there exists `b ∈ Y \\ X` so that\nswapping `a` for `b` in `X` maintains `P`. ","docLink":"./Mathlib/Combinatorics/Matroid/Basic.html#Matroid.ExchangeProperty","kind":"def","line":171,"name":"Matroid.ExchangeProperty","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/087469e24922b85cb737497c74556c7dacc01f22/Mathlib/Combinatorics/Matroid/Basic.lean#L171-L175"}}],"imports":["Init","Mathlib.Combinatorics.Matroid.Init","Mathlib.Data.Finite.Prod","Mathlib.Data.Set.Card","Mathlib.Data.Set.Finite.Powerset","Mathlib.Order.UpperLower.Closure"],"instances":[{"className":"Nonempty","name":"Matroid.instNonemptySubtypeSetIsBase","typeNames":["Subtype"]},{"className":"Matroid.Finite","name":"Matroid.finite_of_finite","typeNames":[]},{"className":"Matroid.RankFinite","name":"Matroid.rankFinite_of_finite","typeNames":[]},{"className":"Matroid.Nonempty","name":"Matroid.rankPos_nonempty","typeNames":[]},{"className":"Matroid.Finitary","name":"Matroid.finitary_of_rankFinite","typeNames":[]}],"name":"Mathlib.Combinatorics.Matroid.Basic"}