span class=\"fn\">z₀</span></span>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Mathlib/Analysis/Analytic/Order.html#analyticOrderAt\">analyticOrderAt</a> <span class=\"fn\">f</span> <span class=\"fn\">z₀</span></span> <a href=\"./Init/Prelude.html#Eq\">=</a> <span class=\"fn\">0</span></div></div>","info":{"doc":"","docLink":"./Mathlib/Analysis/Analytic/Order.html#analyticOrderAt_of_not_analyticAt","kind":"theorem","line":64,"name":"analyticOrderAt_of_not_analyticAt","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/0f1dd7505c3d08b5feb82300ccc73179a457bf51/Mathlib/Analysis/Analytic/Order.lean#L64-L66"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">noncomputable def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Mathlib/Analysis/Analytic/Order.html#analyticOrderNatAt\"><span class=\"name\">analyticOrderNatAt</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">𝕜</span> : <a href=\"./foundational_types.html\">Type</a> u_1}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">E</span> : <a href=\"./foundational_types.html\">Type</a> u_2}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">[<span class=\"fn\"><a href=\"./Mathlib/Analysis/Normed/Field/Basic.html#NontriviallyNormedField\">NontriviallyNormedField</a> <span class=\"fn\">𝕜</span></span>]</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">[<span class=\"fn\"><a href=\"./Mathlib/Analysis/Normed/Group/Defs.html#NormedAddCommGroup\">NormedAddCommGroup</a> <span class=\"fn\">E</span></span>]</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">[<span class=\"fn\"><a href=\"./Mathlib/Analysis/Normed/Module/Basic.html#NormedSpace\">NormedSpace</a> <span class=\"fn\">𝕜</span> <span class=\"fn\">E</span></span>]</span></span>\n</span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">f</span> : <span class=\"fn\"><span class=\"fn\">𝕜</span> → <span class=\"fn\">E</span></span>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">z₀</span> : <span class=\"fn\">𝕜</span>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Init/Prelude.html#Nat\">ℕ</a></div></div>","info":{"doc":"The order of vanishing of `f` at `z₀`, as an element of `ℕ`.\n\nThe order is defined to be `0` if `f` is identically zero on a neighbourhood of `z₀`,\nand is otherwise the unique `n` such that `f` can locally be written as `f z = (z - z₀) ^ n • g z`,\nwhere `g` is analytic and does not vanish at `z₀`. See `AnalyticAt.analyticOrderAt_eq_top` and\n`AnalyticAt.analyticOrderAt_eq_natCast` for these equivalences.\n\nIf `f` isn't analytic at `z₀`, then `analyticOrderNatAt f z₀` returns a junk value of `0`. ","docLink":"./Mathlib/Analysis/Analytic/Order.html#analyticOrderNatAt","kind":"def","line":54,"name":"analyticOrderNatAt","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/0f1dd7505c3d08b5feb82300ccc73179a457bf51/Mathlib/Analysis/Analytic/Order.lean#L54-L62"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">noncomputable def</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Mathlib/Analysis/Analytic/Order.html#analyticOrderAt\"><span class=\"name\">analyticOrderAt</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">𝕜</span> : <a href=\"./foundational_types.html\">Type</a> u_1}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">E</span> : <a href=\"./foundational_types.html\">Type</a> u_2}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">[<span class=\"fn\"><a href=\"./Mathlib/Analysis/Normed/Field/Basic.html#NontriviallyNormedField\">NontriviallyNormedField</a> <span class=\"fn\">𝕜</span></span>]</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">[<span class=\"fn\"><a href=\"./Mathlib/Analysis/Normed/Group/Defs.html#NormedAddCommGroup\">NormedAddCommGroup</a> <span class=\"fn\">E</span></span>]</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">[<span class=\"fn\"><a href=\"./Mathlib/Analysis/Normed/Module/Basic.html#NormedSpace\">NormedSpace</a> <span class=\"fn\">𝕜</span> <span class=\"fn\">E</span></span>]</span></span>\n</span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">f</span> : <span class=\"fn\"><span class=\"fn\">𝕜</span> → <span class=\"fn\">E</span></span>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">z₀</span> : <span class=\"fn\">𝕜</span>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./Mathlib/Data/ENat/Defs.html#ENat\">ℕ∞</a></div></div>","info":{"doc":"The order of vanishing of `f` at `z₀`, as an element of `ℕ∞`.\n\nThe order is defined to be `∞` if `f` is identically 0 on a neighbourhood of `z₀`, and otherwise the\nunique `n` such that `f` can locally be written as `f z = (z - z₀) ^ n • g z`, where `g` is analytic\nand does not vanish at `z₀`. See `AnalyticAt.analyticOrderAt_eq_top` and\n`AnalyticAt.analyticOrderAt_eq_natCast` for these equivalences.\n\nIf `f` isn't analytic at `z₀`, then `analyticOrderAt f z₀` returns a junk value of `0`. ","docLink":"./Mathlib/Analysis/Analytic/Order.html#analyticOrderAt","kind":"def","line":40,"name":"analyticOrderAt","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/0f1dd7505c3d08b5feb82300ccc73179a457bf51/Mathlib/Analysis/Analytic/Order.lean#L40-L52"}}],"imports":["Init","Mathlib.Analysis.Analytic.IsolatedZeros","Mathlib.Analysis.Calculus.Deriv.Mul","Mathlib.Analysis.Calculus.Deriv.Pow","Mathlib.Analysis.Calculus.InverseFunctionTheorem.Analytic","Mathlib.Analysis.Calculus.IteratedDeriv.Lemmas"],"instances":[],"name":"Mathlib.Analysis.Analytic.Order"}