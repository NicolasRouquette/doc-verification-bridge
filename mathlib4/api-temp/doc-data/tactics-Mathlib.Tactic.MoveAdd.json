[{"userName": "move_oper",
  "tags": [],
  "internalName": "Mathlib.MoveAdd.moveOperTac",
  "docString":
  {"element":
   ["p",
    true,
    [],
    [{"element":
      ["p",
       true,
       [],
       [{"text": "The tactic "},
        {"element": ["code", true, [], [{"text": "move_add"}]]},
        {"text": " rearranges summands of expressions."},
        {"raw": "\n"},
        {"text": "Calling "},
        {"element":
         ["code",
          true,
          [],
          [{"text": "move_add"},
           {"text": " "},
           {"text": "[a,"},
           {"text": " "},
           {"text": "←"},
           {"text": " "},
           {"text": "b,"},
           {"text": " "},
           {"text": "...]"}]]},
        {"text": " matches "},
        {"element":
         ["code",
          true,
          [],
          [{"text": "a,"}, {"text": " "}, {"text": "b,..."}]]},
        {"text": " with summands in the main goal."},
        {"raw": "\n"},
        {"text": "It then moves "},
        {"element": ["code", true, [], [{"text": "a"}]]},
        {"text": " to the far right and "},
        {"element": ["code", true, [], [{"text": "b"}]]},
        {"text": " to the far left of each addition in which they appear."},
        {"raw": "\n"},
        {"text":
         "The side to which the summands are moved is determined by the presence or absence of the arrow "},
        {"element": ["code", true, [], [{"text": "←"}]]},
        {"text": "."}]]},
     {"element":
      ["p",
       true,
       [],
       [{"text": "The inputs "},
        {"element":
         ["code",
          true,
          [],
          [{"text": "a,"}, {"text": " "}, {"text": "b,..."}]]},
        {"text": " can be any terms, also with underscores."},
        {"raw": "\n"},
        {"text":
         "The tactic uses the first \"new\" summand that unifies with each one of the given inputs."}]]},
     {"element":
      ["p",
       true,
       [],
       [{"text": "There is a multiplicative variant, called "},
        {"element": ["code", true, [], [{"text": "move_mul"}]]},
        {"text": "."}]]},
     {"element":
      ["p",
       true,
       [],
       [{"text":
         "There is also a general tactic for a \"binary associative commutative operation\": "},
        {"element": ["code", true, [], [{"text": "move_oper"}]]},
        {"text": "."},
        {"raw": "\n"},
        {"text":
         "In this case the syntax requires providing first a term whose head symbol is the operation."},
        {"raw": "\n"},
        {"text": "E.g. "},
        {"element":
         ["code",
          true,
          [],
          [{"text": "move_oper"},
           {"text": " "},
           {"element":
            ["a",
             true,
             [["href", "./Init/Prelude.html#HAdd.hAdd"]],
             [{"text": "HAdd.hAdd"}]]},
           {"text": " "},
           {"text": "[...]"}]]},
        {"text": " is the same as "},
        {"element": ["code", true, [], [{"text": "move_add"}]]},
        {"text": ", while "},
        {"element":
         ["code",
          true,
          [],
          [{"text": "move_oper"},
           {"text": " "},
           {"element":
            ["a",
             true,
             [["href", "./Init/Prelude.html#Max.max"]],
             [{"text": "Max.max"}]]},
           {"text": " "},
           {"text": "[...]"}]]},
        {"raw": "\n"},
        {"text": "rearranges "},
        {"element": ["code", true, [], [{"text": "max"}]]},
        {"text": "s."}]]}]]},
  "definingModule": "Mathlib.Tactic.MoveAdd"}]