up/Defs.html#Norm.norm\">‖</a>) <a href=\"./Init/Prelude.html#HAdd.hAdd\">+</a> <a href=\"./Mathlib/Analysis/Normed/Group/Defs.html#Norm.norm\">‖</a><span class=\"fn\"><span class=\"fn\">f</span> <span class=\"fn\">0</span></span><a href=\"./Mathlib/Analysis/Normed/Group/Defs.html#Norm.norm\">‖</a> <a href=\"./Init/Prelude.html#HMul.hMul\">*</a> (<span class=\"fn\">R</span> <a href=\"./Init/Prelude.html#HAdd.hAdd\">+</a> <a href=\"./Mathlib/Analysis/Normed/Group/Defs.html#Norm.norm\">‖</a><span class=\"fn\">z</span><a href=\"./Mathlib/Analysis/Normed/Group/Defs.html#Norm.norm\">‖</a>) <a href=\"./Init/Prelude.html#HDiv.hDiv\">/</a> (<span class=\"fn\">R</span> <a href=\"./Init/Prelude.html#HSub.hSub\">-</a> <a href=\"./Mathlib/Analysis/Normed/Group/Defs.html#Norm.norm\">‖</a><span class=\"fn\">z</span><a href=\"./Mathlib/Analysis/Normed/Group/Defs.html#Norm.norm\">‖</a>)</div></div>","info":{"doc":"**Borel-Carathéodory theorem**.\n\nIf `f` is analytic on the open ball `‖z‖ < R` and satisfies `(f z).re < M` for all such `z`,\nthen `‖f z‖ ≤ 2 * M * ‖z‖ / (R - ‖z‖) + ‖f 0‖ * (R + ‖z‖) / (R - ‖z‖)` for all `‖z‖ < R`. ","docLink":"./Mathlib/Analysis/Complex/BorelCaratheodory.html#Complex.borelCaratheodory","kind":"theorem","line":106,"name":"Complex.borelCaratheodory","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/0f1dd7505c3d08b5feb82300ccc73179a457bf51/Mathlib/Analysis/Complex/BorelCaratheodory.lean#L106-L122"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">theorem</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Mathlib/Analysis/Complex/BorelCaratheodory.html#Complex.borelCaratheodory_zero\"><span class=\"name\">Complex</span>.<span class=\"name\">borelCaratheodory_zero</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">f</span> : <span class=\"fn\"><a href=\"./Mathlib/Data/Complex/Basic.html#Complex\">ℂ</a> → <a href=\"./Mathlib/Data/Complex/Basic.html