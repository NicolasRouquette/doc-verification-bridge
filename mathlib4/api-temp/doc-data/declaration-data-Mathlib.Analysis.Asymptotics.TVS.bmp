otics/TVS.html#Asymptotics.isLittleOTVS_iff","kind":"theorem","line":92,"name":"Asymptotics.isLittleOTVS_iff","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/0f1dd7505c3d08b5feb82300ccc73179a457bf51/Mathlib/Analysis/Asymptotics/TVS.lean#L92-L92"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">structure</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Mathlib/Analysis/Asymptotics/TVS.html#Asymptotics.IsLittleOTVS\"><span class=\"name\">Asymptotics</span>.<span class=\"name\">IsLittleOTVS</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">𝕜</span> : <a href=\"./foundational_types.html\">Type</a> u_1)</span></span>\n<span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">α</span> : <a href=\"./foundational_types.html\">Type</a> u_2}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">E</span> : <a href=\"./foundational_types.html\">Type</a> u_3}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">F</span> : <a href=\"./foundational_types.html\">Type</a> u_4}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">[<span class=\"fn\"><a href=\"./Mathlib/Analysis/Normed/Group/Defs.html#ENorm\">ENorm</a> <span class=\"fn\">𝕜</span></span>]</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">[<span class=\"fn\"><a href=\"./Mathlib/Topology/Defs/Basic.html#TopologicalSpace\">TopologicalSpace</a> <span class=\"fn\">E</span></span>]</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">[<span class=\"fn\"><a href=\"./Mathlib/Topology/Defs/Basic.html#TopologicalSpace\">TopologicalSpace</a> <span class=\"fn\">F</span></span>]</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">[<span class=\"fn\"><a href=\"./Init/Prelude.html#Zero\">Zero</a> <span class=\"fn\">E</span></span>]</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">[<span class=\"fn\"><a href=\"./Init/Prelude.html#Zero\">Zero</a> <span class=\"fn\">F</span></span>]</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">[<span class=\"fn\"><a href=\"./Init/Prelude.html#SMul\">SMul</a> <span class=\"fn\">𝕜</span> <span class=\"fn\">E</span></span>]</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">[<span class=\"fn\"><a href=\"./Init/Prelude.html#SMul\">SMul</a> <span class=\"fn\">𝕜</span> <span class=\"fn\">F</span></span>]</span></span>\n</span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">l</span> : <span class=\"fn\"><a href=\"./Mathlib/Order/Filter/Defs.html#Filter\">Filter</a> <span class=\"fn\">α</span></span>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">f</span> : <span class=\"fn\"><span class=\"fn\">α</span> → <span class=\"fn\">E</span></span>)</span></span>\n<span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">g</span> : <span class=\"fn\"><span class=\"fn\">α</span> → <span class=\"fn\">F</span></span>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><a href=\"./foundational_types.html\">Prop</a></div></div>","info":{"doc":"`f =o[𝕜; l] g` (`IsLittleOTVS 𝕜 l f g`) is a generalization of `f =o[l] g` (`IsLittleO l f g`)\nthat works in topological `𝕜`-vector spaces.\n\nGiven two functions `f` and `g` taking values in topological vector spaces\nover a normed field `K`,\nwe say that $f = o(g)$ if for any neighborhood of zero `U` in the codomain of `f`\nthere exists a neighborhood of zero `V` in the codomain of `g`\nsuch that $\\operatorname{gauge}_{K, U} (f(x)) = o(\\operatorname{gauge}_{K, V} (g(x)))$,\nwhere $\\operatorname{gauge}_{K, U}(y) = \\inf \\{‖c‖ \\mid y ∈ c • U\\}$.\n\nWe use an `ENNReal`-valued function `egauge` for the gauge,\nso we unfold the definition of little o instead of reusing it. ","docLink":"./Mathlib/Analysis/Asymptotics/TVS.html#Asymptotics.IsLittleOTVS","kind":"structure","line":80,"name":"Asymptotics.IsLittleOTVS","sourceLink":"https://github.com/leanprover-community/mathlib4/blob/0f1dd7505c3d08b5feb82300ccc73179a457bf51/Mathlib/Analysis/Asymptotics/TVS.lean#L80-L95"}}],"imports":["Init","Mathlib.Analysis.Convex.EGauge","Mathlib.Analysis.LocallyConvex.BalancedCoreHull","Mathlib.Analysis.Seminorm","Mathlib.Analysis.Asymptotics.Defs","Mathlib.Topology.Algebra.Module.LinearMapPiProd","Mathlib.Tactic.Peel","Mathlib.Tactic.Bound","Mathlib.Topology.Instances.ENNReal.Lemmas"],"instances":[{"className":"Trans","name":"Asymptotics.instTransIsBigOTVSIsBigOTVS","typeNames":["Asymptotics.IsBigOTVS","Asymptotics.IsBigOTVS","Asymptotics.IsBigOTVS"]},{"className":"Trans","name":"Asymptotics.instTransIsBigOTVSIsThetaTVS","typeNames":["Asymptotics.IsBigOTVS","Asymptotics.IsThetaTVS","Asymptotics.IsBigOTVS"]},{"className":"Trans","name":"Asymptotics.instTransIsThetaOTVSIsBigOTVS","typeNames":["Asymptotics.IsThetaTVS","Asymptotics.IsBigOTVS","Asymptotics.IsBigOTVS"]},{"className":"Trans","name":"Asymptotics.instTransIsThetaOTVS","typeNames":["Asymptotics.IsThetaTVS","Asymptotics.IsThetaTVS","Asymptotics.IsThetaTVS"]},{"className":"Trans","name":"Asymptotics.instTransIsLittleOTVSIsBigOTVS","typeNames":["Asymptotics.IsLittleOTVS","Asymptotics.IsBigOTVS","Asymptotics.IsLittleOTVS"]},{"className":"Trans","name":"Asymptotics.instTransIsLittleOTVSIsThetaTVS","typeNames":["Asymptotics.IsLittleOTVS","Asymptotics.IsThetaTVS","Asymptotics.IsLittleOTVS"]},{"className":"Trans","name":"Asymptotics.instTransIsBigOTVSIsLittleOTVS","typeNames":["Asymptotics.IsBigOTVS","Asymptotics.IsLittleOTVS","Asymptotics.IsLittleOTVS"]},{"className":"Trans","name":"Asymptotics.instTransIsThetaTVSIsLittleOTVS","typeNames":["Asymptotics.IsThetaTVS","Asymptotics.IsLittleOTVS","Asymptotics.IsLittleOTVS"]},{"className":"Trans","name":"Asymptotics.instTransIsLittleOTVSIsLittleOTVS","typeNames":["Asymptotics.IsLittleOTVS","Asymptotics.IsLittleOTVS","Asymptotics.IsLittleOTVS"]}],"name":"Mathlib.Analysis.Asymptotics.TVS"}