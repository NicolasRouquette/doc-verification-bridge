ero</span></a></span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">ax</span> : <span class=\"fn\">↑<a href=\"./BanachTarski/Common.html#S2\">S2</a></span>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\">↑<span class=\"fn\">ax</span></span> <a href=\"./Init/Core.html#Ne\">≠</a> <span class=\"fn\">0</span></div></div>","info":{"doc":"","docLink":"./BanachTarski/Rot.html#s2_nonzero","kind":"theorem","line":20,"name":"s2_nonzero","sourceLink":"https://github.com/aetilley/banach-tarski/blob/a920deea0a3f3207049f8201fc1e7a0bb8cf4c93/BanachTarski/Rot.lean#L20-L26"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">instance</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./BanachTarski/Rot.html#R3_dim_3\"><span class=\"name\">R3_dim_3</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><a href=\"./Mathlib/Logic/Basic.html#Fact\">Fact</a> (<span class=\"fn\"><a href=\"./Mathlib/LinearAlgebra/Dimension/Finrank.html#Module.finrank\">Module.finrank</a> <a href=\"./Mathlib/Data/Real/Basic.html#Real\">ℝ</a> <a href=\"./BanachTarski/Common.html#R3\">R3</a></span> <a href=\"./Init/Prelude.html#Eq\">=</a> <span class=\"fn\">2</span> <a href=\"./Init/Prelude.html#HAdd.hAdd\">+</a> <span class=\"fn\">1</span>)</span></div></div>","info":{"doc":"Here we define and develop basic properties of the parametrized family `rot`\nof rotations.  We work with both this family and the corresponding family\n`rot_iso` of isometries.\n\nIt is much easier to work with the isometry representation as much as possible\nand convert back to matrices at the end (in particular, see lemma `same_action`). ","docLink":"./BanachTarski/Rot.html#R3_dim_3","kind":"instance","line":5,"name":"R3_dim_3","sourceLink":"https://github.com/aetilley/banach-tarski/blob/a920deea0a3f3207049f8201fc1e7a0bb8cf4c93/BanachTarski/Rot.lean#L5-L18"}}],"imports":["Init","Mathlib","BanachTarski.Common"],"instances":[{"className":"Fact","name":"R3_dim_3","typeNames":["Eq"]},{"className":"Fact","name":"orth_dim_2","typeNames":["Eq"]},{"className":"Fact","name":"orth_dim_3","typeNames":["Eq"]},{"className":"Fintype","name":"mod_dim_fintype","typeNames":["mod_dim"]},{"className":"Decidable","name":"mod_dim_decidableEq","typeNames":["Eq"]}],"name":"BanachTarski.Rot"}