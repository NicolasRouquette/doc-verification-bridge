">G</span> <span class=\"fn\">E</span> (<span class=\"fn\">E</span> <a href=\"./Init/Core.html#SDiff.sdiff\">\\</a> <span class=\"fn\">S</span>)</span></span></div></div>","info":{"doc":"","docLink":"./BanachTarski/Basic.html#absorption_lemma_2","kind":"theorem","line":2243,"name":"absorption_lemma_2","sourceLink":"https://github.com/aetilley/banach-tarski/blob/a920deea0a3f3207049f8201fc1e7a0bb8cf4c93/BanachTarski/Basic.lean#L2243-L2325"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">theorem</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./BanachTarski/Basic.html#absorption_lemma_1\"><span class=\"name\">absorption_lemma_1</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">X</span> : <a href=\"./foundational_types.html\">Type</a> u_1}</span></span>\n</span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">G</span> : <a href=\"./foundational_types.html\">Type</a> u_2)</span></span>\n<span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">[<span class=\"fn\"><a href=\"./Mathlib/Algebra/Group/Defs.html#Group\">Group</a> <span class=\"fn\">G</span></span>]</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">[<span class=\"fn\"><a href=\"./Mathlib/Algebra/Group/Action/Defs.html#MulAction\">MulAction</a> <span class=\"fn\">G</span> <span class=\"fn\">X</span></span>]</span></span>\n</span><span class=\"decl_args\">\n<span class=\"fn\">(<span class=\"fn\">E </span><span class=\"fn\">S</span> : <span class=\"fn\"><a href=\"./Mathlib/Data/Set/Defs.html#Set\">Set</a> <span class=\"fn\">X</span></span>)</span></span>\n<span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><span class=\"fn\">(∃ <span class=\"fn\">D</span> ⊆ <span class=\"fn\">E</span>, <span class=\"fn\">S</span> <a href=\"./Init/Core.html#HasSubset.Subset\">⊆</a> <span class=\"fn\">D</span> <a href=\"./Init/Prelude.html#And\">∧</a> <span class=\"fn\">∃ (<span class=\"fn\">ρ</span> : <span class=\"fn\">G</span>), <span class=\"fn\"><a href=\"./BanachTarski/Common.html#f\">f</a> <span class=\"fn\">ρ</span></span> <a href=\"./Mathlib/Data/Set/Defs.html#Set.image\">''</a> <span class=\"fn\">D</span> <a href=\"./Init/Prelude.html#Eq\">=</a> <span class=\"fn\">D</span> <a href=\"./Init/Core.html#SDiff.sdiff\">\\</a> <span class=\"fn\">S</span></span>)</span> → <span class=\"fn\"><a href=\"./BanachTarski/Basic.html#Equidecomposible\">Equidecomposible</a> <span class=\"fn\">G</span> <span class=\"fn\">E</span> (<span class=\"fn\">E</span> <a href=\"./Init/Core.html#SDiff.sdiff\">\\</a> <span class=\"fn\">S</span>)</span></span></div></div>","info":{"doc":"A series of lemmas showing that when considering the paradoxicality of a set E\ncertain subsets S ⊆ E can be \"absorbed\" into E, specifically\nthat E is equidcomposible with E \\ S. ","docLink":"./BanachTarski/Basic.html#absorption_lemma_1","kind":"theorem","line":2128,"name":"absorption_lemma_1","sourceLink":"https://github.com/aetilley/banach-tarski/blob/a920deea0a3f3207049f8201fc1e7a0bb8cf4c93/BanachTarski/Basic.lean#L2128-L2241"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">theorem</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./BanachTarski/Basic.html#hausdorff_paradox\"><span class=\"name\">hausdorff_paradox</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\">∃ <span class=\"fn\">D</span> ⊆ <a href=\"./BanachTarski/Common.html#S2\">S2</a>, <span class=\"fn\"><a href=\"./Mathlib/Data/Countable/Defs.html#Countable\">Countable</a> <span class=\"fn\">↑<span class=\"fn\">D</span></span></span> <a href=\"./Init/Prelude.html#And\">∧</a> <span class=\"fn\"><a href=\"./BanachTarski/Basic.html#Paradoxical\">Paradoxical</a> <span class=\"fn\">(↥<a href=\"./BanachTarski/Common.html#SO3\">SO3</a>)</span> (<a href=\"./BanachTarski/Common.html#S2\">S2</a> <a h