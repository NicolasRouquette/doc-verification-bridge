fn\">n</span> <span class=\"fn\">L</span>)</span></span></span></div></div>","info":{"doc":"The entire remainder of the module is devoted to the proof of a\n-- fact used in the definition of the Sato subgroup:\n-- That wiithout loss of generality we can assume a member of the\n-- kernel ends in σ\nlemma wolog_zero {G : Type} [Group G] (h : FG2 →* G) (a : FG2) :\n  (a ≠ 1) ∧ (h a = 1) → ∃a2 : FG2, (a2 ≠ 1) ∧ (h a2 = 1) ∧\n  (FreeGroup.toWord a2).getLast? = some (0, true) ","docLink":"./BanachTarski/SatoUtils.html#isreduced_of_take_of_reduced","kind":"theorem","line":262,"name":"isreduced_of_take_of_reduced","sourceLink":"https://github.com/aetilley/banach-tarski/blob/a920deea0a3f3207049f8201fc1e7a0bb8cf4c93/BanachTarski/SatoUtils.lean#L262-L287"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">theorem</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./BanachTarski/SatoUtils.html#sevsevlem\"><span class=\"name\">sevsevlem</span></a></span><span class=\"decl_args\"> :</span><div class=\"decl_type\">(<span class=\"fn\">7</span><a href=\"./Init/Prelude.html#Inv.inv\">⁻¹</a> <a href=\"./Init/Prelude.html#HSMul.hSMul\">•</a> <span class=\"fn\">7</span><a href=\"./Init/Prelude.html#Inv.inv\">⁻¹</a> <a href=\"./Init/Prelude.html#HSMul.hSMul\">•</a> <span class=\"fn\">fun (<span class=\"fn\">x</span> : <span class=\"fn\"><a href=\"./Init/Prelude.html#Fin\">Fin</a> <span class=\"fn\">3</span></span>) =&gt; <span class=\"fn\">49</span></span>) <a href=\"./Init/Prelude.html#Eq\">=</a> <span class=\"fn\">fun (<span class=\"fn\">x</span> : <span class=\"fn\"><a href=\"./Init/Prelude.html#Fin\">Fin</a> <span class=\"fn\">3</span></span>) =&gt; <span class=\"fn\">1</span></span></div></div>","info":{"doc":"","docLink":"./BanachTarski/SatoUtils.html#sevsevlem","kind":"theorem","line":255,"name":"sevsevlem","sourceLink":"https://github.com/aetilley/banach-tarski/blob/a920deea0a3f3207049f8201fc1e7a0bb8cf4c93/BanachTarski/SatoUtils.lean#L255-L259"}},{"